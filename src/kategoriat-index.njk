---
layout: base.njk
title: Kategoriat
permalink: /kategoriat/
translationKey: categories_index
---
<section>
  <div class="container">
    <h1 class="h3 mb-3">Kategoriat</h1>
    <div class="list-group">
      {% for cat in collections.categoryList %}
        <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" href="/kategoriat/{{ cat.slug }}/">
          <span>{{ cat.name }}</span>
          <span class="badge text-bg-secondary rounded-pill">{{ cat.count }}</span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>
