---
layout: base.njk
title: Etusivu
lang: fi
translationKey: home
---

{% set uniquePresentationKeys = [] %}
{% for item in ((canva and canva.tableRows) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in (collections.presentations or []) %}
  {% set key = (((item.data and item.data.url) or "") ~ "|" ~ ((item.data and item.data.title) or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in ((finnaAoe and finnaAoe.rows) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% set heroPresentationCount = uniquePresentationKeys | length %}
{% set heroPublicationCount = (researchfi or []) | length %}
{% set heroOpinionCount = (collections.pub_mielipide or []) | length %}
{% set heroSpeechCount = (collections.pub_puhe or []) | length %}
{% set heroStats = [
    { count: heroPresentationCount, label: "Esitystä tai oppimateriaalia", href: "/esitykset/" },
    { count: heroPublicationCount, label: "julkaisua", href: "/julkaisut/" },
    { count: heroOpinionCount, label: "mielipidekirjoitusta", href: "/kynasta/#mielipiteet" },
    { count: heroSpeechCount, label: "puheenvuoroa", href: "/kynasta/#puheet" },
    { count: 100, label: "ohjattua opinnäytettä", href: "/opinnaytteet/" }
] %}

<section class="section-flush home-hero-section" id="heroSection">
    <div class="home-hero-backdrop">
        <div class="container home-hero-content">
            <p class="home-hero-eyebrow mb-2">Jari Laru</p>
            <h1 class="home-hero-title mb-3">Koulutan ja tutkin, miten tekoäly ja oppimisteknologia toimivat koulun arjessa.</h1>
            <div class="home-hero-roles mb-2">
                <a class="home-hero-role-item" href="/tyoni-yliopistonlehtorina/">Yliopistonlehtori</a>
                <a class="home-hero-role-item" href="/larux-tmi/">Kouluttaja (Larux t:mi)</a>
                <a class="home-hero-role-item" href="/politiikka/">Kuntapäättäjä</a>
            </div>
        </div>
    </div>
    <div class="home-hero-wave" aria-hidden="true">
        <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z"/>
        </svg>
    </div>
</section>

{# ── Intro: tiivistys + päätoiminnot ──────────────────────────────────── #}
<section class="py-5 home-intro-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <p class="home-intro-text">Yliopistonlehtori, kouluttaja ja kuntapäättäjä. Tutkin ja koulutan miten tekoäly ja oppimisteknologia toimivat koulun arjessa — ja vaikutan päätöksentekoon, jotta tutkimusnäyttö löytää tiensä luokkahuoneeseen.</p>
                <div class="home-intro-actions">
                    <a class="btn btn-primary rounded-pill px-4" href="/yhteystiedot/">Pyydä tarjous</a>
                    <a class="btn btn-outline-secondary rounded-pill px-4" href="/tietoa/">Tutustu taustaani</a>
                </div>
            </div>
        </div>
    </div>
</section>

{# ── Kolmipolku: kenelle tämä on? ─────────────────────────────────────── #}
<section class="py-5 home-paths-section">
    <div class="container">
        <p class="text-uppercase fw-bold text-center mb-4 home-paths-label">Mistä lähdet liikkeelle?</p>
        <div class="row g-4">

            <div class="col-md-4">
                <a class="home-path-card" href="/larux-tmi/">
                    <div class="home-path-icon">
                        <i class="bi bi-person-workspace" aria-hidden="true"></i>
                    </div>
                    <h2 class="home-path-title">Koulutuksen tilaajalle</h2>
                    <p class="home-path-desc">Tarvitsetko kouluttajan tai keynote-puhujan? Käytännönläheiset koulutukset tekoälystä, digipedagogiikasta ja oppimisesta organisaatioille ja oppilaitoksille.</p>
                    <span class="home-path-cta">Koulutuspalvelut ja tarjouspyyntö →</span>
                </a>
            </div>

            <div class="col-md-4">
                <a class="home-path-card" href="/tutkimus/">
                    <div class="home-path-icon">
                        <i class="bi bi-journal-text" aria-hidden="true"></i>
                    </div>
                    <h2 class="home-path-title">Tutkijalle &amp; kollegalle</h2>
                    <p class="home-path-desc">Vertaisarvioidut julkaisut, hankeyhteistyö ja tutkimusagenda teknologiatuetusta oppimisesta ja tekoälykasvatuksesta.</p>
                    <span class="home-path-cta">Tutkimussivulle →</span>
                </a>
            </div>

            <div class="col-md-4">
                <a class="home-path-card" href="/politiikka/">
                    <div class="home-path-icon">
                        <i class="bi bi-building-check" aria-hidden="true"></i>
                    </div>
                    <h2 class="home-path-title">Medialle &amp; päättäjille</h2>
                    <p class="home-path-desc">Koulutuspolitiikan puheenvuorot, valtuustoaloitteet ja asiantuntijakommentit. Digitalisaatio ja varhaiskasvatuksen laatu.</p>
                    <span class="home-path-cta">Politiikka ja vaikuttaminen →</span>
                </a>
            </div>

        </div>
    </div>
</section>

{# ── Miksi tämä työ on tärkeää? ────────────────────────────────────────── #}
<section class="py-5 bg-body-tertiary home-challenges-section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-lg-7 text-center">
                <h2 class="fw-bold mb-2">Miksi tämä työ on tärkeää?</h2>
                <p class="home-challenges-lead">Kolme toisiinsa kytkeytyvää haastetta, joihin vastaan tutkimuksella, koulutuksella ja yhteiskunnallisella vaikuttamisella.</p>
            </div>
        </div>
        <div class="row g-4">

            <div class="col-md-4">
                <div class="home-challenge-card">
                    <div class="home-challenge-num">01</div>
                    <h3 class="home-challenge-title">Tekoäly muuttaa opettamista nopeammin kuin koulut ehtivät sopeutua</h3>
                    <p class="home-challenge-text">Oppilaitokset etsivät käytännön ratkaisuja tekoälyn integrointiin, mutta tutkimusnäyttöön perustuva tuki ja osaaminen puuttuvat liian usein.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="home-challenge-card">
                    <div class="home-challenge-num">02</div>
                    <h3 class="home-challenge-title">Tutkimustieto jää liian usein vain tutkijoiden pöytälaatikoihin</h3>
                    <p class="home-challenge-text">Tieteellinen tieto ja käytännön luokkahuonetyö eivät kohtaa riittävästi. Sillä on väliä, kuka välittää tietoa ja miten.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="home-challenge-card">
                    <div class="home-challenge-num">03</div>
                    <h3 class="home-challenge-title">Koulutuspäätökset tehdään liian harvoin tutkimusnäytön pohjalta</h3>
                    <p class="home-challenge-text">Digitalisaatiota koskevat kuntapäätökset vaativat asiantuntemusta, jota liian harvoilla päättäjillä on — ja johon voi vaikuttaa.</p>
                </div>
            </div>

        </div>
    </div>
</section>

{# ── KPI-kaista: vaikuttavuusluvut ────────────────────────────────────── #}
<section class="home-stats-section" aria-label="Vaikuttavuusluvut">
    <div class="container">
        <dl class="home-stats-grid">
            {% for stat in heroStats | sort(true, false, "count") %}
            <div class="home-stat">
                <dd class="home-stat-value"><a href="{{ stat.href }}">{{ stat.count }}</a></dd>
                <dt class="home-stat-label">{{ stat.label }}</dt>
            </div>
            {% endfor %}
        </dl>
    </div>
</section>

<section class="py-5 home-overview-section">
    <div class="container">
        <div class="row g-4 g-xl-5">

            {# Kortti 1: Yliopistonlehtori #}
            <div class="col-md-6 col-xl-3 home-overview-col">
                <div class="d-flex flex-column h-100">
                    <p class="home-overview-eyebrow">Yliopisto</p>
                    <h2 class="h5 fw-bold mb-2 home-overview-title">
                        <i class="bi bi-mortarboard me-2 opacity-75"></i>Yliopistonlehtori
                    </h2>
                    <p class="small mb-2 home-overview-lead">Teknologiatuetun oppimisen yliopistonlehtori, Kasvatustieteiden tiedekunta, Oulun yliopisto.</p>
                    <p class="small mb-3 home-overview-lead">Mukana STN:n rahoittamassa <strong>Generation AI</strong> -hankkeessa — tekoälykasvatusta esi- ja perusopetukseen.</p>
                    <ul class="list-unstyled small mb-3 home-overview-lead">
                        <li class="mb-1"><i class="bi bi-check2 me-1 opacity-75"></i>Opettajankoulutus</li>
                        <li class="mb-1"><i class="bi bi-check2 me-1 opacity-75"></i>Digipedagogiikka</li>
                        <li class="mb-1"><i class="bi bi-check2 me-1 opacity-75"></i>Tekoälylukutaito</li>
                        <li><i class="bi bi-check2 me-1 opacity-75"></i>Opinnäytetyöohjaus (100+)</li>
                    </ul>
                    <div class="mt-auto pt-2">
                        <a href="/tyoni-yliopistonlehtorina/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Lue lisää <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>

            {# Kortti 2: Kouluttaja & puhuja #}
            <div class="col-md-6 col-xl-3 home-overview-col">
                <div class="d-flex flex-column h-100">
                    <p class="home-overview-eyebrow">Koulutuspalvelut · Larux t:mi</p>
                    <h2 class="h5 fw-bold mb-2 home-overview-title">
                        <i class="bi bi-mic me-2 opacity-75"></i>Kouluttaja &amp; puhuja
                    </h2>
                    <p class="small mb-3 home-overview-lead">Käytännönläheisiä koulutuksia opettajille, rehtoreille ja organisaatioille — tekoälyn soveltamisesta kouluarjessa keynote-puheenvuoroihin ja työpajoihin.</p>
                    <div class="d-flex flex-wrap gap-1 mb-3">
                        <span class="home-topic-pill">Tekoäly opetuksessa</span>
                        <span class="home-topic-pill">AI-lukutaito</span>
                        <span class="home-topic-pill">Digipedagogiikka</span>
                        <span class="home-topic-pill">Keynote</span>
                        <span class="home-topic-pill">Työpaja</span>
                    </div>
                    <div class="d-flex flex-column gap-1 mb-3">
                        {% for post in collections.presentations | take(2) %}
                        <a href="{{ post.data.url }}" target="_blank" rel="noopener noreferrer" class="d-flex align-items-center gap-2 text-decoration-none home-content-row p-2 rounded">
                            <div class="flex-grow-1 overflow-hidden">
                                <p class="fw-semibold mb-0 text-truncate" style="font-size:0.82rem;">{{ post.data.title }}</p>
                                <p class="text-muted mb-0" style="font-size:0.7rem;">
                                    {%- if post.data.location %}{{ post.data.location }} · {% endif -%}
                                    {{ post.date | dateFormat }}
                                </p>
                            </div>
                            <i class="bi bi-arrow-up-right text-muted flex-shrink-0" style="font-size:0.75rem;"></i>
                        </a>
                        {% endfor %}
                    </div>
                    <div class="d-flex flex-wrap gap-2 mt-auto pt-2">
                        <a href="/larux-tmi/" class="btn btn-primary btn-sm rounded-pill px-3">Tilaa koulutus</a>
                        <a href="/esitykset/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Kaikki esitykset</a>
                    </div>
                </div>
            </div>

            {# Kortti 3: Julkaisut APA7 #}
            <div class="col-md-6 col-xl-3 home-overview-col">
                <div class="d-flex flex-column h-100">
                    <p class="home-overview-eyebrow">Tiede &amp; tutkimus</p>
                    <h2 class="h5 fw-bold mb-2 home-overview-title">
                        <i class="bi bi-journal-text me-2 opacity-75"></i>Julkaisut
                    </h2>
                    <p class="small mb-3 home-overview-lead">Vertaisarvioituja artikkeleita, konferenssijulkaisuja ja oppikirjoja teknologiatuetusta oppimisesta, tekoälykasvatuksesta ja digipedagogiikasta. <strong>{{ researchfi.length }} julkaisua</strong> Research.fi:ssä.</p>
                    <div class="d-flex flex-column gap-2 mb-3">
                        {% for pub in researchfi.slice(0, 3) %}
                        <div class="home-apa-item">
                            <p class="home-apa-ref mb-1">
                                {%- if pub.authors -%}<span class="home-apa-authors">{{ pub.authors | truncate(52) }}</span> {%- endif -%}
                                {%- if pub.year -%}({{ pub.year }}). {%- endif -%}
                                {{ pub.title | truncate(95) }}.{%- if pub.journal %} <em>{{ pub.journal }}</em>.{%- endif %}
                            </p>
                            <div class="d-flex align-items-center gap-1 flex-wrap">
                                <span class="home-apa-badge">{{ pub.typeShort }}</span>
                                {%- if pub.openAccess %}<span class="home-apa-badge home-apa-oa">OA</span>{% endif -%}
                                {%- if pub.doiUrl %}<a href="{{ pub.doiUrl }}" target="_blank" rel="noopener noreferrer" class="home-apa-doi">DOI <i class="bi bi-arrow-up-right"></i></a>{%- elif pub.url %}<a href="{{ pub.url }}" target="_blank" rel="noopener noreferrer" class="home-apa-doi">Artikkeli <i class="bi bi-arrow-up-right"></i></a>{%- endif %}
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                    <div class="mt-auto pt-2">
                        <a href="/julkaisut/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Kaikki julkaisut</a>
                    </div>
                </div>
            </div>

            {# Kortti 4: Politiikka #}
            <div class="col-md-6 col-xl-3 home-overview-col">
                <div class="d-flex flex-column h-100">
                    <p class="home-overview-eyebrow">Yhteiskunnallinen vaikuttaminen</p>
                    <h2 class="h5 fw-bold mb-2 home-overview-title">
                        <i class="bi bi-building me-2 opacity-75"></i>Politiikka
                    </h2>
                    <p class="small mb-2 home-overview-lead">Toisen kauden kaupunginvaltuutettu Oulussa (Kokoomus). Erityisaiheina sivistys, varhaiskasvatuksen laatu ja koulutuksen digitalisaatio.</p>
                    <div class="d-flex gap-3 mb-3">
                        <div class="text-center">
                            <p class="fw-bold mb-0" style="font-size:1.1rem;line-height:1;">{{ heroOpinionCount }}</p>
                            <p class="home-overview-lead mb-0" style="font-size:0.68rem;">mielipidettä</p>
                        </div>
                        <div class="text-center">
                            <p class="fw-bold mb-0" style="font-size:1.1rem;line-height:1;">{{ heroSpeechCount }}</p>
                            <p class="home-overview-lead mb-0" style="font-size:0.68rem;">puheenvuoroa</p>
                        </div>
                    </div>
                    <div class="d-flex flex-column gap-1 mb-3">
                        {% for post in collections.politicsAndOpinions | take(4) %}
                        {% if post.fileSlug != "etusivu" %}
                        <a href="{{ post.url }}" class="d-flex align-items-center gap-2 text-decoration-none home-content-row p-2 rounded">
                            <div class="flex-grow-1 overflow-hidden">
                                <p class="fw-semibold mb-0 text-truncate" style="font-size:0.82rem;">{{ post.data.title }}</p>
                                <p class="text-muted mb-0" style="font-size:0.7rem;">{{ post.data.type | capitalize or "Kirjoitus" }} · {{ post.date | dateFormat }}</p>
                            </div>
                            <i class="bi bi-arrow-right text-muted flex-shrink-0" style="font-size:0.75rem;"></i>
                        </a>
                        {% endif %}
                        {% endfor %}
                    </div>
                    <div class="d-flex flex-wrap gap-2 mt-auto pt-2">
                        <a href="/politiikka/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Politiikkasivu</a>
                        <a href="/kynasta/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Kynästä</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<section class="py-5 bg-body-tertiary home-testimonials-section">
    <div class="container">
        <p class="text-uppercase fw-bold text-center mb-4 home-testimonials-label">Palautetta koulutuksista</p>
        <div class="row g-4 justify-content-center">
            <div class="col-md-5">
                <blockquote class="home-quote">
                    <p>"Ihan fiiliksissä vieläkin setistäsi. Yhteyden katkeaminen ei latistanut, vaan porukka alkoi heti reflektoida kuultua."</p>
                    <footer class="home-quote-footer">Henkilöstökoulutus</footer>
                </blockquote>
            </div>
            <div class="col-md-5">
                <blockquote class="home-quote">
                    <p>"Palaute kyselyn perusteella olit osallistujien mielestä päivän paras puhuja."</p>
                    <footer class="home-quote-footer">Maksullinen seminaari</footer>
                </blockquote>
            </div>
        </div>
    </div>
</section>

{# ── Viimeisin sisältö -ticker ─────────────────────────────────────────── #}
<section class="py-5 home-recent-section">
    <div class="container">
        <div class="d-flex align-items-baseline justify-content-between mb-4">
            <p class="text-uppercase fw-bold mb-0 home-recent-label">Viimeisin sisältö</p>
            <div class="d-flex gap-3">
                <a href="/blogi/" class="home-recent-more">Kirjoitukset →</a>
                <a href="/esitykset/" class="home-recent-more">Esitykset →</a>
                <a href="/julkaisut/" class="home-recent-more">Julkaisut →</a>
            </div>
        </div>
    </div>
    <div class="ticker-wrapper home-ticker-wrapper" id="recentTicker">
        <div class="ticker-track">

            {# ── Setti 1 (alkuperäinen) ─── #}
            <div class="ticker-content">

                {# Blogikirjoitukset #}
                {% for post in collections.blog | take(5) %}
                <div class="home-ticker-item">
                    <p class="home-recent-eyebrow"><span class="home-ticker-badge home-ticker-badge--blog">Kirjoitus</span>&nbsp;·&nbsp;{{ post.date | dateFormat }}</p>
                    <h3 class="home-recent-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
                    {%- if post.data.description -%}
                    <p class="home-recent-desc">{{ post.data.description | truncate(90) }}</p>
                    {%- endif -%}
                    <span class="home-recent-cta">Lue <i class="bi bi-arrow-right"></i></span>
                </div>
                {% endfor %}

                {# Esitykset #}
                {% for post in collections.presentations | take(5) %}
                <div class="home-ticker-item">
                    <p class="home-recent-eyebrow"><span class="home-ticker-badge home-ticker-badge--pres">Esitys</span>&nbsp;·&nbsp;{{ post.date | dateFormat }}</p>
                    <h3 class="home-recent-title"><a href="{{ post.data.url }}" target="_blank" rel="noopener">{{ post.data.title }}</a></h3>
                    {%- if post.data.location -%}
                    <p class="home-recent-desc">{{ post.data.location }}</p>
                    {%- endif -%}
                    <span class="home-recent-cta">Avaa <i class="bi bi-arrow-up-right"></i></span>
                </div>
                {% endfor %}

                {# Julkaisut #}
                {% for pub in researchfi.slice(0, 5) %}
                <div class="home-ticker-item">
                    <p class="home-recent-eyebrow"><span class="home-ticker-badge home-ticker-badge--pub">Julkaisu</span>&nbsp;·&nbsp;{{ pub.year }}</p>
                    <h3 class="home-recent-title">
                        {%- if pub.doiUrl or pub.url -%}
                        <a href="{{ pub.doiUrl or pub.url }}" target="_blank" rel="noopener">{{ pub.title | truncate(90) }}</a>
                        {%- else -%}{{ pub.title | truncate(90) }}{%- endif -%}
                    </h3>
                    {%- if pub.journal -%}
                    <p class="home-recent-desc"><em>{{ pub.journal }}</em></p>
                    {%- endif -%}
                    <span class="home-recent-cta">{% if pub.doiUrl %}DOI <i class="bi bi-arrow-up-right"></i>{% else %}Julkaisu{% endif %}</span>
                </div>
                {% endfor %}

            </div>

            {# ── Setti 2 (klooni saumatonta toistoa varten) ─── #}
            <div class="ticker-content" aria-hidden="true">

                {% for post in collections.blog | take(5) %}
                <div class="home-ticker-item">
                    <p class="home-recent-eyebrow"><span class="home-ticker-badge home-ticker-badge--blog">Kirjoitus</span>&nbsp;·&nbsp;{{ post.date | dateFormat }}</p>
                    <h3 class="home-recent-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
                    {%- if post.data.description -%}
                    <p class="home-recent-desc">{{ post.data.description | truncate(90) }}</p>
                    {%- endif -%}
                    <span class="home-recent-cta">Lue <i class="bi bi-arrow-right"></i></span>
                </div>
                {% endfor %}

                {% for post in collections.presentations | take(5) %}
                <div class="home-ticker-item">
                    <p class="home-recent-eyebrow"><span class="home-ticker-badge home-ticker-badge--pres">Esitys</span>&nbsp;·&nbsp;{{ post.date | dateFormat }}</p>
                    <h3 class="home-recent-title"><a href="{{ post.data.url }}" target="_blank" rel="noopener">{{ post.data.title }}</a></h3>
                    {%- if post.data.location -%}
                    <p class="home-recent-desc">{{ post.data.location }}</p>
                    {%- endif -%}
                    <span class="home-recent-cta">Avaa <i class="bi bi-arrow-up-right"></i></span>
                </div>
                {% endfor %}

                {% for pub in researchfi.slice(0, 5) %}
                <div class="home-ticker-item">
                    <p class="home-recent-eyebrow"><span class="home-ticker-badge home-ticker-badge--pub">Julkaisu</span>&nbsp;·&nbsp;{{ pub.year }}</p>
                    <h3 class="home-recent-title">
                        {%- if pub.doiUrl or pub.url -%}
                        <a href="{{ pub.doiUrl or pub.url }}" target="_blank" rel="noopener">{{ pub.title | truncate(90) }}</a>
                        {%- else -%}{{ pub.title | truncate(90) }}{%- endif -%}
                    </h3>
                    {%- if pub.journal -%}
                    <p class="home-recent-desc"><em>{{ pub.journal }}</em></p>
                    {%- endif -%}
                    <span class="home-recent-cta">{% if pub.doiUrl %}DOI <i class="bi bi-arrow-up-right"></i>{% else %}Julkaisu{% endif %}</span>
                </div>
                {% endfor %}

            </div>
        </div>
    </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const ticker = document.getElementById("recentTicker");
    if (!ticker) return;
    const track = ticker.querySelector(".ticker-track");
    const tickerContent = ticker.querySelector(".ticker-content");
    if (!track || !tickerContent) return;

    let direction = -1;
    const speed = 0.4;
    let currentX = 0;
    let animationId;
    let isDragging = false;
    let prevX = 0;

    track.style.animation = "none";

    function animate() {
        const setWidth = tickerContent.offsetWidth;
        currentX += direction * speed;
        if (currentX <= -setWidth) currentX += setWidth;
        else if (currentX >= 0) currentX -= setWidth;
        track.style.transform = `translateX(${currentX}px)`;
        animationId = requestAnimationFrame(animate);
    }

    animationId = requestAnimationFrame(animate);

    ticker.addEventListener("mouseenter", () => cancelAnimationFrame(animationId));
    ticker.addEventListener("mouseleave", () => {
        isDragging = false;
        ticker.style.cursor = "";
        animationId = requestAnimationFrame(animate);
    });
    ticker.addEventListener("mousedown", (e) => {
        isDragging = true;
        prevX = e.clientX;
        ticker.style.cursor = "grabbing";
        cancelAnimationFrame(animationId);
    });
    ticker.addEventListener("mousemove", (e) => {
        if (!isDragging) return;
        const dx = e.clientX - prevX;
        prevX = e.clientX;
        direction = dx > 0 ? 1 : -1;
        currentX += dx;
        const setWidth = tickerContent.offsetWidth;
        if (currentX <= -setWidth) currentX += setWidth;
        else if (currentX >= 0) currentX -= setWidth;
        track.style.transform = `translateX(${currentX}px)`;
    });
    ticker.addEventListener("mouseup", () => {
        isDragging = false;
        ticker.style.cursor = "ew-resize";
    });
});
</script>

