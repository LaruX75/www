<section class="py-5 home-recent-section" id="ajankohtaista" data-home-mobile-priority="2">
    <div class="site-shell">
        <details class="home-mobile-disclosure" data-home-mobile-collapse open>
            <summary class="home-mobile-disclosure-summary">
                <span>{{ homeCopy.recentTitle }}</span>
                <small>Kirjoitukset, esitykset, lausunnot ja media</small>
            </summary>
            <div class="home-mobile-disclosure-body">
        <div class="home-section-head">
            <p class="home-section-kicker mb-1">Asiantuntijatyö</p>
            <h2 class="home-section-title">{{ homeCopy.recentTitle }}</h2>
            <p class="home-section-lead mb-0">{{ homeCopy.recentLead }}</p>
        </div>
        <div class="home-recent-editorial">
            <article class="home-recent-card">
                {% set featuredRecentPostRoleFlags = [] %}
                {% if featuredRecentPost and featuredRecentPost.data.opinionRoles %}
                    {% for role in featuredRecentPost.data.opinionRoles %}
                        {% set _ = (featuredRecentPostRoleFlags.push(role), null) %}
                    {% endfor %}
                {% elif featuredRecentPost and featuredRecentPost.data.writingRoles %}
                    {% for role in featuredRecentPost.data.writingRoles %}
                        {% set _ = (featuredRecentPostRoleFlags.push(role), null) %}
                    {% endfor %}
                {% endif %}
                <p class="home-recent-card-kicker">{% if featuredRecentPostRoleFlags.indexOf("political") != -1 and featuredRecentPostRoleFlags.indexOf("expert") != -1 %}Asiantuntija + politiikka{% else %}Asiantuntijakirjoitus{% endif %}</p>
                {% if featuredRecentPost %}
                <h3 class="home-recent-card-title"><a href="{{ featuredRecentPost.url }}">{{ featuredRecentPost.data.title | truncate(76) }}</a></h3>
                <p class="home-recent-card-meta">{{ featuredRecentPost.date | dateFormat }}</p>
                {% if featuredRecentPost.data.description %}
                <p class="home-recent-card-text">{{ featuredRecentPost.data.description | truncate(180) }}</p>
                {% endif %}
                <a href="/blogi/" class="home-recent-card-link">Kaikki kirjoitukset</a>
                {% endif %}
            </article>

            <article class="home-recent-card">
                <p class="home-recent-card-kicker">Esitys</p>
                {% if featuredRecentPresentation %}
                <h3 class="home-recent-card-title"><a href="{{ featuredRecentPresentation.url }}" target="_blank" rel="noopener noreferrer">{{ featuredRecentPresentation.title | truncate(76) }}</a></h3>
                <p class="home-recent-card-meta">{{ featuredRecentPresentation.date | dateFormat }}{% if featuredRecentPresentation.location %} · {{ featuredRecentPresentation.location }}{% endif %}</p>
                <p class="home-recent-card-text">Tuore koulutus- tai puheenvuoronosto käytännön tekoälystä, oppimisesta ja koulun arjesta.</p>
                <a href="/esitykset/" class="home-recent-card-link">Kaikki esitykset</a>
                {% endif %}
            </article>

            <article class="home-recent-card">
                <p class="home-recent-card-kicker">Lausunto</p>
                {% if featuredRecentStatement %}
                <h3 class="home-recent-card-title"><a href="{{ featuredRecentStatement.url }}">{{ featuredRecentStatement.data.title | truncate(76) }}</a></h3>
                <p class="home-recent-card-meta">{{ featuredRecentStatement.date | dateFormat }}{% if featuredRecentStatement.data.subtitle %} · {{ featuredRecentStatement.data.subtitle }}{% endif %}</p>
                {% if featuredRecentStatement.data.description %}
                <p class="home-recent-card-text">{{ featuredRecentStatement.data.description | truncate(180) }}</p>
                {% else %}
                <p class="home-recent-card-text">Asiantuntijalausunto opetuksen, tekoälyn tai koulutuksen valmistelun tueksi.</p>
                {% endif %}
                <a href="/kynasta/#lausunnot" class="home-recent-card-link">Kaikki lausunnot</a>
                {% endif %}
            </article>

            <article class="home-recent-card">
                <p class="home-recent-card-kicker">Mediassa</p>
                {% if featuredRecentMedia %}
                <h3 class="home-recent-card-title"><a href="{{ featuredRecentMedia.url }}">{{ featuredRecentMedia.data.title | truncate(76) }}</a></h3>
                <p class="home-recent-card-meta">{{ featuredRecentMedia.date | dateFormat }}{% if featuredRecentMedia.data.mediaOutlet %} · {{ featuredRecentMedia.data.mediaOutlet }}{% endif %}</p>
                {% if featuredRecentMedia.data.description %}
                <p class="home-recent-card-text">{{ featuredRecentMedia.data.description | truncate(180) }}</p>
                {% else %}
                <p class="home-recent-card-text">Haastattelu, podcast tai muu mediaosuma, jossa asiantuntijuus näkyy muiden tuottamassa sisällössä.</p>
                {% endif %}
                <a href="/mediassa/" class="home-recent-card-link">Kaikki mediaosumat</a>
                {% endif %}
            </article>
        </div>
            </div>
        </details>
    </div>
</section>

<section class="py-5 bg-body-tertiary home-closing-section" id="yhteys" style="border-top: 1px solid var(--bs-border-color-translucent);">
    <div class="site-shell">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="home-closing-panel text-center">
                    <p class="text-uppercase text-muted fw-bold mb-2">Seuraava askel</p>
                    <h2 class="fw-bold mb-3">{{ pageContent.etusivu.closing.heading }}</h2>
                    <p class="mb-4">{{ pageContent.etusivu.closing.text }}</p>
                    <div class="home-closing-actions d-flex flex-wrap justify-content-center gap-2 mb-3">
