---
layout: base.njk
title: Etusivu
lang: fi
translationKey: home
---

{% set uniquePresentationKeys = [] %}
{% for item in ((canva and canva.tableRows) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in (collections.presentations or []) %}
  {% set key = (((item.data and item.data.url) or "") ~ "|" ~ ((item.data and item.data.title) or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in ((finnaAoe and finnaAoe.rows) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% set heroPresentationCount = uniquePresentationKeys | length %}
{% set heroPublicationCount = (researchfi or []) | length %}
{% set heroOpinionCount = (collections.pub_mielipide or []) | length %}
{% set heroSpeechCount = (collections.pub_puhe or []) | length %}
{% set heroStats = [
    { count: heroPresentationCount, label: "Esitystä tai oppimateriaalia", href: "/esitykset/" },
    { count: heroPublicationCount, label: "julkaisua", href: "/julkaisut/" },
    { count: heroOpinionCount, label: "mielipidekirjoitusta", href: "/kynasta/#mielipiteet" },
    { count: heroSpeechCount, label: "puheenvuoroa", href: "/kynasta/#puheet" },
    { count: 100, label: "ohjattua opinnäytettä", href: "/opinnaytteet/" }
] %}

<section class="section-flush home-hero-section" id="heroSection">
    <div class="home-hero-backdrop" style="--hero-img: url('{{ '/img/WIN_20210329_16_06_01_Pro.jpg' | url }}')">
        <div class="container home-hero-content">
            <div class="row align-items-center g-4 g-lg-5">
                <div class="col-lg-7">
                    <p class="home-hero-eyebrow mb-2">{{ pageContent.etusivu.hero.eyebrow }}</p>
                    <h1 class="home-hero-title mb-3">{{ pageContent.etusivu.hero.title }}</h1>
                    <div class="home-hero-roles">
                        {% for role in pageContent.etusivu.hero.roles %}
                        <a class="home-hero-role-item" href="{{ role.href }}">{{ role.label }}</a>
                        {% endfor %}
                    </div>
                </div>
                <div class="col-lg-5 d-none d-lg-flex align-items-center justify-content-end">
                    <dl class="home-hero-kpi-grid mb-0">
                        {% for stat in heroStats | sort(true, false, "count") %}
                        <div class="home-hero-kpi">
                            <dd class="home-hero-kpi-value"><a class="home-hero-kpi-link" href="{{ stat.href }}">{{ stat.count }}</a></dd>
                            <dt class="home-hero-kpi-label">{{ stat.label }}</dt>
                        </div>
                        {% endfor %}
                    </dl>
                </div>
            </div>
        </div>
    </div>
    <div class="home-hero-wave" aria-hidden="true">
        <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z"/>
        </svg>
    </div>
</section>

{# ── Intro: tiivistys + päätoiminnot ──────────────────────────────────── #}
<section class="py-5 home-intro-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <p class="home-intro-text">{{ pageContent.etusivu.intro.text }}</p>
                <div class="home-intro-actions">
                    <a class="btn btn-primary rounded-pill px-4" href="{{ pageContent.etusivu.intro.cta1.href }}">{{ pageContent.etusivu.intro.cta1.label }}</a>
                    <a class="btn btn-outline-secondary rounded-pill px-4" href="{{ pageContent.etusivu.intro.cta2.href }}">{{ pageContent.etusivu.intro.cta2.label }}</a>
                </div>
            </div>
        </div>
    </div>
</section>

{# ── Kolmipolku: kenelle tämä on? ─────────────────────────────────────── #}
<section class="py-5 home-paths-section">
    <div class="container">
        <p class="text-uppercase fw-bold text-center mb-4 home-paths-label">{{ pageContent.etusivu.paths.sectionLabel }}</p>
        <div class="row g-4">
            {% for card in pageContent.etusivu.paths.cards %}
            <div class="col-md-4">
                <a class="home-path-card" href="{{ card.href }}">
                    <div class="home-path-icon">
                        <i class="bi {{ card.icon }}" aria-hidden="true"></i>
                    </div>
                    <h2 class="home-path-title">{{ card.title }}</h2>
                    <p class="home-path-desc">{{ card.desc }}</p>
                    <span class="home-path-cta">{{ card.cta }}</span>
                </a>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{# ── Miksi tämä työ on tärkeää? ────────────────────────────────────────── #}
<section class="py-5 bg-body-tertiary home-challenges-section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-lg-7 text-center">
                <h2 class="fw-bold mb-2">{{ pageContent.etusivu.challenges.heading }}</h2>
                <p class="home-challenges-lead">{{ pageContent.etusivu.challenges.lead }}</p>
            </div>
        </div>
        <div class="row g-4">
            {% for card in pageContent.etusivu.challenges.cards %}
            <div class="col-md-4">
                <div class="home-challenge-card">
                    <div class="home-challenge-num">{{ card.num }}</div>
                    <h3 class="home-challenge-title">{{ card.title }}</h3>
                    <p class="home-challenge-text">{{ card.text }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>


<section class="py-5 home-overview-section">
    <div class="container">
        <div class="row g-4 g-xl-5">

            {# Kortti 1: Yliopistonlehtori #}
            <div class="col-md-6 col-xl-3 home-overview-col">
                <div class="d-flex flex-column h-100">
                    <p class="home-overview-eyebrow">{{ pageContent.etusivu.overview.card1.eyebrow }}</p>
                    <h2 class="h5 fw-bold mb-2 home-overview-title">
                        <i class="bi bi-mortarboard me-2 opacity-75"></i>Yliopistonlehtori
                    </h2>
                    <div class="home-overview-lead-wrap mb-3">
                        <p class="small mb-0 home-overview-lead">{{ pageContent.etusivu.overview.card1.lead }}</p>
                        <div class="home-overview-lead-fade"></div>
                    </div>
                    <div class="home-overview-kpis mb-3">
                        <div class="home-overview-kpi">
                            <span class="home-overview-kpi-value">{{ pageContent.etusivu.overview.card1.kpi1.value }}</span>
                            <span class="home-overview-kpi-label">{{ pageContent.etusivu.overview.card1.kpi1.label }}</span>
                        </div>
                        <div class="home-overview-kpi">
                            <span class="home-overview-kpi-value">{{ pageContent.etusivu.overview.card1.kpi2.value }}</span>
                            <span class="home-overview-kpi-label">{{ pageContent.etusivu.overview.card1.kpi2.label }}</span>
                        </div>
                    </div>
                    <div class="home-overview-items mb-3">
                        {% for post in collections.blog | take(3) %}
                        <a href="{{ post.url }}" class="home-overview-item">
                            <p class="home-overview-item-title">{{ post.data.title }}</p>
                            <p class="home-overview-item-meta">Kirjoitus · {{ post.date | dateFormat }}</p>
                        </a>
                        {% endfor %}
                        <div class="home-overview-items-fade"></div>
                    </div>
                    <div class="mt-auto pt-2">
                        <a href="{{ pageContent.etusivu.overview.card1.cta.href }}" class="btn btn-outline-secondary btn-sm rounded-pill px-3">{{ pageContent.etusivu.overview.card1.cta.label }} <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>

            {# Kortti 2: Kouluttaja & puhuja #}
            <div class="col-md-6 col-xl-3 home-overview-col">
                <div class="d-flex flex-column h-100">
                    <p class="home-overview-eyebrow">{{ pageContent.etusivu.overview.card2.eyebrow }}</p>
                    <h2 class="h5 fw-bold mb-2 home-overview-title">
                        <i class="bi bi-mic me-2 opacity-75"></i>Kouluttaja &amp; puhuja
                    </h2>
                    <div class="home-overview-lead-wrap mb-3">
                        <p class="small mb-0 home-overview-lead">{{ pageContent.etusivu.overview.card2.lead }}</p>
                        <div class="home-overview-lead-fade"></div>
                    </div>
                    <div class="home-overview-kpis mb-3">
                        <div class="home-overview-kpi">
                            <span class="home-overview-kpi-value">{{ heroPresentationCount }}</span>
                            <span class="home-overview-kpi-label">esitystä</span>
                        </div>
                        <div class="home-overview-kpi">
                            <span class="home-overview-kpi-value">{{ pageContent.etusivu.overview.card2.kpi2.value }}</span>
                            <span class="home-overview-kpi-label">{{ pageContent.etusivu.overview.card2.kpi2.label }}</span>
                        </div>
                    </div>
                    <div class="home-overview-items mb-3">
                        {% for row in (canva.tableRows or []) | take(3) %}
                        <a href="{{ row.url }}" target="_blank" rel="noopener noreferrer" class="home-overview-item">
                            <p class="home-overview-item-title">{{ row.title }}</p>
                            <p class="home-overview-item-meta">{% if row.location %}{{ row.location }} · {% endif %}{{ row.date | dateFormat }}</p>
                        </a>
                        {% endfor %}
                        <div class="home-overview-items-fade"></div>
                    </div>
                    <div class="d-flex flex-wrap gap-2 mt-auto pt-2">
                        <a href="{{ pageContent.etusivu.overview.card2.cta1.href }}" class="btn btn-primary btn-sm rounded-pill px-3">{{ pageContent.etusivu.overview.card2.cta1.label }}</a>
                        <a href="{{ pageContent.etusivu.overview.card2.cta2.href }}" class="btn btn-outline-secondary btn-sm rounded-pill px-3">{{ pageContent.etusivu.overview.card2.cta2.label }}</a>
                    </div>
                </div>
            </div>

            {# Kortti 3: Julkaisut #}
            <div class="col-md-6 col-xl-3 home-overview-col">
                <div class="d-flex flex-column h-100">
                    <p class="home-overview-eyebrow">{{ pageContent.etusivu.overview.card3.eyebrow }}</p>
                    <h2 class="h5 fw-bold mb-2 home-overview-title">
                        <i class="bi bi-journal-text me-2 opacity-75"></i>Julkaisut
                    </h2>
                    <div class="home-overview-lead-wrap mb-3">
                        <p class="small mb-0 home-overview-lead">{{ pageContent.etusivu.overview.card3.lead }}</p>
                        <div class="home-overview-lead-fade"></div>
                    </div>
                    <div class="home-overview-kpis mb-3">
                        <div class="home-overview-kpi">
                            <span class="home-overview-kpi-value">{{ heroPublicationCount }}</span>
                            <span class="home-overview-kpi-label">julkaisua</span>
                        </div>
                        <div class="home-overview-kpi">
                            <span class="home-overview-kpi-value">{{ semanticscholar.metrics.totalCitations or "600+" }}</span>
                            <span class="home-overview-kpi-label">viittausta</span>
                        </div>
                    </div>
                    <div class="home-overview-items mb-3">
                        {% for pub in researchfi.slice(0, 3) %}
                        {% set pubLink = pub.doiUrl or pub.url %}
                        <a href="{{ pubLink or '/julkaisut/' }}" {% if pubLink %}target="_blank" rel="noopener noreferrer"{% endif %} class="home-overview-item">
                            <p class="home-overview-item-title">{{ pub.title | truncate(85) }}</p>
                            <p class="home-overview-item-meta">{% if pub.authors %}{{ pub.authors | truncate(40) }} · {% endif %}{{ pub.year }}</p>
                        </a>
                        {% endfor %}
                        <div class="home-overview-items-fade"></div>
                    </div>
                    <div class="mt-auto pt-2">
                        <a href="{{ pageContent.etusivu.overview.card3.cta.href }}" class="btn btn-outline-secondary btn-sm rounded-pill px-3">{{ pageContent.etusivu.overview.card3.cta.label }}</a>
                    </div>
                </div>
            </div>

            {# Kortti 4: Politiikka #}
            <div class="col-md-6 col-xl-3 home-overview-col">
                <div class="d-flex flex-column h-100">
                    <p class="home-overview-eyebrow">{{ pageContent.etusivu.overview.card4.eyebrow }}</p>
                    <h2 class="h5 fw-bold mb-2 home-overview-title">
                        <i class="bi bi-building me-2 opacity-75"></i>Politiikka
                    </h2>
                    <div class="home-overview-lead-wrap mb-3">
                        <p class="small mb-0 home-overview-lead">{{ pageContent.etusivu.overview.card4.lead }}</p>
                        <div class="home-overview-lead-fade"></div>
                    </div>
                    <div class="home-overview-kpis mb-3">
                        <div class="home-overview-kpi">
                            <span class="home-overview-kpi-value">{{ heroOpinionCount }}</span>
                            <span class="home-overview-kpi-label">mielipidettä</span>
                        </div>
                        <div class="home-overview-kpi">
                            <span class="home-overview-kpi-value">{{ heroSpeechCount }}</span>
                            <span class="home-overview-kpi-label">puheenvuoroa</span>
                        </div>
                    </div>
                    <div class="home-overview-items mb-3">
                        {% set polItems = [] %}
                        {% for post in collections.politicsAndOpinions %}
                            {% if post.fileSlug != "etusivu" and polItems.length < 3 %}
                                {% set _ = (polItems.push(post), null) %}
                            {% endif %}
                        {% endfor %}
                        {% for post in polItems %}
                        <a href="{{ post.url }}" class="home-overview-item">
                            <p class="home-overview-item-title">{{ post.data.title }}</p>
                            <p class="home-overview-item-meta">{{ post.data.type | capitalize or "Kirjoitus" }} · {{ post.date | dateFormat }}</p>
                        </a>
                        {% endfor %}
                        <div class="home-overview-items-fade"></div>
                    </div>
                    <div class="d-flex flex-wrap gap-2 mt-auto pt-2">
                        <a href="{{ pageContent.etusivu.overview.card4.cta1.href }}" class="btn btn-outline-secondary btn-sm rounded-pill px-3">{{ pageContent.etusivu.overview.card4.cta1.label }}</a>
                        <a href="{{ pageContent.etusivu.overview.card4.cta2.href }}" class="btn btn-outline-secondary btn-sm rounded-pill px-3">{{ pageContent.etusivu.overview.card4.cta2.label }}</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<section class="py-5 bg-body-tertiary home-testimonials-section">
    <div class="container">
        <p class="text-uppercase fw-bold text-center mb-4 home-testimonials-label">{{ pageContent.etusivu.testimonials.sectionLabel }}</p>
        <div class="row g-4 justify-content-center">
            {% for q in pageContent.etusivu.testimonials.quotes %}
            <div class="col-md-5">
                <blockquote class="home-quote">
                    <p>"{{ q.text }}"</p>
                    <footer class="home-quote-footer">{{ q.footer }}</footer>
                </blockquote>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{# ── Viimeisin sisältö -ticker ─────────────────────────────────────────── #}

{# Yhdistetään kaikki sisältötyypit ja lajitellaan uusin ensin #}
{% set allRecentItems = [] %}

{% for post in collections.blog %}
  {% set item = { sortTs: post.date | toTimestamp, type: "blog", dateLabel: post.date | dateFormat, title: post.data.title, href: post.url, desc: post.data.description, isExternal: false } %}
  {% set _ = (allRecentItems.push(item), null) %}
{% endfor %}

{# canva.tableRows käytetään presentations-sijaan: siinä on paikalliset thumbnail-polut #}
{% for row in (canva.tableRows or []) %}
  {% set item = { sortTs: row.date | toTimestamp, type: "pres", dateLabel: row.date | dateFormat, title: row.title, href: row.url, desc: row.location, thumbnail: row.thumbnail, isExternal: true } %}
  {% set _ = (allRecentItems.push(item), null) %}
{% endfor %}

{% for pub in (researchfi or []) %}
  {% set pubDateStr = pub.year ~ "-12-31" %}
  {% set item = { sortTs: pubDateStr | toTimestamp, type: "pub", dateLabel: pub.year, title: pub.title, href: pub.doiUrl or pub.url or "", authors: pub.authors, journal: pub.journal, typeShort: pub.typeShort, isExternal: true, hasDoi: pub.doiUrl } %}
  {% set _ = (allRecentItems.push(item), null) %}
{% endfor %}

{% set allRecentSorted = allRecentItems | sort(true, false, "sortTs") | take(18) %}

<section class="py-5 home-recent-section">
    <div class="container">
        <div class="d-flex align-items-baseline justify-content-between mb-4">
            <p class="text-uppercase fw-bold mb-0 home-recent-label">Viimeisin sisältö</p>
            <div class="d-flex gap-3">
                <a href="/blogi/" class="home-recent-more">Kirjoitukset →</a>
                <a href="/esitykset/" class="home-recent-more">Esitykset →</a>
                <a href="/julkaisut/" class="home-recent-more">Julkaisut →</a>
            </div>
        </div>
    </div>
    <div class="ticker-wrapper home-ticker-wrapper" id="recentTicker">
        <div class="ticker-track">

            {%- macro tickerCard(item) %}
            <div class="home-ticker-item home-ticker-item--{{ item.type }}">

                {# Yläosa: sisältö (kuva / viiteteksti / kuvaus) #}
                <div class="home-ticker-top">
                    {%- if item.type == "pres" and item.thumbnail %}
                    <img src="{{ item.thumbnail }}" alt="" loading="lazy" decoding="async">
                    {%- elif item.type == "pub" %}
                    <p class="home-apa7">
                        {%- if item.authors %}<span class="home-apa7-authors">{{ item.authors }}.</span> {% endif -%}
                        ({{ item.dateLabel }}).
                        <em>{{ item.title }}</em>.
                        {%- if item.journal %} <span class="home-apa7-journal">{{ item.journal }}</span>.{% endif %}
                        {%- if item.hasDoi %} <span class="home-apa7-doi">{{ item.hasDoi }}</span>{% endif %}
                    </p>
                    {%- elif item.desc %}
                    <p class="home-ticker-top-text">{{ item.desc }}</p>
                    {%- endif %}
                    <div class="home-ticker-top-fade"></div>
                </div>

                {# Keskiosa: badge + aikaleima #}
                <div class="home-ticker-meta">
                    <span class="home-ticker-badge home-ticker-badge--{{ item.type }}">
                        {%- if item.type == "blog" %}Kirjoitus{% elif item.type == "pres" %}Esitys{% else %}Julkaisu{% endif -%}
                    </span>
                    <span class="home-ticker-date">&nbsp;·&nbsp;{{ item.dateLabel }}</span>
                    {%- if item.typeShort %}&nbsp;<span class="home-apa7-type">{{ item.typeShort }}</span>{% endif %}
                </div>

                {# Alaosa: otsikko, max 2 riviä #}
                <div class="home-ticker-title-wrap">
                    {%- if item.href %}
                    <a class="home-ticker-title" href="{{ item.href }}"{% if item.isExternal %} target="_blank" rel="noopener"{% endif %}>{{ item.title }}</a>
                    {%- else %}
                    <span class="home-ticker-title">{{ item.title }}</span>
                    {%- endif %}
                </div>

            </div>
            {%- endmacro %}

            {# ── Setti 1 (alkuperäinen) ─── #}
            <div class="ticker-content">
                {% for item in allRecentSorted %}{{ tickerCard(item) }}{% endfor %}
            </div>

            {# ── Setti 2 (klooni saumatonta toistoa varten) ─── #}
            <div class="ticker-content" aria-hidden="true" inert>
                {% for item in allRecentSorted %}{{ tickerCard(item) }}{% endfor %}
            </div>

        </div>
    </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const ticker = document.getElementById("recentTicker");
    if (!ticker) return;
    const track = ticker.querySelector(".ticker-track");
    const tickerContent = ticker.querySelector(".ticker-content");
    if (!track || !tickerContent) return;

    let direction = -1;
    const speed = 0.4;
    let currentX = 0;
    let animationId;
    let isDragging = false;
    let prevX = 0;

    track.style.animation = "none";

    function animate() {
        const setWidth = tickerContent.offsetWidth;
        currentX += direction * speed;
        if (currentX <= -setWidth) currentX += setWidth;
        else if (currentX >= 0) currentX -= setWidth;
        track.style.transform = `translateX(${currentX}px)`;
        animationId = requestAnimationFrame(animate);
    }

    animationId = requestAnimationFrame(animate);

    ticker.addEventListener("mouseenter", () => cancelAnimationFrame(animationId));
    ticker.addEventListener("mouseleave", () => {
        isDragging = false;
        ticker.style.cursor = "";
        animationId = requestAnimationFrame(animate);
    });
    ticker.addEventListener("mousedown", (e) => {
        isDragging = true;
        prevX = e.clientX;
        ticker.style.cursor = "grabbing";
        cancelAnimationFrame(animationId);
    });
    ticker.addEventListener("mousemove", (e) => {
        if (!isDragging) return;
        const dx = e.clientX - prevX;
        prevX = e.clientX;
        direction = dx > 0 ? 1 : -1;
        currentX += dx;
        const setWidth = tickerContent.offsetWidth;
        if (currentX <= -setWidth) currentX += setWidth;
        else if (currentX >= 0) currentX -= setWidth;
        track.style.transform = `translateX(${currentX}px)`;
    });
    ticker.addEventListener("mouseup", () => {
        isDragging = false;
        ticker.style.cursor = "ew-resize";
    });
});
</script>

<section class="py-5 bg-body-tertiary home-closing-section" style="border-top: 1px solid var(--bs-border-color-translucent);">
