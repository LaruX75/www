---
layout: base.njk
title: Kouluttaja, puhuja ja vaikuttaja
description: "Jari Laru kouluttaa tekoälystä ja oppimisteknologiasta, puhuu koulutuksen tulevaisuudesta sekä vaikuttaa tutkimuksessa, mediassa ja Oulun päätöksenteossa."
lang: fi
translationKey: home
---

{% set uniquePresentationKeys = [] %}
{% for item in ((canva and canva.tableRows) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in (collections.presentations or []) %}
  {% set key = (((item.data and item.data.url) or "") ~ "|" ~ ((item.data and item.data.title) or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in ((finnaAoe and finnaAoe.rows) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in (googleslides or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in ((youtube and youtube.tableRows) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% set heroPresentationCount = uniquePresentationKeys | length %}
{% set heroPublicationCount = (researchfi or []) | length %}
{% set heroOpinionCount = (collections.pub_mielipide or []) | length %}
{% set heroSpeechCount = (collections.pub_puhe or []) | length %}
{% set heroStatementItems = [] %}
{% for item in (collections.publications or []) %}
    {% if item.data.type == "lausunto" %}
        {% set _ = (heroStatementItems.push(item), null) %}
    {% endif %}
{% endfor %}
{% set heroStatementCount = heroStatementItems | length %}
{% set heroMediaCount = ((mediaArchive and mediaArchive.all) or []) | length %}
{% set heroRoles = [
    { label: "Kouluttaja (Larux t:mi)", href: "/kouluttaja/" },
    { label: "Kuntapäättäjä", href: "/politiikka/" },
    { label: "Yliopistonlehtori", href: "/tyoni-yliopistonlehtorina/" }
] %}
{% set homeCopy = {
    heroTitle: "Koulutan, puhun ja vaikutan. Koulutuksen tulevaisuuden puolesta.",
    heroLead: "Koulutan ja puhun tekoälylukutaidosta, oppimisesta ja teknologian järkevästä käytöstä. Sama asiantuntijuus näkyy tutkimuksessa, lausunnoissa, mediassa ja päätöksenteossa.",
    heroPanelText: "Luvut kokoavat kouluttaja- ja puhujatyötä, tutkimusta, lausuntoja, mediaosumia, ohjausta ja poliittisia puheenvuoroja. Ne näyttävät, miten asiantuntijuus näkyy eri rooleissa.",
    pathsTitle: "Mistä haluat aloittaa?",
    pathsLead: "Voit siirtyä suoraan koulutuspalveluihin, tutkimukseen tai politiikkaan sen mukaan, miksi tulit sivulle.",
    focusTitle: "Koulutukset, puheenvuorot ja sparraus",
    focusLead: "Käytännön työni näkyy koulutuksina, keynote-puheenvuoroina ja kehittämisen tukena. Tutkimus ja kunnallinen vaikuttaminen tuovat siihen näkökulmaa, mutta etusivulla pääosassa on se, miten voin auttaa käytännössä.",
    recentTitle: "Ajankohtaista asiantuntijatyöstä",
    recentLead: "Tuoreista kirjoituksista, esityksistä, lausunnoista ja mediaosumista näet, missä asiantuntijuus on juuri nyt käytössä."
} %}
{% set heroStats = [
    { count: heroPresentationCount, label: "Esitystä tai oppimateriaalia", href: "/esitykset/" },
    { count: heroPublicationCount, label: "tieteellistä julkaisua", href: "/julkaisut/" },
    { count: heroStatementCount, label: "asiantuntijalausuntoa", href: "/kynasta/#lausunnot" },
    { count: heroMediaCount, label: "mediaosumaa", href: "/mediassa/" },
    { count: heroSpeechCount, label: "puheenvuoroa", href: "/kynasta/#puheet" },
    { count: theses.stats.total, label: "ohjattua opinnäytettä", href: "/opinnaytteet/" }
] %}

<section class="section-flush home-hero-section" id="heroSection">
    <div class="home-hero-backdrop" style="--hero-img: url('{{ '/img/WIN_20210329_16_06_01_Pro.jpg' | url }}')">
        <div class="container home-hero-content">
            <div class="row align-items-center g-4 g-lg-5">
                <div class="col-lg-7">
                    <p class="home-hero-eyebrow mb-2">{{ pageContent.etusivu.hero.eyebrow }}</p>
                    <h1 class="home-hero-title mb-3">{{ homeCopy.heroTitle }}</h1>
                    <p class="home-hero-lead mb-4">{{ homeCopy.heroLead }}</p>
                    <div class="home-hero-roles mb-4">
                        {% for role in heroRoles %}
                        <a class="home-hero-role-item" href="{{ role.href }}">{{ role.label }}</a>
                        {% endfor %}
                    </div>
                    <div class="home-hero-actions">
                        <a class="btn btn-primary rounded-pill px-4" href="{{ pageContent.etusivu.intro.cta1.href }}">{{ pageContent.etusivu.intro.cta1.label }}</a>
                        <a class="btn btn-outline-secondary rounded-pill px-4 home-hero-btn-secondary" href="/politiikka/">Politiikka</a>
                        <a class="home-hero-link" href="{{ pageContent.etusivu.intro.cta2.href }}">{{ pageContent.etusivu.intro.cta2.label }}</a>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="home-hero-panel">
                        <p class="home-hero-panel-kicker">Näyttöä eri rooleista</p>
                        <p class="home-hero-panel-text">{{ homeCopy.heroPanelText }}</p>
                        <dl class="home-hero-kpi-grid mb-0">
                            {% for stat in heroStats | sort(true, false, "count") %}
                            <div class="home-hero-kpi">
                                <dd class="home-hero-kpi-value"><a class="home-hero-kpi-link" href="{{ stat.href }}">{{ stat.count }}</a></dd>
                                <dt class="home-hero-kpi-label">{{ stat.label }}</dt>
                            </div>
                            {% endfor %}
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="home-hero-wave" aria-hidden="true">
        <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z"/>
        </svg>
    </div>
</section>

{% set featuredPresentationRows = (canva.fiRows or canva.tableRows or []) | take(3) %}
{% set recentAcademicPosts = (collections.blogAcademic or []) | take(2) %}
{% set recentPoliticsItems = [] %}
{% for post in collections.politicsAndOpinions %}
    {% if post.fileSlug != "etusivu" and recentPoliticsItems.length < 2 %}
        {% set _ = (recentPoliticsItems.push(post), null) %}
    {% endif %}
{% endfor %}
{% set featuredPublications = (researchfi or []).slice(0, 2) %}
{% set featuredRecentWritingItems = [] %}
{% for item in (collections.writing_expert or []) | sort(true, false, "date") %}
    {% if item.data.type != "lausunto" and item.data.type != "puhe" and item.data.title %}
        {% set _ = (featuredRecentWritingItems.push(item), null) %}
    {% endif %}
{% endfor %}
{% set featuredRecentPost = featuredRecentWritingItems[0] or (collections.blog or [])[0] %}
{% set featuredRecentPresentation = ((canva.fiRows or canva.tableRows or [])[0]) %}
{% set featuredRecentStatement = heroStatementItems[0] %}
{% set featuredRecentMedia = ((mediaArchive and mediaArchive.all) or [])[0] %}

<nav class="home-mobile-path" aria-label="Etusivun tärkeimmät osiot">
    <a href="#aloita">Aloita</a>
    <a href="#painopiste">Kouluttaja</a>
    <a href="#ajankohtaista">Ajankohtaista</a>
    <a href="#yhteys">Yhteys</a>
</nav>

{% set topicProfileKeys = ["tekoalylukutaito", "opettajankoulutus", "julkinen-asiantuntijuus-mediassa"] %}
{% set topicProfileTitleId = "home-topic-profiles-title" %}
{% set topicProfileEyebrow = "Aihepolut" %}
{% set topicProfileTitle = "Keskeiset asiantuntijateemat" %}
{% set topicProfileLead = "Jos etsit tiettyä asiantuntijuuden aluetta, nämä teemaprofiilit kokoavat yhteen kirjoitukset, lausunnot, esitykset, mediaosumat ja tutkimusnäytön." %}

<section class="py-5 home-paths-section" id="aloita">
    <div class="site-shell">
        <div class="home-section-head">
            <p class="home-section-kicker mb-1">{{ pageContent.etusivu.paths.sectionLabel }}</p>
            <h2 class="home-section-title">{{ homeCopy.pathsTitle }}</h2>
            <p class="home-section-lead mb-0">{{ homeCopy.pathsLead }}</p>
        </div>
        <div class="home-paths-grid">
            {% for card in pageContent.etusivu.paths.cards %}
            <a href="{{ card.href }}" class="home-path-card{% if loop.first %} home-path-card--primary{% endif %}">
                <span class="home-path-card-icon"><i class="bi {{ card.icon }}"></i></span>
                <p class="home-path-card-kicker">{{ card.title }}</p>
                <p class="home-path-card-text">{{ card.desc }}</p>
                <span class="home-path-card-cta">{{ card.cta }}</span>
            </a>
            {% endfor %}
        </div>
    </div>
</section>

{% include "topic-profile-links.njk" %}

<section class="py-5 home-focus-section" id="painopiste">
    <div class="site-shell">
        <div class="home-section-head">
            <p class="home-section-kicker mb-1">Painopiste</p>
            <h2 class="home-section-title">{{ homeCopy.focusTitle }}</h2>
            <p class="home-section-lead mb-0">{{ homeCopy.focusLead }}</p>
        </div>

        <div class="home-focus-grid">
            <article class="home-focus-main">
                <div class="home-focus-main-head">
                    <p class="home-focus-eyebrow">{{ pageContent.etusivu.overview.card2.eyebrow }}</p>
                    <h3 class="home-focus-main-title">Kouluttaja &amp; puhuja</h3>
                    <p class="home-focus-main-lead">{{ pageContent.etusivu.overview.card2.lead }}</p>
                </div>

                <div class="home-focus-chip-row">
                    <span class="home-focus-chip">tekoäly koulun arjessa</span>
                    <span class="home-focus-chip">keynote-puheenvuorot</span>
                    <span class="home-focus-chip">työpajat ja sparraus</span>
                </div>

                <div class="home-focus-kpis">
                    <div class="home-focus-kpi">
                        <span class="home-focus-kpi-value">{{ heroPresentationCount }}</span>
                        <span class="home-focus-kpi-label">esitystä</span>
                    </div>
                    <div class="home-focus-kpi">
                        <span class="home-focus-kpi-value">{{ pageContent.etusivu.overview.card2.kpi2.value }}</span>
                        <span class="home-focus-kpi-label">{{ pageContent.etusivu.overview.card2.kpi2.label }}</span>
                    </div>
                    <div class="home-focus-kpi">
                        <span class="home-focus-kpi-value">3</span>
                        <span class="home-focus-kpi-label">selkeää tapaa aloittaa yhteistyö</span>
                    </div>
                </div>

                <div class="home-focus-main-body">
                    <div class="home-focus-proof">
                        <p class="home-focus-proof-label">Tuoreita nostoja</p>
                        <div class="home-focus-proof-list">
                            {% for row in featuredPresentationRows %}
                            <a href="{{ row.url }}" target="_blank" rel="noopener noreferrer" class="home-focus-proof-item">
                                <span class="home-focus-proof-date">{{ row.date | dateFormat }}</span>
                                <strong>{{ row.title }}</strong>
                                <span>{{ row.location or "Esitys tai koulutus" }}</span>
                            </a>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                <div class="home-focus-main-actions">
                    <div class="d-flex flex-wrap gap-2">
                        <a href="{{ pageContent.etusivu.overview.card2.cta1.href }}" class="btn btn-primary btn-sm rounded-pill px-3">{{ pageContent.etusivu.overview.card2.cta1.label }}</a>
                        <a href="{{ pageContent.etusivu.overview.card2.cta2.href }}" class="btn btn-outline-secondary btn-sm rounded-pill px-3">{{ pageContent.etusivu.overview.card2.cta2.label }}</a>
                    </div>
                    <a href="/yhteystiedot/" class="home-focus-inline-link">Keskustele koulutuksesta tai keynote-puheenvuorosta</a>
                </div>
            </article>

            <div class="home-focus-side">
                <article class="home-focus-support">
                    <p class="home-focus-eyebrow">{{ pageContent.etusivu.overview.card4.eyebrow }}</p>
                    <h3 class="home-focus-support-title">Politiikka</h3>
                    <p class="home-focus-support-text">{{ pageContent.etusivu.overview.card4.lead }}</p>
                    <div class="home-focus-mini-kpis">
                        <span><strong>{{ heroOpinionCount }}</strong> mielipidettä</span>
                        <span><strong>{{ heroSpeechCount }}</strong> puheenvuoroa</span>
                    </div>
                    <div class="home-focus-mini-list">
                        {% for post in recentPoliticsItems %}
                        <a href="{{ post.url }}" class="home-focus-mini-item">
                            <strong>{{ post.data.title }}</strong>
                            <span>{{ post.date | dateFormat }}</span>
                        </a>
                        {% endfor %}
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <a href="{{ pageContent.etusivu.overview.card4.cta1.href }}" class="btn btn-outline-secondary btn-sm rounded-pill px-3">{{ pageContent.etusivu.overview.card4.cta1.label }}</a>
                        <a href="{{ pageContent.etusivu.overview.card4.cta2.href }}" class="btn btn-outline-secondary btn-sm rounded-pill px-3">{{ pageContent.etusivu.overview.card4.cta2.label }}</a>
                    </div>
                </article>

                <article class="home-focus-support">
                    <p class="home-focus-eyebrow">{{ pageContent.etusivu.overview.card1.eyebrow }}</p>
                    <h3 class="home-focus-support-title">Yliopistonlehtori</h3>
                    <p class="home-focus-support-text">{{ pageContent.etusivu.overview.card1.lead }}</p>
                    <div class="home-focus-mini-kpis">
                        <span><strong>{{ theses.stats.total }}</strong> ohjattua opinnäytettä</span>
                        <span><strong>{{ pageContent.etusivu.overview.card1.kpi2.value }}</strong> {{ pageContent.etusivu.overview.card1.kpi2.label }}</span>
                    </div>
                    <div class="home-focus-mini-list">
                        {% for post in recentAcademicPosts %}
                        <a href="{{ post.url }}" class="home-focus-mini-item">
                            <strong>{{ post.data.title }}</strong>
                            <span>{{ post.date | dateFormat }}</span>
                        </a>
                        {% endfor %}
                    </div>
                    <a href="{{ pageContent.etusivu.overview.card1.cta.href }}" class="btn btn-outline-secondary btn-sm rounded-pill px-3 align-self-start">{{ pageContent.etusivu.overview.card1.cta.label }}</a>
                </article>
            </div>

            <article class="home-focus-strip">
                <div class="home-focus-strip-copy">
                    <p class="home-focus-eyebrow">{{ pageContent.etusivu.overview.card3.eyebrow }}</p>
                    <h3 class="home-focus-strip-title">Julkaisut</h3>
                    <p class="home-focus-support-text mb-0">{{ pageContent.etusivu.overview.card3.lead }}</p>
                </div>
                <div class="home-focus-strip-kpis">
                    <span><strong>{{ heroPublicationCount }}</strong> julkaisua</span>
                    <span><strong>{{ semanticscholar.metrics.totalCitations or "600+" }}</strong> viittausta</span>
                </div>
                <div class="home-focus-strip-list">
                    {% for pub in featuredPublications %}
                    {% set pubLink = pub.doiUrl or pub.url %}
                    <a href="{{ pubLink or '/julkaisut/' }}" {% if pubLink %}target="_blank" rel="noopener noreferrer"{% endif %} class="home-focus-strip-item">
                        <strong>{{ pub.title | truncate(84) }}</strong>
                        <span>{% if pub.authors %}{{ pub.authors | truncate(42) }} · {% endif %}{{ pub.year }}</span>
                    </a>
                    {% endfor %}
                </div>
                <a href="{{ pageContent.etusivu.overview.card3.cta.href }}" class="btn btn-outline-secondary btn-sm rounded-pill px-3">{{ pageContent.etusivu.overview.card3.cta.label }}</a>
            </article>
        </div>
    </div>
</section>

{% set testimonialLang = "fi" %}
{% set testimonialPlacement = "home" %}
{% include "testimonials.njk" %}

<section class="py-5 home-challenge-section" id="miksi-nyt" data-home-mobile-priority="2">
    <div class="site-shell">
        <details class="home-mobile-disclosure" data-home-mobile-collapse open>
            <summary class="home-mobile-disclosure-summary">
                <span>Miksi tätä työtä tarvitaan juuri nyt</span>
                <small>{{ pageContent.etusivu.challenges.heading }}</small>
            </summary>
            <div class="home-mobile-disclosure-body">
        <div class="home-section-head">
            <p class="home-section-kicker mb-1">{{ pageContent.etusivu.challenges.heading }}</p>
            <h2 class="home-section-title">Miksi tätä työtä tarvitaan juuri nyt</h2>
            <p class="home-section-lead mb-0">{{ pageContent.etusivu.challenges.lead }}</p>
        </div>
        <div class="home-challenge-grid">
            {% for card in pageContent.etusivu.challenges.cards %}
            <article class="home-challenge-card">
                <span class="home-challenge-number">{{ card.num }}</span>
                <h3 class="home-challenge-title">{{ card.title }}</h3>
