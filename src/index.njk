            </div>
            <div class="col-md-6 order-1 order-sm-1 ps-0 pe-0 home-feature-image-col">
                <div class="h-100"><img loading="lazy" decoding="async" class="img-fluid object-fit-cover w-100 h-100 home-section-image" width="1024" height="768" style="min-height: 100%;transform: perspective(0px) scale(1);filter: blur(0px);transition: ease-in;" src="/img/valtuusto.jpg" alt="Valtuustosali"></div>
