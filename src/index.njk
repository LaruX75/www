                                    {% else %}
                                    <div class="rounded-circle flex-shrink-0 me-3 bg-secondary d-flex justify-content-center align-items-center" style="width: 50px; height: 50px;"><i class="bi bi-person text-light"></i></div>
                                    {% endif %}
                                    <div>
                                        <p class="fw-bold mb-0" style="font-size: 0.9rem;">Jari Laru</p>
                                        <p class="text-muted mb-0" style="font-size: 0.8rem;">Kirjoittaja &bull; {{ post.date | dateFormat }}</p>
                                    </div>
                                </div>
                                <p>{{ post.data.description or (post.content | excerpt) }}</p>
                                <div class="d-flex justify-content-start mt-3 mb-2">
                                    <a href="{{ post.url }}" class="btn btn-read-more btn-sm rounded-pill px-3">Lue lisää <i class="bi bi-arrow-right"></i></a>
                                </div>
                                <div class="mt-3">
                                    {% if post.data.categories and post.data.categories.length > 0 %}
                                        {% for cat in post.data.categories %}
                                            <span class="badge text-bg-secondary rounded-pill me-1">{{ cat }}</span>
                                        {% endfor %}
                                    {% elif post.data.type %}
                                        <span class="badge text-bg-secondary rounded-pill me-1">{{ post.data.type | capitalize }}</span>
                                    {% else %}
                                        <span class="badge text-bg-secondary rounded-pill me-1">Julkaisu</span>
                                    {% endif %}
                                </div>
                            </div>
                            {% else %}
                            <div class="ticker-item p-4">
                                <p>Ei vielä kirjoituksia.</p>
                            </div>
                            {% endfor %}
                        </div>
                        <!-- Toinen setti (klooni animaatiota varten) -->
                        <div class="ticker-content" aria-hidden="true">
                            {% for post in collections.politicsAndOpinions | take(6) %}
                            <div class="ticker-item p-4">
                                <h3><a class="ticker-title-link" href="{{ post.url }}">{{ post.data.title }}</a></h3>
                                <div class="d-flex align-items-center mt-3 mb-3">
                                    {% if post.data.thumbnail %}
                                    <img loading="lazy" decoding="async" class="object-fit-cover rounded-circle flex-shrink-0 me-3" width="50" height="50" src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}">
                                    {% else %}
                                    <div class="rounded-circle flex-shrink-0 me-3 bg-secondary d-flex justify-content-center align-items-center" style="width: 50px; height: 50px;"><i class="bi bi-person text-light"></i></div>
                                    {% endif %}
                                    <div>
                                        <p class="fw-bold mb-0" style="font-size: 0.9rem;">Jari Laru</p>
                                        <p class="text-muted mb-0" style="font-size: 0.8rem;">Kirjoittaja &bull; {{ post.date | dateFormat }}</p>
                                    </div>
                                </div>
                                <p>{{ post.data.description or (post.content | excerpt) }}</p>
                                <div class="d-flex justify-content-start mt-3 mb-2">
                                    <a href="{{ post.url }}" class="btn btn-read-more btn-sm rounded-pill px-3">Lue lisää <i class="bi bi-arrow-right"></i></a>
                                </div>
                                <div class="mt-3">
                                    {% if post.data.categories and post.data.categories.length > 0 %}
                                        {% for cat in post.data.categories %}
                                            <span class="badge text-bg-secondary rounded-pill me-1">{{ cat }}</span>
                                        {% endfor %}
                                    {% elif post.data.type %}
                                        <span class="badge text-bg-secondary rounded-pill me-1">{{ post.data.type | capitalize }}</span>
                                    {% else %}
                                        <span class="badge text-bg-secondary rounded-pill me-1">Julkaisu</span>
                                    {% endif %}
                                </div>
                            </div>
                            {% else %}
                            <div class="ticker-item p-4">
                                <p>Ei vielä kirjoituksia.</p>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
                <!-- Karuselli päättyy -->
                <div class="text-center pb-3 pt-2 w-100">
                    <a href="/kynasta/" class="btn btn-primary rounded-pill px-4">Lue kaikki kirjoitukset</a>
                </div>
            </div>
            <div class="col-md-6 order-1 order-sm-1 ps-0 pe-0">
                <div class="h-100"><img loading="lazy" decoding="async" class="img-fluid object-fit-cover w-100 h-100 home-section-image" width="1024" height="768" style="min-height: 100%;transform: perspective(0px) scale(1);filter: blur(0px);transition: ease-in;" src="/img/valtuusto.jpg" alt="Valtuustosali"></div>
            </div>
        </div>
    </div>
</section>

<section class="home-section-heading-strip home-section-heading-strip--light">
    <div class="container-fluid">
        <p class="home-section-heading-strip__eyebrow">Yrityspalvelut</p>
        <h2 class="home-section-heading-strip__title">Referenssit, FAQ ja yhteistyömalli</h2>
    </div>
</section>

<section class="py-4 bg-body-tertiary">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <p class="text-uppercase text-muted fw-bold mb-2">Yrityspalvelut</p>
                <h2 class="fw-bold">Referenssit, FAQ ja yhteistyömalli</h2>
                <p class="mb-3">Siirsin laajemmat case-esimerkit, usein kysytyt kysymykset ja yhteistyön hyödyt yrityssivulle.</p>
                <a class="btn btn-primary" href="/larux-tmi/">Siirry yrityssivulle</a>
            </div>
        </div>
    </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", function() {
  function initTicker(tickerId) {
    const ticker = document.getElementById(tickerId);
    if (!ticker) return;

    const track = ticker.querySelector(".ticker-track");
    if (!track) return;
    
    let direction = -1; // -1 for left, 1 for right
    let speed = 1; // Animation speed multiplier
    let currentX = 0; // Current transform translateX value
    let animationId; // For requestAnimationFrame
    
    let isDragging = false;
    let startX;
    let prevX;

    // Width of a single set of items
    const tickerContent = ticker.querySelector(".ticker-content");
    if (!tickerContent) return;

    function animate() {
      const itemSetWidth = tickerContent.offsetWidth; 
      
      currentX += direction * speed;

      // Seamless loop reset logic
      if (currentX <= -itemSetWidth) {
        currentX += itemSetWidth;
      } else if (currentX >= 0) {
        currentX -= itemSetWidth;
      }

      track.style.transform = `translateX(${currentX}px)`;
      animationId = requestAnimationFrame(animate);
    }

    // Remove CSS animation to use JS animation instead for direction support
    track.style.animation = "none";

    // Start animation loop
    animationId = requestAnimationFrame(animate);

    // Käyttöliittymäkontrollien tapahtumankäsittelijät (hiiri)
    ticker.addEventListener("mouseenter", () => {
      cancelAnimationFrame(animationId);
    });

    ticker.addEventListener("mousedown", (e) => {
      isDragging = true;
      startX = e.clientX;
      prevX = e.clientX;
      ticker.style.cursor = "grabbing"; // Visuaalinen palaute tarttumisesta
    });

    ticker.addEventListener("mousemove", (e) => {
      if (!isDragging) return;
      
      // Suunnanvaihto ja manuaalinen rullaus hiirellä "raadattaessa"
      const deltaX = e.clientX - prevX;
      prevX = e.clientX;
      
      // Päivitetään kulkusuunta sen perusteella, mihin suuntaan hiirtä viimeksi vedettiin
      if (deltaX > 0) direction = 1; // Oikealle
      else if (deltaX < 0) direction = -1; // Vasemmalle

      currentX += deltaX;
      
      const itemSetWidth = tickerContent.offsetWidth; 
      
      // Karusellin saumaton toisto vetäessä
      if (currentX <= -itemSetWidth) {
        currentX += itemSetWidth;
      } else if (currentX >= 0) {
        currentX -= itemSetWidth;
      }

      track.style.transform = `translateX(${currentX}px)`;
    });

    ticker.addEventListener("mouseup", () => {
      isDragging = false;
      ticker.style.cursor = "ew-resize"; // Palauta kohdistin takaisin vapaaksi
    });

    ticker.addEventListener("mouseleave", () => {
      isDragging = false;
      ticker.style.cursor = "ew-resize";
      // Palautetaan tausta-animaatio käyntiin irroitettaessa hiiri koko laatikosta
      cancelAnimationFrame(animationId); 
      animationId = requestAnimationFrame(animate);
    });
  }

  // Initialize both tickers
  initTicker("blogTicker");
  initTicker("presentationTicker");
  initTicker("zoteroTicker");
});
</script>
