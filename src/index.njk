---
layout: base.njk
title: Etusivu
lang: fi
translationKey: home
---

{% set uniquePresentationKeys = [] %}
{% for item in ((canva and canva.tableRows) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in (collections.presentations or []) %}
  {% set key = (((item.data and item.data.url) or "") ~ "|" ~ ((item.data and item.data.title) or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in ((finnaAoe and finnaAoe.rows) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% set heroPresentationCount = uniquePresentationKeys | length %}
{% set heroPublicationCount = (researchfi or []) | length %}
{% set heroOpinionCount = (collections.pub_mielipide or []) | length %}
{% set heroSpeechCount = (collections.pub_puhe or []) | length %}
{% set heroStats = [
    { count: heroPresentationCount, label: "Esitystä tai oppimateriaalia", href: "/esitykset/" },
    { count: heroPublicationCount, label: "julkaisua", href: "/julkaisut/" },
    { count: heroOpinionCount, label: "mielipidekirjoitusta", href: "/kynasta/#mielipiteet" },
    { count: heroSpeechCount, label: "puheenvuoroa", href: "/kynasta/#puheet" },
    { count: 100, label: "ohjattua opinnäytettä", href: "/opinnaytteet/" }
] %}

<section class="section-flush home-hero-section" id="heroSection">
    <div class="home-hero-backdrop">
        <div class="container home-hero-content">
            <p class="home-hero-eyebrow mb-2">Jari Laru</p>
            <h1 class="home-hero-title mb-3">Koulutan ja tutkin, miten tekoäly ja oppimisteknologia toimivat koulun arjessa.</h1>
            <p class="home-hero-lead mb-3">Yliopistonlehtori, kouluttaja ja kuntapäättäjä. Sivulta löydät esitykset, julkaisut, aloitteet ja käytännön työn tulokset samasta näkymästä.</p>

            <div class="home-hero-roles mb-4">
                <a class="home-hero-role-item" href="/tyoni-yliopistonlehtorina/">Yliopistonlehtori</a>
                <a class="home-hero-role-item" href="/larux-tmi/">Kouluttaja (Larux t:mi)</a>
                <a class="home-hero-role-item" href="/politiikka/">Kuntapäättäjä</a>
            </div>

            <div class="d-flex flex-wrap gap-2 mb-4">
                <a href="/yhteystiedot/" class="btn btn-primary btn-sm rounded-pill px-3">Pyydä tarjous</a>
                <a href="/esitykset/" class="btn btn-read-more btn-sm rounded-pill px-3">Katso esitykset <i class="bi bi-arrow-right"></i></a>
                <a href="/tutkimus/" class="btn btn-read-more btn-sm rounded-pill px-3">Tutustu tutkimukseen <i class="bi bi-arrow-right"></i></a>
            </div>

            <div class="home-hero-proof-grid">
                {% for stat in heroStats | sort(true, false, "count") %}
                <a class="home-hero-proof-item" href="{{ stat.href }}">
                    <span class="home-hero-proof-number">{{ stat.count }}</span>
                    <span class="home-hero-proof-label">{{ stat.label }}</span>
                </a>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

<section class="py-5 home-overview-section">
    <div class="container">
        <div class="row g-4 g-xl-5">

            {# Kortti 1: Yliopistonlehtori #}
            <div class="col-md-6 col-xl-3 home-overview-col">
                <div class="d-flex flex-column h-100">
                    <p class="home-overview-eyebrow">Yliopisto</p>
                    <h2 class="h5 fw-bold mb-2 home-overview-title">
                        <i class="bi bi-mortarboard me-2 opacity-75"></i>Yliopistonlehtori
                    </h2>
                    <p class="small mb-2 home-overview-lead">Teknologiatuetun oppimisen yliopistonlehtori, Kasvatustieteiden tiedekunta, Oulun yliopisto.</p>
                    <p class="small mb-3 home-overview-lead">Mukana STN:n rahoittamassa <strong>Generation AI</strong> -hankkeessa — tekoälykasvatusta esi- ja perusopetukseen.</p>
                    <ul class="list-unstyled small mb-3 home-overview-lead">
                        <li class="mb-1"><i class="bi bi-check2 me-1 opacity-75"></i>Opettajankoulutus</li>
                        <li class="mb-1"><i class="bi bi-check2 me-1 opacity-75"></i>Digipedagogiikka</li>
                        <li class="mb-1"><i class="bi bi-check2 me-1 opacity-75"></i>Tekoälylukutaito</li>
                        <li><i class="bi bi-check2 me-1 opacity-75"></i>Opinnäytetyöohjaus (100+)</li>
                    </ul>
                    <div class="mt-auto pt-2">
                        <a href="/tyoni-yliopistonlehtorina/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Lue lisää <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>

            {# Kortti 2: Kouluttaja & puhuja #}
            <div class="col-md-6 col-xl-3 home-overview-col">
                <div class="d-flex flex-column h-100">
                    <p class="home-overview-eyebrow">Koulutuspalvelut</p>
                    <h2 class="h5 fw-bold mb-2 home-overview-title">
                        <i class="bi bi-mic me-2 opacity-75"></i>Kouluttaja &amp; puhuja
                    </h2>
                    <p class="small mb-3 home-overview-lead">Keynote-esityksiä, koulutuksia ja työpajoja tekoälyn opetuskäytöstä, digipedagogiikasta ja oppimisen teknologioista. Larux t:mi.</p>
                    <div class="d-flex flex-column gap-1 mb-3">
                        {% for post in collections.presentations | take(2) %}
                        <a href="{{ post.data.url }}" target="_blank" rel="noopener noreferrer" class="d-flex align-items-center gap-2 text-decoration-none home-content-row p-2 rounded">
                            <div class="flex-grow-1 overflow-hidden">
                                <p class="fw-semibold mb-0 text-truncate" style="font-size:0.82rem;">{{ post.data.title }}</p>
                                <p class="text-muted mb-0" style="font-size:0.7rem;">{{ post.date | dateFormat }}</p>
                            </div>
                            <i class="bi bi-arrow-up-right text-muted flex-shrink-0" style="font-size:0.75rem;"></i>
                        </a>
                        {% endfor %}
                    </div>
                    <div class="d-flex flex-wrap gap-2 mt-auto pt-2">
                        <a href="/larux-tmi/" class="btn btn-primary btn-sm rounded-pill px-3">Tilaa koulutus</a>
                        <a href="/esitykset/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Kaikki esitykset</a>
                    </div>
                </div>
            </div>

            {# Kortti 3: Julkaisut APA7 #}
            <div class="col-md-6 col-xl-3 home-overview-col">
                <div class="d-flex flex-column h-100">
                    <p class="home-overview-eyebrow">Tiede &amp; tutkimus</p>
                    <h2 class="h5 fw-bold mb-2 home-overview-title">
                        <i class="bi bi-journal-text me-2 opacity-75"></i>Julkaisut
                    </h2>
                    <p class="small mb-3 home-overview-lead"><strong>{{ researchfi.length }} julkaisua</strong> — uusimmat Research.fi:stä.</p>
                    <div class="d-flex flex-column gap-2 mb-3">
                        {% for pub in researchfi.slice(0, 2) %}
                        <div class="home-apa-item">
                            <p class="home-apa-ref">
                                {%- if pub.authors -%}{{ pub.authors | truncate(60) }} {%- endif -%}
                                {%- if pub.year -%}({{ pub.year }}). {%- endif -%}
                                {{ pub.title | truncate(90) }}.
                                {%- if pub.journal %} <em>{{ pub.journal }}</em>.{%- endif %}
                                {%- if pub.doiUrl %} <a href="{{ pub.doiUrl }}" target="_blank" rel="noopener noreferrer" class="home-apa-doi">https://doi.org/{{ pub.doi }}</a>{%- elif pub.url %} <a href="{{ pub.url }}" target="_blank" rel="noopener noreferrer" class="home-apa-doi">Lue artikkeli <i class="bi bi-arrow-up-right"></i></a>{%- endif %}
                            </p>
                        </div>
                        {% endfor %}
                    </div>
                    <div class="mt-auto pt-2">
                        <a href="/julkaisut/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Kaikki julkaisut</a>
                    </div>
                </div>
            </div>

            {# Kortti 4: Politiikka #}
            <div class="col-md-6 col-xl-3 home-overview-col">
                <div class="d-flex flex-column h-100">
                    <p class="home-overview-eyebrow">Yhteiskunnallinen vaikuttaminen</p>
                    <h2 class="h5 fw-bold mb-2 home-overview-title">
                        <i class="bi bi-building me-2 opacity-75"></i>Politiikka
                    </h2>
                    <p class="small mb-3 home-overview-lead">Toisen kauden kaupunginvaltuutettu Oulussa (Kokoomus). Käytännön työtä paikallisen päätöksenteon parissa.</p>
                    <div class="d-flex flex-column gap-1 mb-3">
                        {% for post in collections.politicsAndOpinions | take(3) %}
                        {% if post.fileSlug != "etusivu" %}
                        <a href="{{ post.url }}" class="d-flex align-items-center gap-2 text-decoration-none home-content-row p-2 rounded">
                            <div class="flex-grow-1 overflow-hidden">
                                <p class="fw-semibold mb-0 text-truncate" style="font-size:0.82rem;">{{ post.data.title }}</p>
                                <p class="text-muted mb-0" style="font-size:0.7rem;">{{ post.data.type | capitalize or "Kirjoitus" }} · {{ post.date | dateFormat }}</p>
                            </div>
                            <i class="bi bi-arrow-right text-muted flex-shrink-0" style="font-size:0.75rem;"></i>
                        </a>
                        {% endif %}
                        {% endfor %}
                    </div>
                    <div class="d-flex flex-wrap gap-2 mt-auto pt-2">
                        <a href="/politiikka/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Politiikkasivu</a>
                        <a href="/kynasta/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Kynästä</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<section class="py-5 bg-body-tertiary home-testimonials-section">
    <div class="container">
        <p class="text-uppercase fw-bold text-center mb-4 home-testimonials-label">Palautetta koulutuksista</p>
        <div class="row g-4 justify-content-center">
            <div class="col-md-5">
                <blockquote class="home-quote">
                    <p>"Ihan fiiliksissä vieläkin setistäsi. Yhteyden katkeaminen ei latistanut, vaan porukka alkoi heti reflektoida kuultua."</p>
                    <footer class="home-quote-footer">Henkilöstökoulutus</footer>
                </blockquote>
            </div>
            <div class="col-md-5">
                <blockquote class="home-quote">
                    <p>"Palaute kyselyn perusteella olit osallistujien mielestä päivän paras puhuja."</p>
                    <footer class="home-quote-footer">Maksullinen seminaari</footer>
                </blockquote>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-body-tertiary home-closing-section" style="border-top: 1px solid var(--bs-border-color-translucent);">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="home-closing-panel text-center">
                    <p class="text-uppercase text-muted fw-bold mb-2">Seuraava askel</p>
                    <h2 class="fw-bold mb-3">Tarvitsetko kouluttajan, puhujan tai tutkimukseen nojaavan asiantuntijan?</h2>
                    <p class="mb-4">Sivulla esitellyt teemat jatkuvat käytännön yhteistyössä: koulutuksina, puheenvuoroina, hanketukena ja kehittämistyön sparrauksena.</p>
                    <div class="home-closing-actions d-flex flex-wrap justify-content-center gap-2 mb-3">
                        <a class="btn btn-primary rounded-pill px-4" href="/yhteystiedot/">Pyydä tarjous</a>
                        <a class="btn btn-read-more btn-sm rounded-pill px-3" href="/larux-tmi/">Katso palvelut</a>
                        <a class="btn btn-outline-secondary btn-sm rounded-pill px-3" href="/tietoa/">Tutustu taustaani</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
