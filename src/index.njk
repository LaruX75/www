---
layout: base.njk
title: Etusivu
lang: fi
translationKey: home
---

<section class="section-flush" id="heroSection">
    <div class="pb-0 d-flex justify-content-center align-items-center" data-bss-scroll-zoom="true" data-bss-scroll-zoom-speed="1" style="height: 600px;background: linear-gradient(rgba(18,42,71,0) 59%, rgb(4,16,36) 85%), url(&quot;/img/WIN_20210329_16_06_01_Pro.jpg&quot;) center / cover; position: relative; overflow: hidden; margin: 0px;margin-bottom: 0px!important;">
        <h1 class="visually-hidden">Tervetuloa!</h1>
        <div class="hero-drift w-100 px-3 text-center" data-aos="fade" style="z-index: 2;">
            <svg class="hero-aurora-svg w-100" viewBox="0 0 1000 250" preserveAspectRatio="xMidYMid meet" style="max-height: 250px; overflow: visible;">
                <defs>
                    <linearGradient id="auroraGrad" x1="0%" y1="0%" x2="200%" y2="0%">
                        <stop offset="0%" stop-color="#66ffcc" />
                        <stop offset="16%" stop-color="#33ccaa" />
                        <stop offset="33%" stop-color="#7b68ee" />
                        <stop offset="50%" stop-color="#a855f7" />
                        <stop offset="66%" stop-color="#38bdf8" />
                        <stop offset="83%" stop-color="#2dd4bf" />
                        <stop offset="100%" stop-color="#66ffcc" />
                        <animate attributeName="x1" values="0%; -100%; 0%" dur="8s" repeatCount="indefinite" />
                        <animate attributeName="x2" values="200%; 100%; 200%" dur="8s" repeatCount="indefinite" />
                    </linearGradient>
                </defs>
                <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" 
                      fill="transparent" stroke="url(#auroraGrad)" stroke-width="2" stroke-linejoin="round"
                      font-family="'Bree Serif', serif" font-size="160px" font-weight="bold"
                      style="filter: drop-shadow(0 0 10px rgba(102, 255, 204, 0.4));">
                    TERVETULOA!
                </text>
            </svg>
        </div>
    </div>
</section>

<section class="section-flush bg-adaptive-dark-blue">
    <div class="container-fluid" style="padding-top: 0;">
        <div class="row gy-4 gy-md-0">
            <div class="col-md-6 ps-0 pe-0">
                <div class="h-100"><img loading="lazy" decoding="async" class="img-fluid object-fit-cover w-100 h-100" width="1024" height="768" style="min-height: 100%;transform: perspective(0px) scale(1);filter: blur(0px);transition: ease-in;" src="/img/image%20(4).webp" alt="Jari Laru"></div>
            </div>
            <div class="col-md-6 text-center text-md-start d-flex d-sm-flex d-md-flex justify-content-center align-items-center justify-content-md-start align-items-md-center justify-content-xl-center" style="height: auto;min-height: 100%;padding-bottom: 1em;padding-left: 0.5em;padding-right: 1em;padding-top: 0.5em;">
                <div class="border vw-100 align-self-start" style="max-width: none;width: auto;padding-top: 1em;padding-left: 1em;padding-right: 1em;">
                    <h2 class="text-uppercase fw-bold" style="font-family: 'Bree Serif', serif;padding: 0px;">Jari Jukka Laru, KT</h2>
                    <h3>Olen poliitikko</h3>
                    <p>Olen oululainen toisen kauden kaupunginvaltuutettu (.kok). Olen kokenut poliitikko, sillä olen aloittanut yhteiskunnallisten asioiden parissa jo lukiolaisena.</p>
                    <a class="btn btn-primary" href="/politiikka/">Lue lisää politiikasta</a>
                    <h3 style="margin-top: 8px;"><strong>Työskentelen Oulun yliopistossa</strong></h3>
                    <p>Työskentelen Oulun yliopiston kasvatustieteiden tiedekunnassa teknologiatuetun oppimisen- ja opettamisen yliopistonlehtorina.</p>
                    <a class="btn btn-primary" href="/tyoni-yliopistonlehtorina/">Lue lisää työstä</a>
                    <h3><strong>Koulutan ja luennoin sivutoimisesti</strong></h3>
                    <p>Teen sivutoimisena yrittäjänä luennointi-, koulutus-, ja www-sivutöitä [Lue lisää toiminimi Larux tmi:n toiminnasta]</p>
                    <a class="btn btn-primary" href="/koulutukset/">Lue koulutuksista ja luennoista</a>
                    <h3><strong>Olen isä ja aviomies</strong></h3>
                    <p>Asun perheeni kanssa Jäälissä, jossa olen toiminut useiden vuosien ajan asukasyhdistyksen puheenjohtajana. Olen bibliofiili, kulinaristi, automatkailija ja 70-luvun talon remontoija. [Lue lisää]</p>
                    <a class="btn btn-primary mb-3" href="/tietoa/">Lue lisää minusta</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-flush bg-adaptive-dark-blue">
    <div class="container-fluid" style="padding-top: 0;border-radius: 0px;">
        <div class="row gx-0 gy-4 gy-md-0">
            <div class="col-md-6 text-center text-md-start d-flex d-sm-flex d-md-flex flex-column justify-content-center align-items-center align-self-start order-2 order-sm-1 justify-content-md-start align-items-md-center justify-content-xl-center ps-0 pe-0" style="height: auto;min-height: 100%;padding-bottom: 1em;padding-top: 0.5em;">
                <div class="border-0 w-100 align-self-start" style="max-width: none;width: auto;padding-top: 1em;padding-left: 1rem;padding-right: 1rem;">
                    <h2 class="text-uppercase fw-bold" style="font-family: 'Bree Serif', serif;padding: 0px;">Jari Jukka Laru, KT</h2>
                    <h3>Olen poliitikko</h3>
                    <p>Olen oululainen toisen kauden kaupunginvaltuutettu (.kok). Olen kokenut poliitikko, sillä olen aloittanut yhteiskunnallisten asioiden parissa jo lukiolaisena.</p>
                    <a class="btn btn-primary mb-3" href="/politiikka/">Lue lisää politiikasta</a>
                </div>
                <!-- Karuselli alkaa -->
                <div class="ticker-wrapper" id="blogTicker" style="margin-top: 1rem;">
                    <div class="ticker-track">
                        <!-- Ensimmäinen setti -->
                        <div class="ticker-content">
                            {% for post in collections.politicsAndOpinions | take(6) %}
                            <div class="ticker-item p-4">
                                <h3><a class="ticker-title-link" href="{{ post.url }}">{{ post.data.title }}</a></h3>
                                <div class="d-flex align-items-center mt-3 mb-3">
                                    {% if post.data.thumbnail %}
                                    <img loading="lazy" decoding="async" class="object-fit-cover rounded-circle flex-shrink-0 me-3" width="50" height="50" src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}">
                                    {% else %}
                                    <div class="rounded-circle flex-shrink-0 me-3 bg-secondary d-flex justify-content-center align-items-center" style="width: 50px; height: 50px;"><i class="bi bi-person text-light"></i></div>
                                    {% endif %}
                                    <div>
                                        <p class="fw-bold mb-0" style="font-size: 0.9rem;">Jari Laru</p>
                                        <p class="text-muted mb-0" style="font-size: 0.8rem;">Kirjoittaja &bull; {{ post.date | dateFormat }}</p>
                                    </div>
                                </div>
                                <p>{{ post.data.description or (post.content | excerpt) }}</p>
                                <div class="d-flex justify-content-start mt-3 mb-2">
                                    <a href="{{ post.url }}" class="btn btn-read-more btn-sm rounded-pill px-3">Lue lisää <i class="bi bi-arrow-right"></i></a>
                                </div>
                                <div class="mt-3">
                                    {% if post.data.categories and post.data.categories.length > 0 %}
                                        {% for cat in post.data.categories %}
                                            <span class="badge text-bg-secondary rounded-pill me-1">{{ cat }}</span>
                                        {% endfor %}
                                    {% elif post.data.type %}
                                        <span class="badge text-bg-secondary rounded-pill me-1">{{ post.data.type | capitalize }}</span>
                                    {% else %}
                                        <span class="badge text-bg-secondary rounded-pill me-1">Julkaisu</span>
                                    {% endif %}
                                </div>
                            </div>
                            {% else %}
                            <div class="ticker-item p-4">
                                <p>Ei vielä kirjoituksia.</p>
                            </div>
                            {% endfor %}
                        </div>
                        <!-- Toinen setti (klooni animaatiota varten) -->
                        <div class="ticker-content" aria-hidden="true">
                            {% for post in collections.politicsAndOpinions | take(6) %}
                            <div class="ticker-item p-4">
                                <h3><a class="ticker-title-link" href="{{ post.url }}">{{ post.data.title }}</a></h3>
                                <div class="d-flex align-items-center mt-3 mb-3">
                                    {% if post.data.thumbnail %}
                                    <img loading="lazy" decoding="async" class="object-fit-cover rounded-circle flex-shrink-0 me-3" width="50" height="50" src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}">
                                    {% else %}
                                    <div class="rounded-circle flex-shrink-0 me-3 bg-secondary d-flex justify-content-center align-items-center" style="width: 50px; height: 50px;"><i class="bi bi-person text-light"></i></div>
                                    {% endif %}
                                    <div>
                                        <p class="fw-bold mb-0" style="font-size: 0.9rem;">Jari Laru</p>
                                        <p class="text-muted mb-0" style="font-size: 0.8rem;">Kirjoittaja &bull; {{ post.date | dateFormat }}</p>
                                    </div>
                                </div>
                                <p>{{ post.data.description or (post.content | excerpt) }}</p>
                                <div class="d-flex justify-content-start mt-3 mb-2">
                                    <a href="{{ post.url }}" class="btn btn-read-more btn-sm rounded-pill px-3">Lue lisää <i class="bi bi-arrow-right"></i></a>
                                </div>
                                <div class="mt-3">
                                    {% if post.data.categories and post.data.categories.length > 0 %}
                                        {% for cat in post.data.categories %}
                                            <span class="badge text-bg-secondary rounded-pill me-1">{{ cat }}</span>
                                        {% endfor %}
                                    {% elif post.data.type %}
                                        <span class="badge text-bg-secondary rounded-pill me-1">{{ post.data.type | capitalize }}</span>
                                    {% else %}
                                        <span class="badge text-bg-secondary rounded-pill me-1">Julkaisu</span>
                                    {% endif %}
                                </div>
                            </div>
                            {% else %}
                            <div class="ticker-item p-4">
                                <p>Ei vielä kirjoituksia.</p>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
                <!-- Karuselli päättyy -->
            </div>
            <div class="col-md-6 order-1 order-sm-1 ps-0 pe-0">
                <div class="h-100"><img loading="lazy" decoding="async" class="img-fluid object-fit-cover w-100 h-100" width="1024" height="768" style="min-height: 100%;transform: perspective(0px) scale(1);filter: blur(0px);transition: ease-in;" src="/img/valtuusto.jpg" alt="Valtuustosali"></div>
            </div>
        </div>
    </div>
</section>

