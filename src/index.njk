---
layout: base.njk
title: Etusivu
lang: fi
translationKey: home
---

{% set uniquePresentationKeys = [] %}
{% for item in ((canva and canva.tableRows) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in (collections.presentations or []) %}
  {% set key = (((item.data and item.data.url) or "") ~ "|" ~ ((item.data and item.data.title) or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in ((finnaAoe and finnaAoe.rows) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% set heroPresentationCount = uniquePresentationKeys | length %}
{% set heroPublicationCount = (researchfi or []) | length %}
{% set heroOpinionCount = (collections.pub_mielipide or []) | length %}
{% set heroSpeechCount = (collections.pub_puhe or []) | length %}
{% set heroStats = [
    { count: heroPresentationCount, label: "Esitystä tai oppimateriaalia", href: "/esitykset/" },
    { count: heroPublicationCount, label: "julkaisua", href: "/julkaisut/" },
    { count: heroOpinionCount, label: "mielipidekirjoitusta", href: "/kynasta/#mielipiteet" },
    { count: heroSpeechCount, label: "puheenvuoroa", href: "/kynasta/#puheet" },
    { count: 100, label: "ohjattua opinnäytettä", href: "/opinnaytteet/" }
] %}

<section class="section-flush home-hero-section" id="heroSection">
    <div class="home-hero-backdrop">
        <div class="container home-hero-content">
            <p class="home-hero-eyebrow mb-2">Jari Laru</p>
            <h1 class="home-hero-title mb-3">Koulutan ja tutkin, miten tekoäly ja oppimisteknologia toimivat koulun arjessa.</h1>
            <p class="home-hero-lead mb-3">Yliopistonlehtori, kouluttaja ja kuntapäättäjä. Sivulta löydät esitykset, julkaisut, aloitteet ja käytännön työn tulokset samasta näkymästä.</p>

            <div class="home-hero-roles mb-4">
                <a class="home-hero-role-item" href="/tyoni-yliopistonlehtorina/">Yliopistonlehtori</a>
                <a class="home-hero-role-item" href="/larux-tmi/">Kouluttaja (Larux t:mi)</a>
                <a class="home-hero-role-item" href="/politiikka/">Kuntapäättäjä</a>
            </div>

            <div class="d-flex flex-wrap gap-2 mb-4">
                <a href="/yhteystiedot/" class="btn btn-primary btn-sm rounded-pill px-3">Pyydä tarjous</a>
                <a href="/esitykset/" class="btn btn-read-more btn-sm rounded-pill px-3">Katso esitykset <i class="bi bi-arrow-right"></i></a>
                <a href="/tutkimus/" class="btn btn-read-more btn-sm rounded-pill px-3">Tutustu tutkimukseen <i class="bi bi-arrow-right"></i></a>
            </div>

            <div class="home-hero-proof-grid">
                {% for stat in heroStats | sort(true, false, "count") %}
                <a class="home-hero-proof-item" href="{{ stat.href }}">
                    <span class="home-hero-proof-number">{{ stat.count }}</span>
                    <span class="home-hero-proof-label">{{ stat.label }}</span>
                </a>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

<section class="home-section-heading-strip home-section-heading-strip--dark">
    <div class="container-fluid">
        <p class="home-section-heading-strip__eyebrow">Asiantuntija- ja koulutuspalvelut</p>
        <h2 class="home-section-heading-strip__title">Opettajankouluttaja, koulutusteknologi ja täydennyskouluttaja</h2>
    </div>
</section>

<section class="section-flush bg-adaptive-dark-blue py-4 py-md-0 home-feature-section">
    <div class="container-fluid" style="padding-top: 0;border-radius: 0px;">
        <div class="row gx-0 gy-4 gy-md-0">
            <div class="col-md-6 ps-0 pe-0 home-feature-image-col">
                <div class="h-100"><img loading="lazy" decoding="async" class="img-fluid object-fit-cover w-100 h-100 home-section-image" width="1024" height="768" style="min-height: 100%;" src="/img/image%20(4).webp" alt="Koulutus"></div>
            </div>
            <div class="col-md-6 d-flex flex-column justify-content-start ps-0 pe-0" style="padding: 2rem 1.5rem;">
                <p class="text-uppercase text-muted fw-bold mb-2" style="font-size: 0.75rem;">Mitä saat yhteistyöstä</p>
                <h2 class="fw-bold mb-3" style="font-family: 'Bree Serif', serif;">Tutkimusperustaista opetusta ja koulutusta</h2>
                <p class="mb-1 small"><i class="bi bi-mortarboard me-2 opacity-75"></i><strong>Yliopistonlehtori, Oulun yliopisto</strong></p>
                <p class="mb-3 small opacity-75">Teknologiatuetun oppimisen yliopistonlehtori. Mukana STN:n Generation AI -hankkeessa — tekoälykasvatusta esi- ja perusopetukseen.</p>
                <p class="mb-1 small"><i class="bi bi-mic me-2 opacity-75"></i><strong>Kouluttaja &amp; puhuja – Larux t:mi</strong></p>
                <p class="mb-3 small opacity-75">Puheenvuoroja, koulutuksia ja asiantuntijatyötä opetusteknologian, digipedagogiikan ja tekoälyn opetuskäytön teemoista.</p>
                <div class="d-flex flex-wrap gap-2 mb-4">
                    <a href="/larux-tmi/" class="btn btn-primary btn-sm rounded-pill px-3">Tilaa koulutus tai puheenvuoro</a>
                    <a href="/tyoni-yliopistonlehtorina/" class="btn btn-read-more btn-sm rounded-pill px-3">Lue yliopistosta <i class="bi bi-arrow-right"></i></a>
                </div>

                <p class="text-uppercase text-muted fw-bold mb-2" style="font-size: 0.72rem;">Viimeisimmät esitykset</p>
                <div class="d-flex flex-column gap-2 mb-3">
                    {% for post in collections.presentations | take(3) %}
                    <a href="{{ post.data.url }}" target="_blank" rel="noopener noreferrer" class="d-flex align-items-center gap-3 p-2 rounded text-decoration-none home-content-row">
                        {% if post.data.thumbnail %}
                        <img src="{{ post.data.thumbnail }}" alt="" class="rounded flex-shrink-0" style="width:48px;height:36px;object-fit:cover;">
                        {% else %}
                        <div class="rounded flex-shrink-0 bg-secondary d-flex align-items-center justify-content-center" style="width:48px;height:36px;"><i class="bi bi-file-earmark-slides text-light" style="font-size:0.85rem;"></i></div>
                        {% endif %}
                        <div class="flex-grow-1 overflow-hidden">
                            <p class="fw-semibold mb-0 text-truncate" style="font-size:0.85rem;">{{ post.data.title }}</p>
                            <p class="text-muted mb-0" style="font-size: 0.72rem;">{{ post.date | dateFormat }}</p>
                        </div>
                        <i class="bi bi-arrow-up-right text-muted flex-shrink-0" style="font-size:0.8rem;"></i>
                    </a>
                    {% endfor %}
                </div>
                <a href="/esitykset/" class="btn btn-outline-secondary btn-sm rounded-pill px-3 align-self-start">Kaikki esitykset <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
</section>

<section class="home-section-heading-strip home-section-heading-strip--light">
    <div class="container-fluid">
        <p class="home-section-heading-strip__eyebrow">Palautetta</p>
        <h2 class="home-section-heading-strip__title">Mitä minusta on sanottu</h2>
    </div>
</section>

<section class="py-4 bg-body-tertiary home-feedback-section">
    <div class="container">
        <div class="row justify-content-center mb-4">
            <div class="col-lg-8 text-center">
                <p class="text-uppercase text-muted fw-bold mb-2">Vaikutus käytännössä</p>
                <h2 class="fw-bold">Koulutuksista saatua palautetta</h2>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-md-6">
                <article class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <h3 class="h6 text-uppercase text-muted">Henkilöstökoulutus</h3>
                        <p class="mb-0">"Ihan fiiliksissä vieläkin setistäsi. Yhteyden katkeaminen ei latistanut, vaan porukka alkoi heti reflektoida kuultua."</p>
                    </div>
                </article>
            </div>
            <div class="col-md-6">
                <article class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <h3 class="h6 text-uppercase text-muted">Valtion täydennyskoulutus</h3>
                        <p class="mb-0">"Saimme aivan huikean hyvät arvioinnit. Kokonaiskeskiarvo 4,2 / 5 oli erinomainen."</p>
                    </div>
                </article>
            </div>
            <div class="col-md-6">
                <article class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <h3 class="h6 text-uppercase text-muted">Osallistujapalaute (OPH)</h3>
                        <p class="mb-0">"Oikein mielenkiintoista ja opettajan työhön todella tarpeellista ja käytännönläheistä tietoa."</p>
                    </div>
                </article>
            </div>
            <div class="col-md-6">
                <article class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <h3 class="h6 text-uppercase text-muted">Maksullinen seminaari</h3>
                        <p class="mb-0">"Palaute kyselyn perusteella olit osallistujien mielestä päivän paras puhuja."</p>
                    </div>
                </article>
            </div>
        </div>
    </div>
</section>

<section class="home-section-heading-strip home-section-heading-strip--dark">
    <div class="container-fluid">
        <p class="home-section-heading-strip__eyebrow">Tiede &amp; Tutkimus</p>
        <h2 class="home-section-heading-strip__title">Tutkimus ja julkaisut</h2>
    </div>
</section>

<section class="section-flush bg-adaptive-dark-blue py-4 py-md-0 home-feature-section">
    <div class="container-fluid" style="padding-top: 0;border-radius: 0px;">
        <div class="row gx-0 gy-4 gy-md-0 flex-md-row-reverse">
            <div class="col-md-6 ps-0 pe-0 home-feature-image-col">
                <div class="h-100"><img loading="lazy" decoding="async" class="img-fluid object-fit-cover w-100 h-100 home-section-image" width="1024" height="768" style="min-height: 100%;" src="/img/uploads/2026/vaitos.png" alt="Tutkimus ja julkaisut"></div>
            </div>
            <div class="col-md-6 d-flex flex-column justify-content-start ps-0 pe-0" style="padding: 2rem 1.5rem;">
                <p class="text-uppercase text-muted fw-bold mb-2" style="font-size: 0.75rem;">Tutkimusprofiili</p>
                <h2 class="fw-bold mb-3" style="font-family: 'Bree Serif', serif;">Julkaisujen kokonaiskuva</h2>
                <p class="mb-4 small opacity-75">Uusimmat tieteelliset julkaisuni suoraan Research.fi-palvelusta päivitettynä.</p>

                {%- set articleCount = 0 -%}
                {%- set confCount = 0 -%}
                {%- set bookCount = 0 -%}
                {%- for pub in researchfi -%}
                    {%- if pub.typeCode == "A1" or pub.typeCode == "A2" -%}{%- set articleCount = articleCount + 1 -%}{%- endif -%}
                    {%- if pub.typeCode == "A3" or pub.typeCode == "A4" or pub.typeCode == "B3" -%}{%- set confCount = confCount + 1 -%}{%- endif -%}
                    {%- if pub.typeCode == "C1" or pub.typeCode == "C2" or pub.typeCode == "G4" or pub.typeCode == "G5" -%}{%- set bookCount = bookCount + 1 -%}{%- endif -%}
                {%- endfor -%}

                <div class="d-flex flex-wrap gap-3 mb-4">
                    <div class="research-stat-card text-center px-3 py-2">
                        <div class="research-stat-number">{{ researchfi.length }}</div>
                        <div class="research-stat-label">Julkaisua</div>
                    </div>
                    <div class="research-stat-card text-center px-3 py-2">
                        <div class="research-stat-number">{{ articleCount }}</div>
                        <div class="research-stat-label">Lehtiartikkelia</div>
                    </div>
                    <div class="research-stat-card text-center px-3 py-2">
                        <div class="research-stat-number">{{ confCount }}</div>
                        <div class="research-stat-label">Konferenssijulkaisua</div>
                    </div>
                    <div class="research-stat-card text-center px-3 py-2">
                        <div class="research-stat-number">{{ bookCount }}</div>
                        <div class="research-stat-label">Kirjaa &amp; väitöskirjaa</div>
                    </div>
                </div>

                <p class="text-uppercase text-muted fw-bold mb-2" style="font-size: 0.72rem;">Viimeisimmät julkaisut</p>
                <div class="d-flex flex-column gap-2 mb-3">
                    {% for pub in researchfi.slice(0, 3) %}
                    <div class="d-flex align-items-start gap-3 p-2 rounded home-content-row">
                        <div class="flex-grow-1 overflow-hidden">
                            <p class="fw-semibold mb-0" style="font-size:0.85rem;">{{ pub.title | truncate(90) }}</p>
                            <p class="text-muted mb-0" style="font-size: 0.72rem;">{{ pub.typeFi }}{% if pub.year %} · {{ pub.year }}{% endif %}</p>
                        </div>
                        {% if pub.url %}
                        <a href="{{ pub.url }}" target="_blank" rel="noopener noreferrer" class="flex-shrink-0 text-muted" style="font-size:0.8rem;" aria-label="Avaa julkaisu"><i class="bi bi-arrow-up-right"></i></a>
                        {% endif %}
                    </div>
                    {% endfor %}
                </div>
                <a href="/julkaisut/" class="btn btn-primary rounded-pill px-4 align-self-start">Selaa kaikkia julkaisuja</a>
            </div>
        </div>
    </div>
</section>

<section class="home-section-heading-strip home-section-heading-strip--dark">
    <div class="container-fluid">
        <p class="home-section-heading-strip__eyebrow">Yhteiskunnallinen vaikuttaminen</p>
        <h2 class="home-section-heading-strip__title">Politiikka ja vaikuttaminen</h2>
    </div>
</section>

<section class="section-flush bg-adaptive-dark-blue py-4 py-md-0 home-feature-section">
    <div class="container-fluid" style="padding-top: 0;border-radius: 0px;">
        <div class="row gx-0 gy-4 gy-md-0">
            <div class="col-md-6 ps-0 pe-0 home-feature-image-col order-1 order-md-2">
                <div class="h-100"><img loading="lazy" decoding="async" class="img-fluid object-fit-cover w-100 h-100 home-section-image" width="1024" height="768" style="min-height: 100%;" src="/img/valtuusto.jpg" alt="Valtuustosali"></div>
            </div>
            <div class="col-md-6 d-flex flex-column justify-content-start ps-0 pe-0 order-2 order-md-1" style="padding: 2rem 1.5rem;">
                <p class="text-uppercase text-muted fw-bold mb-2" style="font-size: 0.75rem;">Vaikuttamisen teemat</p>
                <h2 class="fw-bold mb-3" style="font-family: 'Bree Serif', serif;">Paikallispolitiikan käytännön työ</h2>
                <div class="home-focus-grid text-start mb-4">
                    <article class="home-focus-card">
                        <h3 class="h6 mb-2"><i class="bi bi-building-fill me-2 opacity-75"></i>Kunnallispolitiikan käytännön työ</h3>
                        <p class="small mb-2">Politiikkasivulla avaan luottamustehtäviä, vaikuttamisen painopisteitä sekä tavoitteita Oulun päätöksenteossa.</p>
                        <a class="btn btn-read-more btn-sm rounded-pill px-3" href="/politiikka/">Lue politiikkasivu</a>
                    </article>
                    <article class="home-focus-card">
                        <h3 class="h6 mb-2"><i class="bi bi-chat-left-text me-2 opacity-75"></i>Kirjoitukset, puheet ja aloitteet</h3>
                        <p class="small mb-2">Kynästä-osio kokoaa mielipidekirjoitukset, puheenvuorot, kolumnit ja aloitteet yhdelle sivulle seurattavaksi.</p>
                        <a class="btn btn-read-more btn-sm rounded-pill px-3" href="/kynasta/">Siirry Kynästä-osioon</a>
                    </article>
                </div>

                <p class="text-uppercase text-muted fw-bold mb-2" style="font-size: 0.72rem;">Viimeisimmät kirjoitukset</p>
                <div class="d-flex flex-column gap-2 mb-3">
                    {% for post in collections.politicsAndOpinions | take(3) %}
                    {% if post.fileSlug != "etusivu" %}
                    <a href="{{ post.url }}" class="d-flex align-items-center gap-3 p-2 rounded text-decoration-none home-content-row">
                        <div class="flex-grow-1 overflow-hidden">
                            <p class="fw-semibold mb-0 text-truncate" style="font-size:0.85rem;">{{ post.data.title }}</p>
                            <p class="text-muted mb-0" style="font-size: 0.72rem;">{{ post.data.type | capitalize or "Kirjoitus" }} · {{ post.date | dateFormat }}</p>
                        </div>
                        <i class="bi bi-arrow-right text-muted flex-shrink-0" style="font-size:0.8rem;"></i>
                    </a>
                    {% endif %}
                    {% endfor %}
                </div>
                <a href="/kynasta/" class="btn btn-primary rounded-pill px-4 align-self-start">Lue kaikki kirjoitukset</a>
            </div>
        </div>
    </div>
</section>

<section class="home-section-heading-strip home-section-heading-strip--light">
    <div class="container-fluid">
        <p class="home-section-heading-strip__eyebrow">Yhteistyö</p>
        <h2 class="home-section-heading-strip__title">Jatketaan tästä</h2>
    </div>
</section>

<section class="py-5 bg-body-tertiary home-closing-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="home-closing-panel text-center">
                    <p class="text-uppercase text-muted fw-bold mb-2">Seuraava askel</p>
                    <h2 class="fw-bold mb-3">Tarvitsetko kouluttajan, puhujan tai tutkimukseen nojaavan asiantuntijan?</h2>
                    <p class="mb-4">Sivulla esitellyt teemat jatkuvat käytännön yhteistyössä: koulutuksina, puheenvuoroina, hanketukena ja kehittämistyön sparrauksena.</p>
                    <div class="home-closing-actions d-flex flex-wrap justify-content-center gap-2 mb-3">
                        <a class="btn btn-primary rounded-pill px-4" href="/yhteystiedot/">Pyydä tarjous</a>
                        <a class="btn btn-read-more btn-sm rounded-pill px-3" href="/larux-tmi/">Katso palvelut</a>
                        <a class="btn btn-outline-secondary btn-sm rounded-pill px-3" href="/tietoa/">Tutustu taustaani</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
