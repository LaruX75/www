                    </div>
                </div>
                <!-- Karuselli päättyy -->
                <div class="text-center pb-3 pt-2 w-100">
                    <a href="/kynasta/" class="btn btn-primary rounded-pill px-4">Lue kaikki kirjoitukset</a>
