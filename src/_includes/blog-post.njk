---
layout: base.njk
---
<section>
  <div class="container">
    <article class="blog-post">
      <div class="card shadow-sm">
        <div class="card-body">
          <p class="text-uppercase small text-muted mb-2">Blogi</p>
          <h1 class="display-6 fw-bold">{{ title }}</h1>
          <p class="text-muted mb-4">{{ date | dateFormat }}</p>
          {% if thumbnail %}
            <img loading="lazy" decoding="async" src="{{ thumbnail }}" class="img-fluid rounded mb-4" alt="{{ title }}">
          {% endif %}
          <div class="post-content content-prose">{{ content | safe }}</div>
          {% if tags %}
            <div class="mt-4">
              {% for tag in tags %}{% if tag != "blog" %}<span class="badge text-bg-secondary me-1">{{ tag }}</span>{% endif %}{% endfor %}
            </div>
          {% endif %}
          {% if categories %}
            <div class="mt-4">
              <p class="text-uppercase small text-muted mb-2">Kategoriat</p>
              {% for cat in categories %}<a class="badge text-bg-secondary me-1 text-decoration-none" href="/kategoriat/{{ cat | slugify }}/">{{ cat }}</a>{% endfor %}
            </div>
          {% endif %}
          {% if keywords %}
            <div class="mt-3">
              <p class="text-uppercase small text-muted mb-2">Avainsanat</p>
              {% for key in keywords %}<a class="badge text-bg-light text-dark border me-1 text-decoration-none" href="/avainsanat/{{ key | slugify }}/">{{ key }}</a>{% endfor %}
            </div>
          {% endif %}
        </div>
        <div class="card-footer bg-white">
          <a href="/blogi/" class="btn btn-outline-primary">&larr; Takaisin blogiin</a>
        </div>
      </div>
    </article>
  </div>
</section>
