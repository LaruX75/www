---
layout: base.njk
---
{% set currentLang = lang or (page.url | langFromUrl) %}
{% set txt = {
  section:    "Blog" if currentLang == "en" else "Blogi",
  toc:        "Contents" if currentLang == "en" else "Sisällys",
  categories: "Categories" if currentLang == "en" else "Kategoriat",
  keywords:   "Keywords" if currentLang == "en" else "Avainsanat",
  back:       "Back to blog" if currentLang == "en" else "Takaisin blogiin",
  backHref:   "/en/blog/" if currentLang == "en" else "/blogi/",
  catBase:    "/en/categories/" if currentLang == "en" else "/kategoriat/",
  kwBase:     "/en/keywords/" if currentLang == "en" else "/avainsanat/"
} %}
{% set externalSourceHref = "" %}
{% if sourceUrl %}
  {% set externalSourceHref = sourceUrl %}
{% elif source_url %}
  {% set externalSourceHref = source_url %}
{% elif originalUrl %}
  {% set externalSourceHref = originalUrl %}
{% elif original_url %}
  {% set externalSourceHref = original_url %}
{% endif %}
<section>
  <div class="site-shell">
    <article class="blog-post">
      <div class="card shadow-sm">
        <div class="card-body">
          <p class="text-uppercase small text-muted mb-2">{{ txt.section }}</p>
          <h1 class="display-6 fw-bold">{{ title }}</h1>
          <p class="text-muted mb-4">{{ date | dateFormat }}</p>
          {% set tocMarkup = content | toc %}
          <div class="row g-4">
            <div class="col-lg-8">
              {% if thumbnail %}
                <figure class="mb-4">
                  <img loading="lazy" decoding="async" src="{{ thumbnail }}" class="img-fluid rounded" alt="{{ imageAlt or title }}">
                  {% if imageCaption %}
                    <figcaption class="small text-muted mt-2">{{ imageCaption }}</figcaption>
                  {% endif %}
                </figure>
              {% endif %}
              <div class="post-content content-prose">{{ content | safe }}</div>
              {% if externalSourceHref %}
                <aside class="content-detail-card my-4" aria-labelledby="blog-original-source-title">
                  <p class="content-detail-card-kicker">{{ "Original source" if currentLang == "en" else "Alkuperäinen lähde" }}</p>
                  <h2 id="blog-original-source-title" class="h5">{{ "This text is based on an earlier publication" if currentLang == "en" else "Teksti pohjautuu aiempaan julkaisuun" }}</h2>
                  <p>
                    {% if sourceLabel %}
                      {{ "Original publication:" if currentLang == "en" else "Alkuperäinen julkaisu:" }} {{ sourceLabel }}.
                    {% else %}
                      {{ "Open the original source for context." if currentLang == "en" else "Avaa alkuperäinen lähde taustatiedoksi." }}
                    {% endif %}
                  </p>
                  <a class="btn btn-outline-primary" href="{{ externalSourceHref }}" target="_blank" rel="noopener noreferrer">
                    {{ "Open original source" if currentLang == "en" else "Avaa alkuperäinen julkaisu" }}
                    <i class="bi bi-box-arrow-up-right ms-1" aria-hidden="true"></i>
                  </a>
                </aside>
              {% endif %}
            </div>
            <aside class="col-lg-4">
              {% include "content-context-sidebar.njk" %}
            </aside>
          </div>
          {% if page.fileSlug in ncNdBlogPosts %}
          <div class="alert alert-secondary mt-4 py-2 small mb-0" role="note">
            <i class="bi bi-c-circle me-1" aria-hidden="true"></i>
            {% if currentLang == "en" %}
            This text is licensed under <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/" target="_blank" rel="noopener noreferrer" class="alert-link">CC BY-NC-ND 4.0</a>. Non-commercial use only, no modifications.
            {% else %}
            Tämä kirjoitus on lisensoitu <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/" target="_blank" rel="noopener noreferrer" class="alert-link">CC BY-NC-ND 4.0</a> -lisenssillä — ei kaupalliseen käyttöön, ei muutoksia.
            {% endif %}
          </div>
          {% endif %}
        </div>
        <div class="card-footer bg-transparent">
          <a href="{{ txt.backHref }}" class="btn btn-outline-primary">&larr; {{ txt.back }}</a>
        </div>
      </div>
    </article>
  </div>
</section>
