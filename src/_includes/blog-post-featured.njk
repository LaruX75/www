---
layout: base.njk
---
<section class="blog-featured-post py-2">
  <div class="container">
    <article class="blog-post blog-post-featured {{ articleClass or '' }}">
      {% if showArticleHeader != false %}
      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <p class="text-uppercase small text-muted mb-2">Blogi</p>
          <h1 class="display-6 fw-bold mb-2">{{ title }}</h1>
          <p class="text-muted mb-0">{{ date | dateFormat }}</p>
        </div>
      </div>
      {% endif %}

      <div class="post-content content-prose">
        {{ content | safe }}
      </div>

      {% if showTaxonomy != false %}
      <div class="mt-4">
        {% if tags %}
        <div class="mb-3">
          {% for tag in tags %}
          {% if tag != "blog" %}
          <span class="badge text-bg-secondary me-1">{{ tag }}</span>
          {% endif %}
          {% endfor %}
        </div>
        {% endif %}
        {% if categories %}
        <div class="mb-3">
          <p class="text-uppercase small text-muted mb-2">Kategoriat</p>
          {% for cat in categories %}
          <a class="badge text-bg-secondary me-1 text-decoration-none" href="/kategoriat/{{ cat | slugify }}/">{{ cat }}</a>
          {% endfor %}
        </div>
        {% endif %}
        {% if keywords %}
        <div class="mb-2">
          <p class="text-uppercase small text-muted mb-2">Avainsanat</p>
          {% for key in keywords %}
          <a class="badge text-bg-light text-dark border me-1 text-decoration-none" href="/avainsanat/{{ key | slugify }}/">{{ key }}</a>
          {% endfor %}
        </div>
        {% endif %}
      </div>
      {% endif %}

      {% if showBackLink != false %}
      <div class="mt-4">
        <a href="/blogi/" class="btn btn-outline-primary">&larr; Takaisin blogiin</a>
      </div>
      {% endif %}
    </article>
  </div>
</section>
