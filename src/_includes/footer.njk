{% set currentLang = lang or (page.url | langFromUrl) %}
<footer class="py-5 border-top bg-body-tertiary mt-5">
  <div class="container">
    <div class="row align-items-center gy-3">
      <div class="col-md-4 text-center text-md-start">
        <p class="mb-0 text-body-secondary small">
          {% if currentLang == "en" %}
          &copy; {{ site.author }}. All rights reserved.
          {% else %}
          &copy; {{ site.author }}. Kaikki oikeudet pidätetään.
          {% endif %}
        </p>
      </div>
      <div class="col-md-4 text-center">
        {% if currentLang == "en" %}
        <a href="/en/accessibility/" class="footer-wcag-badge text-decoration-none d-inline-flex align-items-center gap-2 px-3 py-1 rounded border" aria-label="WCAG 2.1 Level AA conformant – view accessibility statement">
          <span class="footer-wcag-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
              <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="2"/>
              <text x="16" y="12" text-anchor="middle" font-size="7" font-weight="700" font-family="sans-serif" fill="currentColor">W3C</text>
              <text x="16" y="21" text-anchor="middle" font-size="6" font-weight="600" font-family="sans-serif" fill="currentColor">WCAG 2.1</text>
              <text x="16" y="28" text-anchor="middle" font-size="5.5" font-weight="700" font-family="sans-serif" fill="currentColor">Level AA</text>
            </svg>
          </span>
          <span class="footer-wcag-label">
            <span class="d-block fw-semibold" style="font-size:0.7rem;line-height:1.2;">WCAG 2.1 AA</span>
            <span class="d-block" style="font-size:0.65rem;line-height:1.2;">Accessibility statement</span>
          </span>
        </a>
        {% else %}
        <a href="/saavutettavuus/" class="footer-wcag-badge text-decoration-none d-inline-flex align-items-center gap-2 px-3 py-1 rounded border" aria-label="WCAG 2.1 taso AA -vaatimustenmukaisuus – katso saavutettavuusseloste">
          <span class="footer-wcag-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
              <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="2"/>
              <text x="16" y="12" text-anchor="middle" font-size="7" font-weight="700" font-family="sans-serif" fill="currentColor">W3C</text>
              <text x="16" y="21" text-anchor="middle" font-size="6" font-weight="600" font-family="sans-serif" fill="currentColor">WCAG 2.1</text>
              <text x="16" y="28" text-anchor="middle" font-size="5.5" font-weight="700" font-family="sans-serif" fill="currentColor">Taso AA</text>
            </svg>
          </span>
          <span class="footer-wcag-label">
            <span class="d-block fw-semibold" style="font-size:0.7rem;line-height:1.2;">WCAG 2.1 AA</span>
            <span class="d-block" style="font-size:0.65rem;line-height:1.2;">Saavutettavuusseloste</span>
          </span>
        </a>
        {% endif %}
      </div>
      <div class="col-md-4 text-center text-md-end">
        <p class="mb-0 text-body-secondary small">
          {% if currentLang == "en" %}
          Built with <a href="/en/how-this-site-is-built/" class="text-decoration-none text-body-secondary fw-semibold">Eleventy</a> · <a href="/en/privacy/#manage-embed-consent" class="text-decoration-none text-body-secondary fw-semibold">Privacy notice</a> · <a href="/en/site-changes/" class="text-decoration-none text-body-secondary fw-semibold"><i class="bi bi-github me-1" aria-hidden="true"></i>GitHub changes</a>
          {% else %}
          Rakennettu <a href="/miten-sivusto-on-rakennettu/" class="text-decoration-none text-body-secondary fw-semibold">Eleventyllä</a> · <a href="/tietosuojaseloste/#upotusten-suostumuksen-hallinta" class="text-decoration-none text-body-secondary fw-semibold">Tietosuojaseloste</a> · <a href="/sivuston-muutokset/" class="text-decoration-none text-body-secondary fw-semibold"><i class="bi bi-github me-1" aria-hidden="true"></i>GitHub-muutokset</a>
          {% endif %}
        </p>
      </div>
    </div>
  </div>
</footer>
