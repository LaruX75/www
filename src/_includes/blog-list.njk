---
layout: base.njk
---
<section class="blog-hero py-4">
  <div class="site-shell">
    {% set currentLang = lang or (page.url | langFromUrl) %}
    {% set txt = {
      "hero": "Read the latest thoughts, insights and updates.",
      "archiveKicker": "Blog archive",
      "latest": "Latest posts",
      "paths": "Topic paths",
      "pathsLead": "Start with a theme or search the full archive.",
      "all": "All posts",
      "searchLabel": "Search posts",
      "searchPlaceholder": "Search by title, summary, categories...",
      "clear": "Clear",
      "date": "Date",
      "title": "Title",
      "summary": "Summary",
      "cats": "Categories & Keywords",
      "link": "Link",
      "noResults": "No results for this search",
      "showing": "Showing",
      "of": "/"
    } if currentLang == "en" else {
      "hero": "Lue uusimmat ajatukset, oivallukset ja kuulumiset.",
      "archiveKicker": "Blogiarkisto",
      "latest": "Uusimmat kirjoitukset",
      "paths": "Aihepolut",
      "pathsLead": "Aloita aiheesta tai hae koko arkistosta.",
      "all": "Kaikki kirjoitukset",
      "searchLabel": "Hae kirjoituksia",
      "searchPlaceholder": "Hae otsikosta, tiivistelmästä, kategorioista...",
      "clear": "Tyhjennä",
      "date": "Päivämäärä",
      "title": "Otsikko",
      "summary": "Tiivistelmä",
      "cats": "Kategoriat & Avainsanat",
      "link": "Linkki",
      "noResults": "Ei tuloksia haulla",
      "showing": "Näytetään",
      "of": "/"
    } %}
    {% set catBase = "/en/categories/" if currentLang == "en" else "/kategoriat/" %}
    {% set kwBase = "/en/keywords/" if currentLang == "en" else "/avainsanat/" %}
    {% set latestPosts = collections.blog | sort(true, false, "date") | take(3) %}
    {% set archiveTerms = collections.blog | archiveTermCloud(12, "categories") %}
    <h1 class="display-6 fw-bold mb-2">{{ title }}</h1>
    <p class="text-muted">{{ txt.hero }}</p>
    {% if currentLang == "en" %}
    <p class="small text-muted mb-0">This English archive view provides structure, summaries and metadata. Most full blog texts are original Finnish-language sources.</p>
    {% endif %}
  </div>
</section>

<section class="blog-routes py-4">
  <div class="site-shell">
    <div class="row g-3 align-items-stretch">
      <div class="col-lg-7">
        <div class="blog-route-card h-100">
          <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
            <div>
              <p class="content-context-kicker mb-1">{{ txt.archiveKicker }}</p>
              <h2 class="h4 mb-0">{{ txt.latest }}</h2>
            </div>
            <a class="btn btn-outline-primary btn-sm rounded-pill" href="#blog-table-section">{{ txt.all }}</a>
          </div>
          <div class="blog-latest-list">
            {% for post in latestPosts %}
            {% set desc = post.data.description or (post.content | excerpt) %}
            <a class="blog-latest-item" href="{{ post.url }}">
              <span class="blog-latest-date">{{ post.date | dateFormat }}</span>
              <strong>{{ post.data.title }}</strong>
              <span>{{ desc }}</span>
            </a>
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="blog-route-card h-100">
          <p class="content-context-kicker mb-1">{{ txt.paths }}</p>
          <h2 class="h4 mb-2">{{ txt.paths }}</h2>
          <p class="small text-muted mb-3">{{ txt.pathsLead }}</p>
          <div class="content-context-cloud">
            {% for term in archiveTerms %}
            <a class="content-context-term content-context-term--{{ term.weight }}" href="{{ catBase }}{{ term.name | slugify }}/">
              {{ term.name }} <span class="visually-hidden">({{ term.count }})</span>
            </a>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="blog-table-section" class="py-4">
  <div class="site-shell">
    <div class="card shadow-sm">
      <div class="card-header bg-transparent d-flex align-items-center justify-content-between">
        <h2 class="h4 mb-0">{{ txt.all }}</h2>
        <span class="badge text-bg-secondary">{{ collections.blog.length }}</span>
      </div>
      <div class="card-body p-0">
        {# ---- Suodatuspalkki ---- #}
        <div class="p-3 bg-light border-bottom">
          <div class="row g-2 align-items-end">
            <div class="col-md-8">
              <label for="blog-search" class="form-label small text-muted mb-1">{{ txt.searchLabel }}</label>
              <input type="search" id="blog-search" class="form-control form-control-sm"
                     placeholder="{{ txt.searchPlaceholder }}" autocomplete="off">
            </div>
            <div class="col-md-4 d-flex justify-content-md-end gap-2">
              <button id="blog-reset" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-x-circle me-1"></i>{{ txt.clear }}
              </button>
            </div>
          </div>
        </div>

        {# ---- Taulukko ---- #}
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0 blog-table" data-no-header-filters>
            <thead>
              <tr>
                <th class="sortable text-center" data-col="date" style="width:140px">
                  {{ txt.date }} <i class="bi bi-arrow-down-up sort-icon small opacity-50"></i>
                </th>
                <th class="sortable" data-col="title" style="min-width:200px">
                  {{ txt.title }} <i class="bi bi-arrow-down-up sort-icon small opacity-50"></i>
                </th>
                <th style="min-width:250px">{{ txt.summary }}</th>
                <th>{{ txt.cats }}</th>
                <th style="width:80px" class="text-center">{{ txt.link }}</th>
              </tr>
            </thead>
            <tbody id="blog-tbody">
              {# Server-renderöidyt rivit — Google indeksoi nämä ilman JavaScriptiä #}
              {% for post in collections.blog | sort(true, false, "date") %}
              {% set desc = post.data.description or (post.content | excerpt) %}
              {% set catStr = (post.data.categories or []) | join(' ') %}
              {% set kwStr  = (post.data.keywords  or []) | join(' ') %}
              {% set searchText = ([post.data.title, desc, catStr, kwStr] | join(' ')) | lower %}
              <tr
                data-search="{{ searchText | escape }}"
                data-date="{{ post.date | dateToRfc3339 }}"
                data-title="{{ post.data.title | lower | escape }}"
              >
                <td class="col-date text-center">{{ post.date | dateFormat }}</td>
                <td class="col-title">
                  <a href="{{ post.url }}" class="text-decoration-none">{{ post.data.title }}</a>
                </td>
                <td class="col-desc small">
                  {{ desc }}
                  {% if currentLang == "en" and post.data.originalLanguage != "en" and post.data.lang != "en" %}
                  <br><span class="badge bg-body-tertiary border text-body mt-1 me-1"><i class="bi bi-translate me-1"></i>Full text available in Finnish only</span>
                  {% endif %}
                </td>
                <td>
                  {% for cat in (post.data.categories or []) %}
                  <a href="{{ catBase }}{{ cat | slugify }}/" class="badge text-bg-secondary me-1 text-decoration-none">{{ cat }}</a>
                  {% endfor %}
                  {% for kw in (post.data.keywords or []) %}
                  <a href="{{ kwBase }}{{ kw | slugify }}/" class="badge text-bg-light text-dark border me-1 text-decoration-none">{{ kw }}</a>
                  {% endfor %}
                </td>
                <td class="text-center">
                  <a href="{{ post.url }}" class="btn btn-outline-primary btn-sm rounded-pill px-2" aria-label="{{ post.data.title | escape }}" title="{{ 'Read in Finnish' if currentLang == 'en' and post.data.originalLanguage != 'en' and post.data.lang != 'en' else post.data.title | escape }}">
                    <i class="bi bi-arrow-right" aria-hidden="true"></i>
                  </a>
                </td>
              </tr>
              {% endfor %}
              <tr id="blog-no-results" hidden>
                <td colspan="5" class="text-center text-muted py-5">{{ txt.noResults }}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
      <div class="card-footer bg-transparent d-flex flex-wrap align-items-center justify-content-between gap-2 border-top">
        <small id="blog-info"
          data-showing="{{ txt.showing }}"
          data-of="{{ txt.of }}"
          class="text-muted">
        </small>
        <nav aria-label="Sivutus">
          <ul id="blog-pagination" class="pagination pagination-sm mb-0 flex-wrap"></ul>
        </nav>
      </div>
    </div>
  </div>
</section>

<style>
.blog-hero {
  background-color: var(--bs-tertiary-bg, #f8f9fa);
  border-bottom: 1px solid var(--bs-border-color);
}
html[data-bs-theme="dark"]:not([data-a11y-bg]) .blog-hero {
  background-color: #1e2a3a !important;
}

.blog-routes {
  background:
    linear-gradient(180deg, var(--bs-body-bg), var(--bs-tertiary-bg));
}

.blog-route-card {
  border: 1px solid var(--bs-border-color);
  border-radius: 1rem;
  background: var(--bs-body-bg);
  padding: 1rem;
  box-shadow: 0 0.75rem 2rem rgba(15, 23, 42, 0.06);
}

.blog-latest-list {
  display: grid;
  gap: 0.75rem;
}

.blog-latest-item {
  display: grid;
  gap: 0.18rem;
  border: 1px solid var(--bs-border-color);
  border-radius: 0.85rem;
  color: var(--bs-body-color);
  padding: 0.85rem;
  text-decoration: none;
}

.blog-latest-item:hover {
  border-color: color-mix(in srgb, var(--bs-link-color) 34%, var(--bs-border-color));
  color: var(--bs-link-color);
}

.blog-latest-item span:last-child {
  color: var(--bs-secondary-color);
  font-size: 0.86rem;
  line-height: 1.35;
}

.blog-latest-date {
  color: var(--bs-secondary-color);
  font-size: 0.75rem;
  font-weight: 750;
  text-transform: uppercase;
}

[data-bs-theme="dark"] .blog-routes {
  background:
    linear-gradient(180deg, var(--bs-body-bg), rgba(255, 255, 255, 0.035));
}

html[data-bs-theme="dark"]:not([data-a11y-bg]) .blog-route-card,
html[data-bs-theme="dark"]:not([data-a11y-bg]) .blog-latest-item {
  background: rgba(255, 255, 255, 0.035);
  border-color: rgba(255, 255, 255, 0.12);
}

.blog-table th {
  white-space: nowrap;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  background-color: var(--bs-tertiary-bg) !important;
  padding: 0.75rem 0.5rem;
}
html[data-bs-theme="dark"]:not([data-a11y-bg]) .blog-table th {
  background-color: #2e3f59 !important;
  color: #c0d0e0;
}
.blog-table th.sortable {
  cursor: pointer;
  user-select: none;
}
.blog-table th.sortable:hover {
  background-color: var(--bs-secondary-bg) !important;
}
.blog-table th.sort-asc .sort-icon::before { content: "\F128"; opacity: 1 !important; color: var(--bs-primary); }
.blog-table th.sort-desc .sort-icon::before { content: "\F127"; opacity: 1 !important; color: var(--bs-primary); }

.blog-table td {
  padding: 0.75rem 0.5rem;
  vertical-align: top;
}
.blog-table td.col-date {
  font-size: 0.85rem;
  color: var(--bs-secondary-color);
}
.blog-table td.col-title {
  font-weight: 600;
}
.blog-table td.col-desc {
  font-size: 0.875rem;
  color: var(--bs-secondary-color);
}

[data-bs-theme="dark"] .blog-table td {
  border-color: rgba(255,255,255,0.07) !important;
}

[data-bs-theme="dark"] .badge.text-bg-light {
  background-color: rgba(255,255,255,0.12) !important;
  color: #e0e0e0 !important;
  border-color: rgba(255,255,255,0.2) !important;
}
</style>

<script>
(function () {
  const PAGE_SIZE = 10;
  const tbody = document.getElementById('blog-tbody');
  if (!tbody) return;

  // Kaikki server-renderöidyt rivit (paitsi "ei tuloksia" -rivi)
  const allRows = Array.from(tbody.querySelectorAll('tr[data-search]'));
  if (!allRows.length) return;

  let visibleRows = [...allRows];
  let currentPage = 1;
  let sortCol = 'date';
  let sortDir = -1; // -1 = desc (uusin ensin)

  const searchInp    = document.getElementById('blog-search');
  const info         = document.getElementById('blog-info');
  const pagUl        = document.getElementById('blog-pagination');
  const resetBtn     = document.getElementById('blog-reset');
  const noResultsRow = document.getElementById('blog-no-results');

  const showingLabel = info ? (info.dataset.showing || 'Näytetään') : 'Näytetään';
  const ofLabel      = info ? (info.dataset.of      || '/')        : '/';

  function applyFilters() {
    const q = searchInp ? searchInp.value.toLowerCase().trim() : '';
    visibleRows = allRows.filter(row =>
      !q || (row.dataset.search || '').includes(q)
    );
    currentPage = 1;
    render();
  }

  function sortBy(col) {
    if (sortCol === col) { sortDir *= -1; }
    else { sortCol = col; sortDir = col === 'date' ? -1 : 1; }

    visibleRows.sort((a, b) => {
      const av = a.getAttribute('data-' + col) || '';
      const bv = b.getAttribute('data-' + col) || '';
      if (col === 'date') {
        return (new Date(av) - new Date(bv)) * sortDir;
      }
      return av.localeCompare(bv, 'fi') * sortDir;
    });
    currentPage = 1;
    render();
  }

  function render() {
    // Piilota kaikki rivit ensin
    allRows.forEach(row => { row.hidden = true; });

    const total      = visibleRows.length;
    const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    if (currentPage > totalPages) currentPage = totalPages;

    const start = (currentPage - 1) * PAGE_SIZE;
    const slice = visibleRows.slice(start, start + PAGE_SIZE);

    // Näytä ja järjestä nykyisen sivun rivit
    slice.forEach(row => {
      row.hidden = false;
      tbody.appendChild(row); // siirtää rivin tbody:n loppuun oikeaan järjestykseen
    });

    // "Ei tuloksia" -rivi
    if (noResultsRow) noResultsRow.hidden = total > 0;

    // Info-teksti
    if (info) {
      const from = total === 0 ? 0 : start + 1;
      const to   = Math.min(start + PAGE_SIZE, total);
      info.textContent = `${showingLabel} ${from}–${to} ${ofLabel} ${total}`;
    }

    renderPagination(totalPages);
    updateSortIcons();
  }

  function renderPagination(totalPages) {
    if (!pagUl) return;
    pagUl.innerHTML = '';
    if (totalPages <= 1) return;

    for (let i = 1; i <= totalPages; i++) {
      const li = document.createElement('li');
      li.className = 'page-item' + (i === currentPage ? ' active' : '');
      const a = document.createElement('a');
      a.className = 'page-link';
      a.href = '#';
      a.textContent = i;
      a.addEventListener('click', e => {
        e.preventDefault();
        currentPage = i;
        render();
        document.getElementById('blog-table-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
      li.appendChild(a);
      pagUl.appendChild(li);
    }
  }

  function updateSortIcons() {
    document.querySelectorAll('.blog-table th.sortable').forEach(th => {
      th.classList.remove('sort-asc', 'sort-desc');
      if (th.dataset.col === sortCol) {
        th.classList.add(sortDir === 1 ? 'sort-asc' : 'sort-desc');
      }
    });
  }

  // Tapahtumakuuntelijat
  if (searchInp) searchInp.addEventListener('input', applyFilters);
  if (resetBtn)  resetBtn.addEventListener('click', () => {
    if (searchInp) searchInp.value = '';
    applyFilters();
  });
  document.querySelectorAll('.blog-table th.sortable').forEach(th => {
    th.addEventListener('click', () => sortBy(th.dataset.col));
  });

  // Alkurenderöinti: aktivoi sivutus + piilota loput rivit (UI sama kuin ennen)
  render();
})();
</script>
