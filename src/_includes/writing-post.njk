---
layout: base.njk
---
{% set currentLang = lang or (page.url | langFromUrl) %}
{% set currentTags = tags or [] %}
{% set isEnglish = currentLang == "en" %}
{% set externalSourceHref = "" %}

{% if original_url %}
  {% set externalSourceHref = original_url %}
{% elif originalUrl %}
  {% set externalSourceHref = originalUrl %}
{% elif publication_url %}
  {% set externalSourceHref = publication_url %}
{% elif publicationUrl %}
  {% set externalSourceHref = publicationUrl %}
{% elif externalUrl %}
  {% set externalSourceHref = externalUrl %}
{% elif source_url and source_url.startsWith("http") and not ("jarilaru.fi" in source_url) and not ("localhost" in source_url) %}
  {% set externalSourceHref = source_url %}
{% elif sourceUrl and sourceUrl.startsWith("http") and not ("jarilaru.fi" in sourceUrl) and not ("localhost" in sourceUrl) %}
  {% set externalSourceHref = sourceUrl %}
{% endif %}

{% set sectionLabel = "Kirjoitus" %}
{% set backHref = "/kynasta/" %}
{% set backLabel = "Takaisin edelliselle sivulle" %}
{% set isQuestionHour = agenda_title == "Valtuuston kyselytunti" or ("Valtuuston kyselytunti" in (contexts or [])) %}

{% if isEnglish %}
  {% set sectionLabel = "Text" %}
  {% set backHref = "/en/writings/" %}
  {% set backLabel = "Back to previous page" %}
{% endif %}

{% if isQuestionHour %}
  {% set sectionLabel = "Council question hour" if isEnglish else "Valtuuston kyselytunti" %}
  {% set backHref = "/en/writings/#puheet" if isEnglish else "/kynasta/#puheet" %}
{% elif type == "puhe" %}
  {% set sectionLabel = "Speech" if isEnglish else "Puheenvuoro" %}
  {% set backHref = "/en/writings/#puheet" if isEnglish else "/kynasta/#puheet" %}
{% elif type == "lausunto" %}
  {% set sectionLabel = "Expert statement" if isEnglish else "Asiantuntijalausunto" %}
  {% set backHref = "/en/writings/#lausunnot" if isEnglish else "/kynasta/#lausunnot" %}
{% elif type == "mielipide" %}
  {% if opinionRoles and ("political" in opinionRoles) and ("expert" in opinionRoles) %}
    {% set sectionLabel = "Political + expert opinion" if isEnglish else "Poliittinen ja asiantuntijamielipide" %}
    {% set backHref = "/en/writings/?opinions=hybrid#mielipiteet" if isEnglish else "/kynasta/?opinions=hybrid#mielipiteet" %}
  {% elif opinionRoles and ("political" in opinionRoles) %}
    {% set sectionLabel = "Political opinion" if isEnglish else "Poliittinen mielipide" %}
    {% set backHref = "/en/writings/?opinions=political#mielipiteet" if isEnglish else "/kynasta/?opinions=political#mielipiteet" %}
  {% elif opinionRoles and ("expert" in opinionRoles) %}
    {% set sectionLabel = "Expert opinion" if isEnglish else "Asiantuntijamielipide" %}
    {% set backHref = "/en/writings/?opinions=expert#mielipiteet" if isEnglish else "/kynasta/?opinions=expert#mielipiteet" %}
  {% else %}
    {% set sectionLabel = "Opinion" if isEnglish else "Mielipide" %}
    {% set backHref = "/en/writings/#mielipiteet" if isEnglish else "/kynasta/#mielipiteet" %}
  {% endif %}
{% elif type == "kolumni" %}
  {% set sectionLabel = "Column" if isEnglish else "Kolumni" %}
  {% set backHref = "/en/writings/#kolumnit" if isEnglish else "/kynasta/#kolumnit" %}
{% elif initiative_type or ("politics" in currentTags) %}
  {% set sectionLabel = "Council initiative" if isEnglish else "Valtuustoaloite" %}
  {% set backHref = "/en/writings/#aloitteet" if isEnglish else "/kynasta/#aloitteet" %}
{% endif %}

<section>
  <div class="site-shell">
    <article class="blog-post writing-post{{ (' writing-post--' ~ type) if type else '' }}">
      <div class="card shadow-sm">
        <div class="card-body">
          <p class="writing-post-kicker">{{ sectionLabel }}</p>
          <h1 class="display-6 fw-bold">{{ title }}</h1>
          {% if subtitle %}
            <p class="lead text-muted">{{ subtitle }}</p>
          {% endif %}

          <dl class="writing-post-meta">
            {% if date %}
              <div>
                <dt>{{ "Date" if isEnglish else "Päiväys" }}</dt>
                <dd>{{ date | dateFormat }}</dd>
              </div>
            {% endif %}
            {% if meetingDate %}
              {% set meetingDateLabel = "Meeting date" if isEnglish else "Kokouspäivä" %}
              {% if initiative_type or ("politics" in currentTags) %}
                {% set meetingDateLabel = "Submitted in meeting" if isEnglish else "Jätetty kokouksessa" %}
              {% endif %}
              <div>
                <dt>{{ meetingDateLabel }}</dt>
                <dd>
                  {{ meetingDate | dateFormat }}
                  {% if meeting %}
                    <br><span>{{ meeting }}</span>
                  {% endif %}
                </dd>
              </div>
            {% endif %}
            {% if event %}
              <div>
                <dt>{{ "Context" if isEnglish else "Tilaisuus" }}</dt>
                <dd>{{ event }}</dd>
              </div>
            {% elif publication %}
              <div>
                <dt>{{ "Publication" if isEnglish else "Julkaisupaikka" }}</dt>
                <dd>{{ publication }}</dd>
              </div>
            {% endif %}
            {% if asiakohta %}
              <div>
                <dt>{{ "Agenda item" if isEnglish else "Asiakohta" }}</dt>
                <dd>{{ asiakohta }}</dd>
              </div>
            {% endif %}
            {% if diaryNumber %}
              <div>
                <dt>{{ "Diary number" if isEnglish else "Diaarinumero" }}</dt>
                <dd>{{ diaryNumber }}</dd>
              </div>
            {% endif %}
            {% if externalSourceHref %}
              <div class="writing-post-meta__source">
                <dt>{{ "Original source" if isEnglish else "Alkuperäinen julkaisu" }}</dt>
                <dd>
                  <a href="{{ externalSourceHref }}" target="_blank" rel="noopener noreferrer">
                    {{ "Open source" if isEnglish else "Avaa lähde" }}
                    <i class="bi bi-box-arrow-up-right ms-1" aria-hidden="true"></i>
                  </a>
                </dd>
              </div>
            {% endif %}
          </dl>

          {% set tocMarkup = content | toc %}
          <div class="row g-4">
            <div class="col-lg-8">
              {% if thumbnail %}
                <img loading="lazy" decoding="async" src="{{ thumbnail }}" class="img-fluid rounded mb-4" alt="{{ title }}">
              {% endif %}
              <div class="post-content content-prose">{{ content | safe }}</div>
              {% include "council-speech-videos.njk" %}
            </div>
            <aside class="col-lg-4">
              {% include "content-context-sidebar.njk" %}
            </aside>
          </div>

          {% if "politics" in currentTags %}
          <div class="alert alert-secondary mt-4 py-2 small mb-0" role="note">
            <i class="bi bi-c-circle me-1" aria-hidden="true"></i>
            {% if isEnglish %}
            This text is licensed under <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/" target="_blank" rel="noopener noreferrer" class="alert-link">CC BY-NC-ND 4.0</a>. Non-commercial use only, no modifications.
            {% else %}
            Tämä kirjoitus on lisensoitu <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/" target="_blank" rel="noopener noreferrer" class="alert-link">CC BY-NC-ND 4.0</a> -lisenssillä — ei kaupalliseen käyttöön, ei muutoksia.
            {% endif %}
          </div>
          {% endif %}
        </div>
        <div class="card-footer bg-transparent">
          <a href="{{ backHref }}" class="btn btn-outline-primary" data-history-back>&larr; {{ backLabel }}</a>
        </div>
      </div>
    </article>
  </div>
</section>
