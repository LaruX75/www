  <style id="antiClickjack">body{display:none !important;}</style>
  <script>
    if (self === top) {
      var antiClickjack = document.getElementById("antiClickjack");
      antiClickjack.parentNode.removeChild(antiClickjack);
    } else {
      top.location = self.location;
    }
  </script>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {% set currentLang = lang or ("en" if (page.url and page.url.startsWith("/en/")) else "fi") %}
  {% set isHomePage = page.url == "/" or page.url == "/en/" %}
  {% set needsCharts = page.url == "/julkaisut/" or page.url == "/en/publications/" or page.url == "/kynasta/" %}
  {% set pageTitle = title or site.name %}
  {% set siteDescription = site.descriptionEn if currentLang == "en" else site.description %}
  {% set descriptionMissing = (not description) or description == site.description or description == site.descriptionEn %}
  {% set pageDescription = description or siteDescription %}
  {% if descriptionMissing and keyword %}
    {% if currentLang == "en" %}
      {% set pageDescription = 'Keyword "' ~ keyword.name ~ '" brings together ' ~ keyword.count ~ ' writings, speeches, or publications from the Jari Laru site.' %}
    {% else %}
      {% set pageDescription = 'Avainsana "' ~ keyword.name ~ '" kokoaa ' ~ keyword.count ~ ' kirjoitusta, puhetta tai julkaisua Jari Larun sivustolta.' %}
    {% endif %}
  {% elif descriptionMissing and category %}
    {% if currentLang == "en" %}
      {% set pageDescription = 'Category "' ~ category.name ~ '" gathers ' ~ category.count ~ ' related items from the Jari Laru site, including writings, speeches, and publications.' %}
    {% else %}
      {% set pageDescription = 'Kategoria "' ~ category.name ~ '" kokoaa ' ~ category.count ~ ' sisältöä Jari Larun sivustolta: kirjoituksia, puheita ja julkaisuja samasta aihepiiristä.' %}
    {% endif %}
  {% elif descriptionMissing and title and title.startsWith("Avainsana: ") %}
    {% set pageDescription = 'Avainsana "' ~ (title | replace("Avainsana: ", "")) ~ '" kokoaa kirjoituksia, puheita ja julkaisuja Jari Larun sivustolta.' %}
  {% elif descriptionMissing and title and title.startsWith("Keyword: ") %}
    {% set pageDescription = 'Keyword "' ~ (title | replace("Keyword: ", "")) ~ '" brings together writings, speeches, and publications from the Jari Laru site.' %}
  {% endif %}
  {% set pageUrl = page.url | absoluteUrl(site.url or "https://www.jarilaru.fi") %}
  {% set fiAltPath = collections.all | findTranslationUrl(translationKey, "fi") %}
  {% set enAltPath = collections.all | findTranslationUrl(translationKey, "en") %}
  {% set pageType = "article" if ("blog" in (tags or []) or "politics" in (tags or []) or "publications" in (tags or [])) else "website" %}
  {% set sectionLabel = "Blogi" if page.url and "/blog" in page.url else ("Julkaisut" if page.url and "/julkaisut" in page.url else ("Politiikka" if page.url and "/politics" in page.url else "Sivusto")) %}
  {% set personId = (site.url or "https://www.jarilaru.fi") + "#person" %}


  <title>{{ pageTitle }} — {{ site.name }}</title>
  <meta name="description" content="{{ pageDescription }}">
  {% if site.googleSiteVerification %}
  <meta name="google-site-verification" content="{{ site.googleSiteVerification }}">
  {% endif %}
  <meta name="robots" content="index, follow, noai, noimageai">
  <meta name="author" content="{{ site.author }}">
  <link rel="icon" type="image/svg+xml" href="/img/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/img/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png">
  <link rel="shortcut icon" href="/favicon.ico">
  <meta name="theme-color" content="#0c1730">
  <link rel="canonical" href="{{ pageUrl }}">
  {% if fiAltPath %}
  <link rel="alternate" hreflang="fi" href="{{ fiAltPath | absoluteUrl(site.url or "https://www.jarilaru.fi") }}">
  {% endif %}
  {% if enAltPath %}
  <link rel="alternate" hreflang="en" href="{{ enAltPath | absoluteUrl(site.url or "https://www.jarilaru.fi") }}">
  {% endif %}
  <link rel="alternate" hreflang="x-default" href="{{ (fiAltPath or "/") | absoluteUrl(site.url or "https://www.jarilaru.fi") }}">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:locale" content="{{ currentLang | localeForLang }}">
  <meta property="og:type" content="{{ pageType }}">
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:description" content="{{ pageDescription }}">
  <meta property="og:url" content="{{ pageUrl }}">
  <meta property="og:image" content="{{ resolvedOgImage | absoluteUrl(site.url or "https://www.jarilaru.fi") }}">
  <meta property="og:image:alt" content="Jari Laru">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  {% if pageType == "article" %}
  <meta property="article:author" content="{{ site.url or "https://www.jarilaru.fi" }}">
  <meta property="article:published_time" content="{{ page.date | dateToRfc3339 }}">
  <meta property="article:modified_time" content="{{ (modified or page.date) | dateToRfc3339 }}">
  {% endif %}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ pageTitle }}">
  <meta name="twitter:description" content="{{ pageDescription }}">
  <meta name="twitter:image" content="{{ resolvedOgImage | absoluteUrl(site.url or "https://www.jarilaru.fi") }}">
  <meta name="twitter:image:alt" content="Jari Laru">
  {% if isHomePage %}
  <link rel="preload" as="image" href="/img/WIN_20210329_16_06_01_Pro.jpg" fetchpriority="high">
  {% endif %}
