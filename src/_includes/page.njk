---
layout: base.njk
---
<section>
  <div class="site-shell">
    {% set currentLang = lang or (page.url | langFromUrl) %}
    <article class="page-content">
      <div class="card shadow-sm">
        <div class="card-body">
          <h1 class="display-6 fw-bold">{{ title }}</h1>
          {% if subtitle %}
            <p class="lead text-muted">{{ subtitle }}</p>
          {% endif %}
          {% if asiakohta %}
            <p class="text-muted small mb-3"><i class="bi bi-card-list me-1"></i>Asiakohta: {{ asiakohta }}</p>
          {% endif %}
          <div class="content-prose">{{ content | safe }}</div>
          {% if categories %}
            <div class="mt-4">
              <p class="text-uppercase small text-muted mb-2">{{ "Categories" if currentLang == "en" else "Kategoriat" }}</p>
              {% for cat in categories %}<a class="badge text-bg-secondary me-1 text-decoration-none" href="/kategoriat/{{ cat | slugify }}/">{{ cat }}</a>{% endfor %}
            </div>
          {% endif %}
          {% if keywords %}
            <div class="mt-3">
              <p class="text-uppercase small text-muted mb-2">{{ "Keywords" if currentLang == "en" else "Avainsanat" }}</p>
              {% for key in keywords %}<a class="badge text-bg-light text-dark border me-1 text-decoration-none" href="/avainsanat/{{ key | slugify }}/">{{ key }}</a>{% endfor %}
            </div>
          {% endif %}
          {% if "politics" in (tags or []) %}
          <div class="alert alert-secondary mt-4 py-2 small mb-0" role="note">
            <i class="bi bi-c-circle me-1" aria-hidden="true"></i>
            {% if currentLang == "en" %}
            This text is licensed under <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/" target="_blank" rel="noopener noreferrer" class="alert-link">CC BY-NC-ND 4.0</a>. Non-commercial use only, no modifications.
            {% else %}
            Tämä kirjoitus on lisensoitu <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/" target="_blank" rel="noopener noreferrer" class="alert-link">CC BY-NC-ND 4.0</a> -lisenssillä — ei kaupalliseen käyttöön, ei muutoksia.
            {% endif %}
          </div>
          {% endif %}
        </div>
      </div>
    </article>
  </div>
</section>
