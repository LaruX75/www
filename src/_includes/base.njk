<!DOCTYPE html>
<html lang="{{ lang or (page.url | langFromUrl) }}">
<head>
  {% set isHomePage = page.url == "/" or page.url == "/en/" %}
  {% set currentUrl = page.url or "" %}
  {% set breadcrumbKey = "" %}
  {% set writingTypes = ["puhe", "mielipide", "kolumni", "lausunto", "blogikirjoitus", "artikkeli"] %}
  {% if page.inputPath and "src/publications/" in page.inputPath %}
    {% set breadcrumbKey = "writings" if type in writingTypes else "publications" %}
  {% elif page.inputPath and "src/presentations/" in page.inputPath %}
    {% set breadcrumbKey = "presentations" %}
  {% elif page.inputPath and "src/media/" in page.inputPath %}
    {% set breadcrumbKey = "media" %}
  {% elif page.inputPath and "src/blog/" in page.inputPath %}
    {% set breadcrumbKey = "blog" %}
  {% elif page.inputPath and "src/politics/" in page.inputPath %}
    {% set breadcrumbKey = "politics" %}
  {% elif currentUrl == "/julkaisut/" or currentUrl == "/en/publications/" %}
    {% set breadcrumbKey = "publications" %}
  {% elif currentUrl == "/esitykset/" or currentUrl == "/en/presentations/" %}
    {% set breadcrumbKey = "presentations" %}
  {% elif currentUrl == "/opinnaytteet/" or currentUrl == "/en/theses/" %}
    {% set breadcrumbKey = "theses" %}
  {% elif currentUrl == "/blogi/" or currentUrl == "/en/blog/" %}
    {% set breadcrumbKey = "blog" %}
  {% elif currentUrl == "/mediassa/" %}
    {% set breadcrumbKey = "media" %}
  {% elif currentUrl == "/tietoa/" or currentUrl == "/autolomat/" or currentUrl == "/cv/" or currentUrl == "/portfolio/" or currentUrl == "/kouluttaja/" or currentUrl == "/puhuja/" or currentUrl == "/larux-tmi/" or currentUrl == "/yritys/" or currentUrl == "/en/about/" or currentUrl == "/en/cv/" or currentUrl == "/en/portfolio/" or currentUrl == "/en/company/" or currentUrl == "/en/road-trips/" %}
    {% set breadcrumbKey = "me" %}
  {% elif currentUrl == "/opetus/" or currentUrl == "/tutkimus/" or currentUrl == "/tyoni-yliopistonlehtorina/" or currentUrl == "/palkinnot/" or currentUrl == "/en/work/" or currentUrl == "/en/writings/" or currentUrl == "/en/research/" or currentUrl == "/en/awards/" %}
    {% set breadcrumbKey = "work" %}
  {% elif currentUrl == "/politiikka/" or currentUrl == "/politiiikka/" or currentUrl == "/poliittinen-avoimuus/" or currentUrl == "/en/politics/" or currentUrl == "/en/affiliations/" %}
    {% set breadcrumbKey = "politics" %}
  {% elif currentUrl == "/politiikka/kaupunginvaltuusto/" or currentUrl.startsWith("/politiikka/kaupunginvaltuusto/") or currentUrl == "/kaupunginvaltuusto/" or currentUrl.startsWith("/kaupunginvaltuusto/") or currentUrl == "/valtuusto/" or currentUrl.startsWith("/valtuusto/") %}
    {% set breadcrumbKey = "council_meetings" %}
  {% elif currentUrl == "/politiikka/sivistyslautakunta/" or currentUrl.startsWith("/politiikka/sivistyslautakunta/") %}
    {% set breadcrumbKey = "education_committee" %}
  {% elif currentUrl == "/politiikka/vaalikaudet/" or currentUrl == "/vaalikaudet/" or currentUrl == "/vaalihistoria/" or currentUrl == "/en/election-history/" or currentUrl == "/kuntavaalit-2021/" or currentUrl == "/jari-laru-aluevaltuustoon/" or currentUrl == "/kunnallisvaalit-2012/" %}
    {% set breadcrumbKey = "election_history" %}
  {% elif currentUrl == "/kunta-ja-aluevaalit-2025/" or currentUrl == "/en/municipal-and-wellbeing-elections-2025/" %}
    {% set breadcrumbKey = "election_2025" %}
  {% elif currentUrl == "/kynasta/" %}
    {% set breadcrumbKey = "writings" %}
  {% elif currentUrl == "/teemat/" or currentUrl.startsWith("/teemat/") %}
    {% set breadcrumbKey = "topic_profiles" %}
  {% elif currentUrl == "/yhteystiedot/" or currentUrl == "/en/contact/" %}
    {% set breadcrumbKey = "contact" %}
  {% endif %}
  {% set _baseLang = lang or (page.url | langFromUrl) %}
  {% set _baseTitle = title or site.name %}
  {% set _baseTags = tags or [] %}
  {% set _baseKeywords = keywords or [] %}
  {% set _baseContexts = contexts or [] %}
  {% set isCouncilQuestionBreadcrumb = agenda_title == "Valtuuston kyselytunti" or ("Valtuuston kyselytunti" in _baseContexts) or ("valtuustokysely" in _baseKeywords) %}
  {% set isCouncilInitiativeBreadcrumb = initiative_type or ("aloitteet" in _baseTags) or ("valtuustoaloite" in _baseKeywords) %}
  {% set breadcrumbDetailTitle = "" %}
  {% set breadcrumbDetailUrl = "" %}
  {% if isCouncilQuestionBreadcrumb %}
    {% set breadcrumbDetailTitle = "Council question hour" if _baseLang == "en" else "Valtuuston kyselytunti" %}
    {% set breadcrumbDetailUrl = "/en/writings/#puheet" if _baseLang == "en" else "/kynasta/#puheet" %}
  {% elif isCouncilInitiativeBreadcrumb %}
    {% set breadcrumbDetailTitle = "Council initiative" if _baseLang == "en" else "Valtuustoaloite" %}
    {% set breadcrumbDetailUrl = "/en/writings/#aloitteet" if _baseLang == "en" else "/kynasta/#aloitteet" %}
  {% endif %}
  {% set _baseSection = ("Blog" if _baseLang == "en" else "Blogi") if ("blog" in (tags or [])) else (("Publications" if _baseLang == "en" else "Julkaisut") if ("publications" in (tags or [])) else (("Politics" if _baseLang == "en" else "Politiikka") if ("politics" in (tags or [])) else site.name)) %}
  {% setAsync "_ogRaw" %}{% ogImage "og-image.og.njk", { title: _baseTitle, section: _baseSection, siteName: site.name, domain: "jarilaru.fi", ogBgDataUrl: ogBgDataUrl } %}{% endsetAsync %}
  {% set ogImageOverrideValue = og_image or ogImageOverride %}
  {% set resolvedOgImage = ogImageOverrideValue if ogImageOverrideValue else (_ogRaw if _ogRaw and _ogRaw != "null" else "/img/WIN_20210329_16_06_01_Pro.jpg") %}
  {% include "_meta.njk" %}
  {% include "_ldschema.njk" %}
</head>
<body>
  {% set currentLang = lang or (page.url | langFromUrl) %}
  <span hidden data-pagefind-filter="Kieli:{{ 'English' if currentLang == 'en' else 'Suomi' }}"></span>
  <a class="visually-hidden-focusable skip-link btn btn-primary m-2 position-absolute" style="z-index: 9999; top: 0; left: 0;" href="#main-content">{{ "Skip to main content" if currentLang == "en" else "Hyppää pääsisältöön" }}</a>

  {% include "header.njk" %}

  {% if not isHomePage %}
  <section class="subpage-hero-placeholder" aria-hidden="true">
    <div class="subpage-hero-image"></div>
  </section>
  {% endif %}

  {% include "breadcrumb.njk" %}

  <main id="main-content" class="site-main{% if pageMainClass %} {{ pageMainClass }}{% endif %}">
    <div class="bss-scope{% if pageScopeClass %} {{ pageScopeClass }}{% endif %}">
      {% if pageShell %}
        <div class="{{ pageShellClass or 'site-shell' }}">
          {{ content | safe }}
        </div>
      {% else %}
        {{ content | safe }}
      {% endif %}
    </div>
  </main>

  {% include "footer.njk" %}

  <section class="site-news-ticker site-news-ticker--footer" aria-label="{{ 'Latest content' if currentLang == 'en' else 'Uusimmat sisällöt' }}">
    <div class="site-news-ticker-inner">
      <span class="site-news-ticker-label">{{ "Latest" if currentLang == "en" else "Uusimmat" }}</span>
      <div class="site-news-ticker-viewport">
        <div class="site-news-ticker-track" data-latest-track></div>
      </div>
    </div>
  </section>

  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r" crossorigin="anonymous" defer></script>
  <script src="/js/bootstrap.min.js" defer></script>
  <script src="/js/external-media-consent.js" defer></script>
  <script src="/js/site-ui.js" defer></script>

  <!-- Accessibility toolbar / Saavutettavuustyökalut -->
  <div class="a11y-toolbar" id="a11yToolbar" role="region" aria-label="{{ 'Accessibility tools' if currentLang == 'en' else 'Saavutettavuustyökalut' }}">
    <button class="a11y-trigger" id="a11yTrigger" type="button" aria-expanded="false" aria-controls="a11yPanel" aria-haspopup="dialog" aria-label="{{ 'Open accessibility tools' if currentLang == 'en' else 'Avaa saavutettavuustyökalut' }}">
      <svg class="a11y-trigger-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M1.5 12s3.8-7 10.5-7 10.5 7 10.5 7-3.8 7-10.5 7-10.5-7-10.5-7z"/>
        <circle cx="12" cy="12" r="3"/>
      </svg>
      <span aria-hidden="true">Aa</span>
    </button>

    <div class="a11y-panel" id="a11yPanel" role="dialog" aria-modal="true" aria-labelledby="a11yPanelTitle" hidden>
      <div class="a11y-panel-header">
        <span class="a11y-panel-title" id="a11yPanelTitle">{{ "Accessibility tools" if currentLang == "en" else "Saavutettavuustyökalut" }}</span>
        <button class="a11y-close" id="a11yClose" type="button" aria-label="{{ 'Close' if currentLang == 'en' else 'Sulje' }}">×</button>
      </div>

      <div class="a11y-section">
        <span class="a11y-section-label">{{ "Text size" if currentLang == "en" else "Tekstin koko" }}</span>
        <div class="a11y-btn-row">
          <button class="a11y-btn" id="a11yFontDec" type="button" aria-label="{{ 'Smaller text' if currentLang == 'en' else 'Pienennä tekstiä' }}">A−</button>
          <button class="a11y-btn" id="a11yFontReset" type="button" aria-label="{{ 'Default text size' if currentLang == 'en' else 'Palauta tekstin koko' }}">A</button>
          <button class="a11y-btn a11y-btn-large" id="a11yFontInc" type="button" aria-label="{{ 'Larger text' if currentLang == 'en' else 'Suurenna tekstiä' }}">A+</button>
        </div>
      </div>

      <div class="a11y-section">
        <button class="a11y-toggle" id="a11yHighContrast" type="button" aria-pressed="false">
          <span class="a11y-toggle-icon" aria-hidden="true">◐</span>
          {{ "High contrast" if currentLang == "en" else "Korkea kontrasti" }}
        </button>
        <button class="a11y-toggle" id="a11yReducedMotion" type="button" aria-pressed="false">
          <span class="a11y-toggle-icon" aria-hidden="true">≈</span>
          {{ "Reduce motion" if currentLang == "en" else "Vähennä liikettä" }}
        </button>
      </div>

      <div class="a11y-section">
        <button class="a11y-toggle" id="a11yDyslexiaFont" type="button" aria-pressed="false">
          <span class="a11y-toggle-icon" aria-hidden="true">Aa</span>
          {{ "Dyslexia-friendly font" if currentLang == "en" else "Lukemista tukeva fontti" }}
        </button>
        <button class="a11y-toggle" id="a11yTextSpacing" type="button" aria-pressed="false">
          <span class="a11y-toggle-icon" aria-hidden="true">☰</span>
          {{ "Wider text spacing" if currentLang == "en" else "Väljempi tekstiväli" }}
        </button>
        <button class="a11y-toggle" id="a11yReadingGuide" type="button" aria-pressed="false">
          <span class="a11y-toggle-icon" aria-hidden="true">▭</span>
          {{ "Reading guide" if currentLang == "en" else "Lukuviivain" }}
        </button>
        <button class="a11y-toggle" id="a11yFocusAssist" type="button" aria-pressed="false">
          <span class="a11y-toggle-icon" aria-hidden="true">⌖</span>
          {{ "Show focus and skip link" if currentLang == "en" else "Näytä fokus ja ohituslinkki" }}
        </button>
      </div>

      <div class="a11y-section">
        <span class="a11y-section-label">{{ "Background" if currentLang == "en" else "Tausta" }}</span>
        <div class="a11y-swatches">
          <button class="a11y-swatch a11y-swatch-white" type="button" data-a11y-bg="" aria-label="{{ 'Default background' if currentLang == 'en' else 'Oletustausta' }}"></button>
          <button class="a11y-swatch a11y-swatch-beige" type="button" data-a11y-bg="beige" aria-label="{{ 'Beige background' if currentLang == 'en' else 'Beige tausta' }}"></button>
          <button class="a11y-swatch a11y-swatch-yellow" type="button" data-a11y-bg="yellow" aria-label="{{ 'Yellow background' if currentLang == 'en' else 'Keltainen tausta' }}"></button>
          <button class="a11y-swatch a11y-swatch-blue" type="button" data-a11y-bg="blue" aria-label="{{ 'Blue background' if currentLang == 'en' else 'Sininen tausta' }}"></button>
          <button class="a11y-swatch a11y-swatch-green" type="button" data-a11y-bg="green" aria-label="{{ 'Green background' if currentLang == 'en' else 'Vihreä tausta' }}"></button>
        </div>
      </div>

      <div class="a11y-section a11y-tts-section">
        <span class="a11y-section-label">{{ "Read aloud" if currentLang == "en" else "Lue ääneen" }}</span>
        <div class="a11y-btn-row">
          <button class="a11y-btn a11y-btn-tts" id="a11yTtsPlay" type="button">{{ "Read" if currentLang == "en" else "Lue" }}</button>
          <button class="a11y-btn a11y-btn-tts" id="a11yTtsStop" type="button" disabled>{{ "Stop" if currentLang == "en" else "Pysäytä" }}</button>
        </div>
      </div>

      <div class="a11y-section">
        <button class="a11y-btn a11y-btn-reset" id="a11yResetBtn" type="button">{{ "Reset all" if currentLang == "en" else "Nollaa kaikki" }}</button>
      </div>

      <div id="a11yStatus" class="visually-hidden" aria-live="polite" aria-atomic="true"></div>
    </div>
  </div>
  <div id="a11yReadingGuideLine" aria-hidden="true"></div>

  <script src="/js/table-filters.js" defer></script>
  <script src="/js/a11y.js" defer></script>
</body>
</html>
