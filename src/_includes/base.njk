    <script id="site-latest-items" type="application/json">
      [
      {% set comma = joiner(",") %}
      {% for item in collections.all | sort(true, false, "date") %}
        {% set inputPath = item.inputPath or "" %}
        {% if item.url and item.data and item.data.title and inputPath and ("src/blog/" in inputPath or "src/publications/" in inputPath or "src/presentations/" in inputPath or "src/politics/" in inputPath) %}
