<!DOCTYPE html>
<html lang="{{ lang or (page.url | langFromUrl) }}" data-bs-theme="auto">
<head>
  <script>
    // Teeman alustus (estää välkkymisen) - tarkistaa sijainnin localStorage tai OS prefers-color-scheme
    const getStoredTheme = () => localStorage.getItem('theme');
    const getPreferredTheme = () => {
      const storedTheme = getStoredTheme();
      if (storedTheme) {
        return storedTheme;
      }
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    };
    const setTheme = function (theme) {
      if (theme === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches) {
        document.documentElement.setAttribute('data-bs-theme', 'dark');
      } else {
        document.documentElement.setAttribute('data-bs-theme', theme);
      }
    };
    setTheme(getPreferredTheme());

    // Saavutettavuusasetusten alustus (FOUC esto)
    function applyA11ySettings(settings) {
      const htmlEl = document.documentElement;
      
      // Tekstikoko
      htmlEl.classList.remove('a11y-text-large', 'a11y-text-xlarge');
      if (settings.textSize === 'large') htmlEl.classList.add('a11y-text-large');
      else if (settings.textSize === 'xlarge') htmlEl.classList.add('a11y-text-xlarge');
      
      // Kontrasti
      if (settings.highContrast) htmlEl.classList.add('a11y-high-contrast');
      else htmlEl.classList.remove('a11y-high-contrast');
      
      // Animaatiot
      if (settings.reducedMotion) htmlEl.classList.add('a11y-reduced-motion');
      else htmlEl.classList.remove('a11y-reduced-motion');
      
      // Fontti
      if (settings.dyslexiaFont) htmlEl.classList.add('a11y-dyslexia-font');
      else htmlEl.classList.remove('a11y-dyslexia-font');
    }

    try {
      const a11yStored = localStorage.getItem('a11y-settings');
      if (a11yStored) {
        applyA11ySettings(JSON.parse(a11yStored));
      }
    } catch(e) {}
  </script>
  <meta charset="utf-8">
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net data:; img-src 'self' data: https: https://cdn.slidesharecdn.com; connect-src 'self'; frame-src 'self' https: https://www.slideshare.net;">
  <meta name="referrer" content="strict-origin-when-cross-origin">
  <meta http-equiv="X-Frame-Options" content="SAMEORIGIN">
  <style id="antiClickjack">body{display:none !important;}</style>
  <script>
    if (self === top) {
      var antiClickjack = document.getElementById("antiClickjack");
      antiClickjack.parentNode.removeChild(antiClickjack);
    } else {
      top.location = self.location;
    }
  </script>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {% set currentLang = lang or (page.url | langFromUrl) %}
  {% set isHomePage = page.url == "/" or page.url == "/en/" %}
  {% set needsCharts = page.url == "/julkaisut/" or page.url == "/en/publications/" or page.url == "/kynasta/" %}
  {% set pageTitle = title or site.name %}
  {% set pageDescription = description or site.description %}
  {% set pageUrl = page.url | absoluteUrl(site.url or "https://www.jarilaru.fi") %}
  {% set fiAltPath = collections.all | findTranslationUrl(translationKey, "fi") %}
  {% set enAltPath = collections.all | findTranslationUrl(translationKey, "en") %}
  {% set pageType = "article" if page.url and ("/blog" in page.url or "/julkaisut" in page.url or "/politics" in page.url) else "website" %}
  {% set sectionLabel = "Blogi" if page.url and "/blog" in page.url else ("Julkaisut" if page.url and "/julkaisut" in page.url else ("Politiikka" if page.url and "/politics" in page.url else "Sivusto")) %}
  {% set personId = (site.url or "https://www.jarilaru.fi") + "#person" %}
  {% setAsync "ogImageUrl" %}
    {% ogImage "./src/og-image.og.njk", {
      title: pageTitle,
      section: sectionLabel,
      siteName: site.name,
      domain: "jarilaru.fi"
    } %}
  {% endsetAsync %}
  {% set ogImageCandidate = (ogImageUrl or "") | trim %}
  {% set resolvedOgImage = ogImageCandidate if ogImageCandidate and ogImageCandidate != "null" and ogImageCandidate != "undefined" else "/img/hero.webp" %}

  <title>{{ pageTitle }} — {{ site.name }}</title>
  <meta name="description" content="{{ pageDescription }}">
  {% if site.googleSiteVerification %}
  <meta name="google-site-verification" content="{{ site.googleSiteVerification }}">
  {% endif %}
  <meta name="robots" content="index, follow, noai, noimageai">
  <meta name="author" content="{{ site.author }}">
  <link rel="canonical" href="{{ pageUrl }}">
  {% if fiAltPath %}
  <link rel="alternate" hreflang="fi" href="{{ fiAltPath | absoluteUrl(site.url or "https://www.jarilaru.fi") }}">
  {% endif %}
  {% if enAltPath %}
  <link rel="alternate" hreflang="en" href="{{ enAltPath | absoluteUrl(site.url or "https://www.jarilaru.fi") }}">
  {% endif %}
  <link rel="alternate" hreflang="x-default" href="{{ (fiAltPath or "/") | absoluteUrl(site.url or "https://www.jarilaru.fi") }}">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:locale" content="{{ currentLang | localeForLang }}">
  <meta property="og:type" content="{{ pageType }}">
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:description" content="{{ pageDescription }}">
  <meta property="og:url" content="{{ pageUrl }}">
  <meta property="og:image" content="{{ resolvedOgImage | absoluteUrl(site.url or "https://www.jarilaru.fi") }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ pageTitle }}">
  <meta name="twitter:description" content="{{ pageDescription }}">
  <meta name="twitter:image" content="{{ resolvedOgImage | absoluteUrl(site.url or "https://www.jarilaru.fi") }}">
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "{{ site.name | escape }}",
      "url": "{{ site.url or "https://www.jarilaru.fi" }}",
      "description": "{{ site.description | escape }}",
      "inLanguage": "{{ "fi-FI" if currentLang == "fi" else "en-US" }}",
      "publisher": {
        "@id": "{{ personId }}"
      }
    }
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "@id": "{{ personId }}",
      "name": "{{ site.author | escape }}",
      "url": "{{ site.url or "https://www.jarilaru.fi" }}",
      "sameAs": {{ (site.sameAs or []) | dump | safe }}
    }
  </script>
  {% if pageType == "article" %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": "{{ pageTitle | escape }}",
      "description": "{{ pageDescription | escape }}",
      "url": "{{ pageUrl }}",
      "mainEntityOfPage": "{{ pageUrl }}",
      "image": "{{ resolvedOgImage | absoluteUrl(site.url or "https://www.jarilaru.fi") }}",
      "datePublished": "{{ page.date | dateToRfc3339 }}",
      "dateModified": "{{ page.date | dateToRfc3339 }}",
      "inLanguage": "{{ "fi-FI" if currentLang == "fi" else "en-US" }}",
      "author": {
        "@id": "{{ personId }}"
      },
      "publisher": {
        "@id": "{{ personId }}"
      }
    }
  </script>
  {% else %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "{{ pageTitle | escape }}",
      "description": "{{ pageDescription | escape }}",
      "url": "{{ pageUrl }}",
      "image": "{{ resolvedOgImage | absoluteUrl(site.url or "https://www.jarilaru.fi") }}",
      "inLanguage": "{{ "fi-FI" if currentLang == "fi" else "en-US" }}",
      "author": {
        "@id": "{{ personId }}"
      }
    }
  </script>
  {% endif %}
  {% if isHomePage %}
  <link rel="preload" as="image" href="/img/WIN_20210329_16_06_01_Pro.jpg" fetchpriority="high">
  {% endif %}
  <link rel="stylesheet" href="/css/bootstrap.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Bree+Serif&family=Inter:wght@400;600;700&display=swap">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bree+Serif&family=Inter:wght@400;600;700&display=swap" media="print" onload="this.media='all'">
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bree+Serif&family=Inter:wght@400;600;700&display=swap">
  </noscript>
  <link rel="stylesheet" href="/css/bss-overrides.css">
  <link rel="stylesheet" href="/css/mega-menu.css">
  <link rel="preload" href="/css/aos.min.css" as="style">
  <link rel="stylesheet" href="/css/aos.min.css" media="print" onload="this.media='all'">
  <noscript>
    <link rel="stylesheet" href="/css/aos.min.css">
  </noscript>
  <link rel="stylesheet" href="/css/template.css">
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/a11y.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="preload" href="/pagefind/pagefind-ui.css" as="style">
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" media="print" onload="this.media='all'">
  <noscript>
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet">
  </noscript>
  <script src="/pagefind/pagefind-ui.js" defer></script>
  {% if needsCharts %}
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js" defer></script>
  {% endif %}
</head>
<body>
  <a class="visually-hidden-focusable skip-link btn btn-primary m-2 position-absolute" style="z-index: 9999; top: 0; left: 0;" href="#main-content">Hyppää pääsisältöön</a>

  {% include "header.njk" %}

  {% set currentUrl = page.url or "" %}
  {% set breadcrumbKey = "" %}
  {% if page.inputPath and "src/publications/" in page.inputPath %}
    {% set breadcrumbKey = "publications" %}
  {% elif page.inputPath and "src/presentations/" in page.inputPath %}
    {% set breadcrumbKey = "presentations" %}
  {% elif page.inputPath and "src/blog/" in page.inputPath %}
    {% set breadcrumbKey = "blog" %}
  {% elif page.inputPath and "src/politics/" in page.inputPath %}
    {% set breadcrumbKey = "politics" %}
  {% elif currentUrl == "/julkaisut/" or currentUrl == "/en/publications/" %}
    {% set breadcrumbKey = "publications" %}
  {% elif currentUrl == "/esitykset/" or currentUrl == "/en/presentations/" %}
    {% set breadcrumbKey = "presentations" %}
  {% elif currentUrl == "/opinnaytteet/" or currentUrl == "/en/theses/" %}
    {% set breadcrumbKey = "theses" %}
  {% elif currentUrl == "/blogi/" or currentUrl == "/en/blog/" %}
    {% set breadcrumbKey = "blog" %}
  {% elif currentUrl == "/tietoa/" or currentUrl == "/autolomat/" or currentUrl == "/cv/" or currentUrl == "/portfolio/" or currentUrl == "/larux-tmi/" or currentUrl == "/yritys/" or currentUrl == "/en/about/" or currentUrl == "/en/cv/" or currentUrl == "/en/portfolio/" or currentUrl == "/en/company/" or currentUrl == "/en/road-trips/" %}
    {% set breadcrumbKey = "me" %}
  {% elif currentUrl == "/opetus/" or currentUrl == "/tutkimus/" or currentUrl == "/tyoni-yliopistonlehtorina/" or currentUrl == "/palkinnot/" or currentUrl == "/en/writings/" %}
    {% set breadcrumbKey = "work" %}
  {% elif currentUrl == "/politiikka/" or currentUrl == "/politiiikka/" or currentUrl == "/sidonnaisuudet/" or currentUrl == "/en/politics/" or currentUrl == "/en/affiliations/" %}
    {% set breadcrumbKey = "politics" %}
  {% elif currentUrl == "/kynasta/" %}
    {% set breadcrumbKey = "writings" %}
  {% elif currentUrl == "/yhteystiedot/" or currentUrl == "/en/contact/" %}
    {% set breadcrumbKey = "contact" %}
  {% endif %}

  {% if not isHomePage %}
  <section class="subpage-hero-placeholder" aria-hidden="true">
    <div class="subpage-hero-image"></div>
  </section>
  {% endif %}

  {% include "breadcrumb.njk" %}

  <main id="main-content" class="site-main">
    <div class="bss-scope">
      {{ content | safe }}
    </div>
  </main>

  {% include "footer.njk" %}

  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" defer></script>
  <script src="/js/bootstrap.min.js" defer></script>
  <script src="/js/aos.min.js" defer></script>
  <script src="/js/bs-init.js" defer></script>
  <script src="/js/parallax-fix.js" defer></script>
  <script src="/js/external-media-consent.js" defer></script>
  <script>
    // Teemanvaihtajan logiikka
    document.addEventListener('DOMContentLoaded', () => {
      const themeToggles = Array.from(document.querySelectorAll('[data-theme-toggle], #themeToggleBtn'));
      const themeIcons = Array.from(document.querySelectorAll('[data-theme-icon], #themeToggleIcon'));

      const updateIcon = (theme) => {
        themeIcons.forEach((themeIcon) => {
          if (!themeIcon) return;
          if (theme === 'dark') {
            themeIcon.classList.remove('bi-moon-stars-fill');
            themeIcon.classList.add('bi-sun-fill');
          } else {
            themeIcon.classList.remove('bi-sun-fill');
            themeIcon.classList.add('bi-moon-stars-fill');
          }
        });
      };

      if (themeToggles.length) {
        // Aseta oikea ikoni alkuun
        updateIcon(document.documentElement.getAttribute('data-bs-theme'));

        themeToggles.forEach((themeToggle) => {
          themeToggle.addEventListener('click', () => {
            const currentTheme = document.documentElement.getAttribute('data-bs-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
            
            localStorage.setItem('theme', newTheme);
            document.documentElement.setAttribute('data-bs-theme', newTheme);
            updateIcon(newTheme);
          });
        });
      }

      // Sticky header transparency logic
      const navbar = document.querySelector('.site-navbar');
      if (navbar) {
        // Keep header alignment and look consistent on all pages.
        navbar.classList.remove('navbar-hero-transparent');
        navbar.classList.add('navbar-hero-solid');
      }

      // Mega menu interactions (stagger + Esc focus return)
      const megaDropdowns = Array.from(document.querySelectorAll('.mega-dropdown'));
      let activeMegaToggle = null;
      const desktopMq = window.matchMedia('(min-width: 768px)');

      const closeAllMegaMenus = () => {
        megaDropdowns.forEach((dropdown) => {
          const toggle = dropdown.querySelector('[data-bs-toggle="dropdown"]');
          if (!toggle || !window.bootstrap) return;
          const instance = window.bootstrap.Dropdown.getInstance(toggle);
          if (instance) instance.hide();
        });
        if (navbar) navbar.classList.remove('mega-open');
      };

      megaDropdowns.forEach((dropdown) => {
        const toggle = dropdown.querySelector('[data-bs-toggle="dropdown"]');
        const menu = dropdown.querySelector('.mega-menu-panel');
        if (!toggle || !menu) return;
        const href = toggle.getAttribute('href');
        const navLabel = (toggle.textContent || '').trim();
        const jumpPrefix = (document.documentElement.lang || '').toLowerCase().startsWith('en')
          ? 'Go to page:'
          : 'Siirry sivulle:';

        // Mobile-only "go to top-level page" link inside each mega menu.
        if (href && href !== '#') {
          const wrap = menu.querySelector('.mega-wrap');
          if (wrap && !wrap.querySelector('.mega-mobile-jump')) {
            const mobileJump = document.createElement('a');
            mobileJump.className = 'mega-mobile-jump';
            mobileJump.href = href;
            mobileJump.setAttribute('aria-label', `${jumpPrefix} ${navLabel}`);
            mobileJump.innerHTML = `<i class="bi bi-arrow-up-right-circle me-2"></i>${jumpPrefix} ${navLabel}`;
            wrap.insertBefore(mobileJump, wrap.firstChild);
          }
        }

        toggle.addEventListener('click', (e) => {
          if (!desktopMq.matches) return;
          if (!href || href === '#') return;
          e.preventDefault();
          e.stopPropagation();
          closeAllMegaMenus();
          window.location.assign(href);
        });

        const interactiveItems = Array.from(menu.querySelectorAll('a, button')).filter((el) => !el.disabled);
        interactiveItems.forEach((el, idx) => {
          el.classList.add('stagger-item');
          el.style.transitionDelay = `${Math.min(idx * 35, 300)}ms`;
        });

        dropdown.addEventListener('show.bs.dropdown', () => {
          activeMegaToggle = toggle;
          if (navbar) navbar.classList.add('mega-open');
          menu.classList.remove('menu-open');
          requestAnimationFrame(() => menu.classList.add('menu-open'));
        });

        dropdown.addEventListener('hide.bs.dropdown', () => {
          if (navbar) navbar.classList.remove('mega-open');
          menu.classList.remove('menu-open');
        });

        menu.addEventListener('click', (e) => {
          if (!(e.target instanceof Element)) return;
          const clickedLink = e.target.closest('a[href]');
          if (!clickedLink) return;
          closeAllMegaMenus();
        });
      });

      // Hakutoiminnon logiikka
      const searchToggles = Array.from(document.querySelectorAll('[data-search-toggle], #searchToggleBtn'));
      const searchForms = Array.from(document.querySelectorAll('[data-search-form]'));
      const searchClose = document.getElementById('searchCloseBtn');
      const searchOverlay = document.getElementById('searchOverlay');
      let pagefindInitialized = false;

      function closeContainingOffcanvas(node) {
        if (!node || !window.bootstrap) return;
        const offcanvasEl = node.closest('.offcanvas');
        if (!offcanvasEl) return;
        const instance = window.bootstrap.Offcanvas.getInstance(offcanvasEl) || new window.bootstrap.Offcanvas(offcanvasEl);
        instance.hide();
      }

      function openSearch(prefillQuery = '') {
        if (!searchOverlay) return;
        searchOverlay.style.display = 'flex';
        document.body.style.overflow = 'hidden';
        
        if (!pagefindInitialized) {
          const isEn = (document.documentElement.lang || '').toLowerCase().startsWith('en');
          const pagefindTranslations = isEn
            ? {
                placeholder: 'Write a search term...',
                zero_results: 'No results for [SEARCH_TERM]',
                many_results: '[COUNT] results for [SEARCH_TERM]',
                one_result: '[COUNT] result for [SEARCH_TERM]',
                filters_label: 'Filter',
                load_more: 'Load more'
              }
            : {
                placeholder: 'Kirjoita hakusana...',
                zero_results: 'Ei tuloksia haulle [SEARCH_TERM]',
                many_results: '[COUNT] tulosta haulle [SEARCH_TERM]',
                one_result: '[COUNT] tulos haulle [SEARCH_TERM]',
                filters_label: 'Suodata',
                load_more: 'Näytä lisää'
              };
          new PagefindUI({
            element: '#pagefindSearch',
            showSubResults: true,
            showImages: false,
            translations: pagefindTranslations
          });
          pagefindInitialized = true;
        }
        
        setTimeout(() => {
          const input = searchOverlay.querySelector('.pagefind-ui__search-input');
          if (input) {
            input.focus();
            if (prefillQuery) {
              input.value = prefillQuery;
              input.dispatchEvent(new Event('input', { bubbles: true }));
            }
          }
        }, 100);
      }

      function closeSearch() {
        if (!searchOverlay) return;
        searchOverlay.style.display = 'none';
        document.body.style.overflow = '';
      }

      searchToggles.forEach((searchToggle) => {
        searchToggle.addEventListener('click', (e) => {
          closeContainingOffcanvas(e.currentTarget);
          openSearch();
        });
      });
      searchForms.forEach((form) => {
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          const formData = new FormData(form);
          const query = String(formData.get('q') || '').trim();
          closeContainingOffcanvas(form);
          openSearch(query);
        });
      });
      if (searchClose) searchClose.addEventListener('click', closeSearch);

      document.addEventListener('keydown', (e) => {
        if (e.key !== 'Escape') return;

        if (searchOverlay && searchOverlay.style.display === 'flex') {
          closeSearch();
          return;
        }

        const openDropdown = megaDropdowns.find((dropdown) => dropdown.classList.contains('show'));
        if (openDropdown) {
          closeAllMegaMenus();
          if (activeMegaToggle) activeMegaToggle.focus();
        }
      });

      if (searchOverlay) {
        searchOverlay.addEventListener('click', (e) => {
          if (e.target === searchOverlay) closeSearch();
        });
      }
    });
  </script>

  <!-- Saavutettavuuspaneeli ja FAB -->
  <button class="a11y-fab" type="button" data-bs-toggle="offcanvas" data-bs-target="#a11yOffcanvas" aria-controls="a11yOffcanvas" aria-label="Avaa saavutettavuusasetukset">
    <i class="bi bi-person-wheelchair"></i>
  </button>

  <div class="offcanvas offcanvas-end" tabindex="-1" id="a11yOffcanvas" aria-labelledby="a11yOffcanvasLabel">
    <div class="offcanvas-header border-bottom">
      <h5 class="offcanvas-title fw-bold" id="a11yOffcanvasLabel"><i class="bi bi-universal-access-circle me-2"></i>Saavutettavuus</h5>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Sulje"></button>
    </div>
    <div class="offcanvas-body">
      <p class="text-muted small mb-4">Mukauta sivuston ulkoasua omiin tarpeisiisi sopivaksi. Valinnat tallentuvat selaimeesi.</p>
      
      <!-- Tekstikoko -->
      <div class="mb-4">
        <label for="a11yTextSize" class="form-label fw-bold">Tekstin koko</label>
        <select class="form-select" id="a11yTextSize">
          <option value="normal">Normaali koko</option>
          <option value="large">Suuri (+15%)</option>
          <option value="xlarge">Maksimi (+30%)</option>
        </select>
      </div>

      <!-- Kytkimet -->
      <div class="mb-3 form-check form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="a11yHighContrast">
        <label class="form-check-label" for="a11yHighContrast">Korkea kontrasti</label>
      </div>

      <div class="mb-3 form-check form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="a11yReducedMotion">
        <label class="form-check-label" for="a11yReducedMotion">Vähennä animaatioita</label>
      </div>

      <div class="mb-4 form-check form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="a11yDyslexiaFont">
        <label class="form-check-label" for="a11yDyslexiaFont">Lukihäiriöystävällinen fontti</label>
      </div>

      <!-- Palautus -->
      <hr>
      <button type="button" class="btn btn-outline-danger w-100 mt-2" id="a11yResetBtn">
        <i class="bi bi-arrow-counterclockwise me-1"></i> Palauta oletukset
      </button>
    </div>
  </div>

  <script src="/js/a11y.js" defer></script>
</body>
</html>
