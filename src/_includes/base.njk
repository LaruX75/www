            "lang": {{ (item.data.lang or "") | dump | safe }},
            "kind": {{ ("Blog" if "src/blog/" in inputPath else ("Publication" if "src/publications/" in inputPath else ("Presentation" if "src/presentations/" in inputPath else "Politics"))) | dump | safe }}
