<!DOCTYPE html>
<html lang="{{ lang or (page.url | langFromUrl) }}" data-bs-theme="auto">
<head>
  {% include "_meta.njk" %}
  {% include "_ldschema.njk" %}
</head>
<body>
  {% set currentLang = lang or (page.url | langFromUrl) %}
  <a class="visually-hidden-focusable skip-link btn btn-primary m-2 position-absolute" style="z-index: 9999; top: 0; left: 0;" href="#main-content">{{ "Skip to main content" if currentLang == "en" else "Hyppää pääsisältöön" }}</a>

  {% include "header.njk" %}

  {% set isHomePage = page.url == "/" or page.url == "/en/" %}
  {% set currentUrl = page.url or "" %}
  {% set breadcrumbKey = "" %}
  {% if page.inputPath and "src/publications/" in page.inputPath %}
    {% set breadcrumbKey = "publications" %}
  {% elif page.inputPath and "src/presentations/" in page.inputPath %}
    {% set breadcrumbKey = "presentations" %}
  {% elif page.inputPath and "src/blog/" in page.inputPath %}
    {% set breadcrumbKey = "blog" %}
  {% elif page.inputPath and "src/politics/" in page.inputPath %}
    {% set breadcrumbKey = "politics" %}
  {% elif currentUrl == "/julkaisut/" or currentUrl == "/en/publications/" %}
    {% set breadcrumbKey = "publications" %}
  {% elif currentUrl == "/esitykset/" or currentUrl == "/en/presentations/" %}
    {% set breadcrumbKey = "presentations" %}
  {% elif currentUrl == "/opinnaytteet/" or currentUrl == "/en/theses/" %}
    {% set breadcrumbKey = "theses" %}
  {% elif currentUrl == "/blogi/" or currentUrl == "/en/blog/" %}
    {% set breadcrumbKey = "blog" %}
  {% elif currentUrl == "/tietoa/" or currentUrl == "/autolomat/" or currentUrl == "/cv/" or currentUrl == "/portfolio/" or currentUrl == "/larux-tmi/" or currentUrl == "/yritys/" or currentUrl == "/en/about/" or currentUrl == "/en/cv/" or currentUrl == "/en/portfolio/" or currentUrl == "/en/company/" or currentUrl == "/en/road-trips/" %}
    {% set breadcrumbKey = "me" %}
  {% elif currentUrl == "/opetus/" or currentUrl == "/tutkimus/" or currentUrl == "/tyoni-yliopistonlehtorina/" or currentUrl == "/palkinnot/" or currentUrl == "/en/writings/" or currentUrl == "/en/research/" or currentUrl == "/en/awards/" %}
    {% set breadcrumbKey = "work" %}
  {% elif currentUrl == "/politiikka/" or currentUrl == "/politiiikka/" or currentUrl == "/sidonnaisuudet/" or currentUrl == "/en/politics/" or currentUrl == "/en/affiliations/" %}
    {% set breadcrumbKey = "politics" %}
  {% elif currentUrl == "/vaalihistoria/" or currentUrl == "/en/election-history/" or currentUrl == "/kuntavaalit-2021/" or currentUrl == "/jari-laru-aluevaltuustoon/" or currentUrl == "/kunnallisvaalit-2012/" %}
    {% set breadcrumbKey = "election_history" %}
  {% elif currentUrl == "/kunta-ja-aluevaalit-2025/" or currentUrl == "/en/municipal-and-wellbeing-elections-2025/" %}
    {% set breadcrumbKey = "election_2025" %}
  {% elif currentUrl == "/kynasta/" %}
    {% set breadcrumbKey = "writings" %}
  {% elif currentUrl == "/yhteystiedot/" or currentUrl == "/en/contact/" %}
    {% set breadcrumbKey = "contact" %}
  {% endif %}

  {% if not isHomePage %}
  <section class="subpage-hero-placeholder" aria-hidden="true">
    <div class="subpage-hero-image"></div>
  </section>
  {% endif %}

  {% include "breadcrumb.njk" %}

  <main id="main-content" class="site-main">
    <div class="bss-scope">
      {{ content | safe }}
    </div>
  </main>

  {% include "footer.njk" %}

  <section class="site-news-ticker site-news-ticker--footer" aria-label="{{ 'Latest content' if currentLang == 'en' else 'Uusimmat sisällöt' }}">
    <div class="site-news-ticker-inner">
      <span class="site-news-ticker-label">{{ "Latest" if currentLang == "en" else "Uusimmat" }}</span>
      <div class="site-news-ticker-viewport">
        <div class="site-news-ticker-track" data-latest-track></div>
      </div>
    </div>
  </section>

  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" defer></script>
  <script src="/js/bootstrap.min.js" defer></script>
  <script src="/js/external-media-consent.js" defer></script>
  <script src="/js/site-ui.js" defer></script>

  <!-- Accessibility panel / Saavutettavuuspaneeli -->
  <button class="a11y-fab" type="button" data-bs-toggle="offcanvas" data-bs-target="#a11yOffcanvas" aria-controls="a11yOffcanvas" aria-label="{{ 'Open accessibility settings' if currentLang == 'en' else 'Avaa saavutettavuusasetukset' }}">
    <i class="bi bi-person-wheelchair"></i>
  </button>

  <div class="offcanvas offcanvas-end" tabindex="-1" id="a11yOffcanvas" aria-labelledby="a11yOffcanvasLabel">
    <div class="offcanvas-header border-bottom">
      <h5 class="offcanvas-title fw-bold" id="a11yOffcanvasLabel"><i class="bi bi-universal-access-circle me-2"></i>{{ "Accessibility" if currentLang == "en" else "Saavutettavuus" }}</h5>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="{{ 'Close' if currentLang == 'en' else 'Sulje' }}"></button>
    </div>
    <div class="offcanvas-body">
      <p class="text-muted small mb-4">{{ "Customise the appearance to suit your needs. Settings are saved in your browser." if currentLang == "en" else "Mukauta sivuston ulkoasua omiin tarpeisiisi sopivaksi. Valinnat tallentuvat selaimeesi." }}</p>

      <div class="mb-4">
        <label for="a11yTextSize" class="form-label fw-bold">{{ "Text size" if currentLang == "en" else "Tekstin koko" }}</label>
        <select class="form-select" id="a11yTextSize">
          <option value="normal">{{ "Normal" if currentLang == "en" else "Normaali koko" }}</option>
          <option value="large">{{ "Large (+15%)" if currentLang == "en" else "Suuri (+15%)" }}</option>
          <option value="xlarge">{{ "Maximum (+30%)" if currentLang == "en" else "Maksimi (+30%)" }}</option>
        </select>
      </div>

      <div class="mb-3 form-check form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="a11yHighContrast">
        <label class="form-check-label" for="a11yHighContrast">{{ "High contrast" if currentLang == "en" else "Korkea kontrasti" }}</label>
      </div>

      <div class="mb-3 form-check form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="a11yReducedMotion">
        <label class="form-check-label" for="a11yReducedMotion">{{ "Reduce animations" if currentLang == "en" else "Vähennä animaatioita" }}</label>
      </div>

      <div class="mb-4 form-check form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="a11yDyslexiaFont">
        <label class="form-check-label" for="a11yDyslexiaFont">{{ "Dyslexia-friendly font" if currentLang == "en" else "Lukihäiriöystävällinen fontti" }}</label>
      </div>

      <hr>
      <button type="button" class="btn btn-outline-danger w-100 mt-2" id="a11yResetBtn">
        <i class="bi bi-arrow-counterclockwise me-1"></i> {{ "Reset to defaults" if currentLang == "en" else "Palauta oletukset" }}
      </button>
    </div>
  </div>

  <script src="/js/table-filters.js" defer></script>
  <script src="/js/a11y.js" defer></script>
</body>
</html>
