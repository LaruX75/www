{% set testimonialLocale = testimonials.locales[testimonialLang] or testimonials.locales.fi %}
{% set isHomeTestimonials = testimonialPlacement == "home" %}
<section class="py-5 bg-body-tertiary border-top border-bottom home-testimonials-section"{% if isHomeTestimonials %} aria-labelledby="home-testimonials-heading"{% else %} id="{{ "testimonials" if testimonialLang == "en" else "palautteet" }}" aria-labelledby="company-testimonials-heading"{% endif %}>
  <div class="container">
    <h2 class="h4 fw-bold text-center mb-4 home-testimonials-label" id="{{ "home-testimonials-heading" if isHomeTestimonials else "company-testimonials-heading" }}">
      {{ testimonialLocale.homeHeading if isHomeTestimonials else testimonialLocale.companyHeading }}
    </h2>
    <div class="row g-4 justify-content-center">
      {% for testimonial in testimonials.items %}
        {% if testimonialPlacement in testimonial.placements %}
          {% set localizedTestimonial = testimonial.content[testimonialLang] or testimonial.content.fi %}
          <div class="{{ "col-md-4" if isHomeTestimonials else "col-md-6" }}">
            <figure class="home-quote h-100 mb-0">
              <blockquote class="mb-2">
                <p>“{{ localizedTestimonial.quote }}”</p>
              </blockquote>
              <figcaption class="home-quote-footer">{{ localizedTestimonial.attribution }}</figcaption>
            </figure>
          </div>
        {% endif %}
      {% endfor %}
    </div>
    {% if isHomeTestimonials %}
      <div class="text-center mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" href="{{ testimonialLocale.ctaHref }}">{{ testimonialLocale.ctaLabel }}</a>
      </div>
    {% endif %}
  </div>
</section>
