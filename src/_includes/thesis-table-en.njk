{# _includes/thesis-table-en.njk
   Requires:
   - thesisItems: array of thesis objects
   - showType: boolean
#}
<div class="table-responsive">
  <table class="table table-sm table-hover align-middle mb-0 pub-table" data-thesis-table>
    <thead>
      <tr>
        <th class="text-center" style="width:70px">Year</th>
        {% if showType %}<th style="width:130px">Type</th>{% endif %}
        <th>Title</th>
        <th style="min-width:280px">Summary</th>
        <th style="width:200px">Author</th>
      </tr>
    </thead>
    <tbody>
      {% for thesis in thesisItems %}
      <tr>
        <td class="text-center font-monospace small fw-bold text-info">{{ thesis.year }}</td>
        {% if showType %}
        <td>
          {% if thesis.type == "masterThesis" %}
            <span class="badge bg-primary">Master's thesis</span>
          {% elif thesis.type == "bachelorThesis" %}
            <span class="badge bg-info">Bachelor's thesis</span>
          {% else %}
            <span class="badge bg-dark">{{ thesis.type }}</span>
          {% endif %}
        </td>
        {% endif %}
        <td>
          {% if thesis.link %}
            <a href="{{ thesis.link }}" target="_blank" class="text-decoration-none fw-medium text-body" rel="noopener noreferrer">{{ thesis.title }}</a>
            <a href="{{ thesis.link }}" target="_blank" class="ms-2 text-decoration-none align-middle" rel="noopener noreferrer" aria-label="Open thesis: {{ thesis.title }}">
              <i class="bi bi-box-arrow-up-right"></i>
            </a>
            <button
              type="button"
              class="btn btn-outline-primary btn-sm rounded-pill px-2 ms-2 thesis-bib-btn"
              data-title="{{ thesis.title | escape }}"
              data-authors="{{ (thesis.authors | join('; ')) | escape }}"
              data-year="{{ thesis.year }}"
              data-type="{{ thesis.type or '' }}"
              data-url="{{ thesis.link | escape }}"
              title="Export citation as BibTeX"
            >
              <i class="bi bi-quote me-1"></i>Export citation
            </button>
          {% else %}
            <span class="fw-medium">{{ thesis.title }}</span>
          {% endif %}
        </td>
        <td>
          {% if thesis.abstract %}
            <div class="small text-muted thesis-abstract-snippet">{{ thesis.abstract }}</div>
            <button
              type="button"
              class="btn btn-link btn-sm p-0 mt-1 thesis-abstract-trigger"
              data-thesis-title="{{ thesis.title | escape }}"
              data-thesis-abstract="{{ thesis.abstract | escape }}"
              data-thesis-url="{{ thesis.link | escape }}"
            >
              Open summary
            </button>
          {% else %}
            <span class="text-muted small">—</span>
          {% endif %}
        </td>
        <td class="text-secondary small">{{ thesis.authors | join("; ") }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
