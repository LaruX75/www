  {% set currentLang = lang or ("en" if (page.url and page.url.startsWith("/en/")) else "fi") %}
  {% set pageTitle = title or site.name %}
  {% set siteDescription = site.descriptionEn if currentLang == "en" else site.description %}
  {% set descriptionMissing = (not description) or description == site.description or description == site.descriptionEn %}
  {% set pageDescription = description or siteDescription %}
  {% if descriptionMissing and keyword %}
    {% if currentLang == "en" %}
      {% set pageDescription = 'Keyword "' ~ keyword.name ~ '" brings together ' ~ keyword.count ~ ' writings, speeches, or publications from the Jari Laru site.' %}
    {% else %}
      {% set pageDescription = 'Avainsana "' ~ keyword.name ~ '" kokoaa ' ~ keyword.count ~ ' kirjoitusta, puhetta tai julkaisua Jari Larun sivustolta.' %}
    {% endif %}
  {% elif descriptionMissing and category %}
    {% if currentLang == "en" %}
      {% set pageDescription = 'Category "' ~ category.name ~ '" gathers ' ~ category.count ~ ' related items from the Jari Laru site, including writings, speeches, and publications.' %}
    {% else %}
      {% set pageDescription = 'Kategoria "' ~ category.name ~ '" kokoaa ' ~ category.count ~ ' sisältöä Jari Larun sivustolta: kirjoituksia, puheita ja julkaisuja samasta aihepiiristä.' %}
    {% endif %}
  {% elif descriptionMissing and title and title.startsWith("Avainsana: ") %}
    {% set pageDescription = 'Avainsana "' ~ (title | replace("Avainsana: ", "")) ~ '" kokoaa kirjoituksia, puheita ja julkaisuja Jari Larun sivustolta.' %}
  {% elif descriptionMissing and title and title.startsWith("Keyword: ") %}
    {% set pageDescription = 'Keyword "' ~ (title | replace("Keyword: ", "")) ~ '" brings together writings, speeches, and publications from the Jari Laru site.' %}
  {% endif %}
  {% set pageDescription = pageDescription | seoDescription({ title: pageTitle, source: source, type: type, date: page.date, pageUrl: page.url, tags: tags, categories: categories, currentLang: currentLang }) %}
  {% set pageUrl = page.url | absoluteUrl(site.url or "https://www.jarilaru.fi") %}
  {% set pageType = "presentation" if type == "esitys" else ("article" if mediaType or contentType or ("blog" in (tags or []) or "politics" in (tags or []) or "publications" in (tags or [])) else "website") %}
  {% set articleSchemaType = "Article" if mediaType or contentType else "BlogPosting" %}
  {% set personId = (site.url or "https://www.jarilaru.fi") + "#person" %}

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "{{ site.name | escape }}",
      "url": "{{ site.url or "https://www.jarilaru.fi" }}",
      "description": "{{ (site.descriptionEn if currentLang == "en" else site.description) | escape }}",
      "inLanguage": "{{ "fi-FI" if currentLang == "fi" else "en-US" }}",
      "publisher": {
        "@id": "{{ personId }}"
      }
    }
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "@id": "{{ personId }}",
      "name": "{{ site.author | escape }}",
      "givenName": "Jari",
      "familyName": "Laru",
      "url": "{{ site.url or "https://www.jarilaru.fi" }}",
      "image": "{{ resolvedOgImage | absoluteUrl(site.url or "https://www.jarilaru.fi") }}",
      "jobTitle": "{{ "University Lecturer" if currentLang == "en" else "Yliopistonlehtori" }}",
      "affiliation": {
        "@type": "Organization",
        "name": "{{ "University of Oulu" if currentLang == "en" else "Oulun yliopisto" }}",
        "url": "https://www.oulu.fi"
      },
      "knowsLanguage": ["fi", "en"],
      "sameAs": {{ (site.sameAs or []) | jsonSafe | safe }}
    }
  </script>
  {% if not isHomePage %}
  {% set bcSiteBase = site.url or "https://www.jarilaru.fi" %}
  {% set bcHomeUrl = "/en/" if currentLang == "en" else "/" %}
  {% set bcHomeTitle = "Home" if currentLang == "en" else "Etusivu" %}
  {% set bcNodes = headerNav.en if currentLang == "en" else headerNav.fi %}
  {% set bcNavItems = (bcNodes | eleventyNavigationBreadcrumb(breadcrumbKey, { includeSelf: true, allowMissing: true })) if breadcrumbKey else [] %}
  {% set bcAppendCurrent = pageTitle and (not bcNavItems.length or bcNavItems[bcNavItems.length - 1].url != page.url) %}
  {% set ldBcItems = [] %}
  {% set _ = (ldBcItems.push({ "@type": "ListItem", "position": 1, "name": bcHomeTitle, "item": bcHomeUrl | absoluteUrl(bcSiteBase) }), null) %}
  {% for crumb in bcNavItems %}
    {% if crumb.url != bcHomeUrl and crumb.title != bcHomeTitle %}
      {% set _ = (ldBcItems.push({ "@type": "ListItem", "position": ldBcItems.length + 1, "name": crumb.title, "item": crumb.url | absoluteUrl(bcSiteBase) }), null) %}
    {% endif %}
  {% endfor %}
  {% if bcAppendCurrent %}
    {% set _ = (ldBcItems.push({ "@type": "ListItem", "position": ldBcItems.length + 1, "name": pageTitle }), null) %}
  {% endif %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": {{ ldBcItems | jsonSafe | safe }}
    }
  </script>
  {% endif %}
  {% if pageType == "presentation" %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "PresentationDigitalDocument",
      "name": "{{ pageTitle | escape }}",
      "description": "{{ pageDescription | escape }}",
      "url": "{{ pageUrl }}",
      "thumbnailUrl": "{{ thumbnail }}",
      "datePublished": "{{ page.date | dateToRfc3339 }}",
      "inLanguage": "{{ "fi-FI" if currentLang == "fi" else "en-US" }}",
      {% if url %}"sameAs": "{{ url | escape }}",{% endif %}
      "author": {
        "@id": "{{ personId }}"
      }
    }
  </script>
  {% elif pageType == "article" %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "{{ articleSchemaType }}",
      "headline": "{{ pageTitle | escape }}",
      "description": "{{ pageDescription | escape }}",
      "url": "{{ pageUrl }}",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{ pageUrl }}"
      },
      "image": "{{ resolvedOgImage | absoluteUrl(site.url or "https://www.jarilaru.fi") }}",
      "datePublished": "{{ page.date | dateToRfc3339 }}",
      "dateModified": "{{ (modified or page.date) | dateToRfc3339 }}",
      "inLanguage": "{{ "fi-FI" if currentLang == "fi" else "en-US" }}",
      {% if categories and categories.length %}"articleSection": {{ categories | jsonSafe | safe }},{% endif %}
      {% if keywords and keywords.length %}"keywords": {{ keywords | jsonSafe | safe }},{% endif %}
      {% if sourceUrl or externalUrl %}"sameAs": "{{ (sourceUrl or externalUrl) | escape }}",{% endif %}
      "author": {
        "@id": "{{ personId }}"
      },
      "publisher": {
        "@id": "{{ personId }}"
      }
    }
  </script>
  {% else %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "{{ pageTitle | escape }}",
      "description": "{{ pageDescription | escape }}",
      "url": "{{ pageUrl }}",
      "image": "{{ resolvedOgImage | absoluteUrl(site.url or "https://www.jarilaru.fi") }}",
      "inLanguage": "{{ "fi-FI" if currentLang == "fi" else "en-US" }}",
      {% if schemaAbout and schemaAbout.length %}"about": {{ schemaAbout | jsonSafe | safe }},{% endif %}
      {% if schemaMentions and schemaMentions.length %}"mentions": {{ schemaMentions | jsonSafe | safe }},{% endif %}
      "isPartOf": {
        "@id": "{{ site.url or "https://www.jarilaru.fi" }}"
      },
      "author": {
        "@id": "{{ personId }}"
      }
    }
  </script>
  {% endif %}
