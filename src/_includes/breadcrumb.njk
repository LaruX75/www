{% if breadcrumbKey %}
  {% set currentLang = lang or (page.url | langFromUrl) %}
  {% set breadcrumbNodes = headerNav.en if currentLang == "en" else headerNav.fi %}
  {% set breadcrumbItems = breadcrumbNodes | eleventyNavigationBreadcrumb(breadcrumbKey, { includeSelf: true, allowMissing: true }) %}
  {% set lastCrumb = breadcrumbItems[breadcrumbItems.length - 1] if breadcrumbItems and breadcrumbItems.length else null %}
  {% set appendCurrent = title and (not lastCrumb or lastCrumb.url != page.url) %}

  {% if breadcrumbItems.length or appendCurrent %}
  <nav class="container py-2" aria-label="{{ 'Breadcrumb' if currentLang == 'en' else 'Murupolku' }}">
    <ol class="breadcrumb mb-0 small">
      {% for crumb in breadcrumbItems %}
        {% if loop.last and not appendCurrent %}
          <li class="breadcrumb-item active" aria-current="page">{{ crumb.title }}</li>
        {% else %}
          <li class="breadcrumb-item">
            {% if crumb.url %}
              <a href="{{ crumb.url }}">{{ crumb.title }}</a>
            {% else %}
              <span>{{ crumb.title }}</span>
            {% endif %}
          </li>
        {% endif %}
      {% endfor %}

      {% if appendCurrent %}
        <li class="breadcrumb-item active" aria-current="page">{{ title }}</li>
      {% endif %}
    </ol>
  </nav>
  {% endif %}
{% endif %}
