{% set currentLang = lang or (page.url | langFromUrl) %}
{% set localIsHomePage = isHomePage or page.url == "/" or page.url == "/en/" %}
{% set homeTitle = "Home" if currentLang == "en" else "Etusivu" %}
{% set homeUrl = "/en/" if currentLang == "en" else "/" %}
{% set breadcrumbNodes = headerNav.en if currentLang == "en" else headerNav.fi %}
{% set breadcrumbItems = breadcrumbNodes | eleventyNavigationBreadcrumb(breadcrumbKey, { includeSelf: true, allowMissing: true }) if breadcrumbKey else [] %}
{% set hasNavCrumbs = breadcrumbItems and breadcrumbItems.length %}
{% set lastCrumb = breadcrumbItems[breadcrumbItems.length - 1] if hasNavCrumbs else null %}
{% set appendCurrent = title and (not lastCrumb or lastCrumb.url != page.url) %}
{% set shouldRenderFallback = (not hasNavCrumbs) and (not localIsHomePage) and title %}
{% set electionHistoryUrl = "/en/election-history/" if currentLang == "en" else "/vaalihistoria/" %}
{% set electionHistoryTitle = "Election History" if currentLang == "en" else "Vaalihistoria" %}
{% set hasElectionHistoryCrumb = hasNavCrumbs and (breadcrumbItems | selectattr("url", "equalto", electionHistoryUrl) | list | length > 0) %}

{% if hasNavCrumbs or shouldRenderFallback %}
<nav class="container py-2" aria-label="{{ 'Breadcrumb' if currentLang == 'en' else 'Murupolku' }}">
  <ol class="breadcrumb mb-0 small">
    <li class="breadcrumb-item"><a href="{{ homeUrl }}">{{ homeTitle }}</a></li>
    {% if hasNavCrumbs %}
      {% if breadcrumbKey == "election_2025" and not hasElectionHistoryCrumb %}
        <li class="breadcrumb-item"><a href="{{ electionHistoryUrl }}">{{ electionHistoryTitle }}</a></li>
      {% endif %}
      {% for crumb in breadcrumbItems %}
        {% if crumb.url != homeUrl and crumb.title != homeTitle %}
          {% if loop.last and not appendCurrent %}
            <li class="breadcrumb-item active" aria-current="page">{{ crumb.title }}</li>
          {% else %}
            <li class="breadcrumb-item">
              {% if crumb.url %}
                <a href="{{ crumb.url }}">{{ crumb.title }}</a>
              {% else %}
                <span>{{ crumb.title }}</span>
              {% endif %}
            </li>
          {% endif %}
        {% endif %}
      {% endfor %}
      {% if appendCurrent %}
        <li class="breadcrumb-item active" aria-current="page">{{ title }}</li>
      {% endif %}
    {% else %}
      <li class="breadcrumb-item active" aria-current="page">{{ title }}</li>
    {% endif %}
  </ol>
</nav>
{% endif %}
