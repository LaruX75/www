---
layout: base.njk
---
{% set currentLang = lang or (page.url | langFromUrl) %}
{% set sourceHref = sourceUrl or url %}
{% set sourceText = "Esitys" %}
{% if source == "slideshare" %}
  {% set sourceText = "SlideShare" %}
{% elif source == "aoe" %}
  {% set sourceText = "AOE" %}
{% elif sourceHref and "canva.com" in sourceHref %}
  {% set sourceText = "Canva" %}
{% elif sourceHref and ("youtube.com" in sourceHref or "youtu.be" in sourceHref) %}
  {% set sourceText = "YouTube" %}
{% endif %}
{% set isVideoPreview = sourceHref and ("youtube.com" in sourceHref or "youtu.be" in sourceHref) %}

<section class="content-detail-hero content-detail-hero--presentation py-5 border-bottom">
  <div class="site-shell">
    <div class="content-detail-hero-grid">
      <div class="content-detail-copy">
        <p class="content-detail-eyebrow mb-2">Esitys tai opetusmateriaali</p>
        <h1 class="content-detail-title mb-3">{{ title }}</h1>
        {% if subtitle %}
          <p class="content-detail-lead mb-3">{{ subtitle }}</p>
        {% elif description %}
          <p class="content-detail-lead mb-3">{{ description }}</p>
        {% endif %}
        <div class="content-detail-actions">
          {% if sourceHref %}
            <a href="{{ sourceHref }}" target="_blank" rel="noopener noreferrer" class="btn btn-primary rounded-pill px-4">{% if isVideoPreview %}Katso tallenne{% else %}Avaa materiaali{% endif %}</a>
          {% endif %}
          <a href="/esitykset/" class="btn btn-outline-secondary rounded-pill px-4">Kaikki esitykset</a>
        </div>
      </div>

      <aside class="content-detail-visual" aria-label="Esityksen esikatselu">
        {% if thumbnail %}
          <a href="{{ sourceHref or page.url }}" {% if sourceHref %}target="_blank" rel="noopener noreferrer"{% endif %} class="content-detail-thumb{% if isVideoPreview %} video-preview{% endif %}">
            <img src="{{ thumbnail }}" alt="" loading="lazy" decoding="async">
          </a>
        {% else %}
          <div class="content-detail-thumb content-detail-thumb--empty">
            <i class="bi bi-easel2" aria-hidden="true"></i>
          </div>
        {% endif %}
      </aside>
    </div>
  </div>
</section>

<section class="content-detail-body-section py-5">
  <div class="site-shell">
    <article class="content-detail-main">
      <div class="content-detail-card">
        <p class="content-detail-card-kicker">Sisällön kuvaus</p>
        <div class="content-prose">{{ content | safe }}</div>
      </div>

      <div class="content-detail-side-card content-detail-meta-card">
        <p class="content-detail-card-kicker">Materiaali ja käyttöyhteys</p>
        <dl class="content-detail-definition-list mb-0">
          <div>
            <dt>Lähde</dt>
            <dd>{{ sourceText }}</dd>
          </div>
          {% if event %}
          <div>
            <dt>Tilaisuus</dt>
            <dd>{{ event }}</dd>
          </div>
          {% endif %}
          {% if audience %}
          <div>
            <dt>Kohderyhmä</dt>
            <dd>{{ audience }}</dd>
          </div>
          {% endif %}
          {% if date %}
          <div>
            <dt>Päiväys</dt>
            <dd>{{ date | dateFormat }}</dd>
          </div>
          {% endif %}
        </dl>
      </div>

      <aside class="content-detail-related">
        {% include "content-context-sidebar.njk" %}
      </aside>
    </article>
  </div>
</section>
