              <p class="text-uppercase small text-muted mb-1 mt-2">{{ section.heading }}</p>
              <div class="d-grid gap-1 mb-2">
                {% for link in section.links %}
                  <a class="mobile-nav-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ link.title }}</a>
                {% endfor %}
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="accordion-item">
        <h2 class="accordion-header" id="mobileNavFiWritingsHead">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#mobileNavFiWritings" aria-expanded="false" aria-controls="mobileNavFiWritings">Kynästä</button>
        </h2>
        <div id="mobileNavFiWritings" class="accordion-collapse collapse" aria-labelledby="mobileNavFiWritingsHead" data-bs-parent="#mobileNavAccordionFi">
          <div class="accordion-body">
            <a class="btn btn-sm btn-outline-primary rounded-pill mb-3" href="{{ navWritings.url or '/kynasta/' }}">Avaa Kynästä-sivu</a>
            {% if writingsMegaMenu.contentColumns %}
              {% for contentColumn in writingsMegaMenu.contentColumns %}
                <div class="d-grid gap-1 mb-2">
                  {% for link in contentColumn.links %}
                    <a class="mobile-nav-link" href="{{ link.href }}">{{ link.title }}</a>
                  {% endfor %}
                </div>
              {% endfor %}
              {% if writingsMegaMenu.seeAlso %}
                <p class="text-uppercase small text-muted mb-1 mt-2">{{ writingsMegaMenu.seeAlso.heading }}</p>
                <div class="d-grid gap-1 mb-2">
                  {% for link in writingsMegaMenu.seeAlso.links %}
                    <a class="mobile-nav-link" href="{{ link.href }}">{{ link.title }}</a>
                  {% endfor %}
                </div>
              {% endif %}
            {% else %}
              <div class="d-grid gap-1 mb-2">
                {% for link in writingsMegaMenu.links %}
                  <a class="mobile-nav-link" href="{{ link.href }}">{{ link.title }}</a>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
      <div class="accordion-item">
        <h2 class="accordion-header" id="mobileNavFiContactHead">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#mobileNavFiContact" aria-expanded="false" aria-controls="mobileNavFiContact">Ota yhteyttä</button>
        </h2>
        <div id="mobileNavFiContact" class="accordion-collapse collapse" aria-labelledby="mobileNavFiContactHead" data-bs-parent="#mobileNavAccordionFi">
          <div class="accordion-body">
            <a class="btn btn-sm btn-outline-primary rounded-pill mb-3" href="{{ navContact.url or '/yhteystiedot/' }}">Avaa Yhteystiedot</a>
            {% for column in contactMegaMenu.columns %}
              <p class="text-uppercase small text-muted mb-1 mt-2">{{ column.heading }}</p>
              {% if column.links %}
                <div class="d-grid gap-1 mb-2">
                  {% for link in column.links %}
                    <a class="mobile-nav-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ link.title }}</a>
                  {% endfor %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

