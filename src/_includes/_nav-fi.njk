<div class="offcanvas offcanvas-start d-md-none" tabindex="-1" id="mobileNavFi" aria-labelledby="mobileNavFiLabel">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title fw-bold" id="mobileNavFiLabel">Valikko</h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Sulje"></button>
  </div>
  <div class="offcanvas-body">
    <form class="mb-3" data-search-form>
      <label for="mobileNavFiSearchInput" class="form-label small text-muted">Hae sivustolta</label>
      <div class="input-group input-group-sm">
        <input id="mobileNavFiSearchInput" type="search" class="form-control" placeholder="Hae..." autocomplete="off" name="q">
        <button class="btn btn-outline-primary" type="submit" aria-label="Avaa haku">
          <i class="bi bi-search"></i>
        </button>
      </div>
    </form>
    <div class="d-flex align-items-center justify-content-between gap-2 mb-3">
      <div class="btn-group btn-group-sm" role="group" aria-label="Kielen vaihto">
        <a class="btn btn-outline-primary{% if currentLang == 'fi' %} active{% endif %}" href="{{ fiPageUrl or '/' }}" lang="fi">FI</a>
        <a class="btn btn-outline-primary{% if currentLang == 'en' %} active{% endif %}" href="{{ enPageUrl or '/en/' }}" lang="en">EN</a>
      </div>
      <button class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-2" type="button" data-theme-toggle aria-label="Vaihda teemaa">
        <i class="bi bi-moon-stars-fill" data-theme-icon></i><span>Teema</span>
      </button>
    </div>
    <div class="d-grid gap-2 mb-3">
      <a class="btn btn-outline-primary rounded-pill" href="{{ navHome.url or '/' }}">Etusivu</a>
    </div>
    <div class="accordion accordion-flush mobile-nav-accordion" id="mobileNavAccordionFi">
      <div class="accordion-item">
        <h2 class="accordion-header" id="mobileNavFiMeHead">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#mobileNavFiMe" aria-expanded="false" aria-controls="mobileNavFiMe">Minä</button>
        </h2>
        <div id="mobileNavFiMe" class="accordion-collapse collapse" aria-labelledby="mobileNavFiMeHead" data-bs-parent="#mobileNavAccordionFi">
          <div class="accordion-body">
            <a class="btn btn-sm btn-outline-primary rounded-pill mb-3" href="{{ navMe.url or '/tietoa/' }}">Avaa Minä-sivu</a>
            {% for section in meMegaMenu.sections %}
              <p class="text-uppercase small text-muted mb-1 mt-2">{{ section.heading }}</p>
              <div class="d-grid gap-1 mb-2">
                {% for link in section.links %}
                  {% if link.inlineLinks %}
                    <div class="mobile-nav-link d-flex align-items-center gap-2 flex-wrap">
                      {% for inlineLink in link.inlineLinks %}
                        <a class="mobile-nav-link inline-link" href="{{ inlineLink.href }}"{% if inlineLink.external %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ inlineLink.title }}</a>{% if not loop.last %}<span class="mobile-nav-inline-separator" aria-hidden="true">|</span>{% endif %}
                      {% endfor %}
                    </div>
                  {% else %}
                    <a class="mobile-nav-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ link.title }}</a>
                  {% endif %}
                {% endfor %}
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="accordion-item">
        <h2 class="accordion-header" id="mobileNavFiWorkHead">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#mobileNavFiWork" aria-expanded="false" aria-controls="mobileNavFiWork">Työ</button>
        </h2>
        <div id="mobileNavFiWork" class="accordion-collapse collapse" aria-labelledby="mobileNavFiWorkHead" data-bs-parent="#mobileNavAccordionFi">
          <div class="accordion-body">
            <a class="btn btn-sm btn-outline-primary rounded-pill mb-3" href="{{ navWork.url or '/tyoni-yliopistonlehtorina/' }}">Avaa Työ-sivu</a>
