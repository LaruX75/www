        <li class="nav-item dropdown mega-dropdown">
          <a class="nav-link dropdown-toggle {% if page.url and ('/tietoa/' in page.url or '/autolomat/' in page.url or '/cv/' in page.url or '/portfolio/' in page.url or '/larux-tmi/' in page.url or '/yritys/' in page.url) %}active{% endif %}" href="{{ navMe.url or '/tietoa/' }}" role="button" data-bs-toggle="dropdown" aria-expanded="false">
