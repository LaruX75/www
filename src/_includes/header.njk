{% set currentLang = lang or (page.url | langFromUrl) %}
{% set fiPageUrl = collections.all | findTranslationUrl(translationKey, "fi") %}
{% set enPageUrl = collections.all | findTranslationUrl(translationKey, "en") %}
{% set topNavItems = (headerNav.en if currentLang == "en" else headerNav.fi) | eleventyNavigation %}
{% set navHome = topNavItems | navItemByKey("home") %}
{% set navMe = topNavItems | navItemByKey("me") %}
{% set navWork = topNavItems | navItemByKey("work") %}
{% set navPolitics = topNavItems | navItemByKey("politics") %}
{% set navWritings = topNavItems | navItemByKey("writings") %}
{% set navContact = topNavItems | navItemByKey("contact") %}
{% set meMegaMenu = headerNav.megaMenuMe.en if currentLang == "en" else headerNav.megaMenuMe.fi %}
{% set workMegaMenu = headerNav.megaMenuWork.en if currentLang == "en" else headerNav.megaMenuWork.fi %}
{% set politicsMegaMenu = headerNav.megaMenuPolitics.en if currentLang == "en" else headerNav.megaMenuPolitics.fi %}
{% set writingsMegaMenu = headerNav.megaMenuWritings.en if currentLang == "en" else headerNav.megaMenuWritings.fi %}
{% set contactMegaMenu = headerNav.megaMenuContact.en if currentLang == "en" else headerNav.megaMenuContact.fi %}

{% if currentLang == "en" %}
<nav id="siteNav" class="navbar navbar-expand-md site-navbar sticky-top" aria-label="Main Navigation" style="z-index:1030; transition: background-color .3s ease, box-shadow .3s ease;">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/en/">Jari Laru</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMainEn" aria-controls="navbarMainEn" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarMainEn">
      <ul class="navbar-nav align-items-md-center flex-md-nowrap evelenty-main-nav ms-md-2 me-auto">
        <li class="nav-item">
          <a class="nav-link {% if page.url == '/en/' %}active{% endif %}" href="{{ navHome.url or '/en/' }}">
            <i class="{{ navHome.icon or 'bi bi-house-door-fill' }}"></i> {{ navHome.title or 'Home' }}
          </a>
        </li>

        <li class="nav-item dropdown mega-dropdown">
          <a class="nav-link dropdown-toggle {% if page.url and ('/en/about/' in page.url or '/en/cv/' in page.url or '/en/portfolio/' in page.url or '/en/company/' in page.url or '/en/road-trips/' in page.url) %}active{% endif %}" href="{{ navMe.url or '/en/about/' }}" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="{{ navMe.icon or 'bi bi-person-fill' }}"></i> {{ navMe.title or 'Me' }}
          </a>
          <div class="dropdown-menu mega-menu-panel p-0 border-0">
            <div class="mega-wrap grid-8-4">
              <div class="mega-left three-cols">
                {% for section in meMegaMenu.sections %}
                  <section>
                    <h5>{{ section.heading }}</h5>
                    {% for link in section.links %}
                      {% if link.menuLink %}
                        <a class="menu-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener"{% endif %}><i class="{{ link.icon }}"></i><span>{{ link.title }}</span></a>
                      {% else %}
                        <a href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener"{% endif %}><i class="{{ link.icon }}"></i>{{ link.title }}</a>
                      {% endif %}
                      {% if link.description %}
                        <small class="{{ 'menu-link-desc' if link.menuLink }}">{{ link.description }}</small>
                      {% endif %}
                    {% endfor %}
                  </section>
                {% endfor %}
              </div>
              <aside class="mega-right showcase-card">
                {% optimizedImage meMegaMenu.showcase.imageSrc, meMegaMenu.showcase.imageAlt, "img-fluid rounded-3 mb-3", "(max-width: 991px) 180px, 240px" %}
                <h5>{{ meMegaMenu.showcase.title }}</h5>
                <p>{{ meMegaMenu.showcase.description }}</p>
                {% if meMegaMenu.showcase.cta %}
                  <a class="btn btn-accent btn-sm w-100" href="{{ meMegaMenu.showcase.cta.href }}">{{ meMegaMenu.showcase.cta.label }}</a>
                {% endif %}
              </aside>
            </div>
          </div>
        </li>

        <li class="nav-item dropdown mega-dropdown">
          <a class="nav-link dropdown-toggle {% if page.url and ('/en/publications/' in page.url or '/en/theses/' in page.url or '/en/presentations/' in page.url) %}active{% endif %}" href="{{ navWork.url or '/en/work/' }}" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="{{ navWork.icon or 'bi bi-briefcase-fill' }}"></i> {{ navWork.title or 'Work' }}
          </a>
          <div class="dropdown-menu mega-menu-panel p-0 border-0">
            {% if workMegaMenu and workMegaMenu.sections %}
            {% if workMegaMenu.layout == "four-columns" %}
            <div class="mega-wrap">
              <div class="mega-left four-cols">
                {% for section in workMegaMenu.sections %}
                  <section>
                    <h5>{{ section.heading }}</h5>
                    {% for link in section.links %}
                      {% if link.cta %}
                        <div class="work-inline-cta">
                          <a class="menu-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener"{% endif %}>
                            <i class="{{ link.icon }}"></i><span>{{ link.title }}</span>
                          </a>
                          {% if link.description %}
                            <small class="menu-link-desc">{{ link.description }}</small>
                          {% endif %}
                          <a class="btn btn-accent btn-sm w-100 mt-2" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener"{% endif %}>
                            {{ link.ctaLabel or workMegaMenu.cta.label or "Pyydä tarjous" }}
                          </a>
                        </div>
                      {% else %}
                        <a class="menu-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener"{% endif %}><i class="{{ link.icon }}"></i><span>{{ link.title }}</span></a>
                        {% if link.description %}
                          <small class="menu-link-desc">{{ link.description }}</small>
                        {% endif %}
                      {% endif %}
                    {% endfor %}
                  </section>
                {% endfor %}
              </div>
            </div>
            {% else %}
            <div class="mega-wrap grid-8-4">
              <div class="mega-left three-cols">
                {% for section in workMegaMenu.sections %}
                  <section>
                    <h5>{{ section.heading }}</h5>
                    {% for link in section.links %}
                      <a href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener"{% endif %}><i class="{{ link.icon }}"></i>{{ link.title }}</a>
                      {% if link.description %}
                        <small>{{ link.description }}</small>
                      {% endif %}
                    {% endfor %}
                  </section>
                {% endfor %}
              </div>
              <aside class="mega-right cta-card">
                <h5>{{ workMegaMenu.cta.title }}</h5>
                <p>{{ workMegaMenu.cta.description }}</p>
                <a class="btn btn-accent btn-lg w-100" href="{{ workMegaMenu.cta.href }}">{{ workMegaMenu.cta.label }}</a>
              </aside>
            </div>
            {% endif %}
            {% else %}
            <div class="mega-wrap grid-8-4">
              <div class="mega-left three-cols">
                <section>
                  <h5>Research & Scholarship</h5>
                  <a href="/en/publications/"><i class="bi bi-journal-text me-2"></i>Publications</a>
                  <small>Scientific articles and reports.</small>
                  <a href="/en/theses/"><i class="bi bi-mortarboard me-2"></i>Theses Supervised</a>
                  <small>Bachelor's and Master's theses.</small>
                </section>
                <section>
                  <h5>Outreach & Materials</h5>
                  <a href="/en/presentations/"><i class="bi bi-person-video3 me-2"></i>Presentations</a>
                  <small>Slides and keynotes.</small>
                  <a href="/en/portfolio/"><i class="bi bi-folder me-2"></i>Teaching Portfolio</a>
                </section>
                <section>
                  <h5>Academic Networks</h5>
                  <a href="https://www.linkedin.com/in/jarilaru/" target="_blank" rel="noopener"><i class="bi bi-linkedin me-2"></i>LinkedIn</a>
                  <a href="https://www.researchgate.net/profile/Jari-Laru" target="_blank" rel="noopener"><i class="bi bi-globe me-2"></i>ResearchGate</a>
                </section>
              </div>
              <aside class="mega-right cta-card">
                <h5>Book me for a keynote</h5>
                <p>Expert talks on AI, EdTech, and modern pedagogy.</p>
                <a class="btn btn-accent btn-lg w-100" href="/en/contact/">Request a quote</a>
              </aside>
            </div>
            {% endif %}
          </div>
        </li>

        <li class="nav-item dropdown mega-dropdown">
          <a class="nav-link dropdown-toggle {% if page.url and ('/en/politics/' in page.url or '/en/affiliations/' in page.url) %}active{% endif %}" href="{{ navPolitics.url or '/en/politics/' }}" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="{{ navPolitics.icon or 'bi bi-bank2' }}"></i> {{ navPolitics.title or 'Politics' }}
          </a>
          <div class="dropdown-menu mega-menu-panel p-0 border-0">
            <div class="mega-wrap">
              <div class="mega-left three-cols">
                {% for section in politicsMegaMenu.sections %}
                  <section>
                    <h5>{{ section.heading }}</h5>
                    {% for link in section.links %}
                      {% set linkCount = 0 %}
                      {% if link.countKey %}{% set linkCount = (collections[link.countKey] or []) | length %}{% endif %}
                      {% if link.menuLink %}
                        <a class="menu-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener"{% endif %}>
                          <i class="{{ link.icon }}"></i>
                          <span>{{ link.title }}{% if link.countKey and linkCount %} <span class="menu-link-count">{{ linkCount }}</span>{% endif %}</span>
                        </a>
                      {% else %}
                        <a href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener"{% endif %}><i class="{{ link.icon }}"></i>{{ link.title }}</a>
                      {% endif %}
                      {% if link.description %}
                        <small class="{{ 'menu-link-desc' if link.menuLink }}">{{ link.description }}</small>
                      {% endif %}
                    {% endfor %}
                  </section>
                {% endfor %}
              </div>
            </div>
          </div>
        </li>

        <li class="nav-item dropdown mega-dropdown">
          <a class="nav-link dropdown-toggle {% if page.url and '/en/writings/' in page.url %}active{% endif %}" href="{{ navWritings.url or '/en/writings/' }}" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="{{ navWritings.icon or 'bi bi-pencil-fill' }}"></i> {{ navWritings.title or 'Writings' }}
          </a>
          <div class="dropdown-menu mega-menu-panel p-0 border-0">
            <div class="mega-wrap writings-mega-layout">
              {% if writingsMegaMenu.contentColumns %}
                <section class="writings-group-head">
                  <h5>{{ writingsMegaMenu.groupHeading or writingsMegaMenu.heading }}</h5>
                  <p class="menu-desc">{{ writingsMegaMenu.description }}</p>
                </section>
                {% for contentColumn in writingsMegaMenu.contentColumns %}
                  <section class="writings-main-col">
                    {% for link in contentColumn.links %}
                      {% set linkCount = 0 %}
                      {% if link.countKey %}
                        {% set linkCount = (collections[link.countKey] or []) | length %}
                      {% elif link.countData == "theses_total" %}
                        {% set linkCount = theses.stats.total if theses and theses.stats else 0 %}
                      {% elif link.countData == "theses_kandit" %}
                        {% set linkCount = theses.stats.totalKandit if theses and theses.stats else 0 %}
                      {% elif link.countData == "theses_gradut" %}
                        {% set linkCount = theses.stats.totalGradut if theses and theses.stats else 0 %}
                      {% endif %}
                      <a class="menu-link-with-count" href="{{ link.href }}">
                        <span><i class="{{ link.icon }}"></i>{{ link.title }}</span>
                        {% if link.countKey or link.countData %}<span class="menu-link-count">{{ linkCount }}</span>{% endif %}
                      </a>
                    {% endfor %}
                  </section>
                {% endfor %}
                {% if writingsMegaMenu.seeAlso %}
                  <section class="writings-side-head">
                    <h5>{{ writingsMegaMenu.seeAlso.heading }}</h5>
                    {% if writingsMegaMenu.seeAlso.subheading %}
                      <p class="menu-desc">{{ writingsMegaMenu.seeAlso.subheading }}</p>
                    {% endif %}
                  </section>
                  <section class="writings-side-links">
                    {% for link in writingsMegaMenu.seeAlso.links %}
                      {% set linkCount = 0 %}
                      {% if link.countKey %}
                        {% set linkCount = (collections[link.countKey] or []) | length %}
                      {% elif link.countData == "theses_total" %}
                        {% set linkCount = theses.stats.total if theses and theses.stats else 0 %}
                      {% elif link.countData == "theses_kandit" %}
                        {% set linkCount = theses.stats.totalKandit if theses and theses.stats else 0 %}
                      {% elif link.countData == "theses_gradut" %}
                        {% set linkCount = theses.stats.totalGradut if theses and theses.stats else 0 %}
                      {% endif %}
                      <a class="menu-link-with-count" href="{{ link.href }}">
                        <span><i class="{{ link.icon }}"></i>{{ link.title }}</span>
                        {% if link.countKey or link.countData %}<span class="menu-link-count">{{ linkCount }}</span>{% endif %}
                      </a>
                    {% endfor %}
                  </section>
                {% endif %}
              {% else %}
                <section>
                  <h5>{{ writingsMegaMenu.heading }}</h5>
                  <p class="menu-desc">{{ writingsMegaMenu.description }}</p>
                  {% for link in writingsMegaMenu.links %}
                    <a href="{{ link.href }}"><i class="{{ link.icon }}"></i>{{ link.title }}</a>
                  {% endfor %}
                </section>
              {% endif %}
            </div>
          </div>
        </li>

        <li class="nav-item dropdown mega-dropdown">
          <a class="nav-link dropdown-toggle {% if page.url and '/en/contact/' in page.url %}active{% endif %}" href="{{ navContact.url or '/en/contact/' }}" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="{{ navContact.icon or 'bi bi-envelope' }}"></i> {{ navContact.title or 'Contact' }}
          </a>
          <div class="dropdown-menu mega-menu-panel p-0 border-0">
            <div class="mega-wrap">
              <section class="w-100 mb-3">
                <h5>{{ contactMegaMenu.heading }}</h5>
                <p class="menu-desc">{{ contactMegaMenu.description }}</p>
              </section>
              <div class="mega-left four-cols contact-mega-cols">
                {% for column in contactMegaMenu.columns %}
                  <section>
                    <h5>{{ column.heading }}</h5>
                    {% if column.type == "form" and column.form %}
                      <form class="contact-mega-form" action="{{ column.form.action }}" method="{{ column.form.method or 'POST' }}">
                        <input type="text" name="name" class="form-control form-control-sm mb-2" placeholder="{{ column.form.namePlaceholder }}">
                        <input type="email" name="email" class="form-control form-control-sm mb-2" placeholder="{{ column.form.emailPlaceholder }}" required>
                        <textarea name="message" class="form-control form-control-sm mb-2" rows="3" placeholder="{{ column.form.messagePlaceholder }}" required></textarea>
                        <button type="submit" class="btn btn-accent btn-sm w-100">{{ column.form.submitLabel }}</button>
                      </form>
                    {% else %}
                      {% for link in column.links %}
                        <a class="menu-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener"{% endif %}>
                          <i class="{{ link.icon }}"></i><span>{{ link.title }}</span>
                        </a>
                      {% endfor %}
                    {% endif %}
                  </section>
                {% endfor %}
              </div>
            </div>
          </div>
        </li>

        <li class="nav-item ms-md-auto mt-2 mt-md-0">
          <div class="d-flex align-items-center gap-2">
            <button class="btn btn-sm rounded-circle d-flex align-items-center justify-content-center" id="searchToggleBtn" style="width: 38px; height: 38px;" aria-label="Search site" title="Search site">
              <i class="bi bi-search"></i>
            </button>
            <button class="btn btn-sm rounded-circle d-flex align-items-center justify-content-center" id="themeToggleBtn" style="width: 38px; height: 38px;" aria-label="Toggle theme" title="Toggle theme">
              <i class="bi bi-moon-stars-fill" id="themeToggleIcon"></i>
            </button>
          </div>
        </li>
        <li class="nav-item ms-md-2 mt-2 mt-md-0">
          <a class="nav-link py-0 d-flex align-items-center gap-1 text-decoration-none" href="{{ fiPageUrl or '/' }}" lang="fi" aria-label="Vaihda kieleksi suomi">
            <span aria-hidden="true">🇫🇮</span><span>FI</span>
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<div id="searchOverlay" class="search-overlay" style="display: none;">
  <div class="search-overlay-inner">
    <div class="container py-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0"><i class="bi bi-search me-2"></i>Search</h3>
        <button class="btn btn-sm rounded-circle" id="searchCloseBtn" aria-label="Close search" style="width: 38px; height: 38px;">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
      <div id="pagefindSearch"></div>
    </div>
  </div>
</div>
{% else %}
