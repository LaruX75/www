                {% endif %}
              </aside>
            </div>
          </div>
        </li>

        <li class="nav-item dropdown mega-dropdown">
          <a class="nav-link dropdown-toggle {% if page.url and ('/opetus/' in page.url or '/portfolio/' in page.url or '/tutkimus/' in page.url or '/v%C3%A4it%C3%B6skirja/' in page.url or '/väitöskirja/' in page.url or '/palkinnot/' in page.url) %}active{% endif %}" href="{{ navWork.url or '/tyoni-yliopistonlehtorina/' }}" role="button" data-bs-toggle="dropdown" aria-expanded="false">
