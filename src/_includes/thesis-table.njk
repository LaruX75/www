{# _includes/thesis-table.njk
   Vaatii:
   - thesisItems: array of thesis objects
   - showType: boolean — näytetäänkö tyyppisarake
#}
<div class="table-responsive">
  <table class="table table-sm table-hover align-middle mb-0 pub-table" data-thesis-table>
    <thead>
      <tr>
        <th class="col-year text-center">Vuosi</th>
        {% if showType %}<th class="col-type">Tyyppi</th>{% endif %}
        <th class="col-title">Otsikko</th>
        <th class="col-abstract">Tiivistelmä</th>
        <th class="col-subjects">Avainsanat</th>
        <th class="col-author">Tekijä</th>
      </tr>
    </thead>
    <tbody>
      {% for thesis in thesisItems %}
      <tr data-year="{{ thesis.year }}" data-type="{{ thesis.type or '' }}">
        <td class="col-year text-center font-monospace small fw-bold text-info">
          {{ thesis.year }}
          <span class="col-year-author">{{ thesis.authors | join("; ") }}</span>
        </td>
        {% if showType %}
        <td>
          {% if thesis.type == "masterThesis" %}
            <span class="badge bg-primary">Pro gradu</span>
          {% elif thesis.type == "bachelorThesis" %}
            <span class="badge bg-info">Kandidaatintyö</span>
          {% else %}
            <span class="badge bg-dark">{{ thesis.type }}</span>
          {% endif %}
        </td>
        {% endif %}
        <td>
          {% if thesis.link %}
            <a href="{{ thesis.link }}" target="_blank" class="fw-medium text-body" rel="noopener noreferrer">{{ thesis.title }}</a>
            <a href="{{ thesis.link }}" target="_blank" class="ms-2 text-decoration-none align-middle icon-only-link" rel="noopener noreferrer" aria-label="Avaa opinnäytetyö: {{ thesis.title }}">
              <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
            </a>
            <button
              type="button"
              class="btn btn-outline-primary btn-sm rounded-pill px-2 ms-2 thesis-bib-btn"
              data-title="{{ thesis.title | escape }}"
              data-authors="{{ (thesis.authors | join('; ')) | escape }}"
              data-year="{{ thesis.year }}"
              data-type="{{ thesis.type or '' }}"
              data-url="{{ thesis.link | escape }}"
              aria-label="Vie lähdeviite: {{ thesis.title | escape }}"
            >
              <i class="bi bi-quote me-1" aria-hidden="true"></i>Vie viite
            </button>
          {% else %}
            <span class="fw-medium">{{ thesis.title }}</span>
          {% endif %}
        </td>
        <td class="col-abstract">
          {% if thesis.abstract %}
            <div class="small text-muted thesis-abstract-snippet">{{ thesis.abstract }}</div>
            <button
              type="button"
              class="btn btn-link btn-sm p-0 mt-1 thesis-abstract-trigger"
              data-thesis-title="{{ thesis.title | escape }}"
              data-thesis-abstract="{{ thesis.abstract | escape }}"
              data-thesis-url="{{ thesis.link | escape }}"
              data-thesis-authors="{{ (thesis.authors | join('; ')) | escape }}"
              data-thesis-year="{{ thesis.year }}"
              data-thesis-type="{{ thesis.type or '' }}"
            >
              Avaa tiivistelmä
            </button>
          {% else %}
            <span class="text-muted small">—</span>
          {% endif %}
        </td>
        <td class="col-subjects">
          {% if thesis.keywords.length %}
            <div class="d-flex flex-wrap gap-1">
              {% for kw in thesis.keywords %}
                <button type="button" class="badge text-bg-light border thesis-keyword-link" data-keyword="{{ kw | escape }}">{{ kw }}</button>
              {% endfor %}
            </div>
          {% elif thesis.subjects.length %}
            <div class="d-flex flex-wrap gap-1">
              {% for subject in thesis.subjects %}
                <button type="button" class="badge text-bg-secondary border thesis-keyword-link" data-keyword="{{ subject | escape }}" title="Pääaine">{{ subject }}</button>
              {% endfor %}
            </div>
          {% else %}
            <span class="text-muted small">—</span>
          {% endif %}
        </td>
        <td class="text-secondary small">{{ thesis.authors | join("; ") }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
