{% set selectedTopicCards = seoTopics | selectedTopics(topicProfileKeys or []) %}
{% if selectedTopicCards.length %}
<section class="topic-links-section" aria-labelledby="{{ topicProfileTitleId or 'topic-links-title' }}">
  <div class="site-shell">
    <div class="topic-links-card">
      <div class="topic-links-head">
        <p class="taxonomy-kicker">{{ topicProfileEyebrow or "Teemaprofiilit" }}</p>
        <h2 id="{{ topicProfileTitleId or 'topic-links-title' }}">{{ topicProfileTitle or "Syvemmälle aiheisiin" }}</h2>
        <p>{{ topicProfileLead or "Nämä sivut kokoavat saman aiheen kirjoitukset, esitykset, lausunnot, mediaosumat ja tutkimusnäytön yhteen." }}</p>
      </div>
      <div class="topic-links-grid">
        {% for topicCard in selectedTopicCards %}
          <a class="topic-link-card" href="/teemat/{{ topicCard.slug }}/">
            <span class="topic-link-card-title">{{ topicCard.title }}</span>
            <span class="topic-link-card-text">{{ topicCard.lead }}</span>
          </a>
        {% endfor %}
      </div>
      <a class="topic-links-more" href="/teemat/">Kaikki teemaprofiilit</a>
    </div>
  </div>
</section>
{% endif %}
