{%- from "_mega-nav-macro.njk" import megaNavTrigger -%}
<nav id="siteNav" class="navbar navbar-expand-md site-navbar sticky-top" aria-label="Main Navigation" style="z-index:1030; transition: background-color .3s ease, box-shadow .3s ease;">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/en/">Jari Laru</a>
    <button class="navbar-toggler d-md-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileNavEn" aria-controls="mobileNavEn" aria-expanded="false" aria-label="Open mobile navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarMainEn">
      <ul class="navbar-nav align-items-md-center flex-md-nowrap evelenty-main-nav ms-md-2 me-auto">
        <li class="nav-item">
          <a class="nav-link {% if page.url == '/en/' %}active{% endif %}" href="{{ navHome.url or '/en/' }}"{% if page.url == '/en/' %} aria-current="page"{% endif %}>
            <i class="{{ navHome.icon or 'bi bi-house-door-fill' }}"></i> {{ navHome.title or 'Home' }}
          </a>
        </li>

        <li class="nav-item dropdown mega-dropdown">
          {{ megaNavTrigger(navMe.url or '/en/about/', navMe.title or 'Me', navMe.icon or 'bi bi-person-fill', page.url and ('/en/about/' in page.url or '/en/cv/' in page.url or '/en/portfolio/' in page.url or '/en/company/' in page.url or '/en/road-trips/' in page.url), 'megaMenuMeEn', 'megaToggleMeEn', openSubmenuLabel) }}
          <div id="megaMenuMeEn" class="dropdown-menu mega-menu-panel p-0 border-0" aria-labelledby="megaToggleMeEn">
            <div class="mega-wrap grid-8-4">
              <div class="mega-left three-cols">
                {% for section in meMegaMenu.sections %}
                  <section>
                    <h5>{{ section.heading }}</h5>
                    {% for link in section.links %}
                      {% if link.inlineLinks %}
                        <div class="menu-link menu-link-inline-group">
                          <i class="{{ link.icon }}"></i>
                          <span class="menu-link-inline-items">
                            {% for inlineLink in link.inlineLinks %}
                              <a class="menu-link-inline-anchor" href="{{ inlineLink.href }}"{% if inlineLink.external %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ inlineLink.title }}</a>{% if not loop.last %}<span class="menu-link-inline-separator" aria-hidden="true">|</span>{% endif %}
                            {% endfor %}
                          </span>
                        </div>
                      {% elif link.menuLink %}
                        <a class="menu-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}><i class="{{ link.icon }}"></i><span>{{ link.title }}</span></a>
                      {% else %}
                        <a href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}><i class="{{ link.icon }}"></i>{{ link.title }}</a>
                      {% endif %}
                      {% if link.description %}
                        <small class="{{ 'menu-link-desc' if link.menuLink }}">{{ link.description }}</small>
                      {% endif %}
                    {% endfor %}
                  </section>
                {% endfor %}
              </div>
              <aside class="mega-right showcase-card">
                {% optimizedImage meMegaMenu.showcase.imageSrc, meMegaMenu.showcase.imageAlt, "img-fluid rounded-3 mb-3", "(max-width: 991px) 180px, 240px" %}
                <h5>{{ meMegaMenu.showcase.title }}</h5>
                <p>{{ meMegaMenu.showcase.description }}</p>
                {% if meMegaMenu.showcase.cta %}
                  <a class="btn btn-accent btn-lg w-100" href="{{ meMegaMenu.showcase.cta.href }}">{{ meMegaMenu.showcase.cta.label }}</a>
                {% endif %}
              </aside>
            </div>
          </div>
        </li>

        <li class="nav-item dropdown mega-dropdown">
          {{ megaNavTrigger(navWork.url or '/en/work/', navWork.title or 'Work', navWork.icon or 'bi bi-briefcase-fill', page.url and ('/en/publications/' in page.url or '/en/theses/' in page.url or '/en/presentations/' in page.url), 'megaMenuWorkEn', 'megaToggleWorkEn', openSubmenuLabel) }}
          <div id="megaMenuWorkEn" class="dropdown-menu mega-menu-panel p-0 border-0" aria-labelledby="megaToggleWorkEn">
            {% if workMegaMenu and workMegaMenu.sections %}
            {% if workMegaMenu.layout == "four-columns" %}
            <div class="mega-wrap">
              <div class="mega-left four-cols">
                {% for section in workMegaMenu.sections %}
                  <section>
                    <h5>{{ section.heading }}</h5>
                    {% for link in section.links %}
                      {% if link.inlineLinks %}
                        <div class="menu-link menu-link-inline-group">
                          <i class="{{ link.icon }}"></i>
                          <span class="menu-link-inline-items">
                            {% for inlineLink in link.inlineLinks %}
                              <a class="menu-link-inline-anchor" href="{{ inlineLink.href }}"{% if inlineLink.external %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ inlineLink.title }}</a>{% if not loop.last %}<span class="menu-link-inline-separator" aria-hidden="true">|</span>{% endif %}
                            {% endfor %}
                          </span>
                        </div>
                        {% if link.description %}
                          <small class="menu-link-desc">{{ link.description }}</small>
                        {% endif %}
                      {% elif link.cta %}
                        <div class="work-inline-cta">
                          <a class="menu-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}>
                            <i class="{{ link.icon }}"></i><span>{{ link.title }}</span>
                          </a>
                          {% if link.description %}
                            <small class="menu-link-desc">{{ link.description }}</small>
                          {% endif %}
                          <a class="btn btn-accent btn-lg w-100 mt-2" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}>
                            {{ link.ctaLabel or workMegaMenu.cta.label or "Pyydä tarjous" }}
                          </a>
                        </div>
                      {% else %}
                        <a class="menu-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}><i class="{{ link.icon }}"></i><span>{{ link.title }}</span></a>
                        {% if link.description %}
                          <small class="menu-link-desc">{{ link.description }}</small>
                        {% endif %}
                      {% endif %}
                    {% endfor %}
                  </section>
                {% endfor %}
              </div>
            </div>
            {% else %}
            <div class="mega-wrap grid-8-4">
              <div class="mega-left three-cols">
                {% for section in workMegaMenu.sections %}
                  <section>
                    <h5>{{ section.heading }}</h5>
                    {% for link in section.links %}
                      <a href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}><i class="{{ link.icon }}"></i>{{ link.title }}</a>
                      {% if link.description %}
                        <small>{{ link.description }}</small>
                      {% endif %}
                    {% endfor %}
                  </section>
                {% endfor %}
              </div>
              <aside class="mega-right cta-card">
                <h5>{{ workMegaMenu.cta.title }}</h5>
                <p>{{ workMegaMenu.cta.description }}</p>
                <a class="btn btn-accent btn-lg w-100" href="{{ workMegaMenu.cta.href }}">{{ workMegaMenu.cta.label }}</a>
              </aside>
            </div>
            {% endif %}
            {% else %}
            <div class="mega-wrap grid-8-4">
              <div class="mega-left three-cols">
                <section>
                  <h5>Research & Scholarship</h5>
                  <a href="/en/publications/"><i class="bi bi-journal-text me-2"></i>Publications</a>
                  <small>Scientific articles and reports.</small>
                  <a href="/en/theses/"><i class="bi bi-mortarboard me-2"></i>Theses Supervised</a>
                  <small>Bachelor's and Master's theses.</small>
                </section>
                <section>
                  <h5>Outreach & Materials</h5>
                  <a href="/en/presentations/"><i class="bi bi-person-video3 me-2"></i>Presentations</a>
                  <small>Slides and keynotes.</small>
                  <a href="/en/portfolio/"><i class="bi bi-folder me-2"></i>Teaching Portfolio</a>
                </section>
                <section>
                  <h5>Academic Networks</h5>
                  <a href="https://www.linkedin.com/in/jarilaru/" target="_blank" rel="noopener noreferrer"><i class="bi bi-linkedin me-2"></i>LinkedIn</a>
                  <a href="https://www.researchgate.net/profile/Jari-Laru" target="_blank" rel="noopener noreferrer"><i class="bi bi-globe me-2"></i>ResearchGate</a>
                </section>
              </div>
              <aside class="mega-right cta-card">
                <h5>Book me for a keynote</h5>
                <p>Expert talks on AI, EdTech, and modern pedagogy.</p>
                <a class="btn btn-accent btn-lg w-100" href="/en/contact/">Request a quote</a>
              </aside>
            </div>
            {% endif %}
          </div>
        </li>

        <li class="nav-item dropdown mega-dropdown">
          {{ megaNavTrigger(navPolitics.url or '/en/politics/', navPolitics.title or 'Politics', navPolitics.icon or 'bi bi-bank2', page.url and ('/en/politics/' in page.url or '/en/affiliations/' in page.url), 'megaMenuPoliticsEn', 'megaTogglePoliticsEn', openSubmenuLabel) }}
          <div id="megaMenuPoliticsEn" class="dropdown-menu mega-menu-panel p-0 border-0" aria-labelledby="megaTogglePoliticsEn">
            <div class="mega-wrap">
              <div class="mega-left three-cols">
                {% for section in politicsMegaMenu.sections %}
                  <section>
                    <h5>{{ section.heading }}</h5>
                    {% for link in section.links %}
                      {% set linkCount = 0 %}
                      {% if link.countKey %}{% set linkCount = (collections[link.countKey] or []) | length %}{% endif %}
                      {% if link.menuLink %}
                        <a class="menu-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}>
                          <i class="{{ link.icon }}"></i>
                          <span>{{ link.title }}{% if link.countKey and linkCount %} <span class="menu-link-count">{{ linkCount }}</span>{% endif %}</span>
                        </a>
                      {% else %}
                        <a href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}><i class="{{ link.icon }}"></i>{{ link.title }}</a>
                      {% endif %}
                      {% if link.description %}
                        <small class="{{ 'menu-link-desc' if link.menuLink }}">{{ link.description }}</small>
                      {% endif %}
                    {% endfor %}
                  </section>
                {% endfor %}
              </div>
            </div>
          </div>
        </li>

        <li class="nav-item dropdown mega-dropdown">
          {{ megaNavTrigger(navWritings.url or '/en/writings/', navWritings.title or 'Writings', navWritings.icon or 'bi bi-pencil-fill', page.url and '/en/writings/' in page.url, 'megaMenuWritingsEn', 'megaToggleWritingsEn', openSubmenuLabel) }}
          <div id="megaMenuWritingsEn" class="dropdown-menu mega-menu-panel p-0 border-0" aria-labelledby="megaToggleWritingsEn">
            <div class="mega-wrap writings-mega-layout">
              {% if writingsMegaMenu.contentColumns %}
                <section class="writings-group-head">
                  <h5>{{ writingsMegaMenu.groupHeading or writingsMegaMenu.heading }}</h5>
                  <p class="menu-desc">{{ writingsMegaMenu.description }}</p>
                </section>
                {% for contentColumn in writingsMegaMenu.contentColumns %}
                  <section class="writings-main-col">
                    {% for link in contentColumn.links %}
                      {% set linkCount = 0 %}
                      {% if link.countKey %}
                        {% set linkCount = (collections[link.countKey] or []) | length %}
                      {% elif link.countData == "theses_total" %}
                        {% set linkCount = theses.stats.total if theses and theses.stats else 0 %}
                      {% elif link.countData == "theses_kandit" %}
                        {% set linkCount = theses.stats.totalKandit if theses and theses.stats else 0 %}
                      {% elif link.countData == "theses_gradut" %}
                        {% set linkCount = theses.stats.totalGradut if theses and theses.stats else 0 %}
                      {% endif %}
                      <a class="menu-link-with-count" href="{{ link.href }}">
                        <span><i class="{{ link.icon }}"></i>{{ link.title }}</span>
                        {% if link.countKey or link.countData %}<span class="menu-link-count">{{ linkCount }}</span>{% endif %}
                      </a>
                      {% if link.description %}
                        <small class="menu-link-desc">{{ link.description }}</small>
                      {% endif %}
                    {% endfor %}
                  </section>
                {% endfor %}
                {% if writingsMegaMenu.seeAlso %}
                  <section class="writings-side-head">
                    <h5>{{ writingsMegaMenu.seeAlso.heading }}</h5>
                    {% if writingsMegaMenu.seeAlso.subheading %}
                      <p class="menu-desc">{{ writingsMegaMenu.seeAlso.subheading }}</p>
                    {% endif %}
                  </section>
                  <section class="writings-side-links">
                    {% for link in writingsMegaMenu.seeAlso.links %}
                      {% set linkCount = 0 %}
                      {% if link.countKey %}
                        {% set linkCount = (collections[link.countKey] or []) | length %}
                      {% elif link.countData == "theses_total" %}
                        {% set linkCount = theses.stats.total if theses and theses.stats else 0 %}
                      {% elif link.countData == "theses_kandit" %}
                        {% set linkCount = theses.stats.totalKandit if theses and theses.stats else 0 %}
                      {% elif link.countData == "theses_gradut" %}
                        {% set linkCount = theses.stats.totalGradut if theses and theses.stats else 0 %}
                      {% endif %}
                      <a class="menu-link-with-count" href="{{ link.href }}">
                        <span><i class="{{ link.icon }}"></i>{{ link.title }}</span>
                        {% if link.countKey or link.countData %}<span class="menu-link-count">{{ linkCount }}</span>{% endif %}
                      </a>
                      {% if link.description %}
                        <small class="menu-link-desc">{{ link.description }}</small>
                      {% endif %}
                    {% endfor %}
                  </section>
                {% endif %}
              {% else %}
                <section>
                  <h5>{{ writingsMegaMenu.heading }}</h5>
                  <p class="menu-desc">{{ writingsMegaMenu.description }}</p>
                  {% for link in writingsMegaMenu.links %}
                    <a href="{{ link.href }}"><i class="{{ link.icon }}"></i>{{ link.title }}</a>
                  {% endfor %}
                </section>
              {% endif %}
            </div>
          </div>
        </li>

        <li class="nav-item dropdown mega-dropdown">
          {{ megaNavTrigger(navContact.url or '/en/contact/', navContact.title or 'Contact', navContact.icon or 'bi bi-envelope', page.url and '/en/contact/' in page.url, 'megaMenuContactEn', 'megaToggleContactEn', openSubmenuLabel) }}
          <div id="megaMenuContactEn" class="dropdown-menu mega-menu-panel p-0 border-0" aria-labelledby="megaToggleContactEn">
            <div class="mega-wrap">
              <section class="w-100 mb-3">
                <h5>{{ contactMegaMenu.heading }}</h5>
                <p class="menu-desc">{{ contactMegaMenu.description }}</p>
              </section>
              <div class="mega-left four-cols contact-mega-cols">
                {% for column in contactMegaMenu.columns %}
                  <section>
                    <h5>{{ column.heading }}</h5>
                    {% if column.type == "form" and column.form %}
                      <form class="contact-mega-form" action="{{ column.form.action }}" method="{{ column.form.method or 'POST' }}">
                        <label class="form-label small fw-semibold mb-1" for="contactMegaNameEn">{{ column.form.namePlaceholder }}</label>
                        <input id="contactMegaNameEn" type="text" name="name" class="form-control form-control-sm mb-2" placeholder="{{ column.form.namePlaceholder }}" autocomplete="name">
                        <label class="form-label small fw-semibold mb-1" for="contactMegaEmailEn">{{ column.form.emailPlaceholder }}</label>
                        <input id="contactMegaEmailEn" type="email" name="email" class="form-control form-control-sm mb-2" placeholder="{{ column.form.emailPlaceholder }}" autocomplete="email" required>
                        <label class="form-label small fw-semibold mb-1" for="contactMegaMessageEn">{{ column.form.messagePlaceholder }}</label>
                        <textarea id="contactMegaMessageEn" name="message" class="form-control form-control-sm mb-2" rows="3" placeholder="{{ column.form.messagePlaceholder }}" required></textarea>
                        <button type="submit" class="btn btn-accent btn-lg w-100">{{ column.form.submitLabel }}</button>
                      </form>
                      <a class="contact-mega-mobile-cta btn btn-accent btn-lg w-100 mt-2" href="{{ navContact.url or '/en/contact/' }}">
                        <i class="bi bi-envelope-check me-2"></i>Open contact form
                      </a>
                    {% else %}
                      {% for link in column.links %}
                        <a class="menu-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}>
                          <i class="{{ link.icon }}"></i><span>{{ link.title }}</span>
                        </a>
                      {% endfor %}
                    {% endif %}
                  </section>
                {% endfor %}
              </div>
            </div>
          </div>
        </li>

        <li class="nav-item ms-md-auto mt-2 mt-md-0">
          <div class="d-flex align-items-center gap-2">
            <button class="btn btn-sm rounded-circle d-flex align-items-center justify-content-center" id="searchToggleBtn" data-search-toggle style="width: 38px; height: 38px;" aria-label="Search site" title="Search site">
              <i class="bi bi-search"></i>
            </button>
            <button class="btn btn-sm rounded-circle d-flex align-items-center justify-content-center" id="themeToggleBtn" data-theme-toggle style="width: 38px; height: 38px;" aria-label="Toggle theme" title="Toggle theme">
              <i class="bi bi-moon-stars-fill" id="themeToggleIcon" data-theme-icon></i>
            </button>
          </div>
        </li>
        <li class="nav-item ms-md-2 mt-2 mt-md-0">
          <a class="nav-link py-0 d-flex align-items-center gap-1 text-decoration-none" href="{{ fiPageUrl or '/' }}" lang="fi" aria-label="Vaihda kieleksi suomi">
            <span aria-hidden="true">🇫🇮</span><span>FI</span>
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<div class="offcanvas offcanvas-start d-md-none" tabindex="-1" id="mobileNavEn" aria-labelledby="mobileNavEnLabel">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title fw-bold" id="mobileNavEnLabel">Menu</h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>
  <div class="offcanvas-body">
    <form class="mb-3" data-search-form>
      <label for="mobileNavEnSearchInput" class="form-label small text-muted">Search this site</label>
      <div class="input-group input-group-sm">
        <input id="mobileNavEnSearchInput" type="search" class="form-control" placeholder="Search..." autocomplete="off" name="q">
        <button class="btn btn-outline-primary" type="submit" aria-label="Open search">
          <i class="bi bi-search"></i>
        </button>
      </div>
    </form>
    <div class="d-flex align-items-center justify-content-between gap-2 mb-3">
      <div class="btn-group btn-group-sm" role="group" aria-label="Language switcher">
        <a class="btn btn-outline-primary{% if currentLang == 'fi' %} active{% endif %}" href="{{ fiPageUrl or '/' }}" lang="fi">FI</a>
        <a class="btn btn-outline-primary{% if currentLang == 'en' %} active{% endif %}" href="{{ enPageUrl or '/en/' }}" lang="en">EN</a>
      </div>
      <button class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-2" type="button" data-theme-toggle aria-label="Toggle theme">
        <i class="bi bi-moon-stars-fill" data-theme-icon></i><span>Theme</span>
      </button>
    </div>
    <div class="d-grid gap-2 mb-3">
      <a class="btn btn-outline-primary rounded-pill" href="{{ navHome.url or '/en/' }}">Home</a>
    </div>
    <div class="accordion accordion-flush mobile-nav-accordion" id="mobileNavAccordionEn">
      <div class="accordion-item">
        <h2 class="accordion-header" id="mobileNavEnMeHead">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#mobileNavEnMe" aria-expanded="false" aria-controls="mobileNavEnMe">Me</button>
        </h2>
        <div id="mobileNavEnMe" class="accordion-collapse collapse" aria-labelledby="mobileNavEnMeHead" data-bs-parent="#mobileNavAccordionEn">
          <div class="accordion-body">
            <a class="btn btn-sm btn-outline-primary rounded-pill mb-3" href="{{ navMe.url or '/en/about/' }}">Open Me page</a>
            {% for section in meMegaMenu.sections %}
              <p class="text-uppercase small text-muted mb-1 mt-2">{{ section.heading }}</p>
              <div class="d-grid gap-1 mb-2">
                {% for link in section.links %}
                  {% if link.inlineLinks %}
                    <div class="mobile-nav-link d-flex align-items-center gap-2 flex-wrap">
                      {% for inlineLink in link.inlineLinks %}
                        <a class="mobile-nav-link inline-link" href="{{ inlineLink.href }}"{% if inlineLink.external %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ inlineLink.title }}</a>{% if not loop.last %}<span class="mobile-nav-inline-separator" aria-hidden="true">|</span>{% endif %}
                      {% endfor %}
                    </div>
                  {% else %}
                    <a class="mobile-nav-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ link.title }}</a>
                  {% endif %}
                {% endfor %}
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="accordion-item">
        <h2 class="accordion-header" id="mobileNavEnWorkHead">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#mobileNavEnWork" aria-expanded="false" aria-controls="mobileNavEnWork">Work</button>
        </h2>
        <div id="mobileNavEnWork" class="accordion-collapse collapse" aria-labelledby="mobileNavEnWorkHead" data-bs-parent="#mobileNavAccordionEn">
          <div class="accordion-body">
            <a class="btn btn-sm btn-outline-primary rounded-pill mb-3" href="{{ navWork.url or '/en/work/' }}">Open Work page</a>
            {% for section in workMegaMenu.sections %}
              <p class="text-uppercase small text-muted mb-1 mt-2">{{ section.heading }}</p>
              <div class="d-grid gap-1 mb-2">
                {% for link in section.links %}
                  <a class="mobile-nav-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ link.title }}</a>
                {% endfor %}
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="accordion-item">
        <h2 class="accordion-header" id="mobileNavEnPoliticsHead">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#mobileNavEnPolitics" aria-expanded="false" aria-controls="mobileNavEnPolitics">Politics</button>
        </h2>
        <div id="mobileNavEnPolitics" class="accordion-collapse collapse" aria-labelledby="mobileNavEnPoliticsHead" data-bs-parent="#mobileNavAccordionEn">
          <div class="accordion-body">
            <a class="btn btn-sm btn-outline-primary rounded-pill mb-3" href="{{ navPolitics.url or '/en/politics/' }}">Open Politics page</a>
            {% for section in politicsMegaMenu.sections %}
              <p class="text-uppercase small text-muted mb-1 mt-2">{{ section.heading }}</p>
              <div class="d-grid gap-1 mb-2">
                {% for link in section.links %}
                  <a class="mobile-nav-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ link.title }}</a>
                {% endfor %}
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="accordion-item">
        <h2 class="accordion-header" id="mobileNavEnWritingsHead">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#mobileNavEnWritings" aria-expanded="false" aria-controls="mobileNavEnWritings">Writings</button>
        </h2>
        <div id="mobileNavEnWritings" class="accordion-collapse collapse" aria-labelledby="mobileNavEnWritingsHead" data-bs-parent="#mobileNavAccordionEn">
          <div class="accordion-body">
            <a class="btn btn-sm btn-outline-primary rounded-pill mb-3" href="{{ navWritings.url or '/en/writings/' }}">Open Writings page</a>
            {% if writingsMegaMenu.contentColumns %}
              {% for contentColumn in writingsMegaMenu.contentColumns %}
                <div class="d-grid gap-1 mb-2">
                  {% for link in contentColumn.links %}
                    <a class="mobile-nav-link" href="{{ link.href }}">{{ link.title }}</a>
                  {% endfor %}
                </div>
              {% endfor %}
              {% if writingsMegaMenu.seeAlso %}
                <p class="text-uppercase small text-muted mb-1 mt-2">{{ writingsMegaMenu.seeAlso.heading }}</p>
                <div class="d-grid gap-1 mb-2">
                  {% for link in writingsMegaMenu.seeAlso.links %}
                    <a class="mobile-nav-link" href="{{ link.href }}">{{ link.title }}</a>
                  {% endfor %}
                </div>
              {% endif %}
            {% else %}
              <div class="d-grid gap-1 mb-2">
                {% for link in writingsMegaMenu.links %}
                  <a class="mobile-nav-link" href="{{ link.href }}">{{ link.title }}</a>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
      <div class="accordion-item">
        <h2 class="accordion-header" id="mobileNavEnContactHead">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#mobileNavEnContact" aria-expanded="false" aria-controls="mobileNavEnContact">Contact</button>
        </h2>
        <div id="mobileNavEnContact" class="accordion-collapse collapse" aria-labelledby="mobileNavEnContactHead" data-bs-parent="#mobileNavAccordionEn">
          <div class="accordion-body">
            <a class="btn btn-sm btn-outline-primary rounded-pill mb-3" href="{{ navContact.url or '/en/contact/' }}">Open Contact page</a>
            {% for column in contactMegaMenu.columns %}
              <p class="text-uppercase small text-muted mb-1 mt-2">{{ column.heading }}</p>
              {% if column.links %}
                <div class="d-grid gap-1 mb-2">
                  {% for link in column.links %}
                    <a class="mobile-nav-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ link.title }}</a>
                  {% endfor %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div id="searchOverlay" class="search-overlay" role="dialog" aria-modal="true" aria-labelledby="searchOverlayTitle" aria-hidden="true" hidden>
  <div class="search-overlay-inner">
    <div class="container py-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0" id="searchOverlayTitle"><i class="bi bi-search me-2"></i>Search</h3>
        <button class="btn btn-sm rounded-circle" id="searchCloseBtn" aria-label="Close search" style="width: 38px; height: 38px;">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
      <div id="pagefindSearch"></div>
    </div>
  </div>
</div>
