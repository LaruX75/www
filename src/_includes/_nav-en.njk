    <div class="mobile-nav-card-stack" aria-label="Detailed navigation">
      <details class="mobile-nav-card">
        <summary>
          <span class="mobile-nav-card-title"><i class="{{ navMe.icon or 'bi bi-person-fill' }}"></i>Me</span>
          <span class="mobile-nav-card-desc">Profile, background and roles.</span>
        </summary>
        <div class="mobile-nav-card-body">
          <a class="mobile-nav-primary-link" href="{{ navMe.url or '/en/about/' }}">Open Me page</a>
          <div class="mobile-nav-section-grid">
            {% for section in meMegaMenu.sections %}
              <section class="mobile-nav-section-card">
                <h6>{{ section.heading }}</h6>
                {% for link in section.links %}
                  {% if link.inlineLinks %}
                    <div class="mobile-nav-inline-links">
                      {% for inlineLink in link.inlineLinks %}
                        <a class="mobile-nav-link inline-link" href="{{ inlineLink.href }}"{% if inlineLink.external %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ inlineLink.title }}</a>{% if not loop.last %}<span class="mobile-nav-inline-separator" aria-hidden="true">|</span>{% endif %}
                      {% endfor %}
                    </div>
                  {% else %}
                    <a class="mobile-nav-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}>
                      <span><i class="{{ link.icon }}"></i>{{ link.title }}</span>
                    </a>
                  {% endif %}
                {% endfor %}
              </section>
            {% endfor %}
          </div>
        </div>
      </details>

      <details class="mobile-nav-card">
        <summary>
          <span class="mobile-nav-card-title"><i class="{{ navWork.icon or 'bi bi-briefcase-fill' }}"></i>Work</span>
          <span class="mobile-nav-card-desc">University work, training and research.</span>
        </summary>
        <div class="mobile-nav-card-body">
          <a class="mobile-nav-primary-link" href="{{ navWork.url or '/en/work/' }}">Open Work page</a>
          <div class="mobile-nav-section-grid">
            {% for section in workMegaMenu.sections %}
              <section class="mobile-nav-section-card">
                <h6>{{ section.heading }}</h6>
                {% for link in section.links %}
                  <a class="mobile-nav-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}>
                    <span><i class="{{ link.icon }}"></i>{{ link.title }}</span>
                  </a>
                {% endfor %}
              </section>
            {% endfor %}
          </div>
        </div>
      </details>

      <details class="mobile-nav-card">
        <summary>
          <span class="mobile-nav-card-title"><i class="{{ navPolitics.icon or 'bi bi-bank2' }}"></i>Politics</span>
          <span class="mobile-nav-card-desc">Roles, speeches and election periods.</span>
        </summary>
        <div class="mobile-nav-card-body">
          <a class="mobile-nav-primary-link" href="{{ navPolitics.url or '/en/politics/' }}">Open Politics page</a>
          {% if politicsMegaMenu.description %}
            <p class="mobile-nav-note">{{ politicsMegaMenu.description }}</p>
          {% endif %}
          <div class="mobile-nav-section-grid">
            {% if politicsMegaMenu.spotlight %}
              <section class="mobile-nav-section-card mobile-nav-section-card--accent">
                <h6>{{ politicsMegaMenu.spotlight.title }}</h6>
                <ul class="mega-role-list mega-role-list--compact">
                  {% for role in politicsMegaMenu.spotlight.roles %}
                    <li>{{ role }}</li>
                  {% endfor %}
                </ul>
              </section>
            {% endif %}
            {% for section in politicsMegaMenu.sections %}
              <section class="mobile-nav-section-card">
                <h6>{{ section.heading }}</h6>
                {% for link in section.links %}
                  <a class="mobile-nav-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}>
                    <span><i class="{{ link.icon }}"></i>{{ link.title }}</span>
                    {% if link.countKey %}<strong>{{ (collections[link.countKey] or []) | length }}</strong>{% endif %}
                  </a>
                {% endfor %}
              </section>
            {% endfor %}
          </div>
        </div>
      </details>

      <details class="mobile-nav-card" open>
        <summary>
          <span class="mobile-nav-card-title"><i class="{{ navWritings.icon or 'bi bi-pencil-fill' }}"></i>Writings</span>
          <span class="mobile-nav-card-desc">Texts, speeches, statements and media.</span>
        </summary>
        <div class="mobile-nav-card-body">
          <a class="mobile-nav-primary-link" href="{{ navWritings.url or '/en/writings/' }}">Open Writings page</a>
          <p class="mobile-nav-note">{{ writingsMegaMenu.description }}</p>
          <div class="mobile-nav-section-grid">
            {% if writingsMegaMenu.contentColumns %}
              {% for contentColumn in writingsMegaMenu.contentColumns %}
                <section class="mobile-nav-section-card">
                  {% if contentColumn.heading %}
                    <h6>{{ contentColumn.heading }}</h6>
                  {% endif %}
                  {% for link in contentColumn.links %}
                    <a class="mobile-nav-link" href="{{ link.href }}">
                      <span><i class="{{ link.icon }}"></i>{{ link.title }}</span>
                      {% if link.countKey %}<strong>{{ (collections[link.countKey] or []) | length }}</strong>{% endif %}
                    </a>
                  {% endfor %}
                </section>
              {% endfor %}
              {% if writingsMegaMenu.seeAlso %}
                <section class="mobile-nav-section-card">
                  <h6>{{ writingsMegaMenu.seeAlso.heading }}</h6>
                  {% for link in writingsMegaMenu.seeAlso.links %}
                    <a class="mobile-nav-link" href="{{ link.href }}">
                      <span><i class="{{ link.icon }}"></i>{{ link.title }}</span>
                    </a>
                  {% endfor %}
                </section>
              {% endif %}
            {% else %}
              <section class="mobile-nav-section-card">
                {% for link in writingsMegaMenu.links %}
                  <a class="mobile-nav-link" href="{{ link.href }}">
                    <span><i class="{{ link.icon }}"></i>{{ link.title }}</span>
                  </a>
                {% endfor %}
              </section>
            {% endif %}
          </div>
        </div>
      </details>

      <details class="mobile-nav-card">
        <summary>
          <span class="mobile-nav-card-title"><i class="{{ navContact.icon or 'bi bi-envelope' }}"></i>Contact</span>
          <span class="mobile-nav-card-desc">Email, social links and contact form.</span>
        </summary>
        <div class="mobile-nav-card-body">
          <a class="mobile-nav-primary-link" href="{{ navContact.url or '/en/contact/' }}">Open Contact page</a>
          <div class="mobile-nav-section-grid">
            {% for column in contactMegaMenu.columns %}
              <section class="mobile-nav-section-card">
                <h6>{{ column.heading }}</h6>
              {% if column.links %}
                {% for link in column.links %}
                  <a class="mobile-nav-link" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noopener noreferrer"{% endif %}>
                    <span><i class="{{ link.icon }}"></i>{{ link.title }}</span>
                  </a>
                {% endfor %}
              {% endif %}
              </section>
            {% endfor %}
          </div>
        </div>
      </details>
    </div>
  </div>
</div>

<div id="searchOverlay" class="search-overlay" role="dialog" aria-modal="true" aria-labelledby="searchOverlayTitle" aria-hidden="true" hidden>
  <div class="search-overlay-inner">
    <div class="container py-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0" id="searchOverlayTitle"><i class="bi bi-search me-2"></i>Search</h3>
        <button class="btn btn-sm rounded-circle" id="searchCloseBtn" aria-label="Close search" style="width: 38px; height: 38px;">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
      <div
        id="siteSearchUi"
        class="site-search-ui"
        data-pagefind-ui
        data-pagefind-lang="English"
        data-pagefind-placeholder="Write a search term..."
      ></div>
    </div>
  </div>
</div>
