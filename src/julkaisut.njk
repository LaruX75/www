---
layout: base.njk
title: Julkaisut
permalink: /julkaisut/
translationKey: publications_index
---

{%- set articleCount = 0 -%}
{%- set confCount = 0 -%}
{%- set bookCount = 0 -%}
{%- set peerReviewedCount = 0 -%}
{%- set openAccessCount = 0 -%}
{%- for pub in researchfi -%}
  {%- if pub.typeCode == "A1" or pub.typeCode == "A2" -%}{%- set articleCount = articleCount + 1 -%}{%- endif -%}
  {%- if pub.typeCode == "A3" or pub.typeCode == "A4" or pub.typeCode == "B3" -%}{%- set confCount = confCount + 1 -%}{%- endif -%}
  {%- if pub.typeCode == "C1" or pub.typeCode == "C2" or pub.typeCode == "G4" or pub.typeCode == "G5" -%}{%- set bookCount = bookCount + 1 -%}{%- endif -%}
{%- endfor -%}

<section class="bg-light">
  <div class="container py-4">
    <div class="row align-items-center g-4">
      <div class="col-lg-8">
        <p class="text-uppercase small text-muted mb-2">Julkaisut</p>
        <h1 class="display-6 fw-bold mb-2">Julkaisut & Analytiikka</h1>
        <p class="text-muted">Tieteelliset julkaisuni suoraan <a href="https://research.fi/en/results/person/0000-0003-0347-0182" target="_blank" rel="noopener noreferrer">Research.fi-profiilista</a> päivitettynä.</p>
      </div>
      <div class="col-lg-4">
        <div class="d-flex flex-wrap gap-2 justify-content-lg-end" id="headerMetrics">
          <span class="badge text-bg-primary text-dark fs-6">{{ researchfi.length }} julkaisua</span>
          <span class="badge text-bg-info fs-6">{{ articleCount }} artikkelia</span>
          <span class="badge text-bg-secondary fs-6">{{ confCount }} konferenssia</span>
          <span class="badge text-bg-warning fs-6 d-none" id="dynamicTotalCitations" title="Lähde: {{ semanticscholar.metrics.sources }}">... viittausta</span>
          <span class="badge text-bg-success fs-6 d-none" id="dynamicHIndex" title="Lähde: {{ semanticscholar.metrics.sources }}">... h-indeksi</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ANALYTIIKKA-DASHBOARD -->
<section class="py-4 bg-body-tertiary">
  <div class="container">
    <div class="row g-4">

      <!-- Julkaisut vuosittain -->
      <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <h2 class="h6 text-uppercase text-muted fw-bold mb-3"><i class="bi bi-bar-chart-fill me-2"></i>Julkaisut & viittaukset vuosittain</h2>
            <canvas id="yearChart" height="200"></canvas>
          </div>
        </div>
      </div>

      <!-- Julkaisutyypit -->
      <div class="col-lg-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body d-flex flex-column">
            <h2 class="h6 text-uppercase text-muted fw-bold mb-3"><i class="bi bi-pie-chart-fill me-2"></i>Julkaisutyypit</h2>
            <div style="position:relative; height:220px;">
              <canvas id="typeChart"></canvas>
            </div>
          </div>
        </div>
      </div>

      <!-- Open Access & Vertaisarvioitu -->
      <div class="col-lg-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body d-flex flex-column">
            <h2 class="h6 text-uppercase text-muted fw-bold mb-3"><i class="bi bi-unlock-fill me-2"></i>Laatuindikaattorit</h2>
            <div style="position:relative; height:220px;">
              <canvas id="qualityChart"></canvas>
            </div>
          </div>
        </div>
      </div>

      <!-- Yhteistyöverkosto -->
      <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <h2 class="h6 text-uppercase text-muted fw-bold mb-3"><i class="bi bi-people-fill me-2"></i>Top 10 kanssatutkijaa</h2>
            <div id="coauthorFilterStatus" class="small mb-2 d-none"></div>
            <div class="table-responsive">
              <table class="table table-sm table-hover align-middle mb-0 pub-table" id="coauthorTable">
                <thead><tr><th>Tutkija</th><th class="text-end">Yhteisjulkaisut</th></tr></thead>
                <tbody></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- Aihepiirijakauma -->
      <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <h2 class="h6 text-uppercase text-muted fw-bold mb-3"><i class="bi bi-tags-fill me-2"></i>Avainsanat (otsikoista)</h2>
            <div id="wordCloud" class="d-flex flex-wrap gap-2 align-items-center"></div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- AVAINSANASUODATTIMEN STATUSBANNERI -->
<div id="keyword-filter-bar" class="container pb-0 pt-2 d-none">
  <div class="alert alert-info py-2 d-flex align-items-center gap-2 mb-0">
    <i class="bi bi-tag-fill me-1"></i>
    Avainsanasuodatin: <strong id="active-keyword-label"></strong>
    <button type="button" class="btn btn-sm btn-outline-secondary ms-auto py-0 px-2" id="clear-keyword-filter">
      <i class="bi bi-x-circle me-1"></i>Poista suodatin
    </button>
  </div>
</div>

<!-- JULKAISULISTA -->
<section id="researchfi-julkaisut" class="py-5">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h3 class="mb-0">Kaikki julkaisut</h3>
    </div>

    {% if researchfi.length %}

      {# Jaa julkaisut tyyleittäin Dataan perustuen #}
      {% set pubsA = [] %}
      {% set pubsB = [] %}
      {% set pubsC = [] %}
      {% set pubsD = [] %}
      {% set pubsE = [] %}
      {% set pubsG = [] %}
      
      {% for pub in researchfi %}
        {% set typeChar = pub.typeCode | first %}
        {% if typeChar == 'A' %}{% set pubsA = (pubsA.push(pub), pubsA) %}
        {% elif typeChar == 'B' %}{% set pubsB = (pubsB.push(pub), pubsB) %}
        {% elif typeChar == 'C' %}{% set pubsC = (pubsC.push(pub), pubsC) %}
        {% elif typeChar == 'D' %}{% set pubsD = (pubsD.push(pub), pubsD) %}
        {% elif typeChar == 'E' %}{% set pubsE = (pubsE.push(pub), pubsE) %}
        {% elif typeChar == 'G' %}{% set pubsG = (pubsG.push(pub), pubsG) %}
        {% endif %}
      {% endfor %}

      {# Macros for reuse #}
      {% macro drawTable(title, badge, items, tableId, subtypes) %}
      {% if items.length %}
      <div class="card shadow-sm mb-5 section-card" id="card-{{ tableId }}">
        <div class="card-header bg-transparent py-3">
          <div class="d-flex align-items-start justify-content-between">
            <div>
              <h4 class="h5 mb-0"><i class="bi bi-journal-text me-2 text-primary"></i>{{ title }}</h4>
              {% if subtypes and subtypes.length %}
              <div class="mt-1 d-flex flex-wrap">
                {% for st in subtypes %}
                  {% if (items | selectattr("typeCode", "equalto", st.code) | list).length %}
                  <span class="me-3 mt-1" style="font-size:0.78rem; color: var(--bs-secondary-color);">
                    <strong style="font-size:0.76rem;">{{ st.code }}</strong>&nbsp;{{ st.desc }}
                  </span>
                  {% endif %}
                {% endfor %}
              </div>
              {% endif %}
            </div>
            <div class="d-flex align-items-center gap-2 flex-shrink-0 ms-3 mt-1">
              <span class="publication-filter-indicator badge border border-info text-info d-none" data-filter-indicator="{{ tableId }}"></span>
              <span class="badge {{ badge }}">{{ items.length }}</span>
            </div>
          </div>
        </div>
        <div class="card-body p-0">
          <div class="p-3 border-bottom publication-filter-bar">
            <div class="row g-2 align-items-end">
              <div class="col-md-9">
                <label for="search-{{ tableId }}" class="form-label small text-muted mb-1">Suodata</label>
                <input type="search" id="search-{{ tableId }}" class="form-control form-control-sm" placeholder="Hae otsikosta, tekijästä tai julkaisusta..." autocomplete="off" data-pub-search="{{ tableId }}">
              </div>
            </div>
          </div>
          <div id="{{ tableId }}">
            <div class="table-responsive">
              <table class="table table-sm table-hover align-middle mb-0 pub-table">
                <thead>
                  <tr>
                    <th class="text-center" style="width:70px">Vuosi</th>
                    <th style="width:80px">Luokka</th>
                    <th>Otsikko & Julkaisu</th>
                    <th style="width:200px">Tekijä(t)</th>
                    <th style="width:100px" class="text-center">Linkit</th>
                  </tr>
                </thead>
                <tbody>
                  {% for pub in items %}
                  <tr data-authors="{{ pub.authors | escape }}">
                    <td class="text-center font-monospace small fw-bold text-info">{{ pub.year or '—' }}</td>
                    <td><span class="badge bg-secondary" title="{{ pub.typeFi }}">{{ pub.typeShort }}</span></td>
                    <td>
                      <span class="fw-medium d-block mb-1">{{ pub.title }}</span>
                      {% if pub.journal %}<span class="text-muted small d-block fst-italic">{{ pub.journal }}</span>{% endif %}
                      {% set citationCount = (semanticscholar.metrics.doiCitations[pub.doi | lower] if pub.doi and semanticscholar.metrics.doiCitations[pub.doi | lower] else 0) %}
                      <div class="d-flex flex-wrap align-items-center gap-2 mt-1">
                        <span class="badge text-bg-warning rounded-pill" title="Viittaukset">
                          <i class="bi bi-quote me-1"></i>{{ citationCount }} {{ "viite" if citationCount == 1 else "viittausta" }}
                        </span>
                        <button
                          type="button"
                          class="btn btn-sm btn-outline-secondary rounded-pill export-citation-btn"
                          data-title="{{ pub.title | escape }}"
                          data-authors="{{ pub.authors | escape }}"
                          data-year="{{ pub.year or '' }}"
                          data-journal="{{ pub.journal | escape }}"
                          data-doi="{{ pub.doi or '' }}"
                          data-url="{{ pub.url or pub.doiUrl or '' }}"
                          title="Vie lähdeviite"
                        >
                          <i class="bi bi-download me-1"></i>Vie viite
                        </button>
                      </div>
                    </td>
                    <td class="text-secondary small">{{ pub.authors }}</td>
                    <td class="text-center">
                      {% if pub.url %}
                        <a href="{{ pub.url }}" target="_blank" class="btn btn-sm btn-outline-primary py-0 px-2 rounded-pill" rel="noopener noreferrer" title="Avaa julkaisu" aria-label="Avaa julkaisu uuteen välilehteen"><i class="bi bi-box-arrow-up-right"></i></a>
                      {% elif pub.doiUrl %}
                        <a href="{{ pub.doiUrl }}" target="_blank" class="btn btn-sm btn-outline-primary py-0 px-2 rounded-pill" rel="noopener noreferrer" title="Avaa DOI" aria-label="Avaa DOI uuteen välilehteen"><i class="bi bi-box-arrow-up-right"></i></a>
                      {% endif %}
                    </td>
                  </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
      {% endif %}
      {% endmacro %}

      {% set subtypesA = [
        {code: 'A1', desc: 'Alkuperäisartikkeli tieteellisessä aikakauslehdessä'},
        {code: 'A2', desc: 'Katsausartikkeli tieteellisessä aikakauslehdessä'},
        {code: 'A3', desc: 'Kirjan tai muun kokoomateoksen osa'},
        {code: 'A4', desc: 'Artikkeli konferenssijulkaisussa'}
      ] %}
      {% set subtypesB = [
        {code: 'B1', desc: 'Kirjoitus tieteellisessä aikakauslehdessä'},
        {code: 'B2', desc: 'Kirjan tai muun kokoomateoksen osa'},
        {code: 'B3', desc: 'Vertaisarvioimaton artikkeli konferenssijulkaisussa'}
      ] %}
      {% set subtypesC = [
        {code: 'C1', desc: 'Kustannettu tieteellinen erillisteos'},
        {code: 'C2', desc: 'Toimitettu kirja, kokoomateos, konferenssijulkaisu tai lehden erikoisnumero'}
      ] %}
      {% set subtypesD = [
        {code: 'D1', desc: 'Artikkeli ammattilehdessä'},
        {code: 'D2', desc: 'Artikkeli ammatillisessa kokoomateoksessa'},
        {code: 'D3', desc: 'Artikkeli ammatillisessa konferenssijulkaisussa'}
      ] %}
      {% set subtypesE = [
        {code: 'E1', desc: 'Yleistajuinen artikkeli, sanomalehtiartikkeli'},
        {code: 'E2', desc: 'Yleistajuinen monografia'}
      ] %}
      {% set subtypesG = [
        {code: 'G4', desc: 'Väitöskirja (artikkeli)'},
        {code: 'G5', desc: 'Väitöskirja (monografia)'}
      ] %}

      {{ drawTable('A - Vertaisarvioidut tieteelliset artikkelit', 'text-bg-primary', pubsA, 'pub-table-a', subtypesA) }}
      {{ drawTable('B - Vertaisarvioimattomat tieteelliset kirjoitukset', 'text-bg-info', pubsB, 'pub-table-b', subtypesB) }}
      {{ drawTable('C - Tieteelliset kirjat', 'text-bg-warning', pubsC, 'pub-table-c', subtypesC) }}
      {{ drawTable('D - Ammattiyhteisölle suunnatut julkaisut', 'text-bg-secondary', pubsD, 'pub-table-d', subtypesD) }}
      {{ drawTable('E - Suurelle yleisölle suunnatut julkaisut', 'bg-dark', pubsE, 'pub-table-e', subtypesE) }}
      {{ drawTable('G - Opinnäytteet', 'text-bg-success', pubsG, 'pub-table-g', subtypesG) }}
      
    {% else %}
      <div class="alert alert-warning">Ei julkaisuja saatavilla.</div>
    {% endif %}
  </div>
</section>

<div class="modal fade" id="citationExportModal" tabindex="-1" aria-labelledby="citationExportModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title fs-5" id="citationExportModalLabel">Vie lähdeviite</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Sulje"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-md-5">
            <label for="citationFormatSelect" class="form-label small text-muted">Viittausmuoto</label>
            <select id="citationFormatSelect" class="form-select form-select-sm">
              <option value="bibtex">BibTeX (.bib)</option>
              <option value="apa">APA</option>
              <option value="mla">MLA</option>
              <option value="chicago">Chicago</option>
            </select>
          </div>
          <div class="col-md-7 d-flex align-items-end justify-content-md-end gap-2">
            <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill" id="citationCopyBtn">
              <i class="bi bi-clipboard me-1"></i>Kopioi
            </button>
            <button type="button" class="btn btn-primary btn-sm rounded-pill" id="citationDownloadBtn">
              <i class="bi bi-download me-1"></i>Lataa
            </button>
          </div>
        </div>
        <div class="mt-3">
          <label for="citationOutput" class="form-label small text-muted mb-1">Esikatselu</label>
          <textarea id="citationOutput" class="form-control form-control-sm font-monospace" rows="12" readonly></textarea>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Chart.js & Dashboard Scripts -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Inline data from Eleventy
  const publications = [
    {% for pub in researchfi %}
    { year: {{ pub.year or 0 }}, type: "{{ pub.typeCode }}", authors: "{{ pub.authors | replace('"', '\\"') }}", title: "{{ pub.title | replace('"', '\\"') }}", peerReviewed: {{ "true" if pub.peerReviewed else "false" }}, openAccess: {{ pub.openAccess or 0 }}, doi: "{{ pub.doi or '' }}" },
    {% endfor %}
  ];

  // Semantic Scholar / OpenAlex data
  const s2Citations = {{ semanticscholar.metrics.doiCitations | dump | safe }};

  // 0. LASKETAAN TODELLISET METRIIKAT (vain tällä sivulla olevat julkaisut)
  let verifiedTotalCitations = 0;
  const citationArray = [];
  
  publications.forEach(p => {
    if (p.doi && s2Citations[p.doi.toLowerCase()]) {
      const cites = s2Citations[p.doi.toLowerCase()];
      verifiedTotalCitations += cites;
      citationArray.push(cites);
    }
  });
  
  // Lasketaan todellinen h-indeksi näille julkaisuille
  citationArray.sort((a,b) => b - a);
  let verifiedHIndex = 0;
  for (let i = 0; i < citationArray.length; i++) {
    if (citationArray[i] >= i + 1) {
      verifiedHIndex = i + 1;
    } else {
      break;
    }
  }

  // Päivitetään DOM
  if (verifiedTotalCitations > 0) {
    const totalEl = document.getElementById('dynamicTotalCitations');
    totalEl.textContent = verifiedTotalCitations + ' viittausta';
    totalEl.classList.remove('d-none');
    
    const hEl = document.getElementById('dynamicHIndex');
    hEl.textContent = 'h-indeksi ' + verifiedHIndex;
    hEl.classList.remove('d-none');
  }

  const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
  const textColor = isDark ? '#ccc' : '#666';
  const gridColor = isDark ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.08)';

  Chart.defaults.color = textColor;
  Chart.defaults.borderColor = gridColor;

  // Pagination for pub tables
  const ITEMS_PER_PAGE = 10;
  let activeCoauthor = '';
  const tableFilterRefreshers = [];

  function sanitizeFilenamePart(value) {
    return String(value || '')
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '')
      .slice(0, 60) || 'viite';
  }

  function toBibtexAuthors(authors) {
    return String(authors || '')
      .split(';')
      .map((a) => a.trim())
      .filter(Boolean)
      .join(' and ');
  }

  function buildBibtexEntry(payload) {
    const rawAuthors = String(payload.authors || '').trim();
    const authors = toBibtexAuthors(rawAuthors || 'Tuntematon Tekija');
    const year = String(payload.year || '').trim() || 'n.d.';
    const title = String(payload.title || '').trim() || 'Nimeton julkaisu';
    const journal = String(payload.journal || '').trim();
    const doi = String(payload.doi || '').trim();
    const url = String(payload.url || '').trim();
    const firstAuthorToken = (rawAuthors.split(';')[0] || 'tekijä')
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '');
    const keyBase = sanitizeFilenamePart(title.split(/\s+/).slice(0, 6).join('-')).replace(/-/g, '');
    const bibKey = `${firstAuthorToken || 'tekijä'}${year}${keyBase || 'julkaisu'}`;

    const lines = [
      `@article{${bibKey},`,
      `  author = {${authors}},`,
      `  title = {${title}},`,
      `  year = {${year}},`
    ];
    if (journal) lines.push(`  journal = {${journal}},`);
    if (doi) lines.push(`  doi = {${doi}},`);
    if (url) lines.push(`  url = {${url}},`);
    lines.push('}');
    return lines.join('\n');
  }

  function buildApaCitation(payload) {
    const authors = String(payload.authors || '').trim() || 'Tuntematon tekijä';
    const year = String(payload.year || '').trim() || 'n.d.';
    const title = String(payload.title || '').trim() || 'Nimetön julkaisu';
    const journal = String(payload.journal || '').trim();
    const doi = String(payload.doi || '').trim();
    const url = String(payload.url || '').trim();
    let citation = `${authors} (${year}). ${title}.`;
    if (journal) citation += ` ${journal}.`;
    if (doi) citation += ` https://doi.org/${doi}`;
    else if (url) citation += ` ${url}`;
    return citation.trim();
  }

  function buildMlaCitation(payload) {
    const authors = String(payload.authors || '').trim() || 'Tuntematon tekijä';
    const year = String(payload.year || '').trim() || 'n.d.';
    const title = String(payload.title || '').trim() || 'Nimetön julkaisu';
    const journal = String(payload.journal || '').trim();
    const doi = String(payload.doi || '').trim();
    const url = String(payload.url || '').trim();
    let citation = `${authors}. "${title}."`;
    if (journal) citation += ` ${journal},`;
    citation += ` ${year}.`;
    if (doi) citation += ` doi:${doi}.`;
    else if (url) citation += ` ${url}.`;
    return citation.trim();
  }

  function buildChicagoCitation(payload) {
    const authors = String(payload.authors || '').trim() || 'Tuntematon tekijä';
    const year = String(payload.year || '').trim() || 'n.d.';
    const title = String(payload.title || '').trim() || 'Nimetön julkaisu';
    const journal = String(payload.journal || '').trim();
    const doi = String(payload.doi || '').trim();
    const url = String(payload.url || '').trim();
    let citation = `${authors}. "${title}."`;
    if (journal) citation += ` ${journal}`;
    citation += ` (${year}).`;
    if (doi) citation += ` https://doi.org/${doi}.`;
    else if (url) citation += ` ${url}.`;
    return citation.trim();
  }

  function downloadTextFile(filename, text) {
    const blob = new Blob([text], { type: 'text/plain;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);
  }

  const citationFormatSelect = document.getElementById('citationFormatSelect');
  const citationOutput = document.getElementById('citationOutput');
  const citationDownloadBtn = document.getElementById('citationDownloadBtn');
  const citationCopyBtn = document.getElementById('citationCopyBtn');
  const citationModalEl = document.getElementById('citationExportModal');
  let currentCitationPayload = null;

  function getCitationByFormat(payload, format) {
    if (!payload) return '';
    if (format === 'apa') return buildApaCitation(payload);
    if (format === 'mla') return buildMlaCitation(payload);
    if (format === 'chicago') return buildChicagoCitation(payload);
    return buildBibtexEntry(payload);
  }

  function renderCitationPreview() {
    if (!citationOutput) return;
    const format = citationFormatSelect?.value || 'bibtex';
    citationOutput.value = getCitationByFormat(currentCitationPayload, format);
  }

  document.querySelectorAll('.export-citation-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      currentCitationPayload = {
        title: btn.dataset.title || '',
        authors: btn.dataset.authors || '',
        year: btn.dataset.year || '',
        journal: btn.dataset.journal || '',
        doi: btn.dataset.doi || '',
        url: btn.dataset.url || ''
      };
      if (citationFormatSelect) citationFormatSelect.value = 'bibtex';
      renderCitationPreview();
      if (window.bootstrap && window.bootstrap.Modal && citationModalEl) {
        window.bootstrap.Modal.getOrCreateInstance(citationModalEl).show();
      }
    });
  });

  if (citationFormatSelect) {
    citationFormatSelect.addEventListener('change', renderCitationPreview);
  }

  if (citationDownloadBtn) {
    citationDownloadBtn.addEventListener('click', () => {
      if (!currentCitationPayload) return;
      const format = citationFormatSelect?.value || 'bibtex';
      const citation = getCitationByFormat(currentCitationPayload, format);
      const base = sanitizeFilenamePart(currentCitationPayload.title || currentCitationPayload.authors || 'viite');
      const ext = format === 'bibtex' ? 'bib' : 'txt';
      downloadTextFile(`${base}.${ext}`, citation + '\n');
    });
  }

  if (citationCopyBtn) {
    citationCopyBtn.addEventListener('click', async () => {
      if (!citationOutput?.value) return;
      try {
        await navigator.clipboard.writeText(citationOutput.value);
        citationCopyBtn.innerHTML = '<i class="bi bi-check2 me-1"></i>Kopioitu';
        setTimeout(() => {
          citationCopyBtn.innerHTML = '<i class="bi bi-clipboard me-1"></i>Kopioi';
        }, 1400);
      } catch (_) {
        citationOutput.select();
        document.execCommand('copy');
      }
    });
  }

  function setCoauthorFilter(authorName) {
    activeCoauthor = (activeCoauthor === authorName) ? '' : authorName;
    tableFilterRefreshers.forEach((refresh) => refresh());

    const statusEl = document.getElementById('coauthorFilterStatus');
    if (!statusEl) return;
    if (activeCoauthor) {
      statusEl.className = 'small mb-2 text-info';
      statusEl.innerHTML = `Rajaus aktiivinen: <strong>${activeCoauthor}</strong> <button type="button" id="clearCoauthorFilter" class="btn btn-sm btn-outline-secondary rounded-pill ms-2 py-0 px-2">Poista rajaus</button>`;
      const clearBtn = document.getElementById('clearCoauthorFilter');
      if (clearBtn) clearBtn.addEventListener('click', () => setCoauthorFilter(''));
    } else {
      statusEl.className = 'small mb-2 d-none';
      statusEl.textContent = '';
    }
  }

  function initPubPagination(tableId) {
    const tableContainer = document.getElementById(tableId);
    if (!tableContainer) return;

    const table = tableContainer.querySelector('table');
    if (!table) return;

    const tbody = table.querySelector('tbody');
    const rows = Array.from(tbody.querySelectorAll('tr'));
    
      // 5. Build Pagination UI
      let paginationNav = tableContainer.querySelector('.pub-pagination');
      if (!paginationNav) {
        paginationNav = document.createElement('nav');
        const containerId = tableContainer.id || Math.random().toString(36).substring(7);
        paginationNav.setAttribute('aria-label', `Taulukon sivutus ${containerId}`);
        paginationNav.className = 'pub-pagination d-flex justify-content-center mt-3';
        paginationNav.innerHTML = '<ul class="pagination pagination-sm mb-3"></ul>';
        tableContainer.appendChild(paginationNav);
      }
    
    const ul = paginationNav.querySelector('ul');
    const filterIndicator = document.querySelector(`[data-filter-indicator="${tableId}"]`);
    let currentPage = 1;
    let filteredRows = [...rows];
    
    const searchInput = document.querySelector(`[data-pub-search="${tableId}"]`);

    function renderPage(page) {
      currentPage = page;
      const totalPages = Math.ceil(filteredRows.length / ITEMS_PER_PAGE);
      if (currentPage < 1) currentPage = 1;
      if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;

      rows.forEach(r => r.style.display = 'none');
      
      const start = (currentPage - 1) * ITEMS_PER_PAGE;
      const end = start + ITEMS_PER_PAGE;
      filteredRows.slice(start, end).forEach(r => r.style.display = '');

      renderPaginationControls(totalPages);

      if (filterIndicator) {
        if (activeCoauthor) {
          const noun = filteredRows.length === 1 ? 'julkaisuun' : 'julkaisuihin';
          filterIndicator.textContent = `Rajattu "${activeCoauthor}" henkilön kanssa tehtyihin ${noun}`;
          filterIndicator.classList.remove('d-none');
        } else {
          filterIndicator.textContent = '';
          filterIndicator.classList.add('d-none');
        }
      }
    }

    function renderPaginationControls(totalPages) {
      ul.innerHTML = '';
      if (totalPages <= 1) return;

      const prevLi = document.createElement('li');
      prevLi.className = `page-item ${currentPage === 1 ? 'disabled' : ''}`;
      prevLi.innerHTML = `<button type="button" class="page-link" aria-label="Edellinen sivu">&laquo;</button>`;
      prevLi.addEventListener('click', (e) => { e.preventDefault(); if(currentPage > 1) renderPage(currentPage - 1); });
      ul.appendChild(prevLi);

      for (let i = 1; i <= totalPages; i++) {
        const li = document.createElement('li');
        li.className = `page-item ${i === currentPage ? 'active' : ''}`;
        li.innerHTML = `<button type="button" class="page-link" aria-label="Sivu ${i}">${i}</button>`;
        li.addEventListener('click', (e) => { e.preventDefault(); renderPage(i); });
        ul.appendChild(li);
      }

      const nextLi = document.createElement('li');
      nextLi.className = `page-item ${currentPage === totalPages ? 'disabled' : ''}`;
      nextLi.innerHTML = `<button type="button" class="page-link" aria-label="Seuraava sivu">&raquo;</button>`;
      nextLi.addEventListener('click', (e) => { e.preventDefault(); if(currentPage < totalPages) renderPage(currentPage + 1); });
      ul.appendChild(nextLi);
    }

    function applyFilters() {
      const q = (searchInput?.value || '').toLowerCase();
      const coauthorNeedle = activeCoauthor.toLowerCase();
      filteredRows = rows.filter(row => {
        const text = row.textContent.toLowerCase();
        const matchesSearch = !q || text.includes(q);
        const authors = (row.dataset.authors || '').toLowerCase();
        const matchesCoauthor = !coauthorNeedle || authors.includes(coauthorNeedle);
        return matchesSearch && matchesCoauthor;
      });
      renderPage(1);
    }

    if (searchInput) searchInput.addEventListener('input', applyFilters);
    tableFilterRefreshers.push(applyFilters);
    applyFilters();
  }

  ['pub-table-a', 'pub-table-b', 'pub-table-c', 'pub-table-d', 'pub-table-e', 'pub-table-g'].forEach(initPubPagination);

  // 1. VUOSIKAAVIO
  const yearCounts = {};
  publications.forEach(p => { if(p.year) yearCounts[p.year] = (yearCounts[p.year]||0)+1; });
  const years = Object.keys(yearCounts).sort();
  // Citation counts per year from S2 data
  const citesPerYear = {};
  if (s2Citations) {
    publications.forEach(p => {
      if (p.year && p.doi && s2Citations[p.doi.toLowerCase()]) {
        citesPerYear[p.year] = (citesPerYear[p.year]||0) + s2Citations[p.doi.toLowerCase()];
      }
    });
  }

  new Chart(document.getElementById('yearChart'), {
    type: 'bar',
    data: {
      labels: years,
      datasets: [{
        label: 'Julkaisuja',
        data: years.map(y => yearCounts[y]),
        backgroundColor: isDark ? 'rgba(56,189,248,0.6)' : 'rgba(13,110,253,0.7)',
        borderRadius: 4,
        borderSkipped: false,
        yAxisID: 'y'
      },{
        label: 'Viittauksia',
        data: years.map(y => citesPerYear[y] || 0),
        type: 'line',
        borderColor: '#ffc107',
        backgroundColor: 'rgba(255,193,7,0.15)',
        fill: true,
        tension: 0.3,
        pointRadius: 3,
        yAxisID: 'y1'
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { position: 'top', labels: { boxWidth: 12, font: { size: 10 } } } },
      scales: {
        y: { beginAtZero: true, ticks: { stepSize: 1 }, title: { display: true, text: 'Julkaisut', font: { size: 10 } } },
        y1: { beginAtZero: true, position: 'right', grid: { drawOnChartArea: false }, title: { display: true, text: 'Viittaukset', font: { size: 10 } } },
        x: { ticks: { maxRotation: 45 } }
      }
    }
  });

  // 2. TYYPPIKAAVIO
  const typeCounts = {};
  const typeLabels = {
    'A1':'Lehtiartikkeli (A1)', 'A2':'Katsausartikkeli (A2)',
    'A3':'Kirjan osa (A3)', 'A4':'Konferenssi (A4)',
    'B1':'Kirjoitus (B1)', 'B3':'Konferenssi ei-vertaisarv. (B3)',
    'C1':'Tieteellinen teos (C1)', 'C2':'Toimitettu teos (C2)',
    'D1':'Ammattiartikkeli (D1)', 'D2':'Ammatillinen kokoomat. (D2)',
    'E1':'Yleistajuinen (E1)', 'G4':'Väitöskirja (G4)', 'G5':'Väitöskirja (G5)'
  };
  publications.forEach(p => { typeCounts[p.type] = (typeCounts[p.type]||0)+1; });
  const typeKeys = Object.keys(typeCounts).sort((a,b) => typeCounts[b]-typeCounts[a]);
  const typeColors = ['#0d6efd','#6610f2','#6f42c1','#d63384','#dc3545','#fd7e14','#ffc107','#198754','#20c997','#0dcaf0','#6c757d','#adb5bd','#495057'];
  new Chart(document.getElementById('typeChart'), {
    type: 'doughnut',
    data: {
      labels: typeKeys.map(k => typeLabels[k]||k),
      datasets: [{
        data: typeKeys.map(k => typeCounts[k]),
        backgroundColor: typeColors.slice(0, typeKeys.length),
        borderWidth: 0
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { position: 'bottom', labels: { boxWidth: 10, font: { size: 10 } } }
      }
    }
  });

  // 3. LAADULLISET (peer review & OA)
  // Kategorisoidaan julkaisut toisensa poissulkeviin luokkiin
  const isPeerReviewed = (value) => value === true || value === 1 || value === '1' || String(value).toLowerCase() === 'true';
  const isOpenAccess = (value) => value === true || value === 1 || value === '1' || String(value).toLowerCase() === 'true';
  const prAndOa = publications.filter(p => isPeerReviewed(p.peerReviewed) && isOpenAccess(p.openAccess)).length;
  const prOnly = publications.filter(p => isPeerReviewed(p.peerReviewed) && !isOpenAccess(p.openAccess)).length;
  // "Muu / ei vertaisarvioitu" sisältää sekä OA- että ei-OA-julkaisut.
  const nonPeerReviewed = publications.filter(p => !isPeerReviewed(p.peerReviewed)).length;
  
  new Chart(document.getElementById('qualityChart'), {
    type: 'doughnut',
    data: {
      labels: ['Vertaisarvioitu & OA', 'Vain vertaisarvioitu', 'Muu / ei vertaisarvioitu'],
      datasets: [{
        data: [prAndOa, prOnly, nonPeerReviewed],
        backgroundColor: ['#198754', '#20c997', '#dee2e6'],
        borderWidth: 0
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { position: 'bottom', labels: { boxWidth: 10, font: { size: 10 } } }
      }
    }
  });

  // 4. KANSSATUTKIJAT
  const coauthors = {};
  publications.forEach(p => {
    const authors = p.authors.split(';').map(a => a.trim()).filter(a => a.length > 0);
    authors.forEach(a => {
      if (!a.toLowerCase().startsWith('laru')) {
        coauthors[a] = (coauthors[a]||0) + 1;
      }
    });
  });
  const topCoauthors = Object.entries(coauthors).sort((a,b)=>b[1]-a[1]).slice(0,10);
  const tbody = document.querySelector('#coauthorTable tbody');
  topCoauthors.forEach(([name, count]) => {
    const tr = document.createElement('tr');
    const isDarkTheme = document.documentElement.getAttribute('data-bs-theme') === 'dark';
    const badgeStyle = isDarkTheme ? 'background-color: rgba(56,189,248,0.3); color: #e2e6ec;' : 'background-color: rgba(13,110,253,0.15); color: #0d6efd;';
    tr.innerHTML = `
      <td>
        <button type="button" class="btn btn-link p-0 text-start coauthor-filter-btn" data-coauthor="${name}" title="Rajaa julkaisut tekijällä ${name}">
          ${name}
        </button>
      </td>
      <td class="text-end"><span class="badge rounded-pill" style="${badgeStyle}">${count}</span></td>
    `;
    tbody.appendChild(tr);
  });

  document.querySelectorAll('.coauthor-filter-btn').forEach((btn) => {
    btn.addEventListener('click', () => setCoauthorFilter(btn.dataset.coauthor || ''));
  });

  // 5. SANAPILVI (Otsikon sanat, alkuperäinen toimivaksi todettu tapa)
  const stopwords = new Set(['the','of','in','for','a','an','and','to','on','with','from','by','at','as','is','are','was','were','or','using','based','their','its','towards','between','among','during','about','through','case','study','how','can','do','does','than','into','all','not','but','also','been','has','have','had','which','when','what','that','this','these','those','other','more','no','some','varhaiskasvatuksen']);
  const wordCounts = {};
  publications.forEach(p => {
    const words = p.title.toLowerCase().replace(/[^a-zäöüå\s-]/g, '').split(/\s+/);
    words.forEach(w => {
      if (w.length > 3 && !stopwords.has(w)) {
        wordCounts[w] = (wordCounts[w]||0) + 1;
      }
    });
  });
  const topWords = Object.entries(wordCounts).sort((a,b)=>b[1]-a[1]).slice(0,25);
  const cloudEl = document.getElementById('wordCloud');
  let activeKeyword = '';
  const keywordFilterBar = document.getElementById('keyword-filter-bar');
  const activeKeywordLabel = document.getElementById('active-keyword-label');
  const clearKeywordBtn = document.getElementById('clear-keyword-filter');

  function applyKeywordFilter(word) {
    activeKeyword = (activeKeyword === word) ? '' : word;

    document.querySelectorAll('[data-pub-search]').forEach(input => {
      input.value = activeKeyword;
      input.dispatchEvent(new Event('input', { bubbles: true }));
    });

    if (keywordFilterBar) {
      if (activeKeyword) {
        if (activeKeywordLabel) activeKeywordLabel.textContent = activeKeyword;
        keywordFilterBar.classList.remove('d-none');
      } else {
        keywordFilterBar.classList.add('d-none');
      }
    }

    cloudEl.querySelectorAll('.keyword-badge').forEach(btn => {
      const isActive = btn.dataset.word === activeKeyword;
      btn.style.outline = isActive ? '2px solid currentColor' : '';
      btn.style.opacity = isActive ? '1' : btn.dataset.opacity;
    });

    if (activeKeyword) {
      document.getElementById('researchfi-julkaisut')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  if (clearKeywordBtn) {
    clearKeywordBtn.addEventListener('click', () => applyKeywordFilter(''));
  }

  if (topWords.length > 0) {
    const maxCount = topWords[0]?.[1] || 1;
    topWords.forEach(([word, count]) => {
      const size = 0.7 + (count / maxCount) * 1.0;
      const opacity = 0.5 + (count / maxCount) * 0.5;
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'badge rounded-pill border-0 keyword-badge';
      btn.dataset.word = word;
      btn.dataset.opacity = opacity;
      btn.style.cssText = `font-size:${size}rem; opacity:${opacity}; background-color: ${isDark ? 'rgba(56,189,248,0.3)' : 'rgba(13,110,253,0.15)'}; color: ${isDark ? '#e2e6ec' : '#0d6efd'}; font-weight: 500; cursor: pointer; transition: outline 0.1s;`;
      btn.title = `Suodata julkaisut avainsanalla "${word}"`;
      btn.textContent = `${word} (${count})`;
      btn.addEventListener('click', () => applyKeywordFilter(word));
      cloudEl.appendChild(btn);
    });
  } else {
    cloudEl.innerHTML = '<span class="text-muted small">Ei avainsanoja saatavilla</span>';
  }
});
</script>

<style>
.pub-table th {
  white-space: nowrap;
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  background-color: var(--bs-secondary-bg);
}

.publication-filter-bar {
  background-color: var(--bs-tertiary-bg);
  border-color: var(--bs-border-color) !important;
}

.publication-filter-bar .form-control {
  background-color: var(--bs-body-bg);
  color: var(--bs-body-color);
  border-color: var(--bs-border-color);
}

.publication-filter-bar .form-control::placeholder {
  color: var(--bs-tertiary-color);
}
</style>
