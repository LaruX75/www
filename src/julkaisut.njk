---
layout: base.njk
title: Julkaisut
metaTitle: Julkaisut ja tieteellinen tuotanto
description: "Jari Larun tutkimusjulkaisut, viittausdata ja julkaisuluokat Research.fi-aineistosta: vertaisarvioidut artikkelit, konferenssit, kirjat ja yleistajuiset tekstit."
permalink: /julkaisut/
translationKey: publications_index
---

{%- set articleCount = 0 -%}
{%- set confCount = 0 -%}
{%- set bookCount = 0 -%}
{%- set peerReviewedCount = 0 -%}
{%- set openAccessCount = 0 -%}
{%- set pubsA = [] -%}
{%- set pubsB = [] -%}
{%- set pubsC = [] -%}
{%- set pubsD = [] -%}
{%- set pubsE = [] -%}
{%- set pubsG = [] -%}
{%- for pub in researchfi -%}
  {%- set typeChar = pub.typeCode | first -%}
  {%- if typeChar == "A" -%}{%- set pubsA = (pubsA.push(pub), pubsA) -%}
  {%- elif typeChar == "B" -%}{%- set pubsB = (pubsB.push(pub), pubsB) -%}
  {%- elif typeChar == "C" -%}{%- set pubsC = (pubsC.push(pub), pubsC) -%}
  {%- elif typeChar == "D" -%}{%- set pubsD = (pubsD.push(pub), pubsD) -%}
  {%- elif typeChar == "E" -%}{%- set pubsE = (pubsE.push(pub), pubsE) -%}
  {%- elif typeChar == "G" -%}{%- set pubsG = (pubsG.push(pub), pubsG) -%}
  {%- endif -%}
  {%- if pub.typeCode == "A1" or pub.typeCode == "A2" -%}{%- set articleCount = articleCount + 1 -%}{%- endif -%}
  {%- if pub.typeCode == "A3" or pub.typeCode == "A4" or pub.typeCode == "B3" -%}{%- set confCount = confCount + 1 -%}{%- endif -%}
  {%- if pub.typeCode == "C1" or pub.typeCode == "C2" or pub.typeCode == "G4" or pub.typeCode == "G5" -%}{%- set bookCount = bookCount + 1 -%}{%- endif -%}
  {%- if pub.peerReviewed -%}{%- set peerReviewedCount = peerReviewedCount + 1 -%}{%- endif -%}
  {%- if pub.openAccess -%}{%- set openAccessCount = openAccessCount + 1 -%}{%- endif -%}
{%- endfor -%}
{%- for item in collections.publications -%}
  {%- if item.data.publicationType -%}
    {%- set typeChar = item.data.publicationType | first -%}
    {%- set manualPub = [item] | toManualPub -%}
    {%- if typeChar == "A" -%}{%- set pubsA = (pubsA.push(manualPub), pubsA) -%}
    {%- elif typeChar == "B" -%}{%- set pubsB = (pubsB.push(manualPub), pubsB) -%}
    {%- elif typeChar == "C" -%}{%- set pubsC = (pubsC.push(manualPub), pubsC) -%}
    {%- elif typeChar == "D" -%}{%- set pubsD = (pubsD.push(manualPub), pubsD) -%}
    {%- elif typeChar == "E" -%}{%- set pubsE = (pubsE.push(manualPub), pubsE) -%}
    {%- elif typeChar == "G" -%}{%- set pubsG = (pubsG.push(manualPub), pubsG) -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}
{%- set latestResearchHighlights = (researchfi or []).slice(0, 3) -%}
{%- set latestPeerReviewedHighlights = (pubsA or []).slice(0, 2) -%}
{%- set latestPublicHighlights = pubsE or [] -%}

<section class="publications-hero py-4 py-lg-5">
  <div class="site-shell">
    <div class="row align-items-center g-4">
      <div class="col-lg-7">
        <p class="text-uppercase small text-muted mb-2">Julkaisut</p>
        <h1 class="display-6 fw-bold mb-2">Tutkimusprofiili, julkaisut ja vaikuttavuus</h1>
        <p class="text-muted mb-3">Tälle sivulle on koottu tutkimusjulkaisuni, niiden ryhmittely sekä viittaus- ja yhteistyödata. Aineisto päivittyy <a href="https://research.fi/en/results/person/0000-0003-0347-0182" target="_blank" rel="noopener noreferrer">Research.fi-profiilista</a>, ja alta pääset suoraan sekä julkaisuluokkiin että analytiikkaan.</p>
        <div class="d-flex flex-wrap gap-2">
          <a class="nav-link" href="#julkaisuluokat">Julkaisuluokat <span class="nav-count">{{ researchfi.length }}</span></a>
          <a class="nav-link" href="#vaitoskirja">Väitöskirja</a>
          <a class="nav-link" href="#analyticsPanel">Analytiikka</a>
          <a class="nav-link" href="#card-pub-table-a">Vertaisarvioidut</a>
        </div>
      </div>
      <div class="col-lg-4">
        <aside class="publications-hero-aside">
          <p class="publications-hero-kicker mb-2">Mitä tällä sivulla näkyy</p>
          <ul class="publications-hero-list mb-0">
            <li>Vertaisarvioidut, ammatilliset ja yleistajuiset julkaisut on eroteltu omiin ryhmiinsä.</li>
            <li>Viittausluvut ja h-indeksi lasketaan tämän sivun julkaisuista, eivät yleisestä profiiliyhteenvetosta.</li>
            <li>Yhteistyöverkosto ja avainsanat auttavat hahmottamaan tutkimuslinjaa yhdellä silmäyksellä.</li>
          </ul>
        </aside>
      </div>
    </div>
  </div>
</section>

<section class="publication-kpi-section">
  <div class="site-shell">
    <div class="row g-3">
      <div class="col-6 col-xl-3">
        <article class="card border-0 shadow-sm h-100 site-kpi-card publication-kpi-card">
          <div class="card-body">
            <div class="site-kpi-number publication-kpi-value">{{ researchfi.length }}</div>
            <div class="site-kpi-label publication-kpi-label">julkaisua</div>
          </div>
        </article>
      </div>
      <div class="col-6 col-xl-3">
        <article class="card border-0 shadow-sm h-100 site-kpi-card publication-kpi-card">
          <div class="card-body">
            <div class="site-kpi-number publication-kpi-value">{{ peerReviewedCount }}</div>
            <div class="site-kpi-label publication-kpi-label">vertaisarvioitua</div>
          </div>
        </article>
      </div>
      <div class="col-6 col-xl-3">
        <article class="card border-0 shadow-sm h-100 site-kpi-card publication-kpi-card">
          <div class="card-body">
            <div class="site-kpi-number publication-kpi-value" id="dynamicTotalCitations" title="Lähde: {{ semanticscholar.metrics.sources }}">…</div>
            <div class="site-kpi-label publication-kpi-label">viittausta</div>
          </div>
        </article>
      </div>
      <div class="col-6 col-xl-3">
        <article class="card border-0 shadow-sm h-100 site-kpi-card publication-kpi-card">
          <div class="card-body">
            <div class="site-kpi-number publication-kpi-value" id="dynamicHIndex" title="Lähde: {{ semanticscholar.metrics.sources }}">…</div>
            <div class="site-kpi-label publication-kpi-label">h-indeksi</div>
          </div>
        </article>
      </div>
    </div>
    <p class="publication-kpi-note text-muted mb-0 mt-3">{{ openAccessCount }} julkaisua on merkitty avoimesti saataviksi, {{ articleCount }} kuuluu lehtiartikkeleihin ja {{ confCount }} konferenssiaineistoon.</p>
  </div>
</section>

<nav class="publication-mobile-path" aria-label="Julkaisusivun tärkeimmät osiot">
  <a href="#aloita-tasta">Reitit</a>
  <a href="#card-pub-table-a">A-luokka</a>
  <a href="#vaitoskirja">Väitös</a>
  <a href="#analyticsPanel">Analytiikka</a>
  <a href="#julkaisuluokat">Arkisto</a>
</nav>

<section id="aloita-tasta" class="py-4">
  <div class="site-shell">
    <div class="row g-4 align-items-stretch">
      <div class="col-12">
        <p class="text-uppercase small text-muted mb-1">Aloita tästä</p>
        <h2 class="h3 mb-1">Nopeimmat reitit julkaisuarkistoon</h2>
        <p class="text-muted mb-0">Sivun voi lukea joko tutkimusprofiilin esittelynä tai varsinaisena julkaisuarkistona. Nämä sisäänkäynnit vievät suoraan yleisimpiin näkymiin.</p>
      </div>
    </div>

    <div class="row g-3 align-items-stretch publication-entry-grid mt-1">
      <div class="col-md-6 col-xl-3">
        <article class="card border-0 shadow-sm h-100 publication-entry-card">
          <div class="card-body d-flex flex-column">
            <p class="publication-entry-kicker">Uusimmat</p>
            <h3 class="h5 mb-2">Viimeisimmät julkaisut</h3>
            <ul class="publication-entry-list mb-3">
              {% for pub in latestResearchHighlights %}
              <li><a href="#julkaisuluokat">{{ pub.title }}</a> <span class="text-muted">({{ pub.year or "—" }})</span></li>
              {% endfor %}
            </ul>
            <a href="#julkaisuluokat" class="btn btn-outline-secondary btn-sm rounded-pill px-3 mt-auto align-self-start">Siirry luokkiin</a>
          </div>
        </article>
      </div>

      <div class="col-md-6 col-xl-3">
        <article class="card border-0 shadow-sm h-100 publication-entry-card">
          <div class="card-body d-flex flex-column">
            <p class="publication-entry-kicker">Vertaisarvioitu tutkimus</p>
            <h3 class="h5 mb-2">Artikkelit ja konferenssit</h3>
            <p class="small text-muted mb-3">{{ pubsA.length }} A-luokan julkaisua, joista {{ articleCount }} on lehtiartikkeleita.</p>
            <ul class="publication-entry-list mb-3">
              {% for pub in latestPeerReviewedHighlights %}
              <li><a href="#card-pub-table-a">{{ pub.title }}</a></li>
              {% endfor %}
            </ul>
            <a href="#card-pub-table-a" class="btn btn-outline-secondary btn-sm rounded-pill px-3 mt-auto align-self-start">Avaa A-luokka</a>
          </div>
        </article>
      </div>

      <div class="col-md-6 col-xl-3">
        <article class="card border-0 shadow-sm h-100 publication-entry-card">
          <div class="card-body d-flex flex-column">
            <p class="publication-entry-kicker">Kirjat ja väitöskirja</p>
            <h3 class="h5 mb-2">Monografiat ja koosteet</h3>
            <p class="small text-muted mb-3">{{ pubsC.length + pubsG.length }} julkaisua kirjoina, toimitettuina teoksina tai opinnäytteinä.</p>
            <div class="small text-muted mb-3">Mukana myös väitöskirja <em>Scaffolding learning activities with collaborative scripts and mobile devices</em>.</div>
            <div class="d-flex flex-wrap gap-2 mt-auto">
              <a href="/vaitoskirja/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Väitöskirja</a>
              <a href="#card-pub-table-c" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Kirjat</a>
            </div>
          </div>
        </article>
      </div>

      <div class="col-md-6 col-xl-3">
        <article class="card border-0 shadow-sm h-100 publication-entry-card">
          <div class="card-body d-flex flex-column">
            <p class="publication-entry-kicker">Laajempi vaikuttavuus</p>
            <h3 class="h5 mb-2">Ammatilliset ja yleistajuiset tekstit</h3>
            <p class="small text-muted mb-3">{{ pubsD.length + pubsE.length }} julkaisua ammattiyhteisöille ja suurelle yleisölle.</p>
            <ul class="publication-entry-list mb-3">
              {% for pub in latestPublicHighlights %}
              <li><a href="#card-pub-table-e">{{ pub.title }}</a></li>
              {% endfor %}
            </ul>
            <div class="d-flex flex-wrap gap-2 mt-auto">
              <a href="#card-pub-table-d" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Ammatilliset</a>
              <a href="#card-pub-table-e" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Yleistajuiset</a>
            </div>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

<style>
  .analytics-chevron { transition: transform .25s ease; }
  [aria-expanded="true"] .analytics-chevron { transform: rotate(180deg); }
  .chart-zoom-btn { opacity: 0.4; transition: opacity .15s; }
  .card:hover .chart-zoom-btn { opacity: 1; }
  .publications-hero {
    background: linear-gradient(135deg, #eef2f7 0%, #e2eaf4 100%);
    border-bottom: 1px solid rgba(15,34,56,0.08);
  }
  .publications-hero-aside {
    padding: 1rem 1.1rem;
    border-radius: 1rem;
    background: rgba(15,34,56,0.05);
    border: 1px solid rgba(15,34,56,0.12);
  }
  .publications-hero-kicker {
    color: #1e3a5f;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .publications-hero-list {
    padding-left: 1rem;
    color: rgba(15,34,56,0.72);
    display: grid;
    gap: 0.55rem;
  }
  .publication-kpi-section {
    padding: 1.25rem 0 0.5rem;
  }
  .publication-kpi-note {
    font-size: 0.92rem;
  }
  .publication-mobile-path {
    display: none;
  }
  .publication-entry-card {
    border-radius: 1rem;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .publication-entry-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 1rem 2rem rgba(17, 29, 45, 0.08);
  }
  .publication-entry-kicker {
    margin: 0 0 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--bs-secondary-color);
  }
  .publication-entry-list {
    padding-left: 1rem;
    display: grid;
    gap: 0.45rem;
  }
  .publication-entry-list a {
    color: inherit;
    text-decoration: none;
  }
  .publication-entry-list a:hover {
    text-decoration: underline;
  }
  .publication-entry-grid {
    flex-wrap: wrap;
  }
  .publication-analytics-card,
  .publication-spotlight-card,
  .publication-nav-card {
    border-radius: 1rem;
  }
  .publication-spotlight-card {
    border-left: 3px solid rgba(148, 163, 184, 0.35);
  }
  .publication-section-header {
    position: relative;
    padding-left: 1.4rem;
  }
  .publication-section-header::before {
    content: "";
    position: absolute;
    left: 0;
    top: 1rem;
    bottom: 1rem;
    width: 3px;
    border-radius: 999px;
    background: rgba(148, 163, 184, 0.45);
  }
  .publication-group-code {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2rem;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    background: var(--bs-tertiary-bg);
    border: 1px solid var(--bs-border-color);
    color: var(--bs-emphasis-color);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .publication-section-count {
    background: var(--bs-tertiary-bg);
    color: var(--bs-emphasis-color);
    border: 1px solid var(--bs-border-color);
    font-weight: 600;
  }
  .publication-year {
    color: var(--bs-secondary-color);
  }
  .publication-citation-badge {
    background: var(--bs-tertiary-bg);
    color: var(--bs-emphasis-color);
    border: 1px solid var(--bs-border-color);
  }
  .publication-jufo {
    border: 1px solid transparent;
  }
  .publication-jufo--3 {
    background: rgba(25, 135, 84, 0.16);
    color: #166534;
    border-color: rgba(25, 135, 84, 0.25);
  }
  .publication-jufo--2 {
    background: rgba(13, 110, 253, 0.14);
    color: #0b57d0;
    border-color: rgba(13, 110, 253, 0.24);
  }
  .publication-jufo--1 {
    background: var(--bs-tertiary-bg);
    color: var(--bs-emphasis-color);
    border-color: var(--bs-border-color);
  }
  .publication-jufo--0 {
    background: rgba(148, 163, 184, 0.12);
    color: var(--bs-secondary-color);
    border-color: rgba(148, 163, 184, 0.2);
  }
  html[data-bs-theme="dark"] .publications-hero {
    background: #0f172a;
    border-bottom-color: rgba(255,255,255,0.08);
  }
  html[data-bs-theme="dark"] .publications-hero p,
  html[data-bs-theme="dark"] .publications-hero .text-muted {
    color: rgba(255,255,255,0.68) !important;
  }
  html[data-bs-theme="dark"] .publications-hero h1 {
    color: #fff;
  }
  html[data-bs-theme="dark"] .publications-hero-aside {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.14);
  }
  html[data-bs-theme="dark"] .publications-hero-kicker {
    color: rgba(255,255,255,0.82);
  }
  html[data-bs-theme="dark"] .publications-hero-list {
    color: rgba(255,255,255,0.72);
  }
  html[data-bs-theme="dark"] .publication-section-header::before {
    background: rgba(255,255,255,0.16);
  }
  html[data-bs-theme="dark"] .publication-jufo--3 {
    color: #d1fae5;
  }
  html[data-bs-theme="dark"] .publication-jufo--2 {
    color: #dbeafe;
  }

  @media (max-width: 767.98px) {
    .publications-hero {
      padding-block: 2rem !important;
    }

    .publications-hero-aside,
    .publication-kpi-note {
      display: none;
    }

    .publication-kpi-section {
      padding-top: 0.85rem;
    }

    .publication-mobile-path {
      position: sticky;
      top: 0;
      z-index: 20;
      display: flex;
      gap: 0.45rem;
      overflow-x: auto;
      padding: 0.65rem 0.75rem;
      border-bottom: 1px solid rgba(19, 43, 70, 0.1);
      background: color-mix(in srgb, var(--bs-body-bg) 92%, transparent);
      backdrop-filter: blur(10px);
      scrollbar-width: none;
    }

    .publication-mobile-path::-webkit-scrollbar {
      display: none;
    }

    .publication-mobile-path a {
      flex: 0 0 auto;
      padding: 0.45rem 0.72rem;
      border: 1px solid var(--bs-border-color);
      border-radius: 999px;
      background: color-mix(in srgb, var(--bs-body-bg) 84%, var(--bs-primary) 8%);
      color: var(--bs-primary);
      font-size: 0.86rem;
      font-weight: 800;
      text-decoration: none;
    }

    .publication-entry-grid {
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: 0.6rem;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
    }

    .publication-entry-grid::-webkit-scrollbar {
      display: none;
    }

    .publication-entry-grid > [class*="col-"] {
      flex: 0 0 84%;
      max-width: 84%;
      scroll-snap-align: start;
    }

    .publication-entry-card .card-body {
      min-height: 17rem;
    }

    .publication-entry-list {
      max-height: 5.5rem;
      overflow: hidden;
    }

    #analyticsPanel {
      padding-block: 1rem !important;
    }

    #analyticsPanel .publication-analytics-card .card-body {
      padding: 1rem;
    }

    #julkaisuluokat {
      padding-top: 2rem !important;
    }

    .publication-nav-card .card-body {
      padding: 1rem;
    }

    .publication-filter-bar {
      padding: 0.75rem !important;
    }
  }

  @media (max-width: 430px) {
    .publication-entry-grid > [class*="col-"] {
      flex-basis: 88%;
      max-width: 88%;
    }
  }

  html[data-bs-theme="dark"] .publication-mobile-path {
    border-bottom-color: rgba(255, 255, 255, 0.1);
    background: color-mix(in srgb, var(--bs-body-bg) 88%, transparent);
  }

  html[data-bs-theme="dark"] .publication-mobile-path a {
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.08);
    color: #f4f8fd;
  }

  /* Kanssatutkijat-kortti: häivytys oletuksena, avautuu klikkaamalla */
  .coauthor-table-wrap {
    position: relative;
    max-height: 200px;
    overflow: hidden;
  }
  .coauthor-fade-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 90px;
    background: linear-gradient(to bottom, transparent, var(--bs-card-bg, #fff));
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 10px;
    cursor: pointer;
    transition: opacity .2s;
  }
</style>

<!-- KAAVION SUURENNOS -MODAL -->
<div class="modal fade" id="chartZoomModal" tabindex="-1" aria-labelledby="chartZoomModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header py-2">
        <h5 class="modal-title h6" id="chartZoomModalLabel"></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Sulje"></button>
      </div>
      <div class="modal-body">
        <div style="position:relative; height:500px;">
          <canvas id="zoomCanvas"></canvas>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ANALYTIIKKA-DASHBOARD -->
<section id="analyticsPanel" class="py-4 bg-body-tertiary">
  <div class="site-shell">
    <div class="card border-0 shadow-sm publication-analytics-card">
      <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
          <div>
            <p class="text-uppercase small text-muted mb-1">Tilastografiikka</p>
            <h2 class="h4 mb-1">Vaikuttavuus, yhteistyö ja aihepiirit</h2>
            <p class="text-muted mb-0">Kaaviot kokoavat julkaisut vuosittain, julkaisutyypeittäin sekä viittausten, kanssatutkijoiden ja otsikkoavainsanojen näkökulmista.</p>
          </div>
          <button class="btn btn-outline-secondary d-flex align-items-center gap-2"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#analyticsDashboard"
                  aria-expanded="false"
                  aria-controls="analyticsDashboard">
            <span>Näytä analytiikka</span>
            <i class="bi bi-chevron-down analytics-chevron"></i>
          </button>
        </div>

        <div class="collapse mt-4" id="analyticsDashboard">
        <div class="row g-4">

      <!-- Julkaisut vuosittain -->
      <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <h2 class="h6 text-uppercase text-muted fw-bold mb-0" id="yearChartHeading"><i class="bi bi-bar-chart-fill me-2"></i>Julkaisut & viittaukset vuosittain</h2>
              <button class="btn btn-sm btn-link p-0 chart-zoom-btn" data-zoom-target="yearChart" data-zoom-title="Julkaisut & viittaukset vuosittain" title="Suurenna"><i class="bi bi-fullscreen"></i></button>
            </div>
            <div style="position:relative; flex:1; min-height:160px;">
              <canvas id="yearChart"></canvas>
            </div>
          </div>
        </div>
      </div>

      <!-- Julkaisutyypit -->
      <div class="col-lg-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <h2 class="h6 text-uppercase text-muted fw-bold mb-0"><i class="bi bi-pie-chart-fill me-2"></i>Julkaisutyypit</h2>
              <button class="btn btn-sm btn-link p-0 chart-zoom-btn" data-zoom-target="typeChart" data-zoom-title="Julkaisutyypit" title="Suurenna"><i class="bi bi-fullscreen"></i></button>
            </div>
            <div style="position:relative; flex:1; min-height:160px;">
              <canvas id="typeChart"></canvas>
            </div>
          </div>
        </div>
      </div>

      <!-- Open Access & Vertaisarvioitu -->
      <div class="col-lg-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <h2 class="h6 text-uppercase text-muted fw-bold mb-0"><i class="bi bi-unlock-fill me-2"></i>Laatuindikaattorit</h2>
              <button class="btn btn-sm btn-link p-0 chart-zoom-btn" data-zoom-target="qualityChart" data-zoom-title="Laatuindikaattorit" title="Suurenna"><i class="bi bi-fullscreen"></i></button>
            </div>
            <div style="position:relative; flex:1; min-height:160px;">
              <canvas id="qualityChart"></canvas>
            </div>
          </div>
        </div>
      </div>

      <!-- Yhteistyöverkosto -->
      <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100" id="coauthorCard">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h2 class="h6 text-uppercase text-muted fw-bold mb-0"><i class="bi bi-people-fill me-2"></i>Top 10 kanssatutkijaa</h2>
              <div class="d-flex gap-1">
                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill px-2 py-0" id="coauthorSortAlpha" title="Lajittele nimen mukaan">
                  A–Ö
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill px-2 py-0 active" id="coauthorSortCount" title="Lajittele julkaisumäärän mukaan">
                  Määrä <i class="bi bi-arrow-up"></i>
                </button>
              </div>
            </div>
            <div id="coauthorFilterStatus" class="small mb-2 visually-hidden" role="status" aria-live="polite" aria-atomic="true"></div>
            <div class="coauthor-table-wrap" id="coauthorTableWrap">
              <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0 pub-table" id="coauthorTable" data-no-header-filters>
                  <thead><tr><th>Tutkija</th><th class="text-end">Yhteisjulkaisut</th></tr></thead>
                  <tbody></tbody>
                </table>
              </div>
              <div class="coauthor-fade-overlay" id="coauthorFadeOverlay">
                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                  <i class="bi bi-chevron-down me-1"></i>Näytä kaikki
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Aihepiirijakauma -->
      <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <h2 class="h6 text-uppercase text-muted fw-bold mb-3"><i class="bi bi-tags-fill me-2"></i>Avainsanat (otsikoista)</h2>
            <div id="wordCloud" class="d-flex flex-wrap gap-2 align-items-center"></div>
          </div>
        </div>
      </div>

        </div>
        </div>{# /collapse #}
      </div>
    </div>
  </div>
</section>

<!-- AVAINSANASUODATTIMEN STATUSBANNERI -->
