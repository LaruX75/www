{% import "ui.njk" as ui %}
{% set totalSupervised = (theses.stats.totalGradut or 0) + (theses.stats.totalKandit or 0) %}
{% set latestPortfolioPresentations = (collections.presentations or []).slice(0, 4) %}
{% set portfolioMaterialKeys = [] %}
{% for item in ((canva and canva.tableRows) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (portfolioMaterialKeys.indexOf(key) == -1) %}
    {% set _ = (portfolioMaterialKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in (collections.presentations or []) %}
  {% set key = (((item.data and item.data.url) or "") ~ "|" ~ ((item.data and item.data.title) or "")) | trim %}
  {% if key != "|" and (portfolioMaterialKeys.indexOf(key) == -1) %}
    {% set _ = (portfolioMaterialKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in ((finnaAoe and finnaAoe.rows) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (portfolioMaterialKeys.indexOf(key) == -1) %}
    {% set _ = (portfolioMaterialKeys.push(key), null) %}
  {% endif %}
{% endfor %}

{% set portfolioCopy = {
