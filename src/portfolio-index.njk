  @media (max-width: 767.98px) {
    .portfolio-mobile-path {
      display: block;
      position: sticky;
      top: var(--site-header-offset, 0);
      z-index: 10;
      padding: 0.75rem 0;
      background: var(--bs-body-bg);
      border-bottom: 1px solid var(--bs-border-color);
    }
    .portfolio-mobile-path .site-shell {
      display: flex;
      gap: 0.55rem;
      overflow-x: auto;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .portfolio-mobile-path .site-shell::-webkit-scrollbar {
      display: none;
    }
    .portfolio-mobile-path a,
    .portfolio-mobile-disclosure-summary {
      flex: 0 0 auto;
      min-height: 2.45rem;
      border: 1px solid rgba(28, 76, 133, 0.18);
      border-radius: 999px;
      background: rgba(13, 71, 124, 0.06);
      color: #153a62;
      font-size: 0.88rem;
      font-weight: 700;
      text-decoration: none;
    }
    .portfolio-mobile-path a {
      display: inline-flex;
      align-items: center;
      padding: 0.45rem 0.85rem;
    }
    .portfolio-mobile-disclosure {
      border-top: 1px solid var(--bs-border-color);
    }
    .portfolio-mobile-disclosure-summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: calc(100% - 2rem);
      margin: 1rem auto;
      padding: 0.55rem 0.9rem;
      cursor: pointer;
      list-style: none;
    }
    .portfolio-mobile-disclosure-summary::-webkit-details-marker {
      display: none;
