    .portfolio-mobile-disclosure-summary::after {
      content: "+";
      font-size: 1.05rem;
      line-height: 1;
    }
    .portfolio-mobile-disclosure[open] .portfolio-mobile-disclosure-summary::after {
      content: "-";
    }
    .portfolio-hero-title {
      max-width: none;
      font-size: 2.5rem;
    }
    .portfolio-hero-card .card-body,
    .portfolio-principle-card .card-body,
    .portfolio-feature-card .card-body,
