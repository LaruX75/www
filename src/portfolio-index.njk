      padding: 1.2rem;
    }
    [data-bs-theme="dark"] .portfolio-mobile-path {
      background: var(--bs-body-bg);
      border-bottom-color: rgba(255, 255, 255, 0.12);
    }
    [data-bs-theme="dark"] .portfolio-mobile-path a,
    [data-bs-theme="dark"] .portfolio-mobile-disclosure-summary {
      background: rgba(158, 197, 248, 0.1);
      border-color: rgba(158, 197, 248, 0.24);
      color: #d6e8ff;
    }
  }
</style>

<script>
  (() => {
    const disclosures = Array.from(document.querySelectorAll('[data-portfolio-mobile-collapse]'));
    if (!disclosures.length) return;

    const mq = window.matchMedia('(max-width: 767.98px)');
    const syncPortfolioMobile = () => {
      disclosures.forEach((item) => {
        item.open = !mq.matches;
      });
    };

    document.querySelectorAll('.portfolio-mobile-path a[href^="#"]').forEach((link) => {
      link.addEventListener('click', () => {
        const target = document.querySelector(link.getAttribute('href'));
        if (target && target.matches('[data-portfolio-mobile-collapse]')) {
          target.open = true;
        }
      });
    });

    syncPortfolioMobile();
    mq.addEventListener?.('change', syncPortfolioMobile);
  })();
</script>
