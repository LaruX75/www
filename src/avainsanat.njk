---js
{
  layout: "base.njk",
  eleventyComputed: {
    title: data => `Avainsana: ${data.keyword?.name || ""}`,
    description: data => `Avainsana "${data.keyword?.name || ""}" kokoaa ${data.keyword?.count || 0} kirjoitusta, puhetta tai julkaisua Jari Larun sivustolta.`
  },
  pagination: {
    data: "collections.keywordList",
    size: 1,
    alias: "keyword",
    before: data => (process.env.BUILD_TAXONOMY_PAGES === "1" || process.env.BUILD_TAXONOMY_PAGES === "true" || process.env.CI === "true") ? data : []
  },
  permalink: (process.env.BUILD_TAXONOMY_PAGES === "1" || process.env.BUILD_TAXONOMY_PAGES === "true" || process.env.CI === "true") ? (data => `/avainsanat/${data.keyword.slug}/`) : false
}
---
<section>
  <div class="site-shell">
    <div class="d-flex align-items-center justify-content-between mb-3">
      <h1 class="h3 mb-0">{{ keyword.name }}</h1>
      <a class="btn btn-outline-primary btn-sm" href="/avainsanat/">Kaikki avainsanat</a>
    </div>
    <p class="text-muted">Yhteensä {{ keyword.count }} artikkelia.</p>

    <div class="row g-4">
      {% for item in keyword.items %}
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 content-card">
            {% if item.data.thumbnail %}
              <img src="{{ item.data.thumbnail }}" class="card-img-top content-card-img" alt="{{ item.data.title }}">
            {% endif %}
            <div class="card-body">
              <h3 class="h6">
                <a href="{{ item.url }}" class="text-decoration-none">{{ item.data.title }}</a>
              </h3>
              <p class="text-muted small mb-2">{{ item.date | dateFormat }}</p>
              <p class="text-muted">{{ item.data.description or (item.content | excerpt) }}</p>
              {% if item.data.categories %}
                <div class="mt-2">
                  {% for cat in item.data.categories %}
                    <a class="badge text-bg-secondary me-1 text-decoration-none" href="/kategoriat/{{ cat | slugify }}/">{{ cat }}</a>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
