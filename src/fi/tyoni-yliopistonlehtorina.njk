---
title: Työni yliopistonlehtorina
layout: base.njk
permalink: /tyoni-yliopistonlehtorina/
translationKey: university_lecturer_work
subtitle: Opetus, tutkimus ja yhteiskunnallinen vaikuttaminen
description: Yliopistonlehtorin työssäni yhdistyvät opetus, tutkimus ja yhteiskunnallinen vuorovaikutus.
templateEngineOverride: njk
---

{%- set peerReviewedCount = 0 -%}
{%- for pub in researchfi -%}
  {%- if pub.peerReviewed -%}{%- set peerReviewedCount = peerReviewedCount + 1 -%}{%- endif -%}
{%- endfor -%}
{% set expertOpinionItems = [] %}
{% for item in (collections.pub_mielipide or []) %}
  {% set roles = item.data.opinionRoles or item.data.writingRoles or [] %}
  {% if roles.indexOf("expert") != -1 %}
    {% set _ = (expertOpinionItems.push(item), null) %}
  {% endif %}
{% endfor %}
{% set statementItems = [] %}
{% for item in (collections.publications or []) %}
  {% if item.data.type == "lausunto" %}
    {% set _ = (statementItems.push(item), null) %}
  {% endif %}
{% endfor %}
{% set latestExpertOpinions = expertOpinionItems.slice(0, 1) %}
{% set latestStatements = statementItems.slice(0, 3) %}
{% set featuredStatement = latestStatements[0] %}
{% set supportingStatements = latestStatements.slice(1, 3) %}
{% set latestWorkPresentations = (collections.presentations or []).slice(0, 1) %}
{% set curatedWorkPresentations = [
  {
    title: "ITK-avauksen tallenne: Työkalu? Taikakalu?",
    url: "https://www.youtube.com/watch?v=0cJ0Ed3Scs4&t=5s",
    thumbnail: "https://i.ytimg.com/vi/0cJ0Ed3Scs4/hqdefault.jpg",
    date: "2026-04-26",
    typeLabel: "Keynote / videotallenne",
    description: "Avauspuheenvuoro ITK 2026 -tapahtumassa tekoälyn roolista työssä, koulussa ja kotona.",
    external: true
  }
] %}
{% set workPresentationItems = [] %}
{% for item in curatedWorkPresentations %}
  {% set _ = (workPresentationItems.push(item), null) %}
{% endfor %}
{% for item in (collections.presentations or []).slice(0, 4) %}
  {% set _ = (workPresentationItems.push({
    title: item.data.title,
    url: item.data.url or item.url,
    date: item.data.date,
    typeLabel: item.data.source or "Esitys",
    description: item.data.description or (item.templateContent | excerpt),
    external: item.data.url and "http" in item.data.url
  }), null) %}
{% endfor %}
{% set latestWorkPresentations = (workPresentationItems | sort(attribute="date", reverse=true)).slice(0, 2) %}
{% set latestWorkPublications = (researchfi or []).slice(0, 1) %}

{% set workCopy = {
  heroLead: "Opetan tulevia opettajia, ohjaan opinnäytteitä ja kehitän opetusta tutkimuksen rinnalla. Teknologia ei ole itsetarkoitus vaan keino tehdä oppimisesta ja opetuksesta parempaa.",
  heroBody: "Opetan luokanopettajakoulutuksessa digipedagogiikkaa, ohjelmoinnillista ajattelua ja tekoälylukutaitoa. Samalla kehitän opetusta käytännössä. Tavoitteeni on tehdä vaikeistakin asioista opettajalle käyttökelpoisia ja opiskelijalle ymmärrettäviä.",
  evidenceLead: "Työstäni kertovat julkaisut, ohjatut opinnäytteet, kehittämishankkeet ja avoimet materiaalit. Yhtä lailla siitä kertoo opiskelijoiden ja kollegoiden luottamus.",
  teachingBody: "Opetan teknologiatuettua oppimista, digipedagogiikkaa ja tekoälykasvatusta erityisesti luokanopettajakoulutuksessa. Haluan, että teoria muuttuu opetuksessa käytännöksi eikä jää pelkäksi käsitteeksi.",
  teachingPoints: [
    "luokanopettajakoulutus ja opettajankoulutuksen arki",
    "digipedagogiikka, ohjelmoinnillinen ajattelu ja tekoälykasvatus",
    "selkeä rakenne, käytännönläheinen ohjaus ja hyvä rytmi opetuksessa"
  ],
  researchBody: "Tutkin, miten teknologiaa kannattaa käyttää opetuksessa eri koulutusasteilla. Olen tutkinut opetusteknologiaa pitkään, ja nyt keskityn tekoälylukutaitoon ja yhteisölliseen oppimiseen.",
  researchPoints: [
    "teknologiatuettu oppiminen ja opetus",
    "opettajien ja oppijoiden tekoälylukutaito",
    "pitkä tutkimus- ja julkaisuhistoria opetuksen kehittämisen tukena"
  ],
  outreachBody: "Yliopistotyö ei jää kampukselle. Vien tutkittua tietoa opettajille, kouluille, verkostoille ja valmisteluun: koulutuksissa, lausunnoissa, verkossa ja yhteistyöhankkeissa.",
  outreachPoints: [
    "koulutukset, puheenvuorot ja avoimet materiaalit",
    "verkostotyö opettajien, koulujen ja hankkeiden kanssa",
    "lausunnot ja valmistelun kommentointi opetuksen, tekoälyn ja koulutuksen näkökulmasta"
  ],
  projectBody: "Generation AI -hankkeessa toimin vuorovaikutusasiantuntijana. Yhdistän työssäni tutkimusta, opettajankoulutusta ja käytännön sovelluksia. Tutkin opettajien tekoälylukutaitoa, jäsennän hankkeen sisältöjä sekä rakennan ja ylläpidän sen verkkosivuja.",
  projectPoints: [
    "tutkimus, opettajankoulutus ja käytännön sovellukset rinnakkain",
    "tekoälylukutaito opettajien ja koulutuksen näkökulmasta",
    "sisältöjen, sovellusten ja verkkosivujen kehittäminen"
  ],
  trustLead: "Opetustyöstä kertovat kurssien ja ohjauksen lisäksi palkinnot ja opiskelijoiden palaute.",
  awardsBody: "Tunnustukset ovat kertyneet vuosien varrella, eivät yhdestä tempusta.",
  feedbackBody: "Opiskelijapalautteessa toistuvat selkeys, kannustava ote ja se, että vaikeatkin asiat on jäsennetty käytännönläheisesti. Se on minulle opetustyön parasta palautetta.",
  archiveLead: "Alta pääset suoraan tutkimukseen, julkaisuihin, ohjattuihin opinnäytteisiin, opetusportfolioon, ansioluetteloon sekä palkintoihin ja palautteeseen."
} %}

<section class="ylwork-hero mb-0">
  <div class="ylwork-shell py-5">
    <div class="row g-5 align-items-stretch">
      <div class="col-lg-7">
        <p class="ylwork-eyebrow mb-2"><i class="bi bi-mortarboard-fill me-1"></i>Yliopistotyö</p>
        <h1 class="ylwork-hero-title mb-3">Työni yliopistonlehtorina yhdistää opetuksen, tutkimuksen ja kehittämisen</h1>
        <p class="ylwork-hero-manifesto mb-3">Teknologia on minulle opetuksessa väline, ei päämäärä. Tärkeintä on, mitä se saa aikaan oppimisessa ja opetuksessa.</p>
        <p class="ylwork-hero-text mb-4">{{ workCopy.heroLead }}</p>
        <div class="ylwork-hero-points mb-4">
          <div class="ylwork-hero-point">
            <span class="ylwork-hero-point-title">Opetus</span>
            <span class="ylwork-hero-point-text">Luokanopettajakoulutuksesta käytännön digipedagogiikkaan ja tekoälykasvatukseen.</span>
          </div>
          <div class="ylwork-hero-point">
            <span class="ylwork-hero-point-title">Tutkimus</span>
            <span class="ylwork-hero-point-text">Pitkä tutkimuslinja opetusteknologiassa, nyt keskiössä tekoälylukutaito.</span>
          </div>
          <div class="ylwork-hero-point">
            <span class="ylwork-hero-point-title">Kehittäminen</span>
            <span class="ylwork-hero-point-text">Työ jatkuu hankkeissa, koulutuksissa, verkostoissa ja avoimissa materiaaleissa.</span>
          </div>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <a href="#painopisteet" class="btn ylwork-hero-btn-primary">Työn ydinalueet</a>
          <a href="#aineisto" class="btn ylwork-hero-btn-outline">Syvemmälle aineistoon</a>
        </div>
      </div>
      <div class="col-lg-5">
        <aside class="ylwork-hero-card h-100">
          <figure class="ylwork-hero-image">
            <img src="/img/uploads/2026/07/jari-laru-yliopistonlehtorina-hero.jpg" alt="Jari Laru auditorion edessä koulutusyleisön kanssa" loading="eager" decoding="async">
          </figure>
          <div class="ylwork-hero-side">
            <p class="ylwork-hero-side-kicker">Nykyinen tehtävä</p>
            <p class="ylwork-hero-caption">Teknologiatuetun oppimisen ja opetuksen yliopistonlehtori, Kasvatustieteiden tiedekunta, Oulun yliopisto.</p>
            <dl class="ylwork-hero-facts mb-0">
              <div>
                <dt>Työn ydin</dt>
                <dd>Opetus, tutkimus, ohjaus ja käytännön kehittäminen.</dd>
              </div>
              <div>
                <dt>Kohderyhmä</dt>
                <dd>Tulevat opettajat, opettajat, tutkijat, koulut ja kehittämisverkostot.</dd>
              </div>
              <div>
                <dt>Juuri nyt</dt>
                <dd>Tekoälylukutaito, opettajankoulutus ja tutkimustiedon vieminen käytäntöön.</dd>
              </div>
            </dl>
          </div>
        </aside>
      </div>
    </div>
  </div>
</section>
<div class="ylwork-hero-divider"></div>

<section class="ylwork-section ylwork-section--stats" id="naytto">
  <div class="ylwork-shell">
    <div class="ylwork-section-head">
      <p class="ylwork-eyebrow ylwork-eyebrow--dark mb-1"><i class="bi bi-bar-chart-line-fill me-1"></i>Näyttö työstä</p>
      <h2 class="ylwork-section-title">Tuloksia sekä määrässä että laadussa</h2>
      <p class="ylwork-section-lead mb-0">{{ workCopy.evidenceLead }}</p>
    </div>
    <div class="ylwork-kpi-grid">
      <article class="site-kpi-card">
        <span class="site-kpi-number">{{ researchfi.length }}</span>
        <span class="site-kpi-label">julkaisua</span>
      </article>
      <article class="site-kpi-card">
        <span class="site-kpi-number">{{ peerReviewedCount }}</span>
        <span class="site-kpi-label">vertaisarvioitua</span>
      </article>
      <article class="site-kpi-card">
        <span class="site-kpi-number">{{ theses.stats.totalGradut }}</span>
        <span class="site-kpi-label">gradua ohjattu</span>
      </article>
      <article class="site-kpi-card">
        <span class="site-kpi-number">{{ theses.stats.totalKandit }}</span>
        <span class="site-kpi-label">kandia ohjattu</span>
      </article>
    </div>
  </div>
</section>

<section class="ylwork-section bg-body-tertiary" id="painopisteet">
  <div class="ylwork-shell">
    <div class="ylwork-section-head">
      <p class="ylwork-eyebrow ylwork-eyebrow--dark mb-1"><i class="bi bi-bullseye me-1"></i>Työn ydinalueet</p>
      <h2 class="ylwork-section-title">Kolme aluetta, joiden varassa työni on</h2>
      <p class="ylwork-section-lead mb-0">{{ workCopy.heroBody }}</p>
    </div>
    <div class="ylwork-focus-grid">
      <article class="ylwork-focus-card">
        <div class="ylwork-focus-head">
          <span class="ylwork-focus-icon" style="color:#0d6efd"><i class="bi bi-easel2-fill"></i></span>
          <h3 class="ylwork-focus-title">Opetus</h3>
        </div>
        <p class="ylwork-focus-text">{{ workCopy.teachingBody }}</p>
        <ul class="ylwork-focus-list">
          {% for point in workCopy.teachingPoints %}
          <li>{{ point }}</li>
          {% endfor %}
        </ul>
        <a href="/portfolio/" class="ylwork-card-link">Opetusportfolio <span aria-hidden="true">→</span></a>
      </article>
      <article class="ylwork-focus-card">
        <div class="ylwork-focus-head">
          <span class="ylwork-focus-icon" style="color:#198754"><i class="bi bi-search"></i></span>
          <h3 class="ylwork-focus-title">Tutkimus</h3>
        </div>
        <p class="ylwork-focus-text">{{ workCopy.researchBody }}</p>
        <ul class="ylwork-focus-list">
          {% for point in workCopy.researchPoints %}
          <li>{{ point }}</li>
          {% endfor %}
        </ul>
        <a href="/tutkimus/" class="ylwork-card-link">Tutkimussivulle <span aria-hidden="true">→</span></a>
      </article>
      <article class="ylwork-focus-card">
        <div class="ylwork-focus-head">
          <span class="ylwork-focus-icon" style="color:#fd7e14"><i class="bi bi-megaphone-fill"></i></span>
          <h3 class="ylwork-focus-title">Kehittäminen ja vuorovaikutus</h3>
        </div>
        <p class="ylwork-focus-text">{{ workCopy.outreachBody }}</p>
        <ul class="ylwork-focus-list">
          {% for point in workCopy.outreachPoints %}
          <li>{{ point }}</li>
          {% endfor %}
        </ul>
        <a href="/esitykset/" class="ylwork-card-link">Esityksiin ja materiaaleihin <span aria-hidden="true">→</span></a>
      </article>
    </div>
  </div>
</section>

<section class="ylwork-section" id="generation-ai">
  <div class="ylwork-shell">
    <div class="ylwork-section-head">
      <p class="ylwork-eyebrow ylwork-eyebrow--dark mb-1"><i class="bi bi-lightning-charge-fill me-1"></i>Ajankohtaista</p>
      <h2 class="ylwork-section-title">Tekoälykasvatus on nyt työni keskiössä</h2>
      <p class="ylwork-section-lead mb-0">Generation AI -hankkeessa tehdään yhtä aikaa tutkimusta, opettajankoulutusta ja käytännön kehittämistä. Juuri sitä työni yliopistossa nyt on.</p>
    </div>
    <div class="ylwork-project-layout">
      <article class="ylwork-project-card ylwork-project-card--primary">
        <span class="ylwork-project-badge">Generation AI</span>
        <p class="ylwork-project-text">{{ workCopy.projectBody }}</p>
        <ul class="ylwork-focus-list ylwork-focus-list--project">
          {% for point in workCopy.projectPoints %}
          <li>{{ point }}</li>
          {% endfor %}
        </ul>
        <div class="d-flex flex-wrap gap-2 mt-3">
          <a href="https://generation-ai-stn.fi/" target="_blank" rel="noopener" class="btn btn-outline-primary btn-sm">Hankkeen sivu <i class="bi bi-box-arrow-up-right ms-1" aria-hidden="true"></i></a>
          <a href="https://generation-ai-stn.fi/tutkijalle/" target="_blank" rel="noopener" class="btn btn-outline-primary btn-sm">Tutkijalle <i class="bi bi-box-arrow-up-right ms-1" aria-hidden="true"></i></a>
          <a href="https://generation-ai-stn.fi/opettajalle/" target="_blank" rel="noopener" class="btn btn-outline-primary btn-sm">Opettajalle <i class="bi bi-box-arrow-up-right ms-1" aria-hidden="true"></i></a>
          <a href="https://www.gen-ai.fi/fi" target="_blank" rel="noopener" class="btn btn-outline-primary btn-sm">Sovellukset <i class="bi bi-box-arrow-up-right ms-1" aria-hidden="true"></i></a>
        </div>
      </article>
      <div class="ylwork-project-side">
        <article class="ylwork-project-card">
          <span class="ylwork-project-badge ylwork-project-badge--muted">Opettajankoulutus</span>
          <h3 class="ylwork-project-title">Tekoäly ei ole erillinen lisä vaan osa opettajan työtä</h3>
          <p class="ylwork-project-text mb-0">Keskityn nyt siihen, miten tekoälylukutaidosta tulee osa opettajan ammattitaitoa ja arjen ratkaisuja.</p>
        </article>
        <article class="ylwork-project-card">
          <span class="ylwork-project-badge ylwork-project-badge--muted">Käytännön kehittäminen</span>
          <h3 class="ylwork-project-title">Teen myös materiaaleja, verkkosisältöjä ja käytännön välineitä</h3>
          <p class="ylwork-project-text mb-0">Tutkimuksen ja opetuksen lisäksi rakennan verkkosivuja, materiaaleja ja välineitä, jotka on tarkoitettu oikeille käyttäjille.</p>
        </article>
      </div>
    </div>
  </div>
</section>

<section class="ylwork-section bg-body-tertiary" id="ajankohtaista-tyosta">
  <div class="ylwork-shell">
    <div class="ylwork-section-head">
      <p class="ylwork-eyebrow ylwork-eyebrow--dark mb-1"><i class="bi bi-journal-richtext me-1"></i>Ajankohtaista asiantuntijatyöstä</p>
      <h2 class="ylwork-section-title">Lausunnot, opetusmateriaalit ja tutkimus samassa työjäljessä</h2>
      <p class="ylwork-section-lead mb-0">Tässä näkyvät tuoreimmat nostot niistä aineistoista, joissa yliopistotyö kääntyy valmistelun tueksi, opetuksen käytännöiksi ja tutkimusjulkaisuiksi.</p>
    </div>
    <div class="ylwork-live-stack">
      <div class="ylwork-live-layout">
        <article class="ylwork-live-card ylwork-live-card--primary">
          <div class="ylwork-live-head">
            <p class="ylwork-trust-kicker">Asiantuntijatyö</p>
            <h3 class="ylwork-live-title">Asiantuntijalausunnot</h3>
            <p class="ylwork-live-lead">Tässä näkyy suorin reitti siitä, miten tutkimus, opettajankoulutus ja käytännön kehittäminen kääntyvät kannoiksi opetuksesta, tekoälystä ja koulutuksen toimeenpanosta.</p>
          </div>
          {% if featuredStatement %}
          <article class="ylwork-live-feature">
            <div class="ylwork-live-meta">
              <span class="ylwork-live-type">Lausunto</span>
              <span class="ylwork-live-date">{{ featuredStatement.date | dateFormat }}</span>
            </div>
            <h4 class="ylwork-live-feature-title"><a href="{{ featuredStatement.data.url or featuredStatement.url }}">{{ featuredStatement.data.title }}</a></h4>
            <p class="ylwork-live-feature-summary mb-0">{{ featuredStatement.data.description or (featuredStatement.templateContent | excerpt) }}</p>
          </article>
          {% endif %}
          {% if supportingStatements.length %}
          <div class="ylwork-live-list ylwork-live-list--supporting">
            {% for item in supportingStatements %}
            <article class="ylwork-live-item">
              <div class="ylwork-live-meta">
                <span class="ylwork-live-type">Lausunto</span>
                <span class="ylwork-live-date">{{ item.date | dateFormat }}</span>
              </div>
              <h4 class="ylwork-live-item-title"><a href="{{ item.data.url or item.url }}">{{ item.data.title }}</a></h4>
              <p class="ylwork-live-summary mb-0">{{ item.data.description or (item.templateContent | excerpt) }}</p>
            </article>
            {% endfor %}
          </div>
          {% endif %}
          <a href="/kynasta/#lausunnot" class="ylwork-card-link">Kaikki lausunnot <span aria-hidden="true">→</span></a>
        </article>

        <div class="ylwork-live-side">
          <article class="ylwork-live-card ylwork-live-card--compact">
            <div class="ylwork-live-head">
              <p class="ylwork-trust-kicker">Opetus ja koulutukset</p>
              <h3 class="ylwork-live-title">Tuoreimmat esitykset ja materiaalit</h3>
              <p class="ylwork-live-lead">Koulutuksia, luentoja ja avoimia materiaaleja, joissa tutkimus muuttuu käytännöksi.</p>
            </div>
            <div class="ylwork-live-list">
              {% for item in latestWorkPresentations %}
              <article class="ylwork-live-item">
                <div class="ylwork-live-meta">
                  <span class="ylwork-live-type">{{ item.typeLabel or "Esitys" }}</span>
                  <span class="ylwork-live-date">{{ item.date | dateFormat }}</span>
                </div>
                <h4 class="ylwork-live-item-title"><a href="{{ item.url }}"{% if item.external %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ item.title }}</a></h4>
                <p class="ylwork-live-summary mb-0">{{ item.description }}</p>
              </article>
              {% endfor %}
            </div>
            <a href="/esitykset/" class="ylwork-card-link">Kaikki esitykset ja materiaalit <span aria-hidden="true">→</span></a>
          </article>

          <article class="ylwork-live-card ylwork-live-card--compact ylwork-live-card--muted">
            <div class="ylwork-live-head">
              <p class="ylwork-trust-kicker">Tutkimus</p>
              <h3 class="ylwork-live-title">Tuore tutkimusnäyttö</h3>
              <p class="ylwork-live-lead">Viimeisimmät julkaisut näyttävät, mihin tutkimus juuri nyt suuntautuu.</p>
            </div>
            <div class="ylwork-live-list">
              {% for pub in latestWorkPublications %}
              <article class="ylwork-live-item">
                <div class="ylwork-live-meta">
                  <span class="ylwork-live-type">{{ pub.typeShort or "Julkaisu" }}</span>
                  <span class="ylwork-live-date">{{ pub.year or "" }}</span>
                </div>
                <h4 class="ylwork-live-item-title">
                  {% if pub.url %}
                  <a href="{{ pub.url }}" target="_blank" rel="noopener noreferrer">{{ pub.title }}</a>
                  {% else %}
                  {{ pub.title }}
                  {% endif %}
                </h4>
                <p class="ylwork-live-summary mb-0">{% if pub.journal %}{{ pub.journal }}{% elseif pub.publisher %}{{ pub.publisher }}{% else %}Julkaisu tutkimusprofiilista.{% endif %}</p>
              </article>
              {% endfor %}
            </div>
            <a href="/julkaisut/" class="ylwork-card-link">Kaikki julkaisut <span aria-hidden="true">→</span></a>
          </article>

        </div>

        <article class="ylwork-live-card ylwork-live-card--support">
          <div class="ylwork-live-head">
            <p class="ylwork-trust-kicker">Kirjoitukset</p>
            <h3 class="ylwork-live-title">Asiantuntijamielipiteet</h3>
            <p class="ylwork-live-lead">Kirjoitukset täydentävät lausuntoja silloin, kun koulutuksen, teknologian tai opetuksen kehittämisen taustaa pitää avata laajemmin.</p>
          </div>
          <div class="ylwork-live-list">
            {% for item in latestExpertOpinions %}
            <article class="ylwork-live-item">
              <div class="ylwork-live-meta">
                <span class="ylwork-live-type">Mielipide</span>
                <span class="ylwork-live-date">{{ item.date | dateFormat }}</span>
              </div>
              <h4 class="ylwork-live-item-title"><a href="{{ item.url }}">{{ item.data.title }}</a></h4>
              <p class="ylwork-live-summary mb-0">{{ item.data.description or (item.templateContent | excerpt) }}</p>
            </article>
            {% endfor %}
          </div>
          <a href="/kynasta/?opinions=expert#mielipiteet" class="ylwork-card-link">Kaikki asiantuntijamielipiteet <span aria-hidden="true">→</span></a>
        </article>
      </div>
    </div>
  </div>
</section>

<section class="ylwork-section bg-body-tertiary" id="tunnustukset">
  <div class="ylwork-shell">
    <div class="ylwork-section-head">
      <p class="ylwork-eyebrow ylwork-eyebrow--dark mb-1"><i class="bi bi-patch-check-fill me-1"></i>Tunnustukset ja palaute</p>
      <h2 class="ylwork-section-title">Tehdystä työstä kertovat hyvä palaute ja palkinnot</h2>
      <p class="ylwork-section-lead mb-0">{{ workCopy.trustLead }}</p>
    </div>
