  .media-archive-card p,
  .media-role-card p {
    margin: 0;
    color: var(--bs-secondary-color);
    line-height: 1.58;
  }

  .media-feature-primary-body {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .media-feature-side {
    display: grid;
    gap: 0.85rem;
  }

  .media-feature-small {
    display: grid;
    grid-template-columns: 8.5rem minmax(0, 1fr);
    overflow: hidden;
  }

  .media-feature-small-body {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.5rem;
  }

  .media-thumb {
    position: relative;
    display: block;
    overflow: hidden;
    width: 100%;
