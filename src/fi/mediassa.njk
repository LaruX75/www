    text-transform: uppercase;
  }

  .media-meta-row--small span {
    font-size: 0.68rem;
  }

  .media-browser {
    border: 1px solid var(--bs-border-color);
    border-radius: 1.6rem;
    background: var(--bs-body-bg);
    padding: clamp(1rem, 2.5vw, 1.5rem);
    box-shadow: 0 1rem 2.4rem rgba(19, 43, 70, 0.07);
  }

  .media-filter-group {
    margin-bottom: 0.75rem;
  }

  .media-filter-group--secondary {
    margin-bottom: 1.1rem;
  }

  .media-filter {
    padding: 0.54rem 0.85rem;
    cursor: pointer;
  }

  .media-filter.is-active {
    color: var(--bs-body-bg);
    background: var(--bs-body-color);
    border-color: var(--bs-body-color);
  }

  .media-card-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .media-archive-card {
    display: grid;
    grid-template-rows: auto 1fr;
    overflow: hidden;
  }

  .media-archive-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .media-archive-card .media-card-actions {
    margin-top: auto;
    padding-top: 0.35rem;
  }

  .media-topic-row span {
    padding: 0.32rem 0.6rem;
    font-size: 0.75rem;
  }

  .media-pagination {
    border-top: 1px solid rgba(120, 130, 150, 0.18);
  }

  .media-role-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .media-role-card {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    gap: 0.7rem;
  }

  .media-role-number {
    color: var(--bs-secondary-color);
    font-family: 'Bree Serif', serif;
    font-size: clamp(2.3rem, 4vw, 3.7rem);
    line-height: 0.9;
  }

  .media-role-link {
    align-self: flex-start;
    margin-top: auto;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--bs-link-color);
    font-weight: 800;
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .media-source-band {
    grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.65fr);
    align-items: center;
  }

  .media-source-stats span {
    padding: 0.55rem 0.8rem;
    font-size: 0.9rem;
  }

  .media-source-stats strong {
    margin-right: 0.25rem;
    color: var(--bs-body-color);
  }

  [data-bs-theme="dark"] .media-hero {
    background:
      radial-gradient(circle at 8% 0%, rgba(102, 163, 255, 0.14), transparent 34%),
      linear-gradient(180deg, rgba(17, 27, 42, 0.98), rgba(8, 9, 17, 0.98));
  }

  [data-bs-theme="dark"] .media-feature-primary,
  [data-bs-theme="dark"] .media-feature-small,
  [data-bs-theme="dark"] .media-archive-card,
  [data-bs-theme="dark"] .media-browser,
  [data-bs-theme="dark"] .media-role-card,
  [data-bs-theme="dark"] .media-source-band,
  [data-bs-theme="dark"] .media-hero-panel {
    background: rgba(24, 36, 54, 0.94);
    box-shadow: 0 1rem 2.6rem rgba(0, 0, 0, 0.24);
  }

  [data-bs-theme="dark"] .media-meta-row span,
  [data-bs-theme="dark"] .media-topic-row span,
  [data-bs-theme="dark"] .media-filter,
  [data-bs-theme="dark"] .media-source-stats span {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(255, 255, 255, 0.14);
    color: rgba(255, 255, 255, 0.76);
  }

  [data-bs-theme="dark"] .media-filter.is-active {
    color: #111827;
    background: #f8fbff;
    border-color: #f8fbff;
  }

  @media (max-width: 991.98px) {
    .media-hero-layout,
    .media-feature-grid,
    .media-source-band {
      grid-template-columns: 1fr;
    }

    .media-card-grid,
    .media-role-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 767.98px) {
    .media-mobile-path {
      position: sticky;
      top: 0;
      z-index: 12;
      display: flex;
      gap: 0.55rem;
      overflow-x: auto;
      padding: 0.75rem max(0.75rem, env(safe-area-inset-left));
      background: rgba(255, 255, 255, 0.92);
      border-bottom: 1px solid rgba(16, 40, 69, 0.1);
      backdrop-filter: blur(14px);
      -webkit-overflow-scrolling: touch;
    }

    .media-mobile-path::-webkit-scrollbar {
      display: none;
    }

    .media-mobile-path a {
      flex: 0 0 auto;
      padding: 0.48rem 0.8rem;
      border-radius: 999px;
      border: 1px solid rgba(16, 40, 69, 0.12);
      background: rgba(255, 255, 255, 0.78);
      color: #102845;
      font-size: 0.82rem;
      font-weight: 800;
      text-decoration: none;
    }

    .media-card-grid,
    .media-role-grid,
    .media-feature-small {
      grid-template-columns: 1fr;
    }

    .media-feature-small .media-thumb,
    .media-feature-small-thumb {
      border-radius: 1.55rem 1.55rem 0 0;
    }

    .media-filter-group {
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: 0.25rem;
      -webkit-overflow-scrolling: touch;
    }

    .media-filter-group::-webkit-scrollbar {
      display: none;
    }

    .media-filter {
      flex: 0 0 auto;
      white-space: nowrap;
    }

    [data-bs-theme="dark"] .media-mobile-path {
      background: rgba(13, 18, 28, 0.88);
      border-bottom-color: rgba(255, 255, 255, 0.1);
    }

    [data-bs-theme="dark"] .media-mobile-path a {
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(255, 255, 255, 0.14);
      color: #f8fbff;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const browser = document.querySelector('[data-media-browser]');
    if (!browser) return;

    const items = Array.from(browser.querySelectorAll('[data-media-card]'));
    const controls = Array.from(browser.querySelectorAll('[data-media-filter]'));
    const jumpControls = Array.from(document.querySelectorAll('[data-media-jump-filter]'));
    const pagination = browser.querySelector('[data-media-page-controls]');
    const pageInfo = browser.querySelector('[data-media-page-info]');
    const status = browser.querySelector('[data-media-browser-status]');
    const pageSize = Number(browser.dataset.pageSize) || 9;
    let activeFilter = 'all';
    let currentPage = 1;

    const topicAliases = {
      politiikka: ['politiikka', 'kuntapolitiikka', 'valtuusto', 'vaalit', 'päätöksenteko', 'paatoksenteko', 'kampusratkaisu', 'palveluverkko'],
      tekoaly: ['tekoäly', 'tekoaly', 'tekoälylukutaito', 'tekoalylukutaito', 'chatgpt', 'generation ai', 'koulutusteknologia', 'digipedagogiikka', 'opetus'],
      avoin: ['avoin tiede', 'avoimuus', 'avoin oppiminen', 'avoimet oppimateriaalit'],
      paikallinen: ['oulu', 'jääli', 'jaali', 'kiiminki', 'rantapohja', 'munoulu', 'kaupunginosa', 'paikallisuus', 'asukas']
    };

    const matchesFilter = (item) => {
      if (activeFilter === 'all') return true;
      const [kind, value] = activeFilter.split(':');
      if (kind === 'type') return item.dataset.mediaType === value;
      if (kind === 'role') return item.dataset.mediaRole === value;
      if (kind === 'topic') {
        const haystack = item.dataset.mediaTopics || '';
        return (topicAliases[value] || [value]).some((needle) => haystack.includes(needle));
      }
      return true;
    };

    const filteredItems = () => items.filter(matchesFilter);

    const updateControls = () => {
      controls.forEach((control) => {
        const isActive = control.dataset.mediaFilter === activeFilter;
        control.classList.toggle('is-active', isActive);
        control.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      });
    };

    const renderPagination = (pageCount) => {
      if (!pagination) return;
      pagination.innerHTML = '';
      if (pageCount <= 1) return;

      for (let page = 1; page <= pageCount; page += 1) {
        const li = document.createElement('li');
        li.className = `page-item${page === currentPage ? ' active' : ''}`;
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'page-link';
        button.dataset.mediaPage = String(page);
        button.setAttribute('aria-label', `Sivu ${page}`);
        button.textContent = String(page);
        li.appendChild(button);
        pagination.appendChild(li);
      }
    };

    const render = () => {
      const visibleItems = filteredItems();
      const pageCount = Math.max(1, Math.ceil(visibleItems.length / pageSize));
      currentPage = Math.min(currentPage, pageCount);
      const start = (currentPage - 1) * pageSize;
      const end = start + pageSize;
      const pageItems = new Set(visibleItems.slice(start, end));

      items.forEach((item) => {
        item.hidden = !pageItems.has(item);
      });

      const shownStart = visibleItems.length ? start + 1 : 0;
      const shownEnd = Math.min(end, visibleItems.length);
      if (status) {
        status.textContent = visibleItems.length === 1
          ? 'Löytyi 1 mediaosuma.'
          : `Löytyi ${visibleItems.length} mediaosumaa.`;
      }
      if (pageInfo) {
        pageInfo.textContent = visibleItems.length
          ? `Näytetään ${shownStart}-${shownEnd} / ${visibleItems.length}`
          : 'Tällä suodattimella ei löytynyt mediaosumia.';
      }

      updateControls();
      renderPagination(pageCount);
    };

    const setFilter = (filter, shouldScroll = false) => {
      activeFilter = filter || 'all';
      currentPage = 1;
      render();
      if (shouldScroll) {
        document.getElementById('media-arkisto')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    };

    const filterFromUrl = () => {
      const params = new URLSearchParams(window.location.search);
      const type = params.get('type');
      const role = params.get('role');
      const topic = params.get('topic');
      if (type) return `type:${type}`;
      if (role) return `role:${role}`;
      if (topic) return `topic:${topic}`;
      return 'all';
    };

    controls.forEach((control) => {
      control.setAttribute('aria-pressed', control.classList.contains('is-active') ? 'true' : 'false');
      control.addEventListener('click', () => setFilter(control.dataset.mediaFilter));
    });

    jumpControls.forEach((control) => {
      control.addEventListener('click', () => setFilter(control.dataset.mediaJumpFilter, true));
    });

    pagination?.addEventListener('click', (event) => {
      const button = event.target.closest('[data-media-page]');
      if (!button) return;
      const nextPage = Number(button.dataset.mediaPage);
      if (!Number.isFinite(nextPage) || nextPage === currentPage) return;
      currentPage = nextPage;
      render();
    });

    setFilter(filterFromUrl(), window.location.search.length > 0);
  });
</script>
