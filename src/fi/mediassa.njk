---
layout: base.njk
title: Mediassa
description: "Podcastit, haastattelut, lehtijutut ja muut mediaesiintymiset samassa näkymässä."
permalink: /mediassa/
lang: fi
translationKey: media_index
---

{% set mediaAbout = mediaArchive.about or [] %}
{% set mediaGuest = mediaArchive.guest or [] %}
{% set mediaInterviewer = mediaArchive.interviewer or [] %}
{% set mediaTotal = (mediaArchive.all or []) | length %}
{% set mediaHighlights = (mediaArchive.all or []).slice(0, 4) %}

{% macro mediaTypeLabel(type) %}
  {% if type == "podcast" %}Podcast
  {% elif type == "article" %}Lehtijuttu
  {% elif type == "tv" %}TV
  {% elif type == "radio" %}Radio
  {% elif type == "video" %}Video
  {% else %}Media
  {% endif %}
{% endmacro %}

{% macro roleHeading(role) %}
  {% if role == "about" %}Mediassa minusta
  {% elif role == "interviewer" %}Haastattelijana
  {% elif role == "guest" %}Vieraana ja keskustelijana
  {% else %}Mediassa
  {% endif %}
{% endmacro %}

{% macro roleLabel(role) %}
  {% if role == "about" %}Minusta tehty
  {% elif role == "interviewer" %}Haastattelijana
  {% elif role == "guest" %}Vieraana
  {% else %}Media
  {% endif %}
{% endmacro %}

{% macro renderMediaSection(items, role, lead) %}
{% set isPaginated = role == "about" %}
<section class="py-4 py-lg-5" id="media-{{ role }}">
  <div class="site-shell">
    <details class="media-mobile-disclosure" data-media-mobile-collapse{% if role == "about" %} data-media-mobile-default-open{% endif %} open>
      <summary class="media-mobile-disclosure-summary">
        <span>{{ roleHeading(role) }}</span>
        <small>{{ items | length }} osumaa</small>
      </summary>
      <div class="media-mobile-disclosure-body">
    <div class="card shadow-sm section-card border-0"{% if isPaginated %} data-media-pagination data-page-size="4"{% endif %}>
      <div class="card-header bg-transparent py-3 border-0">
        <div class="d-flex flex-wrap align-items-start justify-content-between gap-3">
          <div>
            <p class="text-uppercase text-muted fw-semibold small mb-1">{{ roleHeading(role) }}</p>
            <h2 class="h4 fw-bold mb-2">{{ roleHeading(role) }}</h2>
            <p class="text-muted mb-0">{{ lead }}</p>
          </div>
          <span class="badge rounded-pill border text-body-secondary media-count-badge">{{ items | length }}</span>
        </div>
      </div>
      <div class="card-body pt-0">
        {% if items.length %}
          <div class="media-entry-list"{% if isPaginated %} data-media-page-list{% endif %}>
            {% for item in items %}
            <article class="media-entry{% if not loop.last %} border-bottom{% endif %}"{% if isPaginated %} data-media-page-item{% endif %}>
              <div class="row g-4 align-items-start">
                <div class="col-lg-8">
                  <div class="d-flex flex-wrap gap-2 mb-2">
                    <span class="badge rounded-pill border text-body-secondary">{{ mediaTypeLabel(item.data.mediaType) }}</span>
                    {% if item.data.mediaOutlet %}
                    <span class="badge rounded-pill border text-body-secondary">{{ item.data.mediaOutlet }}</span>
                    {% endif %}
                  </div>
                  <h3 class="h5 fw-bold mb-2">
                    {% if item.data.sourceUrl %}
                    <a href="{{ item.data.sourceUrl }}" target="_blank" rel="noopener noreferrer" class="text-decoration-none">{{ item.data.title }}</a>
                    {% else %}
                    <a href="{{ item.url }}" class="text-decoration-none">{{ item.data.title }}</a>
                    {% endif %}
                  </h3>
                  {% if item.data.description %}
                  <p class="text-muted mb-3">{{ item.data.description }}</p>
                  {% endif %}
                  {% if item.data.categories %}
                  <div class="d-flex flex-wrap gap-2">
                    {% for category in item.data.categories %}
                    <span class="media-topic-chip">{{ category }}</span>
                    {% endfor %}
                  </div>
                  {% endif %}
                </div>
                <div class="col-lg-4">
                  <div class="media-side-card">
                    {% if item.data.thumbnail %}
                    <img src="{{ item.data.thumbnail }}" alt="{{ item.data.title }}" class="img-fluid rounded-4 media-entry-thumb" loading="lazy" decoding="async">
                    {% endif %}
                    <div class="d-grid gap-2{% if item.data.thumbnail %} mt-3{% endif %}">
                      {% if item.data.sourceUrl %}
                      <a href="{{ item.data.sourceUrl }}" target="_blank" rel="noopener noreferrer" class="btn btn-primary rounded-pill">Avaa lähde</a>
                      {% endif %}
                      <a href="{{ item.url }}" class="btn btn-outline-secondary rounded-pill">Arkistosivu</a>
                    </div>
                  </div>
                </div>
              </div>
            </article>
            {% endfor %}
          </div>
          {% if isPaginated and items.length > 4 %}
          <div class="media-pagination d-flex flex-wrap align-items-center justify-content-between gap-3 pt-3">
            <p class="media-pagination__info text-muted mb-0" data-media-page-info aria-live="polite"></p>
            <ul class="pagination pagination-sm mb-0 flex-wrap" data-media-page-controls aria-label="Sivutus: {{ roleHeading(role) }}"></ul>
          </div>
          {% endif %}
        {% else %}
          <div class="media-empty-state">
            <h3 class="h6 fw-bold mb-2">{{ roleHeading(role) }} täydentyy</h3>
            <p class="text-muted mb-0">Tähän ryhmään voidaan koota jatkossa podcasteja, haastatteluja, lehtijuttuja, televisiouutisia ja muita mediaosumia.</p>
          </div>
        {% endif %}
      </div>
    </div>
      </div>
    </details>
  </div>
</section>
{% endmacro %}

<section class="py-5 bg-body-tertiary border-bottom">
  <div class="site-shell">
    <div class="row g-4 align-items-center">
      <div class="col-lg-7">
        <p class="text-uppercase text-muted fw-semibold small mb-2">Mediaesiintymiset</p>
        <h1 class="display-6 fw-bold mb-3">Mediassa</h1>
        <p class="lead mb-3">Tähän kokonaisuuteen kuuluvat podcastit, haastattelut, lehtijutut, televisiouutiset ja muut sisällöt, joissa olen mukana julkisessa roolissa.</p>
        <p class="text-muted mb-0"><a href="/kynasta/">Kynästä</a> kokoaa oman kirjoittamisen. <a href="/esitykset/">Esitykset</a> kokoaa omat puheenvuorot, materiaalit ja tallenteet. Mediassa taas sisältöjä katsotaan roolin kautta: minusta tehtyinä, vieraana tai haastattelijana.</p>
      </div>
      <div class="col-lg-5">
        <aside class="card border-0 shadow-sm media-hero-card">
          <div class="card-body p-4 p-xl-5">
            <p class="text-uppercase text-muted fw-semibold small mb-3">Silmäys aineistoon</p>
            <dl class="home-hero-kpi-grid mb-0">
              <div class="home-hero-kpi">
                <dd class="home-hero-kpi-value">{{ mediaTotal }}</dd>
                <dt class="home-hero-kpi-label">mediaosumaa</dt>
              </div>
              <div class="home-hero-kpi">
                <dd class="home-hero-kpi-value">{{ mediaAbout | length }}</dd>
                <dt class="home-hero-kpi-label">minusta tehtyä</dt>
              </div>
              <div class="home-hero-kpi">
                <dd class="home-hero-kpi-value">{{ mediaGuest | length }}</dd>
                <dt class="home-hero-kpi-label">vieraana</dt>
              </div>
              <div class="home-hero-kpi">
                <dd class="home-hero-kpi-value">{{ mediaInterviewer | length }}</dd>
                <dt class="home-hero-kpi-label">haastattelijana</dt>
              </div>
            </dl>
          </div>
        </aside>
      </div>
    </div>
  </div>
</section>

<nav class="media-mobile-path" aria-label="Mediassa-sivun tärkeimmät osiot">
  <a href="#media-about">Minusta</a>
  <a href="#media-guest">Vieraana</a>
  <a href="#media-interviewer">Haastattelijana</a>
  <a href="#media-nostot">Nostot</a>
</nav>

<section class="py-4 py-lg-5" id="media-nostot" data-media-mobile-priority="2">
  <div class="site-shell">
    <details class="media-mobile-disclosure" data-media-mobile-collapse open>
      <summary class="media-mobile-disclosure-summary">
        <span>Keskeiset mediaosumat</span>
        <small>Nostot ja roolit yhdellä silmäyksellä</small>
      </summary>
      <div class="media-mobile-disclosure-body">
    <div class="mb-4">
      <p class="text-uppercase text-muted fw-semibold small mb-1">Nostot mediasta</p>
      <h2 class="h3 fw-bold mb-2">Keskeiset mediaosumat yhdellä silmäyksellä</h2>
      <p class="text-muted mb-0">Tähän on nostettu muutamia osumia, joista näkyy nopeasti millaisissa podcasteissa, haastatteluissa ja keskusteluissa olen ollut mukana.</p>
    </div>
    <div class="row g-4 mb-5">
      {% for item in mediaHighlights %}
      <div class="col-md-6">
        <article class="card border-0 shadow-sm h-100 media-highlight-card">
          <div class="card-body p-4 d-flex flex-column">
            <div class="d-flex flex-wrap gap-2 mb-2">
              <span class="badge rounded-pill border text-body-secondary">{{ roleLabel(item.data.mediaRole) }}</span>
              <span class="badge rounded-pill border text-body-secondary">{{ mediaTypeLabel(item.data.mediaType) }}</span>
              {% if item.data.mediaOutlet %}
              <span class="badge rounded-pill border text-body-secondary">{{ item.data.mediaOutlet }}</span>
              {% endif %}
            </div>
            <h3 class="h5 fw-bold mb-2">
              {% if item.data.sourceUrl %}
              <a href="{{ item.data.sourceUrl }}" target="_blank" rel="noopener noreferrer" class="text-decoration-none">{{ item.data.title }}</a>
              {% else %}
              <a href="{{ item.url }}" class="text-decoration-none">{{ item.data.title }}</a>
              {% endif %}
            </h3>
            {% if item.data.description %}
            <p class="text-muted mb-3">{{ item.data.description }}</p>
            {% endif %}
            <div class="mt-auto d-flex flex-wrap gap-2">
              {% if item.data.sourceUrl %}
              <a href="{{ item.data.sourceUrl }}" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm rounded-pill">Avaa lähde</a>
              {% endif %}
              <a href="{{ item.url }}" class="btn btn-outline-secondary btn-sm rounded-pill">Arkistosivu</a>
            </div>
          </div>
        </article>
      </div>
      {% endfor %}
    </div>
    <div class="row g-4">
      <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100 media-role-card">
          <div class="card-body p-4">
            <p class="text-uppercase text-muted fw-semibold small mb-2">1</p>
            <h2 class="h5 fw-bold mb-2">Mediassa minusta</h2>
            <p class="text-muted mb-0">Kun juttu, podcast tai video on tehty minusta tai asiantuntijuudestani, se kuuluu tähän ryhmään.</p>
          </div>
        </div>
      </div>
      <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100 media-role-card">
          <div class="card-body p-4">
            <p class="text-uppercase text-muted fw-semibold small mb-2">2</p>
            <h2 class="h5 fw-bold mb-2">Vieraana tai keskustelijana</h2>
            <p class="text-muted mb-0">Tähän kootaan podcastit, paneelit ja muut keskustelut, joissa olen mukana kutsuttuna vieraana.</p>
          </div>
        </div>
      </div>
      <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100 media-role-card">
          <div class="card-body p-4">
            <p class="text-uppercase text-muted fw-semibold small mb-2">3</p>
            <h2 class="h5 fw-bold mb-2">Haastattelijana</h2>
            <p class="text-muted mb-0">Jos roolini on kysyjä, juontaja tai haastattelija, sisältö kuuluu omaan ryhmäänsä. Oma tuotanto voi näkyä samalla myös esitysten ja tallenteiden puolella.</p>
          </div>
        </div>
      </div>
    </div>
      </div>
    </details>
  </div>
</section>

{{ renderMediaSection(mediaAbout, "about", "Podcastit, haastattelut ja muut mediaosumat, joissa puheenaiheena olen minä, oma asiantuntijuuteni tai julkinen roolini.") }}
{{ renderMediaSection(mediaGuest, "guest", "Keskustelut, joissa olen mukana vieraana, kommentoijana tai asiantuntijana muiden tuottamissa formaateissa.") }}
{{ renderMediaSection(mediaInterviewer, "interviewer", "Sisällöt, joissa olen itse haastattelija, keskustelun vetäjä tai juontava osapuoli.") }}

<style>
  .media-mobile-path,
  .media-mobile-disclosure-summary {
    display: none;
  }

  .media-hero-card {
    border-radius: 1.5rem;
  }

  .media-role-card,
  .media-highlight-card,
  .media-side-card {
    border-radius: 1.25rem;
  }

  .media-entry {
    padding-block: 1.5rem;
  }

  .media-entry:first-child {
    padding-top: 1rem;
  }

  .media-entry:last-child {
    padding-bottom: 0.5rem;
  }

  .media-entry-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .media-topic-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.8rem;
    border-radius: 999px;
    border: 1px solid rgba(120, 130, 150, 0.25);
    background: rgba(120, 130, 150, 0.09);
    color: var(--bs-secondary-color);
    font-size: 0.82rem;
    line-height: 1.2;
  }

  .media-empty-state {
    padding: 1.5rem 0.25rem 0.5rem;
  }

  .media-count-badge {
    min-width: 2.5rem;
    justify-content: center;
    padding-inline: 0.85rem;
    padding-block: 0.45rem;
  }

  .media-pagination {
    border-top: 1px solid rgba(120, 130, 150, 0.18);
  }

  .media-pagination__info {
    font-size: 0.9rem;
  }

  [data-bs-theme="dark"] .media-topic-chip {
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.78);
  }

  [data-bs-theme="dark"] .media-pagination {
    border-top-color: rgba(255, 255, 255, 0.12);
  }

  @media (max-width: 767.98px) {
    .media-mobile-path {
      position: sticky;
      top: 0;
      z-index: 12;
      display: flex;
      gap: 0.55rem;
      overflow-x: auto;
      padding: 0.75rem max(0.75rem, env(safe-area-inset-left));
      background: rgba(255, 255, 255, 0.92);
      border-bottom: 1px solid rgba(16, 40, 69, 0.1);
      backdrop-filter: blur(14px);
      -webkit-overflow-scrolling: touch;
    }

    .media-mobile-path::-webkit-scrollbar {
      display: none;
    }

    .media-mobile-path a {
      flex: 0 0 auto;
      padding: 0.48rem 0.8rem;
      border-radius: 999px;
      border: 1px solid rgba(16, 40, 69, 0.12);
      background: rgba(255, 255, 255, 0.78);
      color: #102845;
      font-size: 0.82rem;
      font-weight: 800;
      text-decoration: none;
    }

    [data-bs-theme="dark"] .media-mobile-path {
      background: rgba(13, 18, 28, 0.88);
      border-bottom-color: rgba(255, 255, 255, 0.1);
    }

    [data-bs-theme="dark"] .media-mobile-path a {
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(255, 255, 255, 0.14);
      color: #f8fbff;
    }

    [data-media-mobile-priority="2"] {
      padding-block: 1rem;
    }

    .media-mobile-disclosure {
      display: block;
    }

    .media-mobile-disclosure-summary {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 0.35rem 0.8rem;
      align-items: center;
      padding: 1rem;
      margin-bottom: 1rem;
      border-radius: 1.05rem;
      border: 1px solid rgba(16, 40, 69, 0.1);
      background: rgba(255, 255, 255, 0.94);
      box-shadow: 0 0.75rem 1.7rem rgba(15, 34, 56, 0.08);
      color: #102845;
      cursor: pointer;
      list-style: none;
    }

    .media-mobile-disclosure-summary::-webkit-details-marker {
      display: none;
    }

    .media-mobile-disclosure-summary::after {
      content: "+";
      grid-row: 1 / span 2;
      grid-column: 2;
      width: 2rem;
      height: 2rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      background: rgba(19, 78, 145, 0.1);
      color: #134e91;
      font-weight: 900;
    }

    .media-mobile-disclosure[open] .media-mobile-disclosure-summary::after {
      content: "−";
    }

    .media-mobile-disclosure-summary span {
      font-weight: 900;
      line-height: 1.2;
    }

    .media-mobile-disclosure-summary small {
      color: rgba(16, 40, 69, 0.62);
      font-weight: 650;
    }

    [data-bs-theme="dark"] .media-mobile-disclosure-summary {
      background: rgba(255, 255, 255, 0.07);
      border-color: rgba(255, 255, 255, 0.14);
      color: #f8fbff;
    }

    [data-bs-theme="dark"] .media-mobile-disclosure-summary small {
      color: rgba(255, 255, 255, 0.68);
    }

    .media-entry {
      padding-block: 1.25rem;
    }

    .media-entry-thumb {
      border-radius: 1rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const mobileQuery = window.matchMedia('(max-width: 767.98px)');
    const disclosures = Array.from(document.querySelectorAll('[data-media-mobile-collapse]'));

    const applyMediaMobileState = () => {
      disclosures.forEach((disclosure) => {
        if (!mobileQuery.matches) {
          disclosure.open = true;
          disclosure.dataset.mobilePrepared = 'false';
          return;
        }
        if (disclosure.dataset.mobilePrepared === 'true') return;
        disclosure.open = disclosure.hasAttribute('data-media-mobile-default-open');
        disclosure.dataset.mobilePrepared = 'true';
      });
    };

    applyMediaMobileState();
    mobileQuery.addEventListener('change', applyMediaMobileState);

    const paginatedSections = document.querySelectorAll('[data-media-pagination]');
    if (!paginatedSections.length) return;

    paginatedSections.forEach((section) => {
      const items = Array.from(section.querySelectorAll('[data-media-page-item]'));
      const controls = section.querySelector('[data-media-page-controls]');
      const info = section.querySelector('[data-media-page-info]');
      const pageSize = Number(section.getAttribute('data-page-size')) || 4;
      const pageCount = Math.ceil(items.length / pageSize);
      let currentPage = 1;

      if (!items.length || !controls || pageCount <= 1) return;

      const pageLabel = (page) => {
        const start = (page - 1) * pageSize + 1;
        const end = Math.min(page * pageSize, items.length);
        return `Näytetään ${start}-${end} / ${items.length}`;
      };

      const renderControls = () => {
        controls.innerHTML = '';
        for (let page = 1; page <= pageCount; page += 1) {
          const li = document.createElement('li');
          li.className = `page-item${page === currentPage ? ' active' : ''}`;
          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'page-link';
          button.dataset.mediaPage = String(page);
          button.setAttribute('aria-label', `Sivu ${page}`);
          button.textContent = String(page);
          li.appendChild(button);
          controls.appendChild(li);
        }
      };

      const renderPage = () => {
        const startIndex = (currentPage - 1) * pageSize;
        const endIndex = startIndex + pageSize;
        items.forEach((item, index) => {
          item.hidden = index < startIndex || index >= endIndex;
        });
        if (info) info.textContent = pageLabel(currentPage);
        renderControls();
      };

      controls.addEventListener('click', (event) => {
        const button = event.target.closest('[data-media-page]');
        if (!button) return;
        const nextPage = Number(button.dataset.mediaPage);
        if (!Number.isFinite(nextPage) || nextPage === currentPage) return;
        currentPage = nextPage;
        renderPage();
      });

      renderPage();
    });
  });
</script>
