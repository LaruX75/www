---
layout: base.njk
title: "Mediassa: podcastit, videot ja haastattelut"
description: "Jari Laru mediassa: podcastit, videot, haastattelut, lehtijutut ja asiantuntijaroolit opetuksen, teknologian, tekoälyn ja politiikan teemoista."
permalink: /mediassa/
lang: fi
translationKey: media_index
---

{% set mediaItems = mediaArchive.all or [] %}
{% set mediaAbout = mediaArchive.about or [] %}
{% set mediaAssignments = mediaArchive.expertAssignments or [] %}
{% set mediaGuest = mediaArchive.guest or [] %}
{% set mediaInterviewer = mediaArchive.interviewer or [] %}
{% set mediaTotal = mediaItems | length %}
{% set mediaArticles = [] %}
{% set mediaPodcasts = [] %}
{% set mediaVideos = [] %}
{% set mediaAudio = [] %}
{% for item in mediaItems %}
  {% if item.data.mediaType == "article" %}
    {% set _ = (mediaArticles.push(item), null) %}
  {% elif item.data.mediaType == "podcast" %}
    {% set _ = (mediaPodcasts.push(item), null) %}
  {% elif item.data.mediaType == "video" %}
    {% set _ = (mediaVideos.push(item), null) %}
  {% elif item.data.mediaType == "radio" %}
    {% set _ = (mediaAudio.push(item), null) %}
  {% endif %}
{% endfor %}
{% set mainHighlight = mediaItems[0] %}
{% set podcastHighlight = mediaPodcasts[0] %}
{% set videoHighlight = mediaVideos[0] %}
{% set guestHighlight = mediaGuest[0] or mediaInterviewer[0] %}
{% set sideHighlights = [] %}
{% if podcastHighlight %}{% set _ = (sideHighlights.push(podcastHighlight), null) %}{% endif %}
{% if videoHighlight and videoHighlight.url != podcastHighlight.url %}{% set _ = (sideHighlights.push(videoHighlight), null) %}{% endif %}
{% if guestHighlight and guestHighlight.url != podcastHighlight.url and guestHighlight.url != videoHighlight.url %}{% set _ = (sideHighlights.push(guestHighlight), null) %}{% endif %}
{% for item in mediaItems %}
  {% if sideHighlights.length < 3 and item.url != mainHighlight.url and item.url != podcastHighlight.url and item.url != videoHighlight.url and item.url != guestHighlight.url %}
    {% set _ = (sideHighlights.push(item), null) %}
  {% endif %}
{% endfor %}

{% macro mediaTypeLabel(type) %}
  {% if type == "podcast" %}Podcast
  {% elif type == "assignment" %}Asiantuntijatehtävä
  {% elif type == "article" %}Lehtijuttu
  {% elif type == "tv" %}TV
  {% elif type == "radio" %}Radio
  {% elif type == "video" %}Video
  {% else %}Media
  {% endif %}
{% endmacro %}

{% macro roleLabel(role) %}
  {% if role == "about" %}Minusta tehty
  {% elif role == "expertAssignment" %}Asiantuntijarooli
  {% elif role == "interviewer" %}Haastattelijana
  {% elif role == "guest" %}Vieraana
  {% else %}Media
  {% endif %}
{% endmacro %}

{% macro itemUrl(item) %}
  {{ item.data.sourceUrl or item.url }}
{% endmacro %}

{% macro renderMediaThumb(item, modifier="") %}
  {% if item.data.thumbnail %}
    {% set isVideoPreview = item.data.mediaType == "video" or (item.data.sourceUrl and ("youtube.com" in item.data.sourceUrl or "youtu.be" in item.data.sourceUrl)) %}
    <span class="media-thumb {{ modifier }}{% if isVideoPreview %} video-preview video-preview--sm{% endif %}">
      <img src="{{ item.data.thumbnail }}" alt="{{ item.data.title }}" loading="lazy" decoding="async">
    </span>
  {% else %}
    <span class="media-thumb media-thumb--empty {{ modifier }}">
      <i class="bi bi-newspaper" aria-hidden="true"></i>
    </span>
  {% endif %}
{% endmacro %}

{% macro renderMeta(item) %}
  <span>{{ mediaTypeLabel(item.data.mediaType) }}</span>
  <span>{{ roleLabel(item.data.mediaRole) }}</span>
  {% if item.data.mediaOutlet %}
    <span>{{ item.data.mediaOutlet }}</span>
  {% endif %}
  {% if item.date %}
    <span>{{ item.date | dateFormat }}</span>
  {% endif %}
{% endmacro %}

<section class="media-hero py-5 border-bottom">
  <div class="site-shell">
    <div class="media-hero-layout">
      <div class="media-hero-copy">
        <p class="media-eyebrow mb-2">Mediaesiintymiset</p>
        <h1 class="media-hero-title mb-3">Mediassa</h1>
        <p class="media-hero-lead mb-3">Tämä sivu kokoaa muiden tekemät mediaosumat sekä julkiset asiantuntijaroolit: lehtijutut, podcastit, videot, radiohaastattelut, työryhmät ja muut sisällöt, joissa olen mukana.</p>
        <p class="media-hero-text mb-4"><a href="/kynasta/">Kynästä</a> kokoaa omat kirjoitukseni ja lausuntoni. <a href="/esitykset/">Esitykset</a> kokoaa omat puheenvuorot, materiaalit ja tallenteet. Tämä näkymä kertoo, miten työni on näkynyt muiden tuottamissa medioissa.</p>
        <div class="media-hero-actions">
          <a href="#media-nostot" class="btn btn-primary rounded-pill px-4">Katso nostot</a>
          <a href="#media-arkisto" class="btn btn-outline-secondary rounded-pill px-4">Selaa kaikkia mediaosumia</a>
        </div>
      </div>
      <aside class="media-hero-panel">
        <p class="media-panel-kicker">Silmäys aineistoon</p>
        <dl class="home-hero-kpi-grid mb-0">
          <div class="home-hero-kpi">
            <dd class="home-hero-kpi-value">{{ mediaTotal }}</dd>
            <dt class="home-hero-kpi-label">mediaosumaa</dt>
          </div>
          <div class="home-hero-kpi">
            <dd class="home-hero-kpi-value">{{ mediaArticles | length }}</dd>
            <dt class="home-hero-kpi-label">lehtijuttua</dt>
          </div>
          <div class="home-hero-kpi">
            <dd class="home-hero-kpi-value">{{ mediaPodcasts | length }}</dd>
            <dt class="home-hero-kpi-label">podcastia</dt>
          </div>
          <div class="home-hero-kpi">
            <dd class="home-hero-kpi-value">{{ mediaVideos | length }}</dd>
            <dt class="home-hero-kpi-label">videota</dt>
          </div>
        </dl>
      </aside>
    </div>
  </div>
</section>

<nav class="media-mobile-path" aria-label="Mediassa-sivun tärkeimmät osiot">
  <a href="#media-nostot">Nostot</a>
  <a href="#media-arkisto">Kaikki</a>
  <a href="#media-roolit">Roolit</a>
  <a href="#media-lahteet">Lähteet</a>
</nav>

{% set topicProfileKeys = ["julkinen-asiantuntijuus-mediassa", "tekoalylukutaito", "opettajankoulutus"] %}
{% set topicProfileTitleId = "media-topic-profiles-title" %}
{% set topicProfileEyebrow = "Aiheittain" %}
{% set topicProfileTitle = "Mediaosumat osana asiantuntijaprofiilia" %}
{% set topicProfileLead = "Mediassa-sivu näyttää missä olen ollut esillä. Teemaprofiilit näyttävät, mihin asiantuntijuuden alueeseen mediaosumat liittyvät." %}
{% include "topic-profile-links.njk" %}

<section class="media-feature-section py-5" id="media-nostot" aria-labelledby="media-nostot-heading">
  <div class="site-shell">
    <div class="media-section-head">
      <p class="media-eyebrow mb-1">Nostot</p>
      <h2 id="media-nostot-heading" class="media-section-title">Tuoreita ja tunnistettavia mediaosumia</h2>
      <p class="media-section-lead mb-0">Nostot antavat nopean kuvan siitä, millaisissa yhteyksissä media on käsitellyt työtäni, asiantuntijuuttani ja julkista rooliani.</p>
    </div>

    <div class="media-feature-grid">
      {% if mainHighlight %}
      <article class="media-feature-primary">
        <a href="{{ itemUrl(mainHighlight) | trim }}" class="media-feature-primary-thumb" target="_blank" rel="noopener noreferrer">
          {{ renderMediaThumb(mainHighlight, "media-thumb--primary") }}
        </a>
        <div class="media-feature-primary-body">
          <div class="media-meta-row">{{ renderMeta(mainHighlight) }}</div>
          <h3><a href="{{ itemUrl(mainHighlight) | trim }}" target="_blank" rel="noopener noreferrer">{{ mainHighlight.data.title }}</a></h3>
          {% if mainHighlight.data.description %}
          <p>{{ mainHighlight.data.description }}</p>
          {% endif %}
          <div class="media-card-actions">
            <a href="{{ itemUrl(mainHighlight) | trim }}" target="_blank" rel="noopener noreferrer" class="btn btn-primary rounded-pill px-4">Avaa lähde</a>
            <a href="{{ mainHighlight.url }}" class="btn btn-outline-secondary rounded-pill px-4">Lisätiedot</a>
          </div>
        </div>
      </article>
      {% endif %}

      <div class="media-feature-side">
        {% for item in sideHighlights %}
        <article class="media-feature-small">
          <a href="{{ itemUrl(item) | trim }}" target="_blank" rel="noopener noreferrer" class="media-feature-small-thumb">
            {{ renderMediaThumb(item, "media-thumb--small") }}
          </a>
          <div class="media-feature-small-body">
            <div class="media-meta-row media-meta-row--small">{{ renderMeta(item) }}</div>
            <h3><a href="{{ itemUrl(item) | trim }}" target="_blank" rel="noopener noreferrer">{{ item.data.title }}</a></h3>
            {% if item.data.description %}
            <p>{{ item.data.description }}</p>
            {% endif %}
          </div>
        </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<section class="media-browser-section py-5 bg-body-tertiary border-top border-bottom" id="media-arkisto" aria-labelledby="media-arkisto-heading">
  <div class="site-shell">
    <div class="media-section-head">
      <p class="media-eyebrow mb-1">Selaa mediaosumia</p>
      <h2 id="media-arkisto-heading" class="media-section-title">Kaikki mediaosumat samassa näkymässä</h2>
      <p class="media-section-lead mb-0">Suodata sisältöä muodon, roolin tai aiheen mukaan. Jokaisesta osumasta voit avata alkuperäisen lähteen tai paikallisen lisätietosivun.</p>
    </div>

    <div class="media-browser" data-media-browser data-page-size="9">
      <div class="media-filter-group" aria-label="Suodata mediaosumia sisällön muodon mukaan">
        <button class="media-filter is-active" type="button" data-media-filter="all">Kaikki</button>
        <button class="media-filter" type="button" data-media-filter="type:article">Lehtijutut</button>
        <button class="media-filter" type="button" data-media-filter="type:podcast">Podcastit</button>
        <button class="media-filter" type="button" data-media-filter="type:video">Videot</button>
        <button class="media-filter" type="button" data-media-filter="type:radio">Radio</button>
        <button class="media-filter" type="button" data-media-filter="type:assignment">Asiantuntijatehtävät</button>
      </div>
      <div class="media-filter-group media-filter-group--secondary" aria-label="Suodata mediaosumia roolin ja aiheen mukaan">
        <button class="media-filter" type="button" data-media-filter="role:about">Minusta tehty</button>
        <button class="media-filter" type="button" data-media-filter="role:expertAssignment">Asiantuntijaroolit</button>
        <button class="media-filter" type="button" data-media-filter="role:guest">Vieraana</button>
        <button class="media-filter" type="button" data-media-filter="role:interviewer">Haastattelijana</button>
        <button class="media-filter" type="button" data-media-filter="topic:politiikka">Politiikka</button>
        <button class="media-filter" type="button" data-media-filter="topic:tekoaly">Tekoäly ja koulutus</button>
        <button class="media-filter" type="button" data-media-filter="topic:avoin">Avoin tiede</button>
        <button class="media-filter" type="button" data-media-filter="topic:paikallinen">Paikallinen vaikuttaminen</button>
      </div>

      <p class="media-browser-status text-muted mb-3" data-media-browser-status aria-live="polite"></p>

      <div class="media-card-grid" data-media-card-grid>
        {% for item in mediaItems %}
          {% set topicText = ((item.data.categories or []) | join(" ")) ~ " " ~ ((item.data.keywords or []) | join(" ")) ~ " " ~ item.data.title ~ " " ~ (item.data.description or "") %}
          <article
            class="media-archive-card"
            data-media-card
            data-media-type="{{ item.data.mediaType or '' }}"
            data-media-role="{{ item.data.mediaRole or '' }}"
            data-media-topics="{{ topicText | lower | escape }}"
          >
            <a href="{{ itemUrl(item) | trim }}" target="_blank" rel="noopener noreferrer" class="media-archive-thumb-link">
              {{ renderMediaThumb(item) }}
            </a>
            <div class="media-archive-card-body">
              <div class="media-meta-row media-meta-row--small">{{ renderMeta(item) }}</div>
              <h3><a href="{{ itemUrl(item) | trim }}" target="_blank" rel="noopener noreferrer">{{ item.data.title }}</a></h3>
              {% if item.data.description %}
              <p>{{ item.data.description }}</p>
              {% endif %}
              {% if item.data.categories %}
              <div class="media-topic-row">
                {% for category in item.data.categories.slice(0, 4) %}
                <span>{{ category }}</span>
                {% endfor %}
              </div>
              {% endif %}
              <div class="media-card-actions">
                <a href="{{ itemUrl(item) | trim }}" target="_blank" rel="noopener noreferrer" class="btn btn-outline-primary btn-sm rounded-pill px-3">Avaa lähde</a>
                <a href="{{ item.url }}" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Lisätiedot</a>
              </div>
            </div>
          </article>
        {% endfor %}
      </div>

      <div class="media-pagination d-flex flex-wrap align-items-center justify-content-between gap-3 pt-4">
        <p class="media-pagination__info text-muted mb-0" data-media-page-info aria-live="polite"></p>
        <ul class="pagination pagination-sm mb-0 flex-wrap" data-media-page-controls aria-label="Mediaosumien sivutus"></ul>
      </div>
    </div>
  </div>
</section>

<section class="media-role-section py-5" id="media-roolit" aria-labelledby="media-roolit-heading">
  <div class="site-shell">
    <div class="media-section-head">
      <p class="media-eyebrow mb-1">Roolit</p>
      <h2 id="media-roolit-heading" class="media-section-title">Neljä tapaa olla mukana julkisessa aineistossa</h2>
      <p class="media-section-lead mb-0">Rooli auttaa tulkitsemaan osumaa: onko media tehnyt jutun minusta, olenko mukana keskustelijana, haastattelenko muita vai onko kyse virallisesta asiantuntijatehtävästä.</p>
    </div>
    <div class="media-role-grid">
      <article class="media-role-card">
        <span class="media-role-number">{{ mediaAbout | length }}</span>
        <h3>Mediassa minusta</h3>
        <p>Jutut, podcastit ja videot, joissa aiheena on oma työni, asiantuntijuuteni tai julkinen roolini.</p>
        <button class="media-role-link" type="button" data-media-jump-filter="role:about">Rajaa nämä näkyviin</button>
      </article>
      <article class="media-role-card">
        <span class="media-role-number">{{ mediaAssignments | length }}</span>
        <h3>Asiantuntijaroolit</h3>
        <p>Työryhmät, laatijaryhmät ja muut julkiset asiantuntijatehtävät, joissa olen mukana yliopistotyön kautta.</p>
        <button class="media-role-link" type="button" data-media-jump-filter="role:expertAssignment">Rajaa nämä näkyviin</button>
      </article>
      <article class="media-role-card">
        <span class="media-role-number">{{ mediaGuest | length }}</span>
        <h3>Vieraana ja keskustelijana</h3>
        <p>Keskustelut ja podcastit, joissa olen mukana kutsuttuna vieraana tai asiantuntijana.</p>
        <button class="media-role-link" type="button" data-media-jump-filter="role:guest">Rajaa nämä näkyviin</button>
      </article>
      <article class="media-role-card">
        <span class="media-role-number">{{ mediaInterviewer | length }}</span>
        <h3>Haastattelijana</h3>
        <p>Sisällöt, joissa roolini on kysyjä, keskustelun vetäjä tai juontava osapuoli.</p>
        <button class="media-role-link" type="button" data-media-jump-filter="role:interviewer">Rajaa nämä näkyviin</button>
      </article>
    </div>
  </div>
</section>

<section class="media-source-section py-5 bg-body-tertiary border-top" id="media-lahteet" aria-labelledby="media-lahteet-heading">
  <div class="site-shell">
    <div class="media-source-band">
      <div>
        <p class="media-eyebrow mb-1">Lähteet ja muodot</p>
        <h2 id="media-lahteet-heading" class="media-section-title mb-2">Mediaosumat painottuvat lehtijuttuihin, mutta mukana on myös videoita ja podcasteja</h2>
        <p class="media-section-lead mb-0">Suurin yksittäinen lähde on Kaleva. Muut osumat ja asiantuntijatehtävät täydentävät kuvaa erityisesti opetuksen, tekoälylukutaidon, avoimen tieteen ja paikallisen päätöksenteon näkökulmista.</p>
      </div>
      <div class="media-source-stats">
        <span><strong>{{ mediaArticles | length }}</strong> lehtijuttua</span>
        <span><strong>{{ mediaVideos | length }}</strong> videota</span>
        <span><strong>{{ mediaPodcasts | length }}</strong> podcastia</span>
        <span><strong>{{ mediaAssignments | length }}</strong> asiantuntijatehtävää</span>
        <span><strong>{{ mediaAudio | length }}</strong> radio-osuma</span>
      </div>
    </div>
  </div>
</section>

