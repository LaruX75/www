---
pagination:
  data: councilMeetings
  size: 1
  alias: meeting
permalink: "/politiikka/kaupunginvaltuusto/kokoukset/{{ meeting.date }}/"
layout: base.njk
lang: fi
translationKey: council_meeting
templateEngineOverride: njk
pageShell: true
pageShellClass: site-shell site-shell--wide
pageScopeClass: council-meeting-page-scope
eleventyComputed:
  title: "{{ meeting.meetingLabel }}"
  description: "{% if meeting.heroSummary.agendaLead %}{{ meeting.heroSummary.agendaLead }} {% endif %}{{ meeting.heroSummary.activityLead or (meeting.contextLabel ~ ', ' ~ meeting.meetingLabel) }}"
schemaAbout:
  - "@type": "Thing"
    name: "Oulun kaupunginvaltuusto"
schemaMentions:
  - "@type": "GovernmentOrganization"
    name: "Oulun kaupunki"
    url: "https://www.ouka.fi/"
  - "@type": "Organization"
    name: "Oulun kaupunginvaltuusto"
    url: "https://www.ouka.fi/valtuusto"
---

{% macro renderItems(title, items, emptyText) %}
<section class="council-meeting-section">
  <div class="council-meeting-section__head">
    <h2>{{ title }}</h2>
    <span>{{ items.length }}</span>
  </div>
  {% if items.length %}
  <ol class="council-meeting-items">
    {% for item in items %}
    <li>
      <div>
        <a href="{{ item.url }}">{{ item.title }}</a>
        <p>{{ item.typeLabel }}{% if item.detailLabel %} · {{ item.detailLabel }}{% endif %}</p>
      </div>
      <div class="council-meeting-item-meta">
        {% if item.videoStart %}
        <span>Videolla {{ item.videoStart | secondsToClock }}</span>
        {% elif item.hasVideo %}
        <span>Video kytketty</span>
        {% endif %}
        {% if item.missingMetadata.length %}
        <span>Puuttuu: {{ item.missingMetadata | join(", ") }}</span>
        {% endif %}
      </div>
    </li>
    {% endfor %}
  </ol>
  {% else %}
  <p class="council-meeting-empty">{{ emptyText }}</p>
  {% endif %}
</section>
{% endmacro %}

<article class="council-meeting-page">
  <header class="council-meeting-hero">
    <div>
      <p class="term-eyebrow mb-2">{{ meeting.contextLabel }}</p>
      <h1 class="term-hero-title mb-3">{{ meeting.meetingLabel }}</h1>
      <p class="council-meeting-hero-meta">{{ meeting.date | dateFormat }}</p>
      {% if meeting.summaryTitle %}
      <p class="council-meeting-hero-summary">{{ meeting.summaryTitle }}</p>
      {% endif %}
      <div class="council-meeting-hero-brief">
        {% if meeting.heroSummary.agendaLead %}
        <p>{{ meeting.heroSummary.agendaLead }}</p>
        {% endif %}
        {% if meeting.heroSummary.activityLead %}
        <p>{{ meeting.heroSummary.activityLead }}</p>
        {% endif %}
      </div>
    </div>
    <aside class="council-meeting-hero-card">
      <p class="term-hero-card__kicker">Kokouksen aineisto</p>
      <div class="council-meeting-actions">
        {% if meeting.protocolUrl %}
        <a class="btn btn-read-more rounded-pill px-4" href="{{ meeting.protocolUrl }}" target="_blank" rel="noopener noreferrer">Pöytäkirja</a>
        {% endif %}
        {% if meeting.video and meeting.video.url %}
        <a class="btn btn-outline-primary rounded-pill px-4" href="{{ meeting.video.url }}" target="_blank" rel="noopener noreferrer">Kokousvideo</a>
        {% endif %}
        <a class="btn btn-outline-primary rounded-pill px-4" href="/politiikka/kaupunginvaltuusto/">Kaikki kokoukset</a>
      </div>
    </aside>
  </header>

  <section class="council-meeting-summary" aria-label="Kokouksen yhteenveto">
    <div class="site-kpi-card">
      <span class="site-kpi-number">{{ meeting.counts.speeches }}</span>
      <span class="site-kpi-label">puheenvuoroa</span>
    </div>
    <div class="site-kpi-card">
      {% if meeting.hasQuestionHour %}
      <span class="site-kpi-number">{{ meeting.counts.questions }}</span>
      <span class="site-kpi-label">{{ "kyselytunnin asia" if meeting.counts.questions == 1 else "kyselytunnin asiaa" }}</span>
      {% else %}
      <span class="site-kpi-label site-kpi-label--standalone">Ei kyselytuntia</span>
      {% endif %}
    </div>
    <div class="site-kpi-card">
      <span class="site-kpi-number">{{ meeting.counts.initiatives }}</span>
      <span class="site-kpi-label">{{ "valtuustoaloite" if meeting.counts.initiatives == 1 else "valtuustoaloitetta" }}</span>
    </div>
    <div class="site-kpi-card">
      <span class="site-kpi-number">{{ meeting.missingMetadata.length }}</span>
      <span class="site-kpi-label">tarkistettavaa</span>
    </div>
  </section>

  <div class="council-meeting-layout">
    <main class="council-meeting-main">
      {{ renderItems("Puheenvuorot", meeting.speeches, "Tästä kokouksesta ei ole kytketty puheenvuoroja.") }}
      {{ renderItems("Valtuuston kyselytunti", meeting.questions, "Tästä kokouksesta ei ole kytketty kyselytunnin sisältöjä." if meeting.hasQuestionHour else "Kokouksessa ei ollut valtuuston kyselytuntia.") }}
      {{ renderItems("Valtuustoaloitteet", meeting.initiatives, "Tästä kokouksesta ei ole kytketty valtuustoaloitteita.") }}
      {% if meeting.otherItems.length %}
      {{ renderItems("Muut sisällöt", meeting.otherItems, "") }}
      {% endif %}
    </main>

    <aside class="content-context-sidebar council-meeting-sidebar" aria-label="Kokouksen konteksti">
      <div class="content-context-card content-context-card--primary">
        <p class="content-context-kicker">Kokous</p>
        <h2 class="content-context-title">{{ meeting.meetingLabel }}</h2>
        <p class="content-context-meeting-meta">
          <span>{{ meeting.contextLabel }}</span>
          <span>{{ meeting.date | dateFormat }}</span>
        </p>
      </div>

      <div class="content-context-card">
        <p class="content-context-kicker">Lähteet</p>
        <div class="content-context-chiplist">
          {% if meeting.protocolUrl %}
          <a class="content-context-chip content-context-chip--context" href="{{ meeting.protocolUrl }}" target="_blank" rel="noopener noreferrer">Pöytäkirja</a>
          {% else %}
          <span class="content-context-chip content-context-chip--category">Pöytäkirjalinkki puuttuu</span>
          {% endif %}
          {% if meeting.video and meeting.video.url %}
          <a class="content-context-chip content-context-chip--forum" href="{{ meeting.video.url }}" target="_blank" rel="noopener noreferrer">Kokousvideo</a>
          {% else %}
          <span class="content-context-chip content-context-chip--category">Videolinkki puuttuu</span>
          {% endif %}
        </div>
      </div>

      {% if meeting.missingMetadata.length %}
      <div class="content-context-card">
        <p class="content-context-kicker">Tarkistettavaa</p>
        <p class="council-meeting-sidebar-note">Näistä sisällöistä puuttuu vielä osa metatiedoista, kuten video, asiakohta tai pöytäkirjalinkki.</p>
      </div>
      {% endif %}
    </aside>
  </div>
</article>

<style>
.council-meeting-page {
  display: grid;
  gap: 2rem;
  padding: 3rem 0 4rem;
}

.council-meeting-hero {
  display: grid;
  grid-template-columns: minmax(0, 1.15fr) minmax(18rem, 0.85fr);
  gap: 1.5rem;
  padding: clamp(1.4rem, 3vw, 2rem);
  border: 1px solid rgba(17, 40, 70, 0.1);
  border-radius: 1.4rem;
  background:
    radial-gradient(circle at top right, rgba(125, 159, 199, 0.16), transparent 34%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(245, 249, 255, 0.92));
  box-shadow: 0 1rem 2.4rem rgba(17, 40, 70, 0.08);
}

.council-meeting-hero-card {
  display: grid;
  align-content: center;
  gap: 1rem;
  padding: 1.25rem;
  border: 1px solid rgba(17, 40, 70, 0.1);
  border-radius: 1.2rem;
  background: rgba(255, 255, 255, 0.82);
}

.council-meeting-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.65rem;
}

.council-meeting-hero-meta,
.council-meeting-hero-summary {
  margin: -0.4rem 0 0.85rem;
  color: rgba(17, 40, 70, 0.7);
  font-weight: 700;
}

.council-meeting-hero-summary {
  margin-top: -0.2rem;
  font-weight: 600;
}

.council-meeting-hero-brief {
  display: grid;
  gap: 0.6rem;
  max-width: 62rem;
}

.council-meeting-hero-brief p {
  margin: 0;
  color: rgba(17, 40, 70, 0.78);
  font-size: clamp(1rem, 0.96rem + 0.25vw, 1.14rem);
  line-height: 1.65;
}

.council-meeting-summary {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1rem;
}

.council-meeting-layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(17rem, 0.32fr);
  gap: 1.5rem;
  align-items: start;
}

.council-meeting-main {
  display: grid;
  gap: 1rem;
}

.council-meeting-section {
  padding: 1.25rem;
  border: 1px solid rgba(17, 40, 70, 0.1);
  border-radius: 1.25rem;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 0.7rem 1.8rem rgba(17, 40, 70, 0.06);
}

.council-meeting-section__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 0.9rem;
}

.council-meeting-section__head h2 {
  margin: 0;
  font-size: clamp(1.2rem, 1rem + 0.6vw, 1.6rem);
}

.council-meeting-section__head span {
  min-width: 2rem;
  height: 2rem;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  background: rgba(17, 40, 70, 0.08);
  color: #163e6c;
  font-weight: 800;
}

.council-meeting-items {
  display: grid;
  gap: 0.8rem;
  margin: 0;
  padding: 0;
  list-style: none;
}

.council-meeting-items li {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 1rem;
  padding-top: 0.8rem;
  border-top: 1px solid rgba(100, 116, 139, 0.16);
}

.council-meeting-items li:first-child {
  padding-top: 0;
  border-top: 0;
}

.council-meeting-items a {
  color: #12355f;
  font-weight: 700;
  text-decoration-thickness: 0.08em;
  text-underline-offset: 0.18em;
}

.council-meeting-items p,
.council-meeting-empty,
.council-meeting-sidebar-note {
  margin: 0.25rem 0 0;
  color: rgba(17, 40, 70, 0.66);
  line-height: 1.55;
}

.council-meeting-item-meta {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 0.4rem;
}

.council-meeting-item-meta span {
  display: inline-flex;
  align-items: center;
  min-height: 1.8rem;
  padding: 0.25rem 0.55rem;
  border-radius: 999px;
  background: rgba(17, 40, 70, 0.08);
  color: rgba(17, 40, 70, 0.78);
  font-size: 0.82rem;
  font-weight: 700;
}

.council-meeting-sidebar {
  position: sticky;
  top: 1rem;
}

[data-bs-theme="dark"] .council-meeting-hero,
[data-bs-theme="dark"] .council-meeting-section {
  border-color: rgba(214, 226, 240, 0.18);
  background: linear-gradient(180deg, rgba(23, 36, 54, 0.96), rgba(17, 27, 42, 0.92));
  box-shadow: none;
}

[data-bs-theme="dark"] .council-meeting-hero-card {
  border-color: rgba(214, 226, 240, 0.18);
  background: rgba(255, 255, 255, 0.06);
}

[data-bs-theme="dark"] .council-meeting-hero-meta,
[data-bs-theme="dark"] .council-meeting-hero-summary {
  color: rgba(236, 242, 248, 0.72);
}

[data-bs-theme="dark"] .council-meeting-hero-brief p {
  color: rgba(236, 242, 248, 0.74);
}

[data-bs-theme="dark"] .council-meeting-section__head span,
[data-bs-theme="dark"] .council-meeting-item-meta span {
  background: rgba(214, 226, 240, 0.12);
  color: rgba(246, 251, 255, 0.92);
}

[data-bs-theme="dark"] .council-meeting-items a {
  color: #f6fbff;
}

[data-bs-theme="dark"] .council-meeting-items p,
[data-bs-theme="dark"] .council-meeting-empty,
[data-bs-theme="dark"] .council-meeting-sidebar-note {
  color: rgba(236, 242, 248, 0.68);
}

@media (max-width: 980px) {
  .council-meeting-hero,
  .council-meeting-layout,
  .council-meeting-summary {
    grid-template-columns: 1fr;
  }

  .council-meeting-sidebar {
    position: static;
  }
}

@media (max-width: 640px) {
  .council-meeting-items li {
    grid-template-columns: 1fr;
  }

  .council-meeting-item-meta {
    justify-content: flex-start;
  }
}
</style>
