---js
{
  layout: "base.njk",
  eleventyComputed: {
    title: data => `Kategoria: ${data.category?.name || ""}`,
    description: data => {
      const categoryName = data.category?.name || "";
      const categoryCount = data.category?.count || 0;
      const profile = data.taxonomyProfiles?.categories?.[data.category?.slug];
      return profile?.lead || `Kategoria "${categoryName}" kokoaa ${categoryCount} Jari Larun sivuston sisältöä samasta aihepiiristä: kirjoituksia, puheenvuoroja, esityksiä, mediaosumia ja julkaisuja.`;
    },
    robots: data => (data.category?.count || 0) < 2 ? "noindex, follow" : "index, follow, noai, noimageai",
    sitemap: data => (data.category?.count || 0) < 2 ? { ignore: true } : undefined
  },
  pagination: {
    data: "collections.categoryList",
    size: 1,
    alias: "category"
  },
  permalink: data => `/kategoriat/${data.category.slug}/`
}
---
{% set profile = taxonomyProfiles.categories[category.slug] or taxonomyProfiles.defaultCategory %}
{% set featuredItem = category.items[0] %}
{% set firstTypes = category.typeSummaries | take(6) %}
{% set relatedTerms = category.relatedTerms | take(14) %}

<section class="taxonomy-archive taxonomy-archive--category">
  <div class="site-shell">
    <header class="taxonomy-hero">
      <div class="taxonomy-hero-main">
        <p class="taxonomy-kicker">{{ profile.eyebrow }}</p>
        <h1 class="taxonomy-title">{{ category.name }}</h1>
        <p class="taxonomy-lead">{{ profile.lead }}</p>
        <p class="taxonomy-context">{{ profile.context }}</p>
        <details class="taxonomy-context-details">
          <summary>Lue kuvaus</summary>
          <p>{{ profile.context }}</p>
        </details>
        <div class="taxonomy-actions">
          <a class="btn btn-primary" href="#sisallot">Selaa sisältöjä</a>
          <a class="btn btn-outline-primary" href="/kategoriat/">{{ profile.backLabel }}</a>
        </div>
      </div>
      <aside class="taxonomy-hero-stat" aria-label="Kategorian yhteenveto">
        <span class="taxonomy-stat-number">{{ category.count }}</span>
        <span class="taxonomy-stat-label">sisältöä</span>
        {% if category.yearRange %}
          <span class="taxonomy-stat-range">{{ category.yearRange }}</span>
        {% endif %}
      </aside>
    </header>

    <div class="taxonomy-layout">
      <main class="taxonomy-main">
        {% if firstTypes.length %}
        <section class="taxonomy-section" aria-labelledby="taxonomy-types-title">
          <div class="taxonomy-section-head">
            <p class="taxonomy-kicker">{{ profile.primaryLabel }}</p>
            <h2 id="taxonomy-types-title">{{ profile.highlightsTitle }}</h2>
            <p>{{ profile.primaryText }}</p>
          </div>
          <div class="taxonomy-type-grid">
            {% for type in firstTypes %}
              <a class="taxonomy-type-card{% if profile.primaryType and type.key == profile.primaryType %} taxonomy-type-card--primary{% endif %}" href="#sisallot" data-taxonomy-filter-link="{{ type.key }}">
                <span class="taxonomy-type-count">{{ type.count }}</span>
                <span class="taxonomy-type-label">{{ type.label }}</span>
              </a>
            {% endfor %}
          </div>
        </section>
        {% endif %}

        {% if featuredItem %}
        <section class="taxonomy-feature" aria-labelledby="taxonomy-feature-title">
          <div class="taxonomy-feature-content">
            <p class="taxonomy-kicker">Uusin sisältö</p>
            <h2 id="taxonomy-feature-title">
              <a href="{{ featuredItem.url }}">{{ featuredItem.data.title }}</a>
            </h2>
            <p class="taxonomy-item-meta">
              <span>{{ featuredItem.taxonomyTypeLabel }}</span>
              <span>{{ featuredItem.date | dateFormat }}</span>
            </p>
            {% if featuredItem.data.description %}
              <p>{{ featuredItem.data.description }}</p>
            {% endif %}
          </div>
          {% if featuredItem.data.thumbnail %}
            <img class="taxonomy-feature-image" src="{{ featuredItem.data.thumbnail }}" alt="{{ featuredItem.data.title }}" loading="lazy" decoding="async">
          {% endif %}
        </section>
        {% endif %}

        <section class="taxonomy-section" id="sisallot" aria-labelledby="taxonomy-items-title">
          <div class="taxonomy-section-head taxonomy-section-head--inline">
            <div>
              <p class="taxonomy-kicker">Arkisto</p>
              <h2 id="taxonomy-items-title">{{ profile.browseTitle }}</h2>
              <p>{{ profile.browseLead }}</p>
            </div>
            {% if firstTypes.length > 1 %}
            <div class="taxonomy-filter" role="group" aria-label="Rajaa sisältötyypin mukaan">
              <button class="taxonomy-filter-btn is-active" type="button" data-taxonomy-filter="all">Kaikki</button>
              {% for type in firstTypes %}
                <button class="taxonomy-filter-btn" type="button" data-taxonomy-filter="{{ type.key }}">{{ type.label }}</button>
              {% endfor %}
            </div>
            {% endif %}
          </div>

          <div class="taxonomy-list" data-taxonomy-list>
            {% for item in category.items %}
              <article class="taxonomy-list-item" data-taxonomy-item data-taxonomy-type="{{ item.taxonomyTypeKey }}">
                <div class="taxonomy-list-date">
                  <span>{{ item.date | dateFormat }}</span>
                  <strong>{{ item.taxonomyTypeLabel }}</strong>
                </div>
                <div class="taxonomy-list-body">
                  <h3><a href="{{ item.url }}">{{ item.data.title }}</a></h3>
                  {% if item.data.description %}
                    <p>{{ item.data.description }}</p>
                  {% endif %}
                  {% if item.data.keywords %}
                    <div class="taxonomy-term-row" aria-label="Avainsanat">
                      {% for key in item.data.keywords | take(3) %}
                        <a href="/avainsanat/{{ key | slugify }}/">{{ key }}</a>
                      {% endfor %}
                    </div>
                  {% endif %}
                </div>
              </article>
            {% endfor %}
          </div>
          {% if category.items.length > 8 %}
            <button class="taxonomy-show-more" type="button" data-taxonomy-show-more hidden>Näytä lisää</button>
          {% endif %}
        </section>
      </main>

      <aside class="taxonomy-sidebar" aria-label="Kategorian lisäpolut">
        {% if relatedTerms.length %}
        <div class="taxonomy-side-card">
          <p class="taxonomy-kicker">{{ profile.relatedTitle }}</p>
          <div class="taxonomy-term-cloud">
            {% for term in relatedTerms %}
              <a href="{{ term.href }}">
                <span>{{ term.name }}</span>
                <small>{{ term.count }}</small>
              </a>
            {% endfor %}
          </div>
        </div>
        {% endif %}

        <div class="taxonomy-side-card taxonomy-side-card--quiet">
          <p class="taxonomy-kicker">{{ profile.guideTitle }}</p>
          <p>{{ profile.guideText }}</p>
        </div>
      </aside>
    </div>
  </div>
</section>

<script>
  (() => {
    const root = document.currentScript.previousElementSibling;
    if (!root) return;

    const buttons = root.querySelectorAll('[data-taxonomy-filter]');
    const items = Array.from(root.querySelectorAll('[data-taxonomy-item]'));
    const cardLinks = root.querySelectorAll('[data-taxonomy-filter-link]');
    const showMoreButton = root.querySelector('[data-taxonomy-show-more]');
    const mobileListQuery = window.matchMedia('(max-width: 767.98px)');
    const mobileItemLimit = 8;
    let currentFilter = 'all';
    let listExpanded = false;

    function applyFilter(type) {
      currentFilter = type;
      listExpanded = false;
      buttons.forEach((button) => {
        const active = button.dataset.taxonomyFilter === type;
        button.classList.toggle('is-active', active);
        button.setAttribute('aria-pressed', active ? 'true' : 'false');
      });

      updateVisibleItems();
    }

    function updateVisibleItems() {
      let visibleCount = 0;

      items.forEach((item) => {
        const matchesFilter = currentFilter === 'all' || item.dataset.taxonomyType === currentFilter;
        const withinMobileLimit = !mobileListQuery.matches || listExpanded || visibleCount < mobileItemLimit;
        item.hidden = !matchesFilter || !withinMobileLimit;

        if (matchesFilter) {
          visibleCount += 1;
        }
      });

      if (showMoreButton) {
        showMoreButton.hidden = !mobileListQuery.matches || listExpanded || visibleCount <= mobileItemLimit;
      }
    }

    buttons.forEach((button) => {
      button.setAttribute('aria-pressed', button.classList.contains('is-active') ? 'true' : 'false');
      button.addEventListener('click', () => applyFilter(button.dataset.taxonomyFilter || 'all'));
    });

    cardLinks.forEach((link) => {
      link.addEventListener('click', () => {
        applyFilter(link.dataset.taxonomyFilterLink || 'all');
      });
    });

    if (showMoreButton) {
      showMoreButton.addEventListener('click', () => {
        listExpanded = true;
        updateVisibleItems();
      });
    }

    mobileListQuery.addEventListener('change', updateVisibleItems);
    updateVisibleItems();
  })();
</script>

{% set taxonomyBaseUrl = site.url or "https://www.jarilaru.fi" %}
{% set taxonomyPageUrl = page.url | absoluteUrl(taxonomyBaseUrl) %}
{% set structuredItems = category.items | take(30) %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": {{ ("Kategoria: " ~ category.name) | jsonSafe | safe }},
  "description": {{ profile.lead | jsonSafe | safe }},
  "url": {{ taxonomyPageUrl | jsonSafe | safe }},
  "inLanguage": "fi-FI",
  "about": {
    "@type": "DefinedTerm",
    "name": {{ category.name | jsonSafe | safe }},
    "description": {{ profile.lead | jsonSafe | safe }},
    "url": {{ taxonomyPageUrl | jsonSafe | safe }}
  },
  "isPartOf": {
    "@type": "WebSite",
    "@id": {{ taxonomyBaseUrl | jsonSafe | safe }}
  },
  "mainEntity": {
    "@type": "ItemList",
    "name": {{ ("Sisällöt kategoriassa " ~ category.name) | jsonSafe | safe }},
    "numberOfItems": {{ category.count }},
    "itemListElement": [
      {% for item in structuredItems %}
      {
        "@type": "ListItem",
        "position": {{ loop.index }},
        "item": {
          "@type": "CreativeWork",
          "name": {{ item.data.title | jsonSafe | safe }},
          "url": {{ (item.url | absoluteUrl(taxonomyBaseUrl)) | jsonSafe | safe }},
          "encodingFormat": {{ item.taxonomyTypeLabel | jsonSafe | safe }}{% if item.date %},
          "datePublished": {{ (item.date | dateToRfc3339) | jsonSafe | safe }}{% endif %}{% if item.data.description %},
          "description": {{ item.data.description | jsonSafe | safe }}{% endif %}
        }
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
}
</script>
