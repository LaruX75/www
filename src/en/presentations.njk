---
layout: base.njk
title: Presentations
description: Jari Laru presentations and open learning materials — Canva, AOE, Google Slides and SlideShare
permalink: /en/presentations/
translationKey: presentations_index
lang: en
---

{% set tocSource %}
<h2 id="aoe-heading">AOE Learning Materials</h2>
<h2 id="canva-heading">Canva Presentations</h2>
<h2 id="google-heading">Google Slides Presentations</h2>
<h2 id="slideshare-heading">SlideShare Presentations</h2>
<h2 id="youtube-heading">YouTube Playlists</h2>
{% endset %}
{% set tocMarkup = tocSource | toc %}

{# Collect SlideShare items from static Markdown files #}
{% set ssDataItems = [] %}
{% set canvaPageUrls = [] %}
{% for item in collections.presentations %}
  {% if item.data.source == "slideshare" %}
    {% set _ = (ssDataItems.push({
      title: item.data.title,
      url: item.data.url,
      pageUrl: item.url,
      thumbnail: item.data.thumbnail,
      date: item.data.date,
      description: item.data.description or (item.content | excerpt),
      categories: item.data.categories or [],
      keywords: item.data.keywords or []
    }), null) %}
  {% elif item.data.url and "canva.com" in item.data.url %}
    {% set _ = (canvaPageUrls.push({ externalUrl: item.data.url, pageUrl: item.url }), null) %}
  {% endif %}
{% endfor %}

<div class="container py-5">
  <header class="mb-5 text-center">
    <h1 class="display-4 fw-bold mb-3">Presentations and Learning Materials</h1>
    <p class="lead text-muted">Presentations, open learning materials and more from various platforms.</p>
  </header>

  {% if tocMarkup %}
  <div class="row justify-content-center mb-5">
    <div class="col-lg-8">
      <aside class="card border-0 bg-light">
        <div class="card-body p-3">
          <p class="text-uppercase small text-muted mb-2">On this page</p>
          {{ tocMarkup | safe }}
        </div>
      </aside>
    </div>
  </div>
  {% endif %}

  {# ===================== AOE ===================== #}
  <section class="mb-5" aria-labelledby="aoe-heading">
    <h2 id="aoe-heading" class="section-title mb-4">
      <i class="bi bi-book-fill text-success me-2" style="font-size: 1rem;"></i>AOE Learning Materials
    </h2>
    {% if finnaAoe and finnaAoe.rows and finnaAoe.rows.length %}
      <div class="presentation-scroller mb-4" data-key="aoe" aria-label="AOE presentation scroller">
        <div class="presentation-scroller-track"></div>
      </div>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 pub-table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Description</th>
              <th class="text-nowrap">Date / year</th>
              <th class="text-nowrap">Open</th>
            </tr>
          </thead>
          <tbody id="table-body-aoe"></tbody>
        </table>
      </div>
      <nav class="mt-3" aria-label="AOE pagination">
        <ul class="pagination pagination-sm mb-0" id="pagination-aoe"></ul>
      </nav>
      <div class="mt-3 text-muted small">
        Source: <a href="https://www.finna.fi/" target="_blank" rel="noopener noreferrer">Finna</a> / <a href="https://aoe.fi/" target="_blank" rel="noopener noreferrer">Open Educational Resources Library (AOE)</a>{% if finnaAoe.source == 'cache' %} (cached){% endif %}.
      </div>
    {% else %}
      <p class="text-muted">No AOE learning materials available.</p>
    {% endif %}
  </section>

  {# ===================== CANVA ===================== #}
  <section class="mb-5" aria-labelledby="canva-heading">
    <h2 id="canva-heading" class="section-title mb-4">
      <i class="bi bi-star-fill text-warning me-2" style="font-size: 1rem;"></i>Canva Presentations
    </h2>

    {# CTA card: Canva analysis #}
    <div class="card border-0 shadow-sm mb-4 border-start border-4 border-warning">
      <div class="card-body p-4">
        <div class="row align-items-center g-3">
          <div class="col-auto d-none d-sm-block">
            <i class="bi bi-bar-chart-line text-warning" style="font-size:2rem;"></i>
          </div>
          <div class="col">
            <p class="text-uppercase text-muted fw-semibold small mb-1">Analysis</p>
            <h3 class="h5 fw-bold mb-1">Canva presentations 2021–2026 – 83 presentations analysed</h3>
            <p class="text-muted small mb-0">Topics, trajectories, most extensive presentations and common threads — the decade of AI literacy.</p>
          </div>
          <div class="col-12 col-sm-auto">
            <a href="/esitykset/canva-analyysi/" class="btn btn-warning btn-sm px-3 text-dark">
              Read analysis <i class="bi bi-arrow-right ms-1"></i>
            </a>
          </div>
        </div>
      </div>
    </div>

    {% if canva and canva.tableRows and canva.tableRows.length %}
      <div class="presentation-scroller mb-4" data-key="canva" aria-label="Canva presentation scroller">
        <div class="presentation-scroller-track"></div>
      </div>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 pub-table">
          <thead>
            <tr>
              <th class="text-center" style="width:140px">Date</th>
              <th style="min-width:170px">Preview</th>
              <th style="min-width:200px;max-width:260px;">Title</th>
              <th style="min-width:220px">Summary</th>
              <th style="min-width:190px">Keywords</th>
              <th style="width:90px" class="text-center">Open</th>
            </tr>
          </thead>
          <tbody id="table-body-canva"></tbody>
        </table>
      </div>
      <nav class="mt-3" aria-label="Canva pagination">
        <ul class="pagination pagination-sm mb-0" id="pagination-canva"></ul>
      </nav>
      <div class="mt-3 text-muted small">
        Source: Canva (JSON).
      </div>
    {% else %}
      <p class="text-muted">No Canva presentations available.</p>
    {% endif %}
  </section>

  {# ================ GOOGLE SLIDES ================ #}
  <section class="mb-5" aria-labelledby="google-heading">
    <h2 id="google-heading" class="section-title mb-4">
      <i class="bi bi-file-earmark-slides me-2" style="font-size: 1rem;"></i>Google Slides Presentations
    </h2>
    {% if googleslides and googleslides.length %}
      <div class="presentation-scroller mb-4" data-key="google" aria-label="Google Slides presentation scroller" tabindex="0">
        <div class="presentation-scroller-track"></div>
      </div>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 pub-table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Description</th>
              <th class="text-nowrap">Date / year</th>
              <th class="text-nowrap">Open</th>
            </tr>
          </thead>
          <tbody id="table-body-google"></tbody>
        </table>
      </div>
      <nav class="mt-3" aria-label="Google Slides pagination">
        <ul class="pagination pagination-sm mb-0" id="pagination-google"></ul>
      </nav>
    {% else %}
      <p class="text-muted">No Google Slides presentations available.</p>
    {% endif %}
  </section>

  {# ================= SLIDESHARE ================== #}
  <section class="mb-5" aria-labelledby="slideshare-heading">
    <h2 id="slideshare-heading" class="section-title mb-4">
      <i class="bi bi-collection-play me-2" style="font-size: 1rem;"></i>SlideShare Presentations
    </h2>

    {# CTA card: SlideShare analysis #}
    <div class="card border-0 shadow-sm mb-4 border-start border-4 border-primary">
      <div class="card-body p-4">
        <div class="row align-items-center g-3">
          <div class="col-auto d-none d-sm-block">
            <i class="bi bi-bar-chart-line text-primary" style="font-size:2rem;"></i>
          </div>
          <div class="col">
            <p class="text-uppercase text-muted fw-semibold small mb-1">Analysis</p>
            <h3 class="h5 fw-bold mb-1">SlideShare presentations 2009–2020 – 117 presentations analysed</h3>
            <p class="text-muted small mb-0">Topics, trajectories, most-viewed presentations and common threads by decade — from mobile learning to AI.</p>
          </div>
          <div class="col-12 col-sm-auto">
            <a href="/esitykset/slideshare-analyysi/" class="btn btn-primary btn-sm px-3">
              Read analysis <i class="bi bi-arrow-right ms-1"></i>
            </a>
          </div>
        </div>
      </div>
    </div>

    {% if ssDataItems.length %}
      <div class="presentation-scroller mb-4" data-key="slideshare" aria-label="SlideShare presentation scroller">
        <div class="presentation-scroller-track"></div>
      </div>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 pub-table">
          <thead>
            <tr>
              <th class="text-center" style="width:140px">Date</th>
              <th style="min-width:170px">Preview</th>
              <th style="min-width:200px;max-width:260px;">Title</th>
              <th style="min-width:220px">Summary</th>
              <th style="min-width:190px">Keywords</th>
              <th style="width:90px" class="text-center">Open</th>
            </tr>
          </thead>
          <tbody id="table-body-slideshare"></tbody>
        </table>
      </div>
      <nav class="mt-3" aria-label="SlideShare pagination">
        <ul class="pagination pagination-sm mb-0" id="pagination-slideshare"></ul>
      </nav>
    {% else %}
      <p class="text-muted">No SlideShare presentations available.</p>
    {% endif %}

    <div class="mt-4 text-center">
      <a href="https://www.slideshare.net/larux" target="_blank" rel="noopener noreferrer" class="btn btn-primary px-4 py-2">
        View all on SlideShare ({{ ssDataItems.length }}) <i class="bi bi-arrow-up-right"></i>
      </a>
    </div>
  </section>

  {# ===================== YOUTUBE ===================== #}
  <section class="mb-5" aria-labelledby="youtube-heading">
    <h2 id="youtube-heading" class="section-title mb-4">
      <i class="bi bi-youtube text-danger me-2" style="font-size: 1rem;"></i>YouTube Playlists
    </h2>

    {% if youtube and youtube.tableRows and youtube.tableRows.length %}
      <div class="presentation-scroller mb-4" data-key="youtube" aria-label="YouTube playlist scroller">
        <div class="presentation-scroller-track"></div>
      </div>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 pub-table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Description</th>
              <th class="text-nowrap">Date / year</th>
              <th class="text-nowrap">Open</th>
            </tr>
          </thead>
          <tbody id="table-body-youtube"></tbody>
        </table>
      </div>
      <nav class="mt-3" aria-label="YouTube pagination">
        <ul class="pagination pagination-sm mb-0" id="pagination-youtube"></ul>
      </nav>
      <div class="mt-3 text-muted small">
        Source: YouTube Data API v3{% if youtube.source == 'cache' %} (cached){% endif %}.
      </div>
    {% else %}
      <div class="card border-0 bg-light-subtle">
        <div class="card-body">
          <p class="mb-2 fw-semibold">Could not fetch YouTube playlists.</p>
          <p class="text-muted mb-0 small">
            Set <code>YOUTUBE_API_KEY</code> and, if needed, <code>YOUTUBE_CHANNEL_ID</code> or <code>YOUTUBE_HANDLE</code>.
          </p>
        </div>
      </div>
    {% endif %}
  </section>

  {# Archive list: static link list for all presentation pages (SEO navigation) #}
  <section class="mb-5">
    <div class="container">
      <details>
        <summary class="text-muted small py-2" style="cursor:pointer;">All presentations as archive ({{ collections.presentations | length }})</summary>
        <ul class="list-unstyled row row-cols-1 row-cols-md-2 g-1 mt-2">
          {% for item in collections.presentations | sort(attribute="data.date", reverse=true) %}
            <li class="col"><a class="small text-decoration-none text-muted" href="{{ item.url }}">{{ item.data.title }}</a></li>
          {% endfor %}
        </ul>
      </details>
    </div>
  </section>

</div>

<script>
(() => {
  const PAGE_SIZE = 6;
  const rawData = {
    aoe: {{ (finnaAoe.rows or []) | dump | safe }},
    canva: {{ (canva.tableRows or []) | dump | safe }},
    youtube: {{ (youtube.tableRows or []) | dump | safe }},
    google: {{ (googleslides or []) | dump | safe }},
    slideshare: {{ ssDataItems | dump | safe }}
  };

  // Map Canva MD page URLs to external Canva URLs
  const canvaPageUrlMap = {};
  {{ canvaPageUrls | dump | safe }}.forEach(p => { canvaPageUrlMap[p.externalUrl] = p.pageUrl; });
  rawData.canva.forEach(item => { item.pageUrl = canvaPageUrlMap[item.url] || null; });

  const iconByKey = {
    aoe: "bi-book",
    canva: "bi-file-earmark-slides",
    youtube: "bi-youtube",
    google: "bi-file-earmark-slides",
    slideshare: "bi-collection-play"
  };

  const linkLabelByKey = {
    aoe: "Open in Finna",
    canva: "Open",
    youtube: "YouTube",
    google: "Open",
    slideshare: "SlideShare"
  };

  function escHtml(value) {
    return String(value || "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function truncate(value, max = 120) {
    const text = String(value || "").trim();
    if (!text) return "";
    return text.length > max ? `${text.slice(0, max).trim()}…` : text;
  }

  function toDisplayDate(value) {
    if (!value) return "";
    const parsed = new Date(value);
    if (!Number.isNaN(parsed.getTime())) {
      return new Intl.DateTimeFormat("en-GB").format(parsed);
    }
    return String(value);
  }

  function toIsoDate(value) {
    if (!value) return null;
    const raw = String(value).trim();
    if (/^\d{4}-\d{2}-\d{2}$/.test(raw)) return raw;
    const parsed = new Date(raw);
    if (Number.isNaN(parsed.getTime())) return null;
    const year = parsed.getUTCFullYear();
    const month = String(parsed.getUTCMonth() + 1).padStart(2, "0");
    const day = String(parsed.getUTCDate()).padStart(2, "0");
    return `${year}-${month}-${day}`;
  }

  function extractSlideshareDateFromThumbnail(thumbnailUrl) {
    if (!thumbnailUrl) return null;
    const match = String(thumbnailUrl).match(/-(\d{6})\d{6}-/);
    if (!match) return null;
    const yymmdd = match[1];
    const yy = Number.parseInt(yymmdd.slice(0, 2), 10);
    const mm = Number.parseInt(yymmdd.slice(2, 4), 10);
    const dd = Number.parseInt(yymmdd.slice(4, 6), 10);
    if (!Number.isFinite(yy) || !Number.isFinite(mm) || !Number.isFinite(dd)) return null;
    if (mm < 1 || mm > 12 || dd < 1 || dd > 31) return null;
    const year = yy >= 90 ? 1900 + yy : 2000 + yy;
    return `${year}-${String(mm).padStart(2, "0")}-${String(dd).padStart(2, "0")}`;
  }

  function normalizeSlideshareIsoDate(value, thumbnailUrl) {
    return extractSlideshareDateFromThumbnail(thumbnailUrl) || toIsoDate(value) || "";
  }

  function normalizeRows(key, rows) {
    if (!Array.isArray(rows)) return [];

    if (key === "aoe") {
      return rows.map((r) => ({
        title: r.title || "Unnamed learning material",
        url: r.url || "",
        thumbnail: r.image || "",
        description: r.summary || "",
        meta: "AOE / Learning material",
        date: r.year || ""
      }));
    }

    if (key === "canva") {
      return rows.map((r) => ({
        title: r.title || "Unnamed presentation",
        url: r.url || "",
        thumbnail: r.thumbnail || "",
        description: r.description || "",
        keywords: Array.isArray(r.categories) ? r.categories.filter(Boolean) : [],
        meta: "Canva",
        date: toDisplayDate(toIsoDate(r.date || r.publishedAt || r.createdAt || r.updatedAt || "") || "")
      }));
    }

    if (key === "youtube") {
      return rows.map((r) => ({
        title: r.title || "Unnamed playlist",
        url: r.url || "",
        thumbnail: r.thumbnail || "",
        description: r.description || "",
        meta: `${r.itemCount || 0} videos`,
        date: toDisplayDate(r.publishedAt || "")
      }));
    }

    if (key === "google") {
      return rows.map((r) => ({
        title: r.title || "Unnamed presentation",
        url: r.url || "",
        thumbnail: r.thumbnail || "",
        description: "Google Slides presentation",
        meta: "Google Slides",
        date: r.date || ""
      }));
    }

    if (key === "slideshare") {
      return rows.map((r) => ({
        date: toDisplayDate(normalizeSlideshareIsoDate(r.date || "", r.thumbnail || "")),
        title: r.title || "Unnamed presentation",
        url: r.url || "",
        thumbnail: r.thumbnail || "",
        description: r.description || "",
        keywords: [
          ...(Array.isArray(r.categories) ? r.categories : []),
          ...(Array.isArray(r.keywords) ? r.keywords : [])
        ].map((value) => String(value || "").trim()).filter(Boolean)
      }));
    }

    return [];
  }

  function pickFourRandom(rows) {
    if (!rows.length) return [];
    const shuffled = [...rows];
    for (let i = shuffled.length - 1; i > 0; i -= 1) {
      const j = Math.floor(Math.random() * (i + 1));
      [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
    }
    const picked = shuffled.slice(0, Math.min(4, shuffled.length));
    while (picked.length < 4) {
      picked.push(shuffled[picked.length % shuffled.length]);
    }
    return picked;
  }

  function renderScroller(key, rows) {
    const host = document.querySelector(`.presentation-scroller[data-key="${key}"] .presentation-scroller-track`);
    if (!host) return;
    const cards = pickFourRandom(rows);
    if (!cards.length) {
      host.innerHTML = "";
      return;
    }

    const htmlCards = cards.map((item) => {
      const thumb = item.thumbnail
        ? `<div class="scroller-media">
             <img src="${escHtml(item.thumbnail)}" class="card-img-top" alt="${escHtml(item.title)}" loading="lazy" decoding="async" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
             <div class="scroller-placeholder" style="display:none;"><i class="bi ${escHtml(iconByKey[key] || "bi-file-earmark")}"></i></div>
           </div>`
        : `<div class="scroller-placeholder"><i class="bi ${escHtml(iconByKey[key] || "bi-file-earmark")}"></i></div>`;
      const link = item.url
        ? `<a href="${escHtml(item.url)}" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm rounded-pill px-3">${escHtml(linkLabelByKey[key] || "Open")} <i class="bi bi-arrow-up-right"></i></a>`
        : `<span class="text-muted small"><i class="bi bi-link-45deg"></i> No link</span>`;
      const pageLink = item.pageUrl
        ? `<a href="${escHtml(item.pageUrl)}" class="btn btn-outline-secondary btn-sm rounded-pill px-2 ms-1" title="Presentation page"><i class="bi bi-file-earmark-text"></i></a>`
        : "";
      return `
        <article class="card border-0 shadow-sm presentation-scroller-card">
          ${thumb}
          <div class="card-body p-3">
            <h3 class="h6 mb-1">${escHtml(item.title)}</h3>
            ${item.date ? `<p class="text-muted small mb-1"><i class="bi bi-calendar3 me-1"></i>${escHtml(item.date)}</p>` : ""}
            <p class="text-muted small mb-3">${escHtml(truncate(item.meta || item.description, 72))}</p>
            ${link}${pageLink}
          </div>
        </article>
      `;
    }).join("");

    host.innerHTML = `${htmlCards}${htmlCards}`;
  }

  function renderPagination(key, rows, page, onChange) {
    const host = document.getElementById(`pagination-${key}`);
    if (!host) return;
    const pageCount = Math.ceil(rows.length / PAGE_SIZE);
    if (pageCount <= 1) {
      host.innerHTML = "";
      return;
    }

    let html = "";
    for (let p = 1; p <= pageCount; p += 1) {
      html += `
        <li class="page-item ${p === page ? "active" : ""}">
          <button class="page-link" type="button" data-page="${p}">${p}</button>
        </li>
      `;
    }
    host.innerHTML = html;
    host.querySelectorAll("button[data-page]").forEach((btn) => {
      btn.addEventListener("click", () => onChange(Number(btn.dataset.page)));
    });
  }

  function renderTable(key, rows, page, onChange) {
    const tbody = document.getElementById(`table-body-${key}`);
    if (!tbody) return;
    const start = (page - 1) * PAGE_SIZE;
    const pageRows = rows.slice(start, start + PAGE_SIZE);

    if (key === "canva" || key === "slideshare") {
      tbody.innerHTML = pageRows.map((item) => {
        const keywords = Array.isArray(item.keywords) ? item.keywords : [];
        const keywordHtml = keywords.length
          ? keywords.map((k) => `<span class="badge text-bg-light text-dark border me-1 mb-1">${escHtml(k)}</span>`).join("")
          : '<span class="text-muted small">Not available</span>';
        const preview = item.thumbnail
          ? `<img src="${escHtml(item.thumbnail)}" alt="${escHtml(item.title)}" class="img-fluid border" style="max-height:72px;object-fit:cover;" loading="lazy" decoding="async" onerror="this.outerHTML='<span class=&quot;text-muted small&quot;>Not available</span>';">`
          : '<span class="text-muted small">Not available</span>';
        const summary = item.description ? escHtml(truncate(item.description, 220)) : '<span class="text-muted small">Not available</span>';
        return `
          <tr>
            <td class="text-center small text-muted font-monospace" data-label="Date">${escHtml(item.date || "Not available")}</td>
            <td class="small text-muted text-center" data-label="Preview">${preview}</td>
            <td class="fw-semibold" data-label="Title">${escHtml(item.title)}</td>
            <td class="small" data-label="Summary">${summary}</td>
            <td data-label="Keywords">${keywordHtml}</td>
            <td class="text-center" data-label="Open">
              <div class="d-flex gap-1 justify-content-center flex-wrap">
              ${item.url
                ? `<a href="${escHtml(item.url)}" target="_blank" rel="noopener noreferrer" class="btn btn-outline-primary btn-sm rounded-pill px-2" title="Open presentation"><i class="bi bi-arrow-up-right"></i></a>`
                : `<span class="text-muted small">No link</span>`}
              ${item.pageUrl
                ? `<a href="${escHtml(item.pageUrl)}" class="btn btn-outline-secondary btn-sm rounded-pill px-2" title="Presentation page"><i class="bi bi-file-earmark-text"></i></a>`
                : ""}
              </div>
            </td>
          </tr>
        `;
      }).join("");
    } else {
      tbody.innerHTML = pageRows.map((item) => `
        <tr>
          <td class="fw-semibold" data-label="Title">${escHtml(item.title)}</td>
          <td data-label="Description">
            <div class="small">${escHtml(truncate(item.description, 140) || "-")}</div>
            <div class="small text-muted">${escHtml(item.meta || "")}</div>
          </td>
          <td class="text-nowrap" data-label="Date / year">${escHtml(item.date || "-")}</td>
          <td data-label="Open">
            ${item.url
              ? `<a href="${escHtml(item.url)}" target="_blank" rel="noopener noreferrer" class="btn btn-outline-primary btn-sm rounded-pill px-3">${escHtml(linkLabelByKey[key] || "Open")}</a>`
              : `<span class="text-muted small">No link</span>`}
          </td>
        </tr>
      `).join("");
    }

    renderPagination(key, rows, page, onChange);
  }

  Object.entries(rawData).forEach(([key, rows]) => {
    const normalized = normalizeRows(key, rows);
    if (!normalized.length) return;
    renderScroller(key, normalized);
    let currentPage = 1;
    const rerender = (newPage) => {
      currentPage = newPage;
      renderTable(key, normalized, currentPage, rerender);
    };
    rerender(1);
  });
})();
</script>

