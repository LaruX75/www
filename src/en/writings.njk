#julkaisut .pagination .page-link {
  border-radius: 0.3rem !important;
  margin: 0 1px;
  padding: 0.25rem 0.5rem;
}
</style>

<script>
(function () {
  const PAGE_SIZE = 5;
  const dataEl = document.getElementById('pub-data');
  if (!dataEl) return;
  const rawData = JSON.parse(dataEl.textContent);

  // Järjestetään uusin ensin oletuksena
  let data = [...rawData].sort((a, b) => (b.year || 0) - (a.year || 0));
  let filteredData = [...data];
  let currentPage = 1;
  let sortCol = 'year';
  let sortDir = -1; // -1 = desc, 1 = asc

  const yearSel = document.getElementById('pub-year');
  const searchInp = document.getElementById('pub-search');
  const tbody = document.getElementById('pub-tbody');
  const info = document.getElementById('pub-info');
  const pagUl = document.getElementById('pub-pagination');

  // --- Yearsuodatin ---
  const years = [...new Set(data.filter(d => d.year > 0).map(d => d.year))].sort((a, b) => b - a);
  if (yearSel) {
    years.forEach(y => {
      const opt = document.createElement('option');
      opt.value = y;
      opt.textContent = y;
      yearSel.appendChild(opt);
    });
  }

  // --- Suodatus ---
  function applyFilters() {
    const q = searchInp ? searchInp.value.toLowerCase().trim() : '';
    const yr = yearSel ? yearSel.value : '';
    filteredData = data.filter(d => {
      const matchQ = !q ||
        (d.title || '').toLowerCase().includes(q) ||
        (d.authors || '').toLowerCase().includes(q) ||
        (d.journal || '').toLowerCase().includes(q);
      const matchY = !yr || String(d.year) === yr;
      return matchQ && matchY;
    });
    currentPage = 1;
    render();
  }

  // --- Lajittelu ---
  function sortData(col) {
    if (sortCol === col) { sortDir *= -1; }
    else { sortCol = col; sortDir = col === 'year' ? -1 : 1; }
    filteredData.sort((a, b) => {
      let av = a[col] ?? '';
      let bv = b[col] ?? '';
      if (typeof av === 'string') av = av.toLowerCase();
      if (typeof bv === 'string') bv = bv.toLowerCase();
      if (typeof av === 'number' && typeof bv === 'number') return (av - bv) * sortDir;
      return av.toString().localeCompare(bv.toString(), 'fi') * sortDir;
    });
    currentPage = 1;
    render();
  }

  // --- Renderöinti ---
  function render() {
    if (!tbody || !info) return;

    const totalPages = Math.max(1, Math.ceil(filteredData.length / PAGE_SIZE));
    const start = (currentPage - 1) * PAGE_SIZE;
    const slice = filteredData.slice(start, start + PAGE_SIZE);

    // Taulukko
    if (slice.length === 0) {
      tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-5">No results for this search</td></tr>';
    } else {
      tbody.innerHTML = slice.map((d, index) => {
        const globalIndex = start + index;
        const linkCell = d.url
          ? `<a href="${escHtml(d.url)}" target="_blank" rel="noopener"
               class="btn btn-outline-primary btn-sm rounded-pill px-2" title="Open publication">
               <i class="bi bi-arrow-up-right"></i>
             </a>`
          : `<span class="text-muted small">—</span>`;

        const bibButton = `<button class="btn btn-outline-secondary btn-sm rounded-pill px-2 ms-1 bib-btn" 
                            data-index="${globalIndex}" title="Download BibTeX">
                            <i class="bi bi-quote"></i>
                          </button>`;

        return `<tr>
          <td class="col-authors small text-muted">${escHtml(d.authors || '—')}</td>
          <td class="text-center fw-semibold">${d.year || '—'}</td>
          <td class="col-title">${escHtml(d.title || '—')}</td>
          <td class="col-pub">${escHtml(d.journal || '—')}</td>
          <td class="text-center">
            <div class="d-flex justify-content-center">
              ${linkCell}
              ${bibButton}
            </div>
          </td>
        </tr>`;
      }).join('');

      // Lisää kuuntelijat BibTeX-napeille
      tbody.querySelectorAll('.bib-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const idx = parseInt(btn.dataset.index);
          downloadBibTeX(filteredData[idx]);
        });
      });
    }

    // Info
    const total = filteredData.length;
    const from = total === 0 ? 0 : start + 1;
    const to = Math.min(start + PAGE_SIZE, total);
    info.textContent = `Showing ${from}–${to} / ${total}`;

    // Pagination
    renderPagination(totalPages);

    // Sarakekorostus
    document.querySelectorAll('.pub-table th.sortable').forEach(th => {
      th.classList.remove('sort-asc', 'sort-desc');
      if (th.dataset.col === sortCol) {
        th.classList.add(sortDir === 1 ? 'sort-asc' : 'sort-desc');
      }
    });
  }

  function renderPagination(total) {
    if (!pagUl) return;
    pagUl.innerHTML = '';
    
    // Yksinkertainen sivutus (1, 2, 3...)
    for (let i = 1; i <= total; i++) {
      const li = document.createElement('li');
      li.className = `page-item${i === currentPage ? ' active' : ''}`;
      const a = document.createElement('a');
      a.className = 'page-link';
      a.href = '#';
      a.textContent = i;
      a.addEventListener('click', e => {
        e.preventDefault();
        currentPage = i;
        render();
        // Skrollaus kortin alkuun
        document.getElementById('julkaisut')?.scrollIntoView({behavior:'smooth', block:'start'});
      });
      li.appendChild(a);
      pagUl.appendChild(li);
    }
  }

  function escHtml(str) {
    if (!str) return '';
    return String(str)
      .replace(/&/g,'&amp;').replace(/</g,'&lt;')
      .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // --- Tapahtumankäsittelijät ---
  if (searchInp) searchInp.addEventListener('input', applyFilters);
  if (yearSel) yearSel.addEventListener('change', applyFilters);
  
  const resetBtn = document.getElementById('pub-reset');
  if (resetBtn) {
    resetBtn.addEventListener('click', () => {
      if (searchInp) searchInp.value = '';
      if (yearSel) yearSel.value = '';
      applyFilters();
    });
  }

  document.querySelectorAll('.pub-table th.sortable').forEach(th => {
    th.addEventListener('click', () => sortData(th.dataset.col));
  });

  function downloadBibTeX(d) {
    const typeMap = {
      "A1": "article", "A2": "article", "B1": "article",
      "A3": "incollection", "B2": "incollection",
      "A4": "inproceedings", "B3": "inproceedings", "D3": "inproceedings",
      "C1": "book", "E2": "book",
      "C2": "proceedings",
      "G4": "phdthesis", "G5": "phdthesis"
    };

    const bibType = typeMap[d.typeCode] || "misc";
    const authors = d.authors || "Laru, Jari";
    const firstAuthor = authors.split(/[,&]/)[0].trim().split(/\s+/).pop().toLowerCase();
    const key = `${firstAuthor}${d.year || 'unknown'}${d.title.split(/\s+/)[0].replace(/[^a-z]/gi, '').toLowerCase()}`;

    let bib = `@${bibType}{${key},\n`;
    bib += `  title = {${d.title}},\n`;
    bib += `  author = {${authors}},\n`;
    if (d.year) bib += `  year = {${d.year}},\n`;
    if (d.journal) {
      if (bibType === "article") bib += `  journal = {${d.journal}},\n`;
      else if (bibType === "inproceedings" || bibType === "incollection") bib += `  booktitle = {${d.journal}},\n`;
      else bib += `  publisher = {${d.journal}},\n`;
    }
    if (d.url) bib += `  url = {${d.url}},\n`;
    bib += `}`;

    const blob = new Blob([bib], { type: 'text/plain' });
    const url = window.URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.style.display = 'none';
    a.href = url;
    a.download = `${key}.bib`;
    document.body.appendChild(a);
    a.click();
    window.URL.revokeObjectURL(url);
    document.body.removeChild(a);
  }

  // Initialize
  render();
})();

// --- Blog taulukon logiikka ---
(function () {
  const BLOG_PAGE_SIZE = 5;
  const blogDataEl = document.getElementById('blog-data');
  if (!blogDataEl) return;
  const blogData = JSON.parse(blogDataEl.textContent);

  let filteredBlogData = [...blogData];
  let blogCurrentPage = 1;
  let blogSortCol = 'date';
  let blogSortDir = -1; // -1 = desc

  const blogSearchInp = document.getElementById('blog-search');
  const blogTbody = document.getElementById('blog-tbody');
  const blogInfo = document.getElementById('blog-info');
  const blogPagUl = document.getElementById('blog-pagination');

  function applyBlogFilters() {
    const q = blogSearchInp ? blogSearchInp.value.toLowerCase().trim() : '';
    filteredBlogData = blogData.filter(d => {
      const matchQ = !q ||
        (d.title || '').toLowerCase().includes(q) ||
        (d.description || '').toLowerCase().includes(q) ||
        (d.categories || []).some(c => c.toLowerCase().includes(q)) ||
        (d.keywords || []).some(k => k.toLowerCase().includes(q));
      return matchQ;
    });
    blogCurrentPage = 1;
    renderBlog();
  }

  function sortBlogData(col) {
    if (blogSortCol === col) { blogSortDir *= -1; }
    else { blogSortCol = col; blogSortDir = col === 'date' ? -1 : 1; }
    
    filteredBlogData.sort((a, b) => {
      let av = a[col] ?? '';
      let bv = b[col] ?? '';
      if (typeof av === 'string') av = av.toLowerCase();
      if (typeof bv === 'string') bv = bv.toLowerCase();
      if (col === 'date') {
        return (new Date(av) - new Date(bv)) * blogSortDir;
      }
      return av.toString().localeCompare(bv.toString(), 'fi') * blogSortDir;
    });
    blogCurrentPage = 1;
    renderBlog();
  }

  function renderBlog() {
    if (!blogTbody || !blogInfo) return;

    const totalPages = Math.max(1, Math.ceil(filteredBlogData.length / BLOG_PAGE_SIZE));
    const start = (blogCurrentPage - 1) * BLOG_PAGE_SIZE;
    const slice = filteredBlogData.slice(start, start + BLOG_PAGE_SIZE);

    if (slice.length === 0) {
      blogTbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-5">No results for this search</td></tr>';
    } else {
      blogTbody.innerHTML = slice.map(d => {
        const catBadges = (d.categories || []).map(c => `<a href="/kategoriat/${slugify(c)}/" class="badge text-bg-secondary me-1 text-decoration-none">${c}</a>`).join('');
        const keyBadges = (d.keywords || []).map(k => `<a href="/avainsanat/${slugify(k)}/" class="badge text-bg-light text-dark border me-1 text-decoration-none">${k}</a>`).join('');

        return `<tr>
          <td class="col-date text-center small text-muted font-monospace">${d.formattedDate}</td>
          <td class="col-title fw-medium"><a href="${d.url}" class="text-decoration-none">${escHtml(d.title)}</a></td>
          <td class="col-desc small text-muted">${escHtml(d.description)}</td>
          <td>
            <div class="mb-1">${catBadges}</div>
            <div>${keyBadges}</div>
          </td>
          <td class="text-center">
            <a href="${d.url}" class="btn btn-outline-primary btn-sm rounded-pill px-2" title="Read blogipostaus">
              <i class="bi bi-arrow-right"></i>
            </a>
          </td>
        </tr>`;
      }).join('');
    }

    const total = filteredBlogData.length;
    const from = total === 0 ? 0 : start + 1;
    const to = Math.min(start + BLOG_PAGE_SIZE, total);
    blogInfo.textContent = `Showing ${from}–${to} / ${total}`;

    renderBlogPagination(totalPages);

    document.querySelectorAll('.blog-table th.sortable').forEach(th => {
      th.classList.remove('sort-asc', 'sort-desc');
      if (th.dataset.col === blogSortCol) {
        th.classList.add(blogSortDir === 1 ? 'sort-asc' : 'sort-desc');
      }
    });
  }

  function renderBlogPagination(total) {
    if (!blogPagUl) return;
    blogPagUl.innerHTML = '';
    if (total <= 1) return;
    
    for (let i = 1; i <= total; i++) {
      const li = document.createElement('li');
      li.className = `page-item${i === blogCurrentPage ? ' active' : ''}`;
      const a = document.createElement('a');
      a.className = 'page-link';
      a.href = '#';
      a.textContent = i;
      a.addEventListener('click', e => {
        e.preventDefault();
        blogCurrentPage = i;
        renderBlog();
        document.getElementById('blogi')?.scrollIntoView({behavior:'smooth', block:'start'});
      });
      li.appendChild(a);
      blogPagUl.appendChild(li);
    }
  }

  function escHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function slugify(str) {
    if (!str) return "";
    return str.toLowerCase().replace(/ä/g, "a").replace(/ö/g, "o").replace(/å/g, "a").replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");
  }

  if (blogSearchInp) blogSearchInp.addEventListener('input', applyBlogFilters);
  
  const blogResetBtn = document.getElementById('blog-reset');
  if (blogResetBtn) {
    blogResetBtn.addEventListener('click', () => {
      if (blogSearchInp) blogSearchInp.value = '';
      applyBlogFilters();
    });
  }

  document.querySelectorAll('.blog-table th.sortable').forEach(th => {
    th.addEventListener('click', () => sortBlogData(th.dataset.col));
  });

  renderBlog();
})();

