// --- Columns taulukon logiikka ---
(function () {
  const KOLUMNIT_PAGE_SIZE = 5;
  const kolumnitDataEl = document.getElementById('kolumnit-data');
  if (!kolumnitDataEl) return;
  const kolumnitData = JSON.parse(kolumnitDataEl.textContent);

  let filteredColumnsData = [...kolumnitData];
  let kolumnitCurrentPage = 1;
  let kolumnitSortCol = 'date';
  let kolumnitSortDir = -1; // -1 = desc

  const kolumnitSearchInp = document.getElementById('kolumnit-search');
  const kolumnitTbody = document.getElementById('kolumnit-tbody');
  const kolumnitInfo = document.getElementById('kolumnit-info');
  const kolumnitPagUl = document.getElementById('kolumnit-pagination');

  function applyColumnsFilters() {
    const q = kolumnitSearchInp ? kolumnitSearchInp.value.toLowerCase().trim() : '';
    filteredColumnsData = kolumnitData.filter(d => {
      const matchQ = !q ||
        (d.title || '').toLowerCase().includes(q) ||
        (d.description || '').toLowerCase().includes(q) ||
        (d.publication || '').toLowerCase().includes(q) ||
        (d.categories || []).some(c => c.toLowerCase().includes(q)) ||
        (d.keywords || []).some(k => k.toLowerCase().includes(q));
      return matchQ;
    });
    kolumnitCurrentPage = 1;
    renderColumns();
  }

  function sortColumnsData(col) {
    if (kolumnitSortCol === col) { kolumnitSortDir *= -1; }
    else { kolumnitSortCol = col; kolumnitSortDir = col === 'date' ? -1 : 1; }
    
    filteredColumnsData.sort((a, b) => {
      let av = a[col] ?? '';
      let bv = b[col] ?? '';
      if (typeof av === 'string') av = av.toLowerCase();
      if (typeof bv === 'string') bv = bv.toLowerCase();
      if (col === 'date') {
        return (new Date(av) - new Date(bv)) * kolumnitSortDir;
      }
