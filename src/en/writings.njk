<style>
/* ---- Kynasta hero ---- */
.kynasta-hero {
  background-color: var(--bs-tertiary-bg, #f8f9fa);
  border-bottom: 1px solid var(--bs-border-color);
}
[data-bs-theme="dark"] .kynasta-hero {
  background-color: #1e2a3a !important;
  border-bottom-color: rgba(255,255,255,0.1);
}
[data-bs-theme="dark"] .kynasta-hero h1,
[data-bs-theme="dark"] .kynasta-hero p {
  color: #e0e0e0;
}

/* ---- Nav pills: theme-aware ---- */
.kynasta-hero .nav-link {
  color: var(--bs-body-color);
  background-color: var(--bs-secondary-bg);
  border-radius: 2rem;
  padding: 0.3rem 0.9rem;
  font-size: 0.875rem;
  font-weight: 500;
  transition: all 0.2s;
}
.kynasta-hero .nav-link:hover {
  background-color: var(--bs-emphasis-color);
  color: var(--bs-body-bg);
}
[data-bs-theme="dark"] .kynasta-hero .nav-link {
  background-color: rgba(255,255,255,0.08);
  color: #e0e0e0;
}
[data-bs-theme="dark"] .kynasta-hero .nav-link:hover {
  background-color: rgba(255,255,255,0.18);
  color: #ffffff;
}

/* ---- Nav count badge ---- */
.nav-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 1.4rem;
  height: 1.4rem;
  padding: 0 0.3rem;
  border-radius: 999px;
  font-size: 0.7rem;
  font-weight: 700;
  line-height: 1;
  background-color: rgba(0,0,0,0.12);
  color: inherit;
  margin-left: 0.25rem;
  vertical-align: middle;
}
[data-bs-theme="dark"] .nav-count {
  background-color: rgba(255,255,255,0.18);
}

/* ---- Card headers: theme-aware border ---- */
.card-header.bg-transparent {
  border-bottom-color: var(--bs-border-color);
}
[data-bs-theme="dark"] .card-header.bg-transparent {
  border-bottom-color: rgba(255,255,255,0.1) !important;
}
[data-bs-theme="dark"] .card-header.bg-transparent h2 {
  color: #ffffff;
}

/* ---- Section spacing ---- */
section[id] {
  /* Offset anchor jumps so section titles are not hidden behind sticky navbar */
  scroll-margin-top: 7rem;
  padding-top: 2rem;
  padding-bottom: 2rem;
}

/* ---- Keyword badges in dark mode ---- */
[data-bs-theme="dark"] .badge.text-bg-light {
