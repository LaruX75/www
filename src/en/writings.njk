        <p class="text-uppercase small text-muted mb-2">Writings</p>
        <h1 class="display-6 fw-bold mb-2">Writings, speeches and publications</h1>
        <p class="text-muted">A consolidated view of opinion pieces, columns, initiatives, speeches and publications.</p>
      </div>
      <div class="col-lg-4">
        <nav class="nav nav-pills flex-wrap gap-2 justify-content-lg-end">
          <a class="nav-link" href="#opinions">
            Opinions <span class="nav-count">{{ collections.pub_mielipide.length }}</span>
          </a>
          <a class="nav-link" href="#kolumnit">
            Columns <span class="nav-count">{{ collections.pub_kolumni.length }}</span>
          </a>
