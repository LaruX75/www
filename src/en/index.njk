                </blockquote>
            </div>
        </div>
    </div>
</section>

{# ── Recent content ticker ─────────────────────────────────────────── #}

{% set allRecentItems = [] %}

{% for post in collections.blog %}
  {% set item = { sortTs: post.date | toTimestamp, type: "blog", dateLabel: post.date | dateFormat, title: post.data.title, href: post.url, desc: post.data.description, isExternal: false } %}
  {% set _ = (allRecentItems.push(item), null) %}
{% endfor %}

{% for row in (canva.enRows or canva.tableRows or []) %}
  {% set item = { sortTs: row.date | toTimestamp, type: "pres", dateLabel: row.date | dateFormat, title: row.title, href: row.url, desc: row.location, thumbnail: row.thumbnail, isExternal: true } %}
  {% set _ = (allRecentItems.push(item), null) %}
{% endfor %}

{% for pub in (researchfi or []) %}
  {% set pubDateStr = pub.year ~ "-12-31" %}
  {% set item = { sortTs: pubDateStr | toTimestamp, type: "pub", dateLabel: pub.year, title: pub.title, href: pub.doiUrl or pub.url or "", authors: pub.authors, journal: pub.journal, typeShort: pub.typeShort, isExternal: true, hasDoi: pub.doiUrl } %}
  {% set _ = (allRecentItems.push(item), null) %}
{% endfor %}

{% set allRecentSorted = allRecentItems | sort(true, false, "sortTs") | take(9) %}

<section class="py-5 home-recent-section">
    <div class="container">
        <div class="d-flex align-items-baseline justify-content-between mb-4">
            <p class="text-uppercase fw-bold mb-0 home-recent-label">Recent content</p>
            <div class="d-flex gap-3">
                <a href="/en/writings/" class="home-recent-more">Writings →</a>
                <a href="/en/presentations/" class="home-recent-more">Presentations →</a>
                <a href="/en/publications/" class="home-recent-more">Publications →</a>
            </div>
        </div>
    </div>
    <div class="ticker-wrapper home-ticker-wrapper" id="recentTicker">
        <div class="ticker-track">

            {%- macro tickerCard(item) %}
            <div class="home-ticker-item home-ticker-item--{{ item.type }}">

                <div class="home-ticker-top">
                    {%- if item.type == "pres" and item.thumbnail %}
                    <img src="{{ item.thumbnail }}" alt="" loading="lazy" decoding="async">
                    {%- elif item.type == "pub" %}
                    <p class="home-apa7">
                        {%- if item.authors %}<span class="home-apa7-authors">{{ item.authors }}.</span> {% endif -%}
                        ({{ item.dateLabel }}).
                        <em>{{ item.title }}</em>.
                        {%- if item.journal %} <span class="home-apa7-journal">{{ item.journal }}</span>.{% endif %}
                        {%- if item.hasDoi %} <span class="home-apa7-doi">{{ item.hasDoi }}</span>{% endif %}
                    </p>
                    {%- elif item.desc %}
                    <p class="home-ticker-top-text">{{ item.desc }}</p>
                    {%- endif %}
                    <div class="home-ticker-top-fade"></div>
                </div>

                <div class="home-ticker-meta">
                    <span class="home-ticker-badge home-ticker-badge--{{ item.type }}">
                        {%- if item.type == "blog" %}Post{% elif item.type == "pres" %}Presentation{% else %}Publication{% endif -%}
                    </span>
                    <span class="home-ticker-date">&nbsp;·&nbsp;{{ item.dateLabel }}</span>
                    {%- if item.typeShort %}&nbsp;<span class="home-apa7-type">{{ item.typeShort }}</span>{% endif %}
                </div>

                <div class="home-ticker-title-wrap">
                    {%- if item.href %}
                    <a class="home-ticker-title" href="{{ item.href }}"{% if item.isExternal %} target="_blank" rel="noopener"{% endif %}>{{ item.title }}</a>
                    {%- else %}
                    <span class="home-ticker-title">{{ item.title }}</span>
                    {%- endif %}
                </div>

            </div>
            {%- endmacro %}

            {# Set 1 (original) #}
            <div class="ticker-content">
                {% for item in allRecentSorted %}{{ tickerCard(item) }}{% endfor %}
            </div>

            {# Set 2 (clone for seamless loop) #}
            <div class="ticker-content" aria-hidden="true" inert>
                {% for item in allRecentSorted %}{{ tickerCard(item) }}{% endfor %}
            </div>

        </div>
    </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const ticker = document.getElementById("recentTicker");
    if (!ticker) return;
    const track = ticker.querySelector(".ticker-track");
    const tickerContent = ticker.querySelector(".ticker-content");
    if (!track || !tickerContent) return;

    let direction = -1;
    const speed = 0.4;
    let currentX = 0;
    let animationId;
    let isDragging = false;
    let prevX = 0;

    track.style.animation = "none";

    function animate() {
        const setWidth = tickerContent.offsetWidth;
        currentX += direction * speed;
        if (currentX <= -setWidth) currentX += setWidth;
        else if (currentX >= 0) currentX -= setWidth;
        track.style.transform = `translateX(${currentX}px)`;
        animationId = requestAnimationFrame(animate);
    }

    animationId = requestAnimationFrame(animate);

    ticker.addEventListener("mouseenter", () => cancelAnimationFrame(animationId));
    ticker.addEventListener("mouseleave", () => {
        isDragging = false;
        ticker.style.cursor = "";
        animationId = requestAnimationFrame(animate);
    });
    ticker.addEventListener("mousedown", (e) => {
        isDragging = true;
        prevX = e.clientX;
        ticker.style.cursor = "grabbing";
        cancelAnimationFrame(animationId);
    });
    ticker.addEventListener("mousemove", (e) => {
        if (!isDragging) return;
        const dx = e.clientX - prevX;
        prevX = e.clientX;
        direction = dx > 0 ? 1 : -1;
        currentX += dx;
        const setWidth = tickerContent.offsetWidth;
        if (currentX <= -setWidth) currentX += setWidth;
        else if (currentX >= 0) currentX -= setWidth;
        track.style.transform = `translateX(${currentX}px)`;
    });
    ticker.addEventListener("mouseup", () => {
        isDragging = false;
        ticker.style.cursor = "ew-resize";
    });
});
</script>

<section class="py-5 bg-body-tertiary home-closing-section" style="border-top: 1px solid var(--bs-border-color-translucent);">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="home-closing-panel text-center">
                    <p class="text-uppercase text-muted fw-bold mb-2">Next step</p>
                    <h2 class="fw-bold mb-3">Looking for a trainer, speaker, or researcher?</h2>
                    <p class="mb-4">I am available for training sessions, keynotes, and research collaboration on AI literacy, learning technology, and educational development.</p>
                    <div class="home-closing-actions d-flex flex-wrap justify-content-center gap-2 mb-3">
                        <a class="btn btn-primary rounded-pill px-4" href="/en/contact/">Get in touch</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
