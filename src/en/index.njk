---
layout: base.njk
title: Home
lang: en
translationKey: home
permalink: /en/
description: University lecturer, researcher, municipal politician, and speaker.
---

{% set heroPresentationCount = (collections.presentations or []) | length + (slideshare or []) | length %}
{% set heroPublicationCount = (researchfi or []) | length %}
{% set heroOpinionCount = (collections.pub_mielipide or []) | length %}
{% set heroSpeechCount = (collections.pub_puhe or []) | length %}
{% set heroStats = [
    { count: heroPresentationCount, label: "presentations", href: "/en/presentations/" },
    { count: heroPublicationCount, label: "publications", href: "/en/publications/" },
    { count: heroOpinionCount, label: "opinion pieces", href: "/en/writings/#opinions" },
    { count: heroSpeechCount, label: "speeches", href: "/en/writings/#speeches" },
    { count: 100, label: "supervised theses", href: "/en/theses/" }
] %}

<section class="section-flush home-hero-section" id="heroSection">
    <div class="home-hero-backdrop" style="--hero-img: url('{{ '/img/WIN_20210329_16_06_01_Pro.jpg' | url }}')">
        <div class="container home-hero-content">
            <div class="row align-items-center g-4 g-lg-5">
                <div class="col-lg-7">
                    <p class="home-hero-eyebrow mb-2">Jari Laru</p>
                    <h1 class="home-hero-title mb-3">I train and research how AI and learning technology work in everyday education.</h1>
                    <div class="home-hero-roles">
                        <a class="home-hero-role-item" href="/en/work/">University Lecturer</a>
                        <a class="home-hero-role-item" href="/en/company/">Trainer (Larux t:mi)</a>
                        <a class="home-hero-role-item" href="/en/politics/">Municipal Politician</a>
                    </div>
                </div>
                <div class="col-lg-5 d-none d-lg-flex align-items-center justify-content-end">
                    <dl class="home-hero-kpi-grid mb-0">
                        {% for stat in heroStats | sort(true, false, "count") %}
                        <div class="home-hero-kpi">
                            <dd class="home-hero-kpi-value"><a class="home-hero-kpi-link" href="{{ stat.href }}">{{ stat.count }}</a></dd>
                            <dt class="home-hero-kpi-label">{{ stat.label }}</dt>
                        </div>
                        {% endfor %}
                    </dl>
                </div>
            </div>
        </div>
    </div>
    <div class="home-hero-wave" aria-hidden="true">
        <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z"/>
        </svg>
    </div>
</section>

<section class="section-flush bg-adaptive-dark-blue py-4 py-md-0 home-feature-section">
    <div class="container-fluid" style="padding-top: 0;">
        <div class="row gx-0 gy-4 gy-md-0">
            <div class="col-md-6 ps-0 pe-0 home-feature-image-col">
                <div class="h-100"><img loading="eager" fetchpriority="high" decoding="async" class="img-fluid object-fit-cover w-100 h-100" width="1024" height="768" style="min-height: 100%;" src="/img/WIN_20210329_16_06_01_Pro.jpg" alt="Jari Laru"></div>
            </div>
            <div class="col-md-6 d-flex flex-column justify-content-center ps-0 pe-0" style="padding: 2rem 1.5rem;">
                <h2 class="fw-bold mb-4" style="font-family: 'Bree Serif', serif;">Jari Jukka Laru, KT</h2>
                <div class="d-flex flex-column gap-4">
                    <div>
                        <h3 class="h5 fw-bold mb-1"><i class="bi bi-building me-2"></i>Municipal politician</h3>
                        <p class="text-muted mb-2">Second-term city councillor in Oulu (National Coalition Party). Involved in civic influence since high school.</p>
                        <a class="btn btn-outline-primary btn-sm" href="/en/politics/">Politics &rarr;</a>
                    </div>
                    <div>
                        <h3 class="h5 fw-bold mb-1"><i class="bi bi-mortarboard me-2"></i>University lecturer</h3>
                        <p class="text-muted mb-2">Lecturer in technology-enhanced learning at the Faculty of Education, University of Oulu.</p>
                        <a class="btn btn-outline-primary btn-sm" href="/en/work/">Work &rarr;</a>
                    </div>
                    <div>
                        <h3 class="h5 fw-bold mb-1"><i class="bi bi-mic me-2"></i>Trainer &amp; speaker</h3>
                        <p class="text-muted mb-2">Expert lectures and training in AI literacy, learning technology, and modern pedagogy.</p>
                        <a class="btn btn-outline-primary btn-sm" href="/en/company/">Training &amp; talks &rarr;</a>
                    </div>
                    <div>
                        <h3 class="h5 fw-bold mb-1"><i class="bi bi-house me-2"></i>Father &amp; husband</h3>
                        <p class="text-muted mb-2">Lives with family in Jääli, Oulu. Bibliophile, food enthusiast, road-tripper, and renovator of a 1970s house.</p>
                        <a class="btn btn-outline-primary btn-sm" href="/en/about/">About me &rarr;</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-flush bg-adaptive-dark-blue">
    <div class="container-fluid" style="padding-top: 0;border-radius: 0px;">
        <div class="row gx-0 gy-4 gy-md-0">
            <div class="col-md-6 text-center text-md-start d-flex d-sm-flex d-md-flex flex-column justify-content-center align-items-center align-self-start order-2 order-sm-1 justify-content-md-start align-items-md-center justify-content-xl-center ps-0 pe-0" style="height: auto;min-height: 100%;padding-bottom: 1em;padding-top: 0.5em;">
                <div class="border-0 w-100 align-self-start" style="max-width: none;width: auto;padding-top: 1em;padding-left: 1rem;padding-right: 1rem;">
                    <h2 class="text-uppercase fw-bold" style="font-family: 'Bree Serif', serif;padding: 0px;">Civic Impact</h2>
                    <h4>Politics and decision-making</h4>
                    <p>I work as a second-term city councillor in Oulu (National Coalition Party), with a long-term focus on practical, evidence-informed local policy.</p>
                    <a class="btn btn-read-more btn-sm rounded-pill px-3 mb-3" href="/en/politics/">Read more about politics</a>
                </div>
                <!-- Karuselli alkaa -->
                <div class="ticker-wrapper" id="blogTicker" style="margin-top: 1rem;">
                    <div class="ticker-track">
                        <!-- Ensimmäinen setti -->
                        <div class="ticker-content">
                            {% for post in collections.politicsAndOpinions | take(6) %}
                            <div class="ticker-item p-4">
                                <h4><a href="{{ post.url }}">{{ post.data.title }}</a></h4>
                                <div class="d-flex align-items-center mt-3 mb-3">
                                    {% if post.data.thumbnail %}
                                    <img loading="lazy" decoding="async" class="object-fit-cover rounded-circle flex-shrink-0 me-3" width="50" height="50" src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}">
                                    {% else %}
                                    <div class="rounded-circle flex-shrink-0 me-3 bg-secondary d-flex justify-content-center align-items-center" style="width: 50px; height: 50px;"><i class="bi bi-person text-light"></i></div>
                                    {% endif %}
                                    <div>
                                        <p class="fw-bold mb-0" style="font-size: 0.9rem;">Jari Laru</p>
                                        <p class="text-muted mb-0" style="font-size: 0.8rem;">Author &bull; {{ post.date | dateFormat }}</p>
                                    </div>
                                </div>
                                <p>{{ post.data.description or (post.content | excerpt) }}</p>
                                <div class="d-flex justify-content-start mt-3 mb-2">
                                    <a href="{{ post.url }}" class="btn btn-read-more btn-sm rounded-pill px-3">Read more <i class="bi bi-arrow-right"></i></a>
                                </div>
                                <div class="mt-3">
                                    {% if post.data.categories and post.data.categories.length > 0 %}
                                        {% for cat in post.data.categories %}
                                            <span class="badge text-bg-secondary rounded-pill me-1">{{ cat }}</span>
                                        {% endfor %}
                                    {% elif post.data.type %}
                                        <span class="badge text-bg-secondary rounded-pill me-1">{{ post.data.type | capitalize }}</span>
                                    {% else %}
                                        <span class="badge text-bg-secondary rounded-pill me-1">Publication</span>
                                    {% endif %}
                                </div>
                            </div>
                            {% else %}
                            <div class="ticker-item p-4">
                                <p>No posts yet.</p>
                            </div>
                            {% endfor %}
                        </div>
                        <!-- Toinen setti (klooni animaatiota varten) -->
                        <div class="ticker-content" aria-hidden="true">
                            {% for post in collections.politicsAndOpinions | take(6) %}
                            <div class="ticker-item p-4">
                                <h4><a href="{{ post.url }}">{{ post.data.title }}</a></h4>
                                <div class="d-flex align-items-center mt-3 mb-3">
                                    {% if post.data.thumbnail %}
                                    <img loading="lazy" decoding="async" class="object-fit-cover rounded-circle flex-shrink-0 me-3" width="50" height="50" src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}">
                                    {% else %}
                                    <div class="rounded-circle flex-shrink-0 me-3 bg-secondary d-flex justify-content-center align-items-center" style="width: 50px; height: 50px;"><i class="bi bi-person text-light"></i></div>
                                    {% endif %}
                                    <div>
                                        <p class="fw-bold mb-0" style="font-size: 0.9rem;">Jari Laru</p>
                                        <p class="text-muted mb-0" style="font-size: 0.8rem;">Author &bull; {{ post.date | dateFormat }}</p>
                                    </div>
                                </div>
                                <p>{{ post.data.description or (post.content | excerpt) }}</p>
                                <div class="d-flex justify-content-start mt-3 mb-2">
                                    <a href="{{ post.url }}" class="btn btn-read-more btn-sm rounded-pill px-3">Read more <i class="bi bi-arrow-right"></i></a>
                                </div>
                                <div class="mt-3">
                                    {% if post.data.categories and post.data.categories.length > 0 %}
                                        {% for cat in post.data.categories %}
                                            <span class="badge text-bg-secondary rounded-pill me-1">{{ cat }}</span>
                                        {% endfor %}
                                    {% elif post.data.type %}
                                        <span class="badge text-bg-secondary rounded-pill me-1">{{ post.data.type | capitalize }}</span>
                                    {% else %}
                                        <span class="badge text-bg-secondary rounded-pill me-1">Publication</span>
                                    {% endif %}
                                </div>
                            </div>
                            {% else %}
                            <div class="ticker-item p-4">
                                <p>No posts yet.</p>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
                <!-- Karuselli päättyy -->
            </div>
            <div class="col-md-6 order-1 order-sm-1 ps-0 pe-0 home-feature-image-col">
                <div class="h-100"><img loading="lazy" decoding="async" class="img-fluid object-fit-cover w-100 h-100" width="1024" height="768" style="min-height: 100%;transform: perspective(0px) scale(1);filter: blur(0px);transition: ease-in;" src="/img/valtuusto.jpg" alt="City council chamber"></div>
            </div>
        </div>
    </div>
</section>

