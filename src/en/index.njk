<script>
document.addEventListener("DOMContentLoaded", function() {
  function initTicker(tickerId) {
    const ticker = document.getElementById(tickerId);
    if (!ticker) return;

    const track = ticker.querySelector(".ticker-track");
    if (!track) return;
    
    let direction = -1; // -1 for left, 1 for right
    let speed = 1; // Animation speed multiplier
    let currentX = 0; // Current transform translateX value
    let animationId; // For requestAnimationFrame
    
    let isDragging = false;
    let startX;
    let prevX;

    // Width of a single set of items
    const tickerContent = ticker.querySelector(".ticker-content");
    if (!tickerContent) return;

    function animate() {
      const itemSetWidth = tickerContent.offsetWidth; 
      
      currentX += direction * speed;

      // Seamless loop reset logic
      if (currentX <= -itemSetWidth) {
        currentX += itemSetWidth;
      } else if (currentX >= 0) {
        currentX -= itemSetWidth;
      }

      track.style.transform = `translateX(${currentX}px)`;
      animationId = requestAnimationFrame(animate);
    }

    // Remove CSS animation to use JS animation instead for direction support
    track.style.animation = "none";

    // Start animation loop
    animationId = requestAnimationFrame(animate);

    // Käyttöliittymäkontrollien tapahtumankäsittelijät (hiiri)
    ticker.addEventListener("mouseenter", () => {
      cancelAnimationFrame(animationId);
    });

    ticker.addEventListener("mousedown", (e) => {
      isDragging = true;
      startX = e.clientX;
      prevX = e.clientX;
      ticker.style.cursor = "grabbing"; // Visuaalinen palaute tarttumisesta
    });

    ticker.addEventListener("mousemove", (e) => {
      if (!isDragging) return;
      
      // Suunnanvaihto ja manuaalinen rullaus hiirellä "raadattaessa"
      const deltaX = e.clientX - prevX;
      prevX = e.clientX;
      
      // Päivitetään kulkusuunta sen perusteella, mihin suuntaan hiirtä viimeksi vedettiin
      if (deltaX > 0) direction = 1; // Oikealle
      else if (deltaX < 0) direction = -1; // Vasemmalle

      currentX += deltaX;
      
      const itemSetWidth = tickerContent.offsetWidth; 
      
      // Karusellin saumaton toisto vetäessä
      if (currentX <= -itemSetWidth) {
        currentX += itemSetWidth;
      } else if (currentX >= 0) {
        currentX -= itemSetWidth;
      }

      track.style.transform = `translateX(${currentX}px)`;
    });

    ticker.addEventListener("mouseup", () => {
      isDragging = false;
      ticker.style.cursor = "ew-resize"; // Palauta kohdistin takaisin vapaaksi
    });

    ticker.addEventListener("mouseleave", () => {
      isDragging = false;
      ticker.style.cursor = "ew-resize";
      // Palautetaan tausta-animaatio käyntiin irroitettaessa hiiri koko laatikosta
      cancelAnimationFrame(animationId); 
      animationId = requestAnimationFrame(animate);
    });
  }

  // Initialize both tickers
  initTicker("blogTicker");
  initTicker("presentationTicker");
  initTicker("zoteroTicker");
});
</script>
