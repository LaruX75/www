---
layout: base.njk
title: Home
lang: en
translationKey: home
permalink: /en/
description: University lecturer, researcher, municipal politician, and speaker.
---

{% set uniquePresentationKeys = [] %}
{% for item in ((canva and canva.tableRows) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in (collections.presentations or []) %}
  {% set key = (((item.data and item.data.url) or "") ~ "|" ~ ((item.data and item.data.title) or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in ((finnaAoe and finnaAoe.rows) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (uniquePresentationKeys.indexOf(key) == -1) %}
    {% set _ = (uniquePresentationKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% set heroPresentationCount = uniquePresentationKeys | length %}
{% set heroPublicationCount = (researchfi or []) | length %}
{% set heroOpinionCount = (collections.pub_mielipide or []) | length %}
{% set heroSpeechCount = (collections.pub_puhe or []) | length %}
{% set heroStats = [
    { count: heroPresentationCount, label: "presentations", href: "/en/presentations/" },
    { count: heroPublicationCount, label: "publications", href: "/en/publications/" },
    { count: heroOpinionCount, label: "opinion pieces", href: "/en/writings/#opinions" },
    { count: heroSpeechCount, label: "speeches", href: "/en/writings/#speeches" },
    { count: theses.stats.total, label: "supervised theses", href: "/en/theses/" }
] %}

<section class="section-flush home-hero-section" id="heroSection">
    <div class="home-hero-backdrop" style="--hero-img: url('{{ '/img/WIN_20210329_16_06_01_Pro.jpg' | url }}')">
        <div class="container home-hero-content">
            <div class="row align-items-center g-4 g-lg-5">
                <div class="col-lg-7">
                    <p class="home-hero-eyebrow mb-2">Jari Laru</p>
                    <h1 class="home-hero-title mb-3">I train and research how AI and learning technology work in everyday education.</h1>
                    <div class="home-hero-roles">
                        <a class="home-hero-role-item" href="/en/work/">University Lecturer</a>
                        <a class="home-hero-role-item" href="/en/company/">Trainer (Larux t:mi)</a>
                        <a class="home-hero-role-item" href="/en/politics/">City Councillor</a>
                        <a class="home-hero-role-item" href="/en/about/">About me</a>
                    </div>
                </div>
                <div class="col-lg-5 d-none d-lg-flex align-items-center justify-content-end">
                    <dl class="home-hero-kpi-grid mb-0">
                        {% for stat in heroStats | sort(true, false, "count") %}
                        <div class="home-hero-kpi">
                            <dd class="home-hero-kpi-value"><a class="home-hero-kpi-link" href="{{ stat.href }}">{{ stat.count }}</a></dd>
                            <dt class="home-hero-kpi-label">{{ stat.label }}</dt>
                        </div>
                        {% endfor %}
                    </dl>
                </div>
            </div>
        </div>
    </div>
    <div class="home-hero-wave" aria-hidden="true">
        <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z"/>
        </svg>
    </div>
</section>

<section class="py-5 home-intro-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <p class="home-intro-text">I work at the intersection of education, technology, and civic life. As a university lecturer I study AI and learning technology; as a trainer I help organisations and educators put them to practical use; as a city councillor I pursue evidence-informed local policy.</p>
                <div class="home-intro-actions">
                    <a class="btn btn-primary rounded-pill px-4" href="/en/presentations/">Presentations</a>
                    <a class="btn btn-outline-secondary rounded-pill px-4" href="/en/about/">About me</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 home-overview-section">
    <div class="container">
        <div class="row g-4 g-xl-5">

            {# Card 1: University Lecturer #}
            <div class="col-md-6 col-xl-3 home-overview-col">
                <div class="d-flex flex-column h-100">
                    <p class="home-overview-eyebrow">University of Oulu</p>
                    <h2 class="h5 fw-bold mb-2 home-overview-title">
                        <i class="bi bi-mortarboard me-2 opacity-75"></i>University Lecturer
                    </h2>
                    <div class="home-overview-lead-wrap mb-3">
                        <p class="small mb-0 home-overview-lead">Lecturer in technology-enhanced learning at the Faculty of Education. Research focuses on AI literacy, mobile learning, and collaborative learning environments.</p>
                        <div class="home-overview-lead-fade"></div>
                    </div>
                    <div class="home-overview-kpis mb-3">
                        <div class="home-overview-kpi">
                            <span class="home-overview-kpi-value">{{ theses.stats.total }}</span>
                            <span class="home-overview-kpi-label">theses supervised</span>
                        </div>
                        <div class="home-overview-kpi">
                            <span class="home-overview-kpi-value">{{ semanticscholar.metrics.totalCitations or "600+" }}</span>
                            <span class="home-overview-kpi-label">citations</span>
                        </div>
                    </div>
                    <div class="home-overview-items mb-3">
                        {% for post in collections.blogAcademic | take(3) %}
                        <a href="{{ post.url }}" class="home-overview-item">
                            <p class="home-overview-item-title">{{ post.data.title }}</p>
                            <p class="home-overview-item-meta">Post · {{ post.date | dateFormat }}</p>
                        </a>
                        {% endfor %}
                        <div class="home-overview-items-fade"></div>
                    </div>
                    <div class="mt-auto pt-2">
                        <a href="/en/work/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Work &amp; research <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>

            {# Card 2: Trainer & Speaker #}
            <div class="col-md-6 col-xl-3 home-overview-col">
                <div class="d-flex flex-column h-100">
                    <p class="home-overview-eyebrow">Larux t:mi</p>
                    <h2 class="h5 fw-bold mb-2 home-overview-title">
                        <i class="bi bi-mic me-2 opacity-75"></i>Trainer &amp; Speaker
                    </h2>
                    <div class="home-overview-lead-wrap mb-3">
                        <p class="small mb-0 home-overview-lead">Expert training and keynotes on AI literacy, learning technology, and modern pedagogical practices — for educators, organisations, and policymakers.</p>
                        <div class="home-overview-lead-fade"></div>
                    </div>
                    <div class="home-overview-kpis mb-3">
                        <div class="home-overview-kpi">
                            <span class="home-overview-kpi-value">{{ heroPresentationCount }}</span>
                            <span class="home-overview-kpi-label">presentations</span>
                        </div>
                        <div class="home-overview-kpi">
                            <span class="home-overview-kpi-value">20+</span>
                            <span class="home-overview-kpi-label">years of training</span>
                        </div>
                    </div>
                    <div class="home-overview-items mb-3">
                        {% for row in (canva.enRows or canva.tableRows or []) | take(3) %}
                        <a href="{{ row.url }}" target="_blank" rel="noopener noreferrer" class="home-overview-item">
                            <p class="home-overview-item-title">{{ row.title }}</p>
                            <p class="home-overview-item-meta">{% if row.location %}{{ row.location }} · {% endif %}{{ row.date | dateFormat }}</p>
                        </a>
                        {% endfor %}
                        <div class="home-overview-items-fade"></div>
                    </div>
                    <div class="d-flex flex-wrap gap-2 mt-auto pt-2">
                        <a href="/en/presentations/" class="btn btn-primary btn-sm rounded-pill px-3">Presentations</a>
                        <a href="/en/company/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Training services</a>
                    </div>
                </div>
            </div>

            {# Card 3: Publications #}
            <div class="col-md-6 col-xl-3 home-overview-col">
                <div class="d-flex flex-column h-100">
                    <p class="home-overview-eyebrow">Research output</p>
                    <h2 class="h5 fw-bold mb-2 home-overview-title">
                        <i class="bi bi-journal-text me-2 opacity-75"></i>Publications
                    </h2>
                    <div class="home-overview-lead-wrap mb-3">
                        <p class="small mb-0 home-overview-lead">Scientific articles, book chapters, opinion pieces, and speeches on learning technology, AI in education, and educational policy.</p>
                        <div class="home-overview-lead-fade"></div>
                    </div>
                    <div class="home-overview-kpis mb-3">
                        <div class="home-overview-kpi">
                            <span class="home-overview-kpi-value">{{ heroPublicationCount }}</span>
                            <span class="home-overview-kpi-label">publications</span>
                        </div>
                        <div class="home-overview-kpi">
                            <span class="home-overview-kpi-value">{{ semanticscholar.metrics.totalCitations or "600+" }}</span>
                            <span class="home-overview-kpi-label">citations</span>
                        </div>
                    </div>
                    <div class="home-overview-items mb-3">
                        {% for pub in researchfi.slice(0, 3) %}
                        {% set pubLink = pub.doiUrl or pub.url %}
                        <a href="{{ pubLink or '/en/publications/' }}" {% if pubLink %}target="_blank" rel="noopener noreferrer"{% endif %} class="home-overview-item">
                            <p class="home-overview-item-title">{{ pub.title | truncate(85) }}</p>
                            <p class="home-overview-item-meta">{% if pub.authors %}{{ pub.authors | truncate(40) }} · {% endif %}{{ pub.year }}</p>
                        </a>
                        {% endfor %}
                        <div class="home-overview-items-fade"></div>
                    </div>
                    <div class="mt-auto pt-2">
                        <a href="/en/publications/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">All publications <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>

            {# Card 4: Politics #}
            <div class="col-md-6 col-xl-3 home-overview-col">
                <div class="d-flex flex-column h-100">
                    <p class="home-overview-eyebrow">City of Oulu</p>
                    <h2 class="h5 fw-bold mb-2 home-overview-title">
                        <i class="bi bi-building me-2 opacity-75"></i>Politics
                    </h2>
                    <div class="home-overview-lead-wrap mb-3">
                        <p class="small mb-0 home-overview-lead">Second-term city councillor in Oulu (National Coalition Party). Long-term focus on education, services for families, and evidence-informed local decision-making.</p>
                        <div class="home-overview-lead-fade"></div>
                    </div>
                    <div class="home-overview-kpis mb-3">
                        <div class="home-overview-kpi">
                            <span class="home-overview-kpi-value">{{ heroOpinionCount }}</span>
                            <span class="home-overview-kpi-label">opinion pieces</span>
                        </div>
                        <div class="home-overview-kpi">
                            <span class="home-overview-kpi-value">{{ heroSpeechCount }}</span>
                            <span class="home-overview-kpi-label">speeches</span>
                        </div>
                    </div>
                    <div class="home-overview-items mb-3">
                        {% set polItems = [] %}
                        {% for post in collections.politicsAndOpinions %}
                            {% if post.fileSlug != "etusivu" and polItems.length < 3 %}
                                {% set _ = (polItems.push(post), null) %}
                            {% endif %}
                        {% endfor %}
                        {% for post in polItems %}
                        <a href="{{ post.url }}" class="home-overview-item">
                            <p class="home-overview-item-title">{{ post.data.title }}</p>
                            <p class="home-overview-item-meta">{{ post.data.type | capitalize or "Post" }} · {{ post.date | dateFormat }}</p>
                        </a>
                        {% endfor %}
                        <div class="home-overview-items-fade"></div>
                    </div>
                    <div class="d-flex flex-wrap gap-2 mt-auto pt-2">
                        <a href="/en/politics/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Politics</a>
                        <a href="/en/writings/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Writings</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<section class="py-5 bg-body-tertiary home-testimonials-section">
    <div class="container">
        <p class="text-uppercase fw-bold text-center mb-4 home-testimonials-label">What people say</p>
        <div class="row g-4 justify-content-center">
            <div class="col-md-5">
                <blockquote class="home-quote">
                    <p>"Jari's training on AI in education was both practically useful and thought-provoking. Exactly what our staff needed."</p>
                    <footer class="home-quote-footer">Training participant, Finnish school</footer>
                </blockquote>
            </div>
            <div class="col-md-5">
                <blockquote class="home-quote">
                    <p>"A rare combination of deep research knowledge and the ability to make it accessible and actionable for practitioners."</p>
