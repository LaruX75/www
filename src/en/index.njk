<section class="section-flush bg-adaptive-dark-blue py-5 py-md-0">
    <div class="container-fluid" style="padding-top: 0;border-radius: 0px;">
        <div class="row gx-0 gy-4 gy-md-0">
            <div class="col-md-6 text-center text-md-start d-flex d-sm-flex d-md-flex flex-column justify-content-center align-items-center align-self-start justify-content-md-start align-items-md-center justify-content-xl-center ps-0 pe-0" style="height: auto;min-height: 100%;padding-bottom: 1em;padding-top: 0.5em;">
                <div class="text-center pb-2 pt-4 w-100" style="padding-right: 1.5em;padding-left: 1.5em;">
                    <p class="text-uppercase text-muted fw-bold mb-2">Science and Research</p>
                    <h2 class="fw-bold mb-3">Publications</h2>
                    <p class="mb-3">My latest scientific publications and articles, synced from the Research.fi service.</p>
                    
                    {%- set articleCount = 0 -%}
                    {%- set confCount = 0 -%}
                    {%- set bookCount = 0 -%}
                    {%- set minYear = 9999 -%}
                    {%- set maxYear = 0 -%}
                    {%- for pub in researchfi -%}
                        {%- if pub.typeCode == "A1" or pub.typeCode == "A2" -%}
                            {%- set articleCount = articleCount + 1 -%}
                        {%- endif -%}
                        {%- if pub.typeCode == "A3" or pub.typeCode == "A4" or pub.typeCode == "B3" -%}
                            {%- set confCount = confCount + 1 -%}
                        {%- endif -%}
                        {%- if pub.typeCode == "C1" or pub.typeCode == "C2" or pub.typeCode == "G4" or pub.typeCode == "G5" -%}
                            {%- set bookCount = bookCount + 1 -%}
                        {%- endif -%}
                        {%- if pub.year and pub.year < minYear -%}{%- set minYear = pub.year -%}{%- endif -%}
                        {%- if pub.year and pub.year > maxYear -%}{%- set maxYear = pub.year -%}{%- endif -%}
                    {%- endfor -%}

                    <!-- Research Data Dashboard -->
                    <div class="d-flex flex-wrap justify-content-center gap-3 mb-4">
                        <div class="research-stat-card text-center px-3 py-2">
                            <div class="research-stat-number">{{ researchfi.length }}</div>
                            <div class="research-stat-label">Publications</div>
                        </div>
                        <div class="research-stat-card text-center px-3 py-2">
                            <div class="research-stat-number">{{ articleCount }}</div>
                            <div class="research-stat-label">Journal articles</div>
                        </div>
                        <div class="research-stat-card text-center px-3 py-2">
                            <div class="research-stat-number">{{ confCount }}</div>
                            <div class="research-stat-label">Conference papers</div>
                        </div>
                        <div class="research-stat-card text-center px-3 py-2">
                            <div class="research-stat-number">{{ bookCount }}</div>
                            <div class="research-stat-label">Books and theses</div>
                        </div>
                    </div>
                </div>
                <!-- Karuselli alkaa -->
                <div id="zoteroTicker" class="ticker-container w-100 position-relative pb-4" tabindex="0" role="region" aria-label="Latest publications">
                    <!-- Häivetykset reunoilla (vasen ja oikea) -->
                    <div class="ticker-fade-left"></div>
                    <div class="ticker-fade-right"></div>
                    
                    <div class="ticker-track">
                        <!-- Ensimmäinen setti -->
                        <div class="ticker-content">
                            {% for pub in researchfi.slice(0, 10) %}
                            <div class="ticker-item p-4">
                                <h4>{{ pub.typeShort }}</h4>
                                <p class="fw-bold mb-1">{{ pub.title }}</p>
                                {% if pub.journal %}
                                <p class="text-muted mb-1" style="font-size: 0.9rem;"><em>{{ pub.journal }}</em>{% if pub.year %} ({{ pub.year }}){% endif %}</p>
                                {% elif pub.year %}
                                <p class="text-muted mb-1" style="font-size: 0.9rem;">({{ pub.year }})</p>
                                {% endif %}
                                <div class="d-flex justify-content-start mt-3 mb-2">
                                    {% if pub.url %}
                                    <a href="{{ pub.url }}" target="_blank" rel="noopener noreferrer" class="btn btn-read-more btn-sm rounded-pill px-3">Open publication <i class="bi bi-arrow-up-right"></i></a>
                                    {% else %}
                                    <button class="btn btn-read-more btn-sm rounded-pill px-3" disabled>No link</button>
                                    {% endif %}
                                </div>
                            </div>
                            {% else %}
                            <div class="ticker-item p-4">
                                <p>No publications yet.</p>
                            </div>
                            {% endfor %}
                        </div>
                        <!-- Toinen setti (klooni animaatiota varten) -->
                        <div class="ticker-content" aria-hidden="true">
                            {% for pub in researchfi.slice(0, 10) %}
                            <div class="ticker-item p-4">
                                <h4>{{ pub.typeShort }}</h4>
                                <p class="fw-bold mb-1">{{ pub.title }}</p>
                                {% if pub.journal %}
                                <p class="text-muted mb-1" style="font-size: 0.9rem;"><em>{{ pub.journal }}</em>{% if pub.year %} ({{ pub.year }}){% endif %}</p>
                                {% elif pub.year %}
                                <p class="text-muted mb-1" style="font-size: 0.9rem;">({{ pub.year }})</p>
                                {% endif %}
                                <div class="d-flex justify-content-start mt-3 mb-2">
                                    {% if pub.url %}
                                    <a href="{{ pub.url }}" target="_blank" rel="noopener noreferrer" class="btn btn-read-more btn-sm rounded-pill px-3">Open publication <i class="bi bi-arrow-up-right"></i></a>
                                    {% else %}
                                    <button class="btn btn-read-more btn-sm rounded-pill px-3" disabled>No link</button>
                                    {% endif %}
                                </div>
                            </div>
                            {% else %}
                            <div class="ticker-item p-4">
                                <p>No publications yet.</p>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
                <!-- Karuselli päättyy -->
                <div class="text-center pb-4 pt-2 w-100">
                    <a href="/en/publications/" class="btn btn-primary rounded-pill px-4">Browse all publications</a>
                </div>
            </div>
            <div class="col-md-6 order-1 order-sm-1 ps-0 pe-0">
                <div class="h-100"><img loading="lazy" decoding="async" class="img-fluid object-fit-cover w-100 h-100" width="1024" height="768" style="min-height: 100%;transform: perspective(0px) scale(1);filter: blur(0px);transition: ease-in;" src="/img/uploads/2026/vaitos.png" alt="Research and publications"></div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-body-tertiary">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <p class="text-uppercase text-muted fw-bold mb-2">Company Services</p>
                <h2 class="fw-bold">References, FAQ and Collaboration Model</h2>
                <p class="mb-3">I moved the full case examples, frequently asked questions and value proposition to the company page.</p>
                <a class="btn btn-primary" href="/en/company/">Go to company page</a>
            </div>
        </div>
    </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", function() {
  function initTicker(tickerId) {
    const ticker = document.getElementById(tickerId);
    if (!ticker) return;

    const track = ticker.querySelector(".ticker-track");
    if (!track) return;
    
    let direction = -1; // -1 for left, 1 for right
    let speed = 1; // Animation speed multiplier
    let currentX = 0; // Current transform translateX value
    let animationId; // For requestAnimationFrame
    
    let isDragging = false;
    let startX;
    let prevX;

    // Width of a single set of items
    const tickerContent = ticker.querySelector(".ticker-content");
    if (!tickerContent) return;

    function animate() {
      const itemSetWidth = tickerContent.offsetWidth; 
      
      currentX += direction * speed;

      // Seamless loop reset logic
      if (currentX <= -itemSetWidth) {
        currentX += itemSetWidth;
      } else if (currentX >= 0) {
        currentX -= itemSetWidth;
      }

      track.style.transform = `translateX(${currentX}px)`;
      animationId = requestAnimationFrame(animate);
    }

    // Remove CSS animation to use JS animation instead for direction support
    track.style.animation = "none";

    // Start animation loop
    animationId = requestAnimationFrame(animate);

    // Käyttöliittymäkontrollien tapahtumankäsittelijät (hiiri)
    ticker.addEventListener("mouseenter", () => {
      cancelAnimationFrame(animationId);
    });

    ticker.addEventListener("mousedown", (e) => {
      isDragging = true;
      startX = e.clientX;
      prevX = e.clientX;
      ticker.style.cursor = "grabbing"; // Visuaalinen palaute tarttumisesta
    });

    ticker.addEventListener("mousemove", (e) => {
      if (!isDragging) return;
      
      // Suunnanvaihto ja manuaalinen rullaus hiirellä "raadattaessa"
      const deltaX = e.clientX - prevX;
      prevX = e.clientX;
      
      // Päivitetään kulkusuunta sen perusteella, mihin suuntaan hiirtä viimeksi vedettiin
      if (deltaX > 0) direction = 1; // Oikealle
      else if (deltaX < 0) direction = -1; // Vasemmalle

      currentX += deltaX;
      
      const itemSetWidth = tickerContent.offsetWidth; 
      
      // Karusellin saumaton toisto vetäessä
      if (currentX <= -itemSetWidth) {
        currentX += itemSetWidth;
      } else if (currentX >= 0) {
        currentX -= itemSetWidth;
      }

      track.style.transform = `translateX(${currentX}px)`;
    });

    ticker.addEventListener("mouseup", () => {
      isDragging = false;
      ticker.style.cursor = "ew-resize"; // Palauta kohdistin takaisin vapaaksi
    });

    ticker.addEventListener("mouseleave", () => {
      isDragging = false;
      ticker.style.cursor = "ew-resize";
      // Palautetaan tausta-animaatio käyntiin irroitettaessa hiiri koko laatikosta
      cancelAnimationFrame(animationId); 
      animationId = requestAnimationFrame(animate);
    });
  }

  // Initialize both tickers
  initTicker("blogTicker");
  initTicker("presentationTicker");
  initTicker("zoteroTicker");
});
</script>
