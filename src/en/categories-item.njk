---
layout: base.njk
title: Category
pagination:
  data: collections.categoryList
  size: 1
  alias: category
permalink: /en/categories/{{ category.slug }}/
lang: en
---
<section>
  <div class="container">
    <div class="d-flex align-items-center justify-content-between mb-3">
      <h1 class="h3 mb-0">{{ category.name }}</h1>
      <a class="btn btn-outline-primary btn-sm" href="/en/categories/">All categories</a>
    </div>
    <p class="text-muted">Total {{ category.count }} posts.</p>

    <div class="row g-4">
      {% for item in category.items %}
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 content-card">
            {% if item.data.thumbnail %}
              <img src="{{ item.data.thumbnail }}" class="card-img-top content-card-img" alt="{{ item.data.title }}">
            {% endif %}
            <div class="card-body">
              <h3 class="h6">
                <a href="{{ item.url }}" class="text-decoration-none">{{ item.data.title }}</a>
              </h3>
              <p class="text-muted small mb-2">{{ item.date | dateFormat }}</p>
              <p class="text-muted">{{ item.data.description or (item.content | excerpt) }}</p>
              {% if item.data.keywords %}
                <div class="mt-2">
                  {% for key in item.data.keywords %}
                    <a class="badge text-bg-light text-dark border me-1 text-decoration-none" href="/en/keywords/{{ key | slugify }}/">{{ key }}</a>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
