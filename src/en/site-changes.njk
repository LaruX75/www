---
layout: base.njk
title: Site Changes
permalink: /en/site-changes/
translationKey: site_changes
lang: en
---

<section class="py-4 bg-body-tertiary border-bottom">
  <div class="container">
    <p class="text-uppercase small text-muted mb-2">GitHub</p>
    <h1 class="display-6 fw-bold mb-2">Site Changes</h1>
    <p class="mb-0 text-muted">
      This table shows recent commits directly from
      <a href="{{ githubchanges.repo.url }}" target="_blank" rel="noopener noreferrer">{{ githubchanges.repo.owner }}/{{ githubchanges.repo.repo }}</a>
      (branch: <code>{{ githubchanges.repo.branch }}</code>).
    </p>
  </div>
</section>

<section class="py-4">
  <div class="container">
    {% if githubchanges.source == "cache" and githubchanges.cacheSavedAt %}
      <div class="alert alert-warning py-2 small" role="status">
        GitHub API was unavailable. Showing cached data ({{ githubchanges.cacheSavedAt | dateFormat }}).
      </div>
    {% endif %}

    {% if githubchanges.rows and githubchanges.rows.length %}
      <div class="table-responsive">
        <table class="table table-hover align-middle">
          <thead>
            <tr>
              <th style="width: 140px;">Date</th>
              <th>Change</th>
              <th style="width: 180px;">Author</th>
              <th style="width: 130px;">Commit</th>
            </tr>
          </thead>
          <tbody>
            {% for change in githubchanges.rows %}
              <tr>
                <td>{{ change.date | dateFormat }}</td>
                <td>{{ change.message }}</td>
                <td>{{ change.author }}</td>
                <td>
                  <a href="{{ change.url }}" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary rounded-pill px-2">
                    {{ change.shortSha }}
                  </a>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% else %}
      <div class="alert alert-secondary mb-0" role="status">
        Changes could not be loaded at the moment.
        {% if githubchanges.error %}<div class="small mt-2">{{ githubchanges.error }}</div>{% endif %}
      </div>
    {% endif %}
  </div>
</section>
