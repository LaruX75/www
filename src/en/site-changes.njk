---
layout: base.njk
title: Site Changes
permalink: /en/site-changes/
translationKey: site_changes
lang: en
---

<section class="py-4 bg-body-tertiary border-bottom">
  <div class="container">
    <p class="text-uppercase small text-muted mb-2">GitHub</p>
    <h1 class="display-6 fw-bold mb-2">Site Changes</h1>
    <p class="mb-0 text-muted">
      This table shows recent commits directly from
      <a href="{{ githubchanges.repo.url }}" target="_blank" rel="noopener noreferrer">{{ githubchanges.repo.owner }}/{{ githubchanges.repo.repo }}</a>
      (branch: <code>{{ githubchanges.repo.branch }}</code>).
    </p>
  </div>
</section>

<section class="py-4">
  <div class="container">
    <div class="alert alert-info py-2 small" role="status">
      Want the implementation overview? See:
      <a href="/en/how-this-site-is-built/" class="fw-semibold">How this site is built</a>.
    </div>

    {% if githubchanges.source == "cache" and githubchanges.cacheSavedAt %}
      <div class="alert alert-warning py-2 small" role="status">
        GitHub API was unavailable. Showing cached data ({{ githubchanges.cacheSavedAt | dateFormat }}).
      </div>
    {% endif %}

    {% if githubchanges.rows and githubchanges.rows.length %}
      {% set firstRow = githubchanges.rows[0] %}
      {% set lastRow = githubchanges.rows[githubchanges.rows.length - 1] %}
      <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
          <div class="card border-0 shadow-sm h-100 text-center">
            <div class="card-body py-3">
              <div class="fs-2 fw-bold text-primary">{{ githubchanges.rows.length }}</div>
              <div class="small text-muted mt-1">Changes total</div>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card border-0 shadow-sm h-100 text-center">
            <div class="card-body py-3">
              <div class="fs-5 fw-bold text-success">{{ firstRow.date | dateFormat }}</div>
              <div class="small text-muted mt-1">Latest change</div>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card border-0 shadow-sm h-100 text-center">
            <div class="card-body py-3">
              <div class="fs-5 fw-bold text-secondary">{{ lastRow.date | dateFormat }}</div>
              <div class="small text-muted mt-1">Oldest shown</div>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <a href="{{ githubchanges.repo.url }}" target="_blank" rel="noopener noreferrer" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 text-center">
              <div class="card-body py-3">
                <div class="fs-5 fw-bold text-dark"><i class="bi bi-github me-1"></i>{{ githubchanges.repo.repo }}</div>
                <div class="small text-muted mt-1">Branch: <code>{{ githubchanges.repo.branch }}</code></div>
              </div>
            </div>
          </a>
        </div>
      </div>
    {% endif %}

    {% if githubchanges.rows and githubchanges.rows.length %}
      <div class="table-responsive">
        <table class="table table-hover align-middle" id="github-changes-table">
          <thead>
            <tr>
              <th style="width: 140px;">Date</th>
              <th>Change</th>
              <th style="width: 180px;">Author</th>
              <th style="width: 130px;">Commit</th>
            </tr>
          </thead>
          <tbody id="github-changes-tbody">
            {% for change in githubchanges.rows %}
              <tr class="github-change-row">
                <td>{{ change.date | dateFormat }}</td>
                <td><a href="{{ change.url }}" target="_blank" rel="noopener noreferrer">{{ change.message }}</a></td>
                <td>{{ change.author }}</td>
                <td>
                  <a href="{{ change.url }}" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary rounded-pill px-2">
                    {{ change.shortSha }}
                  </a>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
        <small class="text-muted" id="github-changes-meta"></small>
        <ul class="pagination pagination-sm mb-0 flex-wrap" id="github-changes-pagination"></ul>
      </div>
    {% else %}
      <div class="alert alert-secondary mb-0" role="status">
        Changes could not be loaded at the moment.
        {% if githubchanges.error %}<div class="small mt-2">{{ githubchanges.error }}</div>{% endif %}
      </div>
    {% endif %}
  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const rows = Array.from(document.querySelectorAll("#github-changes-tbody .github-change-row"));
  const pagination = document.getElementById("github-changes-pagination");
  const meta = document.getElementById("github-changes-meta");
  if (!rows.length || !pagination || !meta) return;

  const perPage = 10;
  const totalPages = Math.max(1, Math.ceil(rows.length / perPage));
  let currentPage = 1;

  function render() {
    const start = (currentPage - 1) * perPage;
    const end = start + perPage;

    rows.forEach((row, index) => {
      row.style.display = index >= start && index < end ? "" : "none";
    });

    meta.textContent = `Showing ${Math.min(start + 1, rows.length)}-${Math.min(end, rows.length)} of ${rows.length}`;

    pagination.innerHTML = "";
    for (let page = 1; page <= totalPages; page += 1) {
      const li = document.createElement("li");
      li.className = `page-item${page === currentPage ? " active" : ""}`;

      const button = document.createElement("button");
      button.type = "button";
      button.className = "page-link";
      button.textContent = String(page);
      button.addEventListener("click", () => {
        currentPage = page;
        render();
      });

      li.appendChild(button);
      pagination.appendChild(li);
    }
  }

  render();
});
</script>
