---
layout: base.njk
title: Kirjoitukset ja puheet
permalink: /kynasta/
translationKey: writings_index
---

<section class="kynasta-hero py-4">
  <div class="container">
    <div class="row align-items-center g-4">
      <div class="col-lg-8">
        <p class="text-uppercase small text-muted mb-2">Kynästä</p>
        <h1 class="display-6 fw-bold mb-2">Kirjoitukset, puheet ja julkaisut</h1>
        <p class="text-muted">Kooste mielipidekirjoituksista, kolumneista, aloitteista, puheista ja julkaisuista.</p>
      </div>
      <div class="col-lg-4">
        <nav class="nav nav-pills flex-wrap gap-2 justify-content-lg-end">
          <a class="nav-link" href="#mielipiteet">
            Mielipiteet <span class="nav-count">{{ collections.pub_mielipide.length }}</span>
          </a>
          <a class="nav-link" href="#kolumnit">
            Kolumnit <span class="nav-count">{{ collections.pub_kolumni.length }}</span>
          </a>
          <a class="nav-link" href="#aloitteet">
            Aloitteet <span class="nav-count">{{ collections.politics.length }}</span>
          </a>
          <a class="nav-link" href="#puheet">
            Puheet <span class="nav-count">{{ collections.pub_puhe.length }}</span>
          </a>
          <a class="nav-link" href="#blogi">
            Blogi <span class="nav-count">{{ collections.blog.length }}</span>
          </a>
          <a class="nav-link" href="#julkaisut">
            Julkaisut <span class="nav-count">{{ researchfi.length }}</span>
          </a>
        </nav>
      </div>
    </div>
  </div>
</section>

<section id="yhteenveto">
  <div class="container">
    <div class="card shadow-sm">
      <div class="card-header bg-transparent d-flex align-items-center justify-content-between">
        <h2 class="h4 mb-0">Yhteenveto</h2>
        <span class="badge text-bg-primary">Chart.js</span>
      </div>
      <div class="card-body">
        <div class="row g-3 mb-4">
          <div class="col-6 col-md-4 col-lg-2">
            <div class="summary-kpi p-3 rounded border h-100">
              <div class="summary-kpi-label">Mielipiteet</div>
              <div id="kpi-mielipiteet" class="summary-kpi-value">0</div>
            </div>
          </div>
          <div class="col-6 col-md-4 col-lg-2">
            <div class="summary-kpi p-3 rounded border h-100">
              <div class="summary-kpi-label">Kolumnit</div>
              <div id="kpi-kolumnit" class="summary-kpi-value">0</div>
            </div>
          </div>
          <div class="col-6 col-md-4 col-lg-2">
            <div class="summary-kpi p-3 rounded border h-100">
              <div class="summary-kpi-label">Aloitteet</div>
              <div id="kpi-aloitteet" class="summary-kpi-value">0</div>
            </div>
          </div>
          <div class="col-6 col-md-4 col-lg-2">
            <div class="summary-kpi p-3 rounded border h-100">
              <div class="summary-kpi-label">Puheet</div>
              <div id="kpi-puheet" class="summary-kpi-value">0</div>
            </div>
          </div>
          <div class="col-6 col-md-4 col-lg-2">
            <div class="summary-kpi p-3 rounded border h-100">
              <div class="summary-kpi-label">Blogi</div>
              <div id="kpi-blogi" class="summary-kpi-value">0</div>
            </div>
          </div>
          <div class="col-6 col-md-4 col-lg-2">
            <div class="summary-kpi p-3 rounded border h-100">
              <div class="summary-kpi-label">Julkaisut</div>
              <div id="kpi-julkaisut" class="summary-kpi-value">0</div>
            </div>
          </div>
        </div>

        <div class="row g-4">
          <div class="col-lg-4">
            <h3 class="h6 text-muted mb-2">Sisältöjen jakauma</h3>
            <div class="chart-wrap">
              <canvas id="kynasta-summary-donut" height="260"></canvas>
            </div>
          </div>
          <div class="col-lg-8">
            <h3 class="h6 text-muted mb-2">Sisällöt vuosittain</h3>
            <div class="chart-wrap">
              <canvas id="kynasta-summary-trend" height="260"></canvas>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{# Kerätään kaikki mielipiteet JSON-muotoon JS:ää varten #}
<script id="mielipiteet-data" type="application/json">
[
  {% for pub in collections.pub_mielipide %}
  {
    "title": {{ pub.data.title | dump | safe }},
    "date": "{{ pub.date }}",
    "formattedDate": "{{ pub.date | dateFormat }}",
    "description": {{ (pub.data.description or "") | dump | safe }},
    "publication": {{ (pub.data.publication or "") | dump | safe }},
    "url": "{{ pub.data.url or pub.url }}",
    "isExternal": {{ (pub.data.url != null) | dump | safe }},
    "categories": {{ (pub.data.categories or []) | dump | safe }},
    "keywords": {{ (pub.data.keywords or []) | dump | safe }}
  }{% if not loop.last %},{% endif %}
  {% endfor %}
]
</script>

<span id="mielipidekirjoitukset-eri-sanomalehdissa"></span>
<section id="mielipiteet">
  <div class="container">
    <div class="card shadow-sm">
      <div class="card-header bg-transparent d-flex align-items-center justify-content-between">
        <h2 class="h4 mb-0">Mielipidekirjoitukset</h2>
        <span class="badge text-bg-secondary">{{ collections.pub_mielipide.length }}</span>
      </div>
      <div class="card-body p-0">
        {# ---- Suodatuspalkki ---- #}
        <div class="p-3 bg-light border-bottom">
          <div class="row g-2 align-items-end">
            <div class="col-md-9">
              <label for="mielipiteet-search" class="form-label small text-muted mb-1">Hae mielipidekirjoituksia</label>
              <input type="search" id="mielipiteet-search" class="form-control form-control-sm"
                     placeholder="Hae otsikosta, tiivistelmästä, julkaisusta, kategorioista..." autocomplete="off">
            </div>
            <div class="col-md-3 d-flex justify-content-md-end gap-2">
              <button id="mielipiteet-reset" class="btn btn-outline-secondary btn-sm w-100">
                <i class="bi bi-x-circle me-1"></i>Tyhjennä
              </button>
            </div>
          </div>
        </div>

        {# ---- Taulukko ---- #}
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0 pub-table mielipiteet-table">
            <thead>
              <tr>
                <th class="sortable text-center" data-col="date" style="width:140px">
                  Päivämäärä <i class="bi bi-arrow-down-up sort-icon small opacity-50"></i>
                </th>
                <th class="sortable" data-col="title" style="min-width:200px">
                  Otsikko <i class="bi bi-arrow-down-up sort-icon small opacity-50"></i>
                </th>
                <th style="min-width:200px">Tiivistelmä & Julkaisu</th>
                <th>Kategoriat & Avainsanat</th>
                <th style="width:80px" class="text-center">Lue</th>
              </tr>
            </thead>
            <tbody id="mielipiteet-tbody">
              <tr><td colspan="5" class="text-center text-muted py-4">Ladataan mielipidekirjoituksia...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
      <div class="card-footer bg-transparent d-flex flex-wrap align-items-center justify-content-between gap-2 border-top">
        <small id="mielipiteet-info" class="text-muted"></small>
        <nav aria-label="Sivutus">
          <ul id="mielipiteet-pagination" class="pagination pagination-sm mb-0 flex-wrap"></ul>
        </nav>
      </div>
    </div>
  </div>
</section>

