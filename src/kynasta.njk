{# Kerätään esitykset ja AOE-oppimateriaalit JSON-muotoon JS:ää varten #}
<script id="esitykset-data" type="application/json">
[
  {% set aoeRows = finnaAoe.rows or [] %}
  {% for presentation in collections.presentations %}
  {% set presentationDate = presentation.data.date or presentation.date %}
  {
    "title": {{ presentation.data.title | dump | safe }},
    "date": {{ presentationDate | dump | safe }},
    "formattedDate": "{{ presentationDate | dateFormat }}",
    "description": {{ (presentation.data.description or (presentation.content | excerpt)) | dump | safe }},
    "url": {{ (presentation.data.url or "") | dump | safe }},
    "thumbnail": {{ (presentation.data.thumbnail or "") | dump | safe }},
    "categories": {{ (presentation.data.categories or []) | dump | safe }},
    "type": {{ (presentation.data.type or "Canva") | dump | safe }}
  }{% if not loop.last or aoeRows.length %},{% endif %}
  {% endfor %}
  {% for item in aoeRows %}
  {
    "title": {{ item.title | dump | safe }},
    "date": "{{ item.year }}-01-01",
    "formattedDate": {{ item.year | dump | safe }},
    "description": {{ (item.summary or "") | dump | safe }},
    "url": {{ item.url | dump | safe }},
    "thumbnail": {{ (item.image or "") | dump | safe }},
    "categories": [],
    "type": "AOE / Finna"
  }{% if not loop.last %},{% endif %}
  {% endfor %}
]
</script>

