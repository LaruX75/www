  {% set meetingDate = pub.data.meetingDate or councilMeta.meetingDate or pub.date.toISOString().slice(0, 10) %}
  {% set protocolUrl = councilMeta.protocolUrl or (resolvedEvent == "Oulun kaupunginvaltuusto" and oukaCouncilSpeechProtocols.protocolsByDate[meetingDate]) %}
  {
    "title": {{ pub.data.title | jsonSafe | safe }},
    "date": "{{ pub.date }}",
    "formattedDate": "{{ pub.date | dateFormat }}",
    "description": {{ (pub.data.description or "") | jsonSafe | safe }},
    "event": {{ resolvedEvent | jsonSafe | safe }},
    "asiakohta": {{ resolvedAsiakohta | jsonSafe | safe }},
    "protocolUrl": {{ (protocolUrl or "") | jsonSafe | safe }},
    "url": "{{ resolvedUrl }}",
    "isExternal": {{ (pub.data.url != null) | jsonSafe | safe }},
    "categories": {{ (pub.data.categories or []) | jsonSafe | safe }},
    "keywords": {{ (pub.data.keywords or []) | jsonSafe | safe }},
    "tags": {{ (pub.data.tags or []) | jsonSafe | safe }}
  }{% if not loop.last %},{% endif %}
  {% endfor %}
]
</script>

