      const a = document.createElement('a');
      a.className = 'page-link';
      a.href = '#';
      a.textContent = i;
      a.addEventListener('click', e => {
        e.preventDefault();
        kolumnitCurrentPage = i;
        renderKolumnit();
        document.getElementById('kolumnit')?.scrollIntoView({behavior:'smooth', block:'start'});
      });
      li.appendChild(a);
