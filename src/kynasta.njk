          </td>
        </tr>`;
      }).join('');
    }

    const total = filteredMielipiteetData.length;
    const from = total === 0 ? 0 : start + 1;
    const to = Math.min(start + MIELIPITEET_PAGE_SIZE, total);
    mielipiteetInfo.textContent = `Näytetään ${from}–${to} / ${total}`;

    renderMielipiteetPagination(totalPages);

    document.querySelectorAll('.mielipiteet-table th.sortable').forEach(th => {
      th.classList.remove('sort-asc', 'sort-desc');
      if (th.dataset.col === mielipiteetSortCol) {
        th.classList.add(mielipiteetSortDir === 1 ? 'sort-asc' : 'sort-desc');
      }
    });
  }

  function renderMielipiteetPagination(total) {
    if (!mielipiteetPagUl) return;
    mielipiteetPagUl.innerHTML = '';
    if (total <= 1) return;
    
    for (let i = 1; i <= total; i++) {
      const li = document.createElement('li');
      li.className = `page-item${i === mielipiteetCurrentPage ? ' active' : ''}`;
      const a = document.createElement('a');
      a.className = 'page-link';
      a.href = '#';
      a.textContent = i;
      a.addEventListener('click', e => {
        e.preventDefault();
        mielipiteetCurrentPage = i;
        renderMielipiteet();
        document.getElementById('mielipiteet')?.scrollIntoView({behavior:'smooth', block:'start'});
      });
      li.appendChild(a);
      mielipiteetPagUl.appendChild(li);
    }
  }

  function escHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function slugify(str) {
    if (!str) return "";
    return str.toLowerCase().replace(/ä/g, "a").replace(/ö/g, "o").replace(/å/g, "a").replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");
  }

  if (mielipiteetSearchInp) mielipiteetSearchInp.addEventListener('input', applyMielipiteetFilters);
  
  const mielipiteetResetBtn = document.getElementById('mielipiteet-reset');
  if (mielipiteetResetBtn) {
    mielipiteetResetBtn.addEventListener('click', () => {
      if (mielipiteetSearchInp) mielipiteetSearchInp.value = '';
      applyMielipiteetFilters();
    });
  }

  document.querySelectorAll('.mielipiteet-table th.sortable').forEach(th => {
    th.addEventListener('click', () => sortMielipiteetData(th.dataset.col));
  });

  renderMielipiteet();
})();


</script>

{# Staattinen arkistolista — takaa inlinkit kaikille julkaisuille hakukoneille #}
<section class="py-3">
  <div class="site-shell">
    <details>
      <summary class="text-muted small py-2">Kaikki kirjoitukset arkistona ({{ collections.publications | length }})</summary>
      <ul class="list-unstyled row row-cols-1 row-cols-md-2 g-1 mt-2">
        {% for pub in collections.publications | sort(attribute="data.date", reverse=true) %}
        <li class="col"><a class="small text-decoration-none text-muted" href="{{ pub.url }}">{{ pub.data.title }}</a></li>
        {% endfor %}
      </ul>
    </details>
  </div>
</section>
