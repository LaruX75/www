<script>
(function () {
  // Näytä taulukko-osiot tarkoituksellisessa lukujärjestyksessä riippumatta lähdekoodin lohkojärjestyksestä.
  const sectionOrder = ['puheet', 'aloitteet', 'blogi', 'mielipiteet', 'kolumnit', 'esitykset', 'julkaisut'];
  const sections = sectionOrder
    .map(id => document.getElementById(id))
    .filter(Boolean);
  if (sections.length > 1) {
    const parent = sections[0].parentElement;
    const anchor = document.createComment('kynasta-sections-order-anchor');
    parent.insertBefore(anchor, sections[0]);
    const fragment = document.createDocumentFragment();
    sections.forEach(section => fragment.appendChild(section));
    parent.insertBefore(fragment, anchor);
    anchor.remove();
  }

  const parseJson = (id) => {
    const el = document.getElementById(id);
    if (!el) return [];
    try { return JSON.parse(el.textContent || '[]'); } catch (_) { return []; }
  };
  const MAX_SLIDESHARE_DATE = '2020-12-31';
  const isSlideshareItem = (item) => {
    const src = String(item?.source || '').toLowerCase();
    const type = String(item?.type || '').toLowerCase();
    const url = String(item?.url || '').toLowerCase();
    return src === 'slideshare' || type.includes('slideshare') || url.includes('slideshare.net');
  };
  const toIsoDate = (value) => {
    if (value === null || value === undefined) return null;
    const raw = String(value).trim();
    if (/^\d{4}-\d{2}-\d{2}$/.test(raw)) return raw;
    const parsed = new Date(raw);
    if (Number.isNaN(parsed.getTime())) return null;
    const year = parsed.getUTCFullYear();
    const month = String(parsed.getUTCMonth() + 1).padStart(2, '0');
    const day = String(parsed.getUTCDate()).padStart(2, '0');
    return `${year}-${month}-${day}`;
  };
  const extractSlideshareDateFromThumbnail = (thumbnailUrl) => {
    if (!thumbnailUrl) return null;
    const match = String(thumbnailUrl).match(/-(\d{6})\d{6}-thumbnail/i);
    if (!match) return null;
    const yymmdd = match[1];
    const yy = Number.parseInt(yymmdd.slice(0, 2), 10);
    const mm = Number.parseInt(yymmdd.slice(2, 4), 10);
    const dd = Number.parseInt(yymmdd.slice(4, 6), 10);
    if (!Number.isFinite(yy) || !Number.isFinite(mm) || !Number.isFinite(dd)) return null;
    if (mm < 1 || mm > 12 || dd < 1 || dd > 31) return null;
    const year = yy >= 90 ? 1900 + yy : 2000 + yy;
    return `${year}-${String(mm).padStart(2, '0')}-${String(dd).padStart(2, '0')}`;
  };
  const normalizeSlidesharePresentation = (item) => {
    if (!isSlideshareItem(item)) return item;
    let iso = toIsoDate(item?.date) || extractSlideshareDateFromThumbnail(item?.thumbnail);
    if (!iso) return item;
    if (iso > MAX_SLIDESHARE_DATE) iso = MAX_SLIDESHARE_DATE;
    return { ...item, date: iso };
  };
  const cleanMobileLabel = (value) => String(value || '')
    .replace(/Ei lajittelua/gi, '')
    .replace(/Pienin ensin/gi, '')
    .replace(/Suurin ensin/gi, '')
    .replace(/Uusin ensin/gi, '')
    .replace(/Vanhin ensin/gi, '')
    .replace(/A-ÖÖ-A/gi, '')
    .replace(/\s+/g, ' ')
    .trim();

  const syncMobileTableLabels = () => {
    document.querySelectorAll('.pub-table').forEach((table) => {
      const headers = Array.from(table.querySelectorAll('thead th')).map((th) =>
        cleanMobileLabel(th.dataset.mobileLabel || th.textContent || '')
      );
      table.querySelectorAll('tbody tr').forEach((row) => {
        Array.from(row.children).forEach((cell, idx) => {
          if (cell.tagName !== 'TD') return;
          if (cell.hasAttribute('colspan')) {
            cell.setAttribute('data-label', '');
            return;
          }
          cell.setAttribute('data-label', headers[idx] || '');
        });
      });
    });
  };

  syncMobileTableLabels();
  const mobileTableObserver = new MutationObserver(() => syncMobileTableLabels());
  document.querySelectorAll('.pub-table tbody').forEach((tbody) => {
    mobileTableObserver.observe(tbody, { childList: true, subtree: true });
  });
  const yearFromDate = (value) => {
    if (value === null || value === undefined) return null;
    if (typeof value === 'number' && value >= 1900 && value <= 2100) return value;
    const str = String(value).trim();
    if (!str) return null;
    const yearMatch = str.match(/\b(19|20)\d{2}\b/);
    if (yearMatch) return Number(yearMatch[0]);
    const d = new Date(str);
    return Number.isNaN(d.getTime()) ? null : d.getFullYear();
  };

  const mielipiteet = parseJson('mielipiteet-data');
  const kolumnit = parseJson('kolumnit-data');
  const aloitteet = parseJson('aloitteet-data');
  const puheet = parseJson('puheet-data');
  const blogi = parseJson('blog-data');
  const esitykset = parseJson('esitykset-data')
    .map(normalizeSlidesharePresentation)
    .filter((item, index, arr) => {
      const key = `${String(item?.url || '').trim()}|${String(item?.title || '').trim()}`;
      if (!key || key === '|') return false;
      return arr.findIndex((candidate) => {
        const candidateKey = `${String(candidate?.url || '').trim()}|${String(candidate?.title || '').trim()}`;
        return candidateKey === key;
      }) === index;
    });
  const julkaisut = parseJson('pub-data');

  const counts = {
    mielipiteet: mielipiteet.length,
    kolumnit: kolumnit.length,
    aloitteet: aloitteet.length,
    puheet: puheet.length,
    blogi: blogi.length,
    esitykset: esitykset.length,
    julkaisut: julkaisut.length
  };

  const setText = (id, value) => {
    const el = document.getElementById(id);
    if (el) el.textContent = String(value);
  };
  setText('kpi-mielipiteet', counts.mielipiteet);
  setText('kpi-kolumnit', counts.kolumnit);
  setText('kpi-aloitteet', counts.aloitteet);
  setText('kpi-puheet', counts.puheet);
  setText('kpi-blogi', counts.blogi);
  setText('kpi-esitykset', counts.esitykset);
  setText('kpi-julkaisut', counts.julkaisut);

  const yearly = {};
  const addYear = (arr, key) => {
    arr.forEach((item) => {
      const y = key === 'year' ? Number(item.year) : yearFromDate(item.date);
      if (!y || y < 1990 || y > 2100) return;
      if (!yearly[y]) yearly[y] = { mielipiteet: 0, kolumnit: 0, aloitteet: 0, puheet: 0, blogi: 0, esitykset: 0, julkaisut: 0 };
      yearly[y][key === 'year' ? 'julkaisut' : key] += 1;
    });
  };

  addYear(mielipiteet, 'mielipiteet');
  addYear(kolumnit, 'kolumnit');
  addYear(aloitteet, 'aloitteet');
  addYear(puheet, 'puheet');
  addYear(blogi, 'blogi');
  addYear(esitykset, 'esitykset');
  addYear(julkaisut, 'year');

  const years = Object.keys(yearly).map(Number).sort((a, b) => a - b);

  const labels = ['Aloitteet', 'Blogi', 'Esitykset', 'Julkaisut', 'Kolumnit', 'Mielipiteet', 'Puheet'];
  const values = [
    counts.aloitteet,
    counts.blogi,
    counts.esitykset,
    counts.julkaisut,
    counts.kolumnit,
    counts.mielipiteet,
    counts.puheet
  ];
  const palette = ['#fd7e14', '#6610f2', '#0dcaf0', '#198754', '#20c997', '#0d6efd', '#dc3545'];

  function drawCharts() {
    if (typeof Chart === 'undefined') return false;

    const donutCanvas = document.getElementById('kynasta-summary-donut');
    if (donutCanvas) {
      window._kynastaDonutChart = new Chart(donutCanvas, {
        type: 'doughnut',
        data: {
          labels,
          datasets: [{ data: values, backgroundColor: palette, borderWidth: 1 }]
        },
        options: {
          plugins: { legend: { position: 'bottom' } },
          maintainAspectRatio: false
        }
      });
    }

    const trendCanvas = document.getElementById('kynasta-summary-trend');
    if (trendCanvas && years.length > 0) {
      const makeSeries = (name, color, field) => ({
        label: name,
        data: years.map((y) => yearly[y][field] || 0),
        backgroundColor: color,
        borderColor: color,
        borderWidth: 1
      });
      window._kynastaTrendChart = new Chart(trendCanvas, {
        type: 'bar',
        data: {
          labels: years,
          datasets: [
            makeSeries('Aloitteet', palette[0], 'aloitteet'),
            makeSeries('Blogi', palette[1], 'blogi'),
            makeSeries('Esitykset', palette[2], 'esitykset'),
            makeSeries('Julkaisut', palette[3], 'julkaisut'),
            makeSeries('Kolumnit', palette[4], 'kolumnit'),
            makeSeries('Mielipiteet', palette[5], 'mielipiteet'),
            makeSeries('Puheet', palette[6], 'puheet')
          ]
        },
        options: {
          maintainAspectRatio: false,
          responsive: true,
          scales: {
            x: { stacked: true },
            y: { stacked: true, beginAtZero: true, ticks: { precision: 0 } }
          },
          plugins: {
            legend: { position: 'bottom' },
            tooltip: { mode: 'index', intersect: false }
          }
        }
      });
    }
    return true;
  }

  if (!drawCharts()) {
    let retries = 0;
    const timer = setInterval(() => {
      retries += 1;
      if (drawCharts() || retries > 20) clearInterval(timer);
    }, 150);
  }

  // Mobiili-accordion: resize kaaviot kun collapse aukeaa
  const kynastaCollapseEl = document.getElementById('kynastaChartsDashboard');
  if (kynastaCollapseEl) {
    kynastaCollapseEl.addEventListener('shown.bs.collapse', () => {
      [window._kynastaDonutChart, window._kynastaTrendChart].forEach(c => c && c.resize());
    });
    const kynastaToggleBtn = document.querySelector('[data-bs-target="#kynastaChartsDashboard"]');
    if (kynastaToggleBtn) {
      kynastaCollapseEl.addEventListener('show.bs.collapse', () => kynastaToggleBtn.setAttribute('aria-expanded', 'true'));
      kynastaCollapseEl.addEventListener('hide.bs.collapse', () => kynastaToggleBtn.setAttribute('aria-expanded', 'false'));
    }
  }
})();

(function () {
  const PAGE_SIZE = 5;
  const dataEl = document.getElementById('pub-data');
  if (!dataEl) return;
  const rawData = JSON.parse(dataEl.textContent);

  // Järjestetään oletuksena uusimmasta vanhimpaan (vuosi)
  let data = [...rawData].sort((a, b) => (b.year || 0) - (a.year || 0));
  let filteredData = [...data];
  let currentPage = 1;
  let sortCol = 'year';
  let sortDir = -1; // -1 = desc, 1 = asc

  const yearSel = document.getElementById('pub-year');
  const searchInp = document.getElementById('pub-search');
  const tbody = document.getElementById('pub-tbody');
  const info = document.getElementById('pub-info');
  const pagUl = document.getElementById('pub-pagination');

  // --- Vuosisuodatin ---
  const years = [...new Set(data.filter(d => d.year > 0).map(d => d.year))].sort((a, b) => b - a);
  if (yearSel) {
    years.forEach(y => {
      const opt = document.createElement('option');
      opt.value = y;
      opt.textContent = y;
      yearSel.appendChild(opt);
    });
  }

  // --- Suodatus ---
  function applyFilters() {
    const q = searchInp ? searchInp.value.toLowerCase().trim() : '';
    const yr = yearSel ? yearSel.value : '';
    filteredData = data.filter(d => {
      const matchQ = !q ||
        (d.title || '').toLowerCase().includes(q) ||
        (d.authors || '').toLowerCase().includes(q) ||
        (d.journal || '').toLowerCase().includes(q);
      const matchY = !yr || String(d.year) === yr;
      return matchQ && matchY;
    });
    currentPage = 1;
    render();
  }

  // --- Lajittelu ---
  function sortData(col) {
    if (sortCol === col) { sortDir *= -1; }
    else { sortCol = col; sortDir = col === 'year' ? -1 : 1; }
    filteredData.sort((a, b) => {
      let av = a[col] ?? '';
      let bv = b[col] ?? '';
      if (typeof av === 'string') av = av.toLowerCase();
      if (typeof bv === 'string') bv = bv.toLowerCase();
      if (typeof av === 'number' && typeof bv === 'number') return (av - bv) * sortDir;
      return av.toString().localeCompare(bv.toString(), 'fi') * sortDir;
    });
    currentPage = 1;
    render();
  }

  function buildApaCitationHtml(d) {
    const authors = escHtml(formatApaAuthors(d.authors));
    const year = escHtml(String(d.year || '').trim() || 'n.d.');
    const title = escHtml((d.title || '').trim() || 'Nimetön julkaisu');
    const journal = escHtml((d.journal || '').trim());
    const doi = escHtml((d.doi || '').trim());
    const url = escHtml((d.url || '').trim());
    const volume = escHtml((d.volume || '').trim());
    const issue = escHtml((d.issue || '').trim());
    const pages = escHtml((d.pages || '').trim());

    let citation = `${authors} (${year}). ${title}.`;
    if (journal) {
      citation += ` <span class="apa-journal">${journal}</span>`;
      if (volume) {
        citation += `, <span class="apa-volume">${volume}</span>`;
        if (issue) citation += `(${issue})`;
      } else if (issue) {
        citation += ` (${issue})`;
      }
      if (pages) citation += `, ${pages}`;
      citation += '.';
    }
    if (doi) citation += ` <span class="apa-url">https://doi.org/${doi}</span>`;
    else if (url) citation += ` <span class="apa-url">${url}</span>`;
    return citation.trim();
  }

  function formatApaAuthors(value) {
    const raw = String(value || '').trim();
    if (!raw) return 'Tuntematon tekijä';

    const authors = raw
      .split(';')
      .map((author) => author.trim())
      .filter(Boolean)
      .map((author) => {
        if (!author.includes(',')) return author;
        const [family, ...rest] = author.split(',');
        const given = rest.join(',').trim();
        if (!given) return family.trim();
        const initials = given
          .split(/\s+/)
          .filter(Boolean)
          .map((part) => part
            .split('-')
            .filter(Boolean)
            .map((segment) => `${segment.charAt(0).toUpperCase()}.`)
            .join('-'))
          .join(' ');
        return `${family.trim()}, ${initials}`.trim();
      });

    if (authors.length === 1) return authors[0];
    if (authors.length <= 20) {
      return `${authors.slice(0, -1).join(', ')}, & ${authors[authors.length - 1]}`;
    }
    return `${authors.slice(0, 19).join(', ')}, ... ${authors[authors.length - 1]}`;
  }

  // --- Renderöinti ---
  function render() {
    if (!tbody || !info) return;

    const totalPages = Math.max(1, Math.ceil(filteredData.length / PAGE_SIZE));
    const start = (currentPage - 1) * PAGE_SIZE;
    const slice = filteredData.slice(start, start + PAGE_SIZE);

    // Taulukko
    if (slice.length === 0) {
      tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-5">Ei tuloksia haulla</td></tr>';
    } else {
      tbody.innerHTML = slice.map((d, index) => {
        const globalIndex = start + index;
        const linkCell = d.url
          ? `<a href="${escHtml(d.url)}" target="_blank" rel="noopener"
               class="btn btn-outline-primary btn-sm rounded-pill px-2" title="Avaa julkaisu">
               <i class="bi bi-arrow-up-right"></i>
             </a>`
          : `<span class="text-muted small">—</span>`;

        const bibButton = `<button class="btn btn-outline-secondary btn-sm rounded-pill px-2 ms-1 bib-btn" 
                            data-index="${globalIndex}" title="Lataa BibTeX">
                            <i class="bi bi-quote"></i>
                          </button>`;

        return `<tr>
          <td class="col-authors small text-muted">${escHtml(d.authors || '—')}</td>
          <td class="col-year text-center fw-semibold">${d.year || '—'}</td>
          <td class="col-title">
            <span class="pub-title-desktop">${escHtml(d.title || '—')}</span>
            <div class="pub-apa-mobile">${buildApaCitationHtml(d)}</div>
          </td>
          <td class="col-pub">${escHtml(d.journal || '—')}</td>
          <td class="col-action text-center">
            <div class="d-flex justify-content-center">
              ${linkCell}
              ${bibButton}
            </div>
          </td>
        </tr>`;
      }).join('');

      // Lisää kuuntelijat BibTeX-napeille
      tbody.querySelectorAll('.bib-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const idx = parseInt(btn.dataset.index);
          downloadBibTeX(filteredData[idx]);
        });
      });
    }

    // Info
    const total = filteredData.length;
    const from = total === 0 ? 0 : start + 1;
    const to = Math.min(start + PAGE_SIZE, total);
    info.textContent = `Näytetään ${from}–${to} / ${total}`;

    // Sivutus
    renderPagination(totalPages);

    // Sarakekorostus
    document.querySelectorAll('.pub-table th.sortable').forEach(th => {
      th.classList.remove('sort-asc', 'sort-desc');
      if (th.dataset.col === sortCol) {
        th.classList.add(sortDir === 1 ? 'sort-asc' : 'sort-desc');
      }
    });
  }

  function renderPagination(total) {
    if (!pagUl) return;
    pagUl.innerHTML = '';
    
    // Yksinkertainen sivutus (1, 2, 3...)
    for (let i = 1; i <= total; i++) {
      const li = document.createElement('li');
      li.className = `page-item${i === currentPage ? ' active' : ''}`;
      const a = document.createElement('a');
      a.className = 'page-link';
      a.href = '#';
      a.textContent = i;
      a.addEventListener('click', e => {
        e.preventDefault();
        currentPage = i;
        render();
        // Skrollaus kortin alkuun
        document.getElementById('julkaisut')?.scrollIntoView({behavior:'smooth', block:'start'});
      });
      li.appendChild(a);
      pagUl.appendChild(li);
    }
  }

  function escHtml(str) {
    if (!str) return '';
    return String(str)
      .replace(/&/g,'&amp;').replace(/</g,'&lt;')
      .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // --- Tapahtumankäsittelijät ---
  if (searchInp) searchInp.addEventListener('input', applyFilters);
  if (yearSel) yearSel.addEventListener('change', applyFilters);
  
  const resetBtn = document.getElementById('pub-reset');
  if (resetBtn) {
    resetBtn.addEventListener('click', () => {
      if (searchInp) searchInp.value = '';
      if (yearSel) yearSel.value = '';
      applyFilters();
    });
  }

  document.querySelectorAll('.pub-table th.sortable').forEach(th => {
    th.addEventListener('click', () => sortData(th.dataset.col));
  });

  function downloadBibTeX(d) {
    const typeMap = {
      "A1": "article", "A2": "article", "B1": "article",
      "A3": "incollection", "B2": "incollection",
      "A4": "inproceedings", "B3": "inproceedings", "D3": "inproceedings",
      "C1": "book", "E2": "book",
      "C2": "proceedings",
      "G4": "phdthesis", "G5": "phdthesis"
    };

    const bibType = typeMap[d.typeCode] || "misc";
    const authors = d.authors || "Laru, Jari";
    const firstAuthor = authors.split(/[,&]/)[0].trim().split(/\s+/).pop().toLowerCase();
    const key = `${firstAuthor}${d.year || 'unknown'}${d.title.split(/\s+/)[0].replace(/[^a-z]/gi, '').toLowerCase()}`;

    let bib = `@${bibType}{${key},\n`;
    bib += `  title = {${d.title}},\n`;
    bib += `  author = {${authors}},\n`;
    if (d.year) bib += `  year = {${d.year}},\n`;
    if (d.journal) {
      if (bibType === "article") bib += `  journal = {${d.journal}},\n`;
      else if (bibType === "inproceedings" || bibType === "incollection") bib += `  booktitle = {${d.journal}},\n`;
      else bib += `  publisher = {${d.journal}},\n`;
    }
    if (d.url) bib += `  url = {${d.url}},\n`;
    bib += `}`;

    const blob = new Blob([bib], { type: 'text/plain' });
    const url = window.URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.style.display = 'none';
    a.href = url;
    a.download = `${key}.bib`;
    document.body.appendChild(a);
    a.click();
    window.URL.revokeObjectURL(url);
    document.body.removeChild(a);
  }

  // Käynnistys
  render();
})();

// --- Blogi taulukon logiikka ---
(function () {
  const BLOG_PAGE_SIZE = 5;
  const blogDataEl = document.getElementById('blog-data');
  if (!blogDataEl) return;
  const blogData = JSON.parse(blogDataEl.textContent);

  let filteredBlogData = [...blogData].sort((a, b) => new Date(b.date) - new Date(a.date));
  let blogCurrentPage = 1;
  let blogSortCol = 'date';
  let blogSortDir = -1; // -1 = desc

  const blogSearchInp = document.getElementById('blog-search');
  const blogTbody = document.getElementById('blog-tbody');
  const blogInfo = document.getElementById('blog-info');
  const blogPagUl = document.getElementById('blog-pagination');

  function applyBlogFilters() {
    const q = blogSearchInp ? blogSearchInp.value.toLowerCase().trim() : '';
    filteredBlogData = blogData.filter(d => {
      const matchQ = !q ||
        (d.title || '').toLowerCase().includes(q) ||
        (d.description || '').toLowerCase().includes(q) ||
        (d.categories || []).some(c => c.toLowerCase().includes(q)) ||
        (d.keywords || []).some(k => k.toLowerCase().includes(q));
      return matchQ;
    }).sort((a, b) => new Date(b.date) - new Date(a.date));
    blogCurrentPage = 1;
    renderBlog();
  }

  function sortBlogData(col) {
    if (blogSortCol === col) { blogSortDir *= -1; }
    else { blogSortCol = col; blogSortDir = col === 'date' ? -1 : 1; }
    
    filteredBlogData.sort((a, b) => {
      let av = a[col] ?? '';
      let bv = b[col] ?? '';
      if (typeof av === 'string') av = av.toLowerCase();
      if (typeof bv === 'string') bv = bv.toLowerCase();
      if (col === 'date') {
        return (new Date(av) - new Date(bv)) * blogSortDir;
      }
      return av.toString().localeCompare(bv.toString(), 'fi') * blogSortDir;
    });
    blogCurrentPage = 1;
    renderBlog();
  }

  function renderBlog() {
    if (!blogTbody || !blogInfo) return;

    const totalPages = Math.max(1, Math.ceil(filteredBlogData.length / BLOG_PAGE_SIZE));
    const start = (blogCurrentPage - 1) * BLOG_PAGE_SIZE;
    const slice = filteredBlogData.slice(start, start + BLOG_PAGE_SIZE);

    if (slice.length === 0) {
      blogTbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-5">Ei tuloksia haulla</td></tr>';
    } else {
      blogTbody.innerHTML = slice.map(d => {
        const catBadges = (d.categories || []).map(c => `<a href="/kategoriat/${slugify(c)}/" class="badge text-bg-secondary me-1 text-decoration-none">${c}</a>`).join('');
        const keyBadges = (d.keywords || []).map(k => `<a href="/avainsanat/${slugify(k)}/" class="badge text-bg-light text-dark border me-1 text-decoration-none">${k}</a>`).join('');

        return `<tr>
          <td class="col-date text-center small text-muted font-monospace">${d.formattedDate}</td>
          <td class="col-title fw-medium"><a href="${d.url}" class="text-decoration-none">${escHtml(d.title)}</a></td>
          <td class="col-desc small text-muted"><span class="summary-text">${escHtml(d.description)}</span></td>
          <td class="col-taxonomy">
            <div class="mb-1">${catBadges}</div>
            <div>${keyBadges}</div>
          </td>
          <td class="col-action text-center">
            <a href="${d.url}" class="btn btn-outline-primary btn-sm rounded-pill px-2" title="Lue blogipostaus">
              <i class="bi bi-arrow-right"></i>
            </a>
          </td>
        </tr>`;
      }).join('');
    }

    const total = filteredBlogData.length;
    const from = total === 0 ? 0 : start + 1;
    const to = Math.min(start + BLOG_PAGE_SIZE, total);
    blogInfo.textContent = `Näytetään ${from}–${to} / ${total}`;

    renderBlogPagination(totalPages);

    document.querySelectorAll('.blog-table th.sortable').forEach(th => {
      th.classList.remove('sort-asc', 'sort-desc');
      if (th.dataset.col === blogSortCol) {
        th.classList.add(blogSortDir === 1 ? 'sort-asc' : 'sort-desc');
      }
    });
  }

  function renderBlogPagination(total) {
    if (!blogPagUl) return;
    blogPagUl.innerHTML = '';
    if (total <= 1) return;
    
    for (let i = 1; i <= total; i++) {
      const li = document.createElement('li');
      li.className = `page-item${i === blogCurrentPage ? ' active' : ''}`;
      const a = document.createElement('a');
      a.className = 'page-link';
      a.href = '#';
      a.textContent = i;
      a.addEventListener('click', e => {
        e.preventDefault();
        blogCurrentPage = i;
        renderBlog();
        document.getElementById('blogi')?.scrollIntoView({behavior:'smooth', block:'start'});
      });
      li.appendChild(a);
      blogPagUl.appendChild(li);
    }
  }

  function escHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function slugify(str) {
    if (!str) return "";
    return str.toLowerCase().replace(/ä/g, "a").replace(/ö/g, "o").replace(/å/g, "a").replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");
  }

  if (blogSearchInp) blogSearchInp.addEventListener('input', applyBlogFilters);
  
  const blogResetBtn = document.getElementById('blog-reset');
  if (blogResetBtn) {
    blogResetBtn.addEventListener('click', () => {
      if (blogSearchInp) blogSearchInp.value = '';
      applyBlogFilters();
    });
  }

  document.querySelectorAll('.blog-table th.sortable').forEach(th => {
    th.addEventListener('click', () => sortBlogData(th.dataset.col));
  });

  renderBlog();
})();

// --- Esitykset taulukon logiikka ---
(function () {
  const ESITYKSET_PAGE_SIZE = 5;
  const MAX_SLIDESHARE_DATE = '2020-12-31';
  const esityksetDataEl = document.getElementById('esitykset-data');
  if (!esityksetDataEl) return;
  const isSlideshareItem = (item) => {
    const src = String(item?.source || '').toLowerCase();
    const type = String(item?.type || '').toLowerCase();
    const url = String(item?.url || '').toLowerCase();
    return src === 'slideshare' || type.includes('slideshare') || url.includes('slideshare.net');
  };
  const toIsoDate = (value) => {
    if (value === null || value === undefined) return null;
    const raw = String(value).trim();
    if (/^\d{4}-\d{2}-\d{2}$/.test(raw)) return raw;
    const parsed = new Date(raw);
    if (Number.isNaN(parsed.getTime())) return null;
    const year = parsed.getUTCFullYear();
    const month = String(parsed.getUTCMonth() + 1).padStart(2, '0');
    const day = String(parsed.getUTCDate()).padStart(2, '0');
    return `${year}-${month}-${day}`;
  };
  const extractSlideshareDateFromThumbnail = (thumbnailUrl) => {
    if (!thumbnailUrl) return null;
    const match = String(thumbnailUrl).match(/-(\d{6})\d{6}-thumbnail/i);
    if (!match) return null;
    const yymmdd = match[1];
    const yy = Number.parseInt(yymmdd.slice(0, 2), 10);
    const mm = Number.parseInt(yymmdd.slice(2, 4), 10);
    const dd = Number.parseInt(yymmdd.slice(4, 6), 10);
    if (!Number.isFinite(yy) || !Number.isFinite(mm) || !Number.isFinite(dd)) return null;
    if (mm < 1 || mm > 12 || dd < 1 || dd > 31) return null;
    const year = yy >= 90 ? 1900 + yy : 2000 + yy;
    return `${year}-${String(mm).padStart(2, '0')}-${String(dd).padStart(2, '0')}`;
  };
  const formatDateFi = (isoDate) => {
    const parsed = new Date(isoDate);
    if (Number.isNaN(parsed.getTime())) return isoDate;
    return parsed.toLocaleDateString('fi-FI', { day: 'numeric', month: 'long', year: 'numeric' });
  };
  const normalizeSlidesharePresentation = (item) => {
    if (!isSlideshareItem(item)) return item;
    let iso = toIsoDate(item?.date) || extractSlideshareDateFromThumbnail(item?.thumbnail);
    if (!iso) return item;
    if (iso > MAX_SLIDESHARE_DATE) iso = MAX_SLIDESHARE_DATE;
    return { ...item, date: iso, formattedDate: formatDateFi(iso) };
  };
  const rawEsityksetData = JSON.parse(esityksetDataEl.textContent);
  const seenMaterialKeys = new Set();
  const esityksetData = rawEsityksetData
    .map((item) => {
      const normalized = normalizeSlidesharePresentation(item);
      const iso = toIsoDate(normalized?.date);
      const formattedDate = normalized?.formattedDate || (iso ? formatDateFi(iso) : '');
      return {
        ...normalized,
        date: iso || normalized?.date || '',
        formattedDate
      };
    })
    .filter((item) => {
      const key = `${String(item.url || '').trim()}|${String(item.title || '').trim()}`;
      if (!key || key === '|') return false;
      if (seenMaterialKeys.has(key)) return false;
      seenMaterialKeys.add(key);
      return true;
    });

  let filteredEsityksetData = [...esityksetData].sort((a, b) => new Date(b.date) - new Date(a.date));
  let esityksetCurrentPage = 1;
  let esityksetSortCol = 'date';
  let esityksetSortDir = -1; // -1 = desc

  const esityksetSearchInp = document.getElementById('esitykset-search');
  const esityksetApplicationFilter = document.getElementById('esitykset-application-filter');
  const esityksetTbody = document.getElementById('esitykset-tbody');
  const esityksetInfo = document.getElementById('esitykset-info');
  const esityksetPagUl = document.getElementById('esitykset-pagination');

  let activeEsityksetApplication = '';

  const getTimeValue = (value) => {
    if (!value) return 0;
    const t = new Date(value).getTime();
    return Number.isNaN(t) ? 0 : t;
  };

  const toKeywordList = (item) => {
    const list = [...(item.categories || []), ...(item.keywords || [])]
      .map((value) => String(value || '').trim())
      .filter(Boolean);
    return [...new Set(list)];
  };

  const inferApplication = (item) => {
    const bag = [
      item.source || '',
      item.type || '',
      item.url || '',
      item.title || ''
    ].join(' ').toLowerCase();
    if (bag.includes('slideshare')) return 'SlideShare';
    if (bag.includes('canva')) return 'Canva';
    if (bag.includes('aoe') || bag.includes('finna')) return 'AOE';
    if (bag.includes('google slides') || bag.includes('docs.google.com/presentation')) return 'Google Slides';
    if (bag.includes('powerpoint') || bag.includes('.ppt') || bag.includes('.pptx')) return 'PowerPoint';
    return 'Muu';
  };

  const normalizeEsitysItem = (item) => {
    const normalized = normalizeSlidesharePresentation(item);
    const iso = toIsoDate(normalized?.date);
    const formattedDate = normalized?.formattedDate || (iso ? formatDateFi(iso) : '');
    const summary = String(normalized?.description || '').trim();
    return {
      ...normalized,
      date: iso || normalized?.date || '',
      formattedDate,
      summary,
      keywordList: toKeywordList(normalized),
      application: inferApplication(normalized)
    };
  };

  const sortEsityksetRows = (rows) => {
    return [...rows].sort((a, b) => {
      if (esityksetSortCol === 'date') {
        return (getTimeValue(a.date) - getTimeValue(b.date)) * esityksetSortDir;
      }
      const av = String(a[esityksetSortCol] || '').toLowerCase();
      const bv = String(b[esityksetSortCol] || '').toLowerCase();
      return av.localeCompare(bv, 'fi') * esityksetSortDir;
    });
  };

  const normalizedEsityksetData = esityksetData.map(normalizeEsitysItem);
  filteredEsityksetData = sortEsityksetRows(normalizedEsityksetData);

  function initEsityksetApplicationFilter() {
    if (!esityksetApplicationFilter) return;
    const applications = [...new Set(normalizedEsityksetData.map((item) => item.application).filter(Boolean))]
      .sort((a, b) => a.localeCompare(b, 'fi'));
    esityksetApplicationFilter.innerHTML = '<option value="">Kaikki</option>' +
      applications.map((app) => `<option value="${escHtml(app)}">${escHtml(app)}</option>`).join('');
    esityksetApplicationFilter.value = activeEsityksetApplication;
  }

  function applyEsityksetFilters() {
    const q = esityksetSearchInp ? esityksetSearchInp.value.toLowerCase().trim() : '';
    filteredEsityksetData = sortEsityksetRows(normalizedEsityksetData.filter((d) => {
      const appOk = !activeEsityksetApplication || d.application === activeEsityksetApplication;
      if (!appOk) return false;
      const searchBag = [
        d.title || '',
        d.summary || '',
        d.description || '',
        d.application || '',
        d.type || '',
        ...d.keywordList
      ].join(' ').toLowerCase();
      return !q || searchBag.includes(q);
    }));
    esityksetCurrentPage = 1;
    renderEsitykset();
  }

  function sortEsityksetData(col) {
    if (esityksetSortCol === col) {
      esityksetSortDir *= -1;
    } else {
      esityksetSortCol = col;
      esityksetSortDir = col === 'date' ? -1 : 1;
    }
    filteredEsityksetData = sortEsityksetRows(filteredEsityksetData);
    esityksetCurrentPage = 1;
    renderEsitykset();
  }

  function renderEsitykset() {
    if (!esityksetTbody || !esityksetInfo) return;

    const totalPages = Math.max(1, Math.ceil(filteredEsityksetData.length / ESITYKSET_PAGE_SIZE));
    const start = (esityksetCurrentPage - 1) * ESITYKSET_PAGE_SIZE;
    const slice = filteredEsityksetData.slice(start, start + ESITYKSET_PAGE_SIZE);

    if (slice.length === 0) {
      esityksetTbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-5">Ei tuloksia haulla</td></tr>';
    } else {
      esityksetTbody.innerHTML = slice.map(d => {
        const summaryText = d.summary
          ? `<span class="summary-text">${escHtml(d.summary)}</span>`
          : '<span class="text-muted small">Ei saatavilla</span>';
        const keywordBadges = d.keywordList.length
          ? d.keywordList.map((k) => `<span class="badge text-bg-light text-dark border me-1 mb-1">${escHtml(k)}</span>`).join('')
          : '<span class="text-muted small">Ei saatavilla</span>';
        const preview = d.thumbnail
          ? `<button type="button" class="preview-thumb-btn p-0 border-0 bg-transparent" data-preview-src="${escHtml(d.thumbnail)}" data-preview-alt="${escHtml(d.title)}" title="Avaa kansikuva">
               <img src="${escHtml(d.thumbnail)}" alt="${escHtml(d.title)}" class="img-fluid border" style="max-height:72px; object-fit:cover;">
             </button>`
          : '<span class="text-muted small">Ei saatavilla</span>';
        const linkBtn = d.url
          ? `<a href="${escHtml(d.url)}" target="_blank" rel="noopener" class="btn btn-outline-primary btn-sm rounded-pill px-2" title="Avaa esitys"><i class="bi bi-arrow-up-right"></i></a>`
          : `<span class="text-muted small">Ei saatavilla</span>`;

        return `<tr>
          <td class="col-date text-center small text-muted font-monospace">${escHtml(d.formattedDate || 'Ei saatavilla')}</td>
          <td class="col-preview small text-muted text-center">${preview}</td>
          <td class="col-title fw-medium">${escHtml(d.title)}</td>
          <td class="col-desc small">${summaryText}</td>
          <td class="col-taxonomy">${keywordBadges}</td>
          <td class="col-app"><span class="badge text-bg-light text-dark border">${escHtml(d.application || 'Muu')}</span></td>
          <td class="col-action text-center">${linkBtn}</td>
        </tr>`;
      }).join('');
    }

    const total = filteredEsityksetData.length;
    const from = total === 0 ? 0 : start + 1;
    const to = Math.min(start + ESITYKSET_PAGE_SIZE, total);
    esityksetInfo.textContent = `Näytetään ${from}–${to} / ${total}`;

    renderEsityksetPagination(totalPages);

    document.querySelectorAll('.esitykset-table th.sortable').forEach(th => {
      th.classList.remove('sort-asc', 'sort-desc');
      if (th.dataset.col === esityksetSortCol) {
        th.classList.add(esityksetSortDir === 1 ? 'sort-asc' : 'sort-desc');
      }
    });
  }

  function renderEsityksetPagination(total) {
    if (!esityksetPagUl) return;
    esityksetPagUl.innerHTML = '';
    if (total <= 1) return;
    const isMobile = window.matchMedia('(max-width: 767.98px)').matches;

    const appendPageLink = (label, page, { active = false, disabled = false, ariaLabel = '' } = {}) => {
      const li = document.createElement('li');
      li.className = `page-item${active ? ' active' : ''}${disabled ? ' disabled' : ''}`;
      const a = document.createElement('a');
      a.className = 'page-link';
      a.href = '#';
      a.textContent = label;
      if (ariaLabel) a.setAttribute('aria-label', ariaLabel);
      if (!disabled) {
        a.addEventListener('click', e => {
          e.preventDefault();
          esityksetCurrentPage = page;
          renderEsitykset();
          document.getElementById('esitykset')?.scrollIntoView({behavior:'smooth', block:'start'});
        });
      } else {
        a.setAttribute('aria-disabled', 'true');
        a.setAttribute('tabindex', '-1');
      }
      li.appendChild(a);
      esityksetPagUl.appendChild(li);
    };

    const appendEllipsis = () => {
      const li = document.createElement('li');
      li.className = 'page-item disabled';
      li.innerHTML = '<span class="page-link">…</span>';
      esityksetPagUl.appendChild(li);
    };

    if (!isMobile) {
      for (let i = 1; i <= total; i++) {
        appendPageLink(String(i), i, { active: i === esityksetCurrentPage });
      }
      return;
    }

    appendPageLink('‹', Math.max(1, esityksetCurrentPage - 1), {
      disabled: esityksetCurrentPage === 1,
      ariaLabel: 'Edellinen sivu'
    });

    const pages = new Set([1, total, esityksetCurrentPage - 1, esityksetCurrentPage, esityksetCurrentPage + 1]);
    const orderedPages = [...pages].filter((page) => page >= 1 && page <= total).sort((a, b) => a - b);

    let previousPage = null;
    orderedPages.forEach((page) => {
      if (previousPage !== null && page - previousPage > 1) {
        appendEllipsis();
      }
      appendPageLink(String(page), page, { active: page === esityksetCurrentPage });
      previousPage = page;
    });

    appendPageLink('›', Math.min(total, esityksetCurrentPage + 1), {
      disabled: esityksetCurrentPage === total,
      ariaLabel: 'Seuraava sivu'
    });
  }

  function escHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  if (esityksetSearchInp) esityksetSearchInp.addEventListener('input', applyEsityksetFilters);

  document.addEventListener('click', (event) => {
    const trigger = event.target.closest('.preview-thumb-btn');
    if (!trigger) return;
    const src = trigger.getAttribute('data-preview-src');
    if (!src) return;
    const alt = trigger.getAttribute('data-preview-alt') || 'Esityksen kansi';
    const image = document.getElementById('esitysPreviewImage');
    if (image) {
      image.src = src;
      image.alt = alt;
    }
    if (window.bootstrap && window.bootstrap.Modal) {
      window.bootstrap.Modal.getOrCreateInstance(document.getElementById('esitysPreviewModal')).show();
    }
  });

  const esityksetResetBtn = document.getElementById('esitykset-reset');
  if (esityksetResetBtn) {
    esityksetResetBtn.addEventListener('click', () => {
      if (esityksetSearchInp) esityksetSearchInp.value = '';
      activeEsityksetApplication = '';
      if (esityksetApplicationFilter) esityksetApplicationFilter.value = '';
      applyEsityksetFilters();
    });
  }

  if (esityksetApplicationFilter) {
    esityksetApplicationFilter.addEventListener('change', () => {
      activeEsityksetApplication = esityksetApplicationFilter.value || '';
      applyEsityksetFilters();
    });
  }

  document.querySelectorAll('.esitykset-table th.sortable').forEach(th => {
    th.addEventListener('click', () => sortEsityksetData(th.dataset.col));
  });

  initEsityksetApplicationFilter();
  renderEsitykset();
})();

// --- Puheet taulukon logiikka ---
(function () {
  const PUHEET_PAGE_SIZE = 5;
  const puheetDataEl = document.getElementById('puheet-data');
  if (!puheetDataEl) return;
  const puheetData = JSON.parse(puheetDataEl.textContent);

  let filteredPuheetData = [...puheetData].sort((a, b) => new Date(b.date) - new Date(a.date));
  let puheetCurrentPage = 1;
  let puheetSortCol = 'date';
  let puheetSortDir = -1; // -1 = desc

  const puheetSearchInp = document.getElementById('puheet-search');
  const puheetTbody = document.getElementById('puheet-tbody');
  const puheetInfo = document.getElementById('puheet-info');
  const puheetPagUl = document.getElementById('puheet-pagination');

  function shortTitle(t) {
    // Strip "Puheenvuoro[ni]" or "Valtuustopuheenvuoro" prefix
    let s = t.replace(/^(?:Valtuustopuheenvuoro|Puheenvuoro(?:ni)?)\s+/i, '');
    // If § reference present, take everything after it
    let afterParagraph = s.replace(/^.*?§\s*\d+\s*[.:–\s]+/i, '');
    if (afterParagraph !== s) return afterParagraph.trim();
    // Otherwise strip up to first ": "
    let afterColon = s.replace(/^[^:]+:\s*/, '');
    if (afterColon !== s) return afterColon.trim();
    return s.trim();
  }

  function applyPuheetFilters() {
    const q = puheetSearchInp ? puheetSearchInp.value.toLowerCase().trim() : '';
    filteredPuheetData = puheetData.filter(d => {
      const matchQ = !q ||
