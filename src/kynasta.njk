{# Kerätään kaikki Research.fi julkaisut JSON-muotoon JS:ää varten #}
<script id="pub-data" type="application/json">
[
  {% for pub in researchfi %}
  {
    "title": {{ pub.title | dump | safe }},
    "year": {{ (pub.year or 0) | dump | safe }},
    "authors": {{ (pub.authors or "") | dump | safe }},
    "journal": {{ (pub.journal or "") | dump | safe }},
    "url": {{ (pub.url or "") | dump | safe }},
    "type": {{ (pub.typeFi or "") | dump | safe }},
    "typeCode": {{ (pub.typeCode or "") | dump | safe }}
  }{% if not loop.last %},{% endif %}
  {% endfor %}
]
</script>

<section id="julkaisut">
  <div class="container">
    <div class="card shadow-sm">
      <div class="card-header bg-transparent d-flex align-items-center justify-content-between">
        <h2 class="h4 mb-0">Tieteelliset julkaisut</h2>
        <span class="badge text-bg-secondary">{{ researchfi.length }}</span>
      </div>
      <div class="card-body p-0">
        {# ---- Suodatuspalkki ---- #}
        <div class="p-3 bg-light border-bottom">
          <div class="row g-2 align-items-end">
            <div class="col-md-5">
              <label for="pub-search" class="form-label small text-muted mb-1">Hae julkaisua</label>
              <input type="search" id="pub-search" class="form-control form-control-sm"
                     placeholder="Otsikko, kirjoittaja tai julkaisu..." autocomplete="off">
            </div>
            <div class="col-md-3">
              <label for="pub-year" class="form-label small text-muted mb-1">Vuosiluku</label>
              <select id="pub-year" class="form-select form-select-sm">
                <option value="">Kaikki vuodet</option>
              </select>
            </div>
            <div class="col-md-4 d-flex justify-content-md-end gap-2">
              <button id="pub-reset" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-x-circle me-1"></i>Tyhjennä
              </button>
            </div>
          </div>
        </div>

        {# ---- Taulukko ---- #}
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0 pub-table">
            <thead>
              <tr>
                <th class="sortable" data-col="authors" style="min-width:180px">
                  Kirjoittajat <i class="bi bi-arrow-down-up sort-icon small opacity-50"></i>
                </th>
                <th class="sortable text-center" data-col="year" style="width:90px">
                  Vuosi <i class="bi bi-arrow-down-up sort-icon small opacity-50"></i>
                </th>
                <th class="sortable" data-col="title">
                  Otsikko <i class="bi bi-arrow-down-up sort-icon small opacity-50"></i>
                </th>
                <th class="sortable" data-col="journal" style="min-width:150px">
                  Julkaisun nimi <i class="bi bi-arrow-down-up sort-icon small opacity-50"></i>
                </th>
                <th style="width:110px" class="text-center">Toiminnot</th>
              </tr>
            </thead>
            <tbody id="pub-tbody">
              <tr><td colspan="5" class="text-center text-muted py-4">Ladataan julkaisuja...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
      <div class="card-footer bg-transparent d-flex flex-wrap align-items-center justify-content-between gap-2 border-top">
        <small id="pub-info" class="text-muted"></small>
        <nav aria-label="Sivutus">
          <ul id="pub-pagination" class="pagination pagination-sm mb-0 flex-wrap"></ul>
        </nav>
      </div>
    </div>
  </div>
</section>

