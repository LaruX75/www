        const allKeywords = [...(d.keywords || []), ...extraTags];
        const keyBadges = allKeywords.map(k => `<a href="/avainsanat/${slugify(k)}/" class="badge text-bg-light text-dark border me-1 text-decoration-none">${k}</a>`).join('');

