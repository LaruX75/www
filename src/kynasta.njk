{# Kerätään esitykset ja AOE-oppimateriaalit JSON-muotoon JS:ää varten #}
<script id="esitykset-data" type="application/json">
[
  {% set canvaRows = (canva and canva.tableRows) or [] %}
  {% set aoeRows = finnaAoe.rows or [] %}
  {% for item in canvaRows %}
  {
    "title": {{ item.title | jsonSafe | safe }},
    "date": {{ (item.date or "") | jsonSafe | safe }},
    "formattedDate": {{ (item.date or "") | jsonSafe | safe }},
    "description": {{ (item.description or "") | jsonSafe | safe }},
    "url": {{ (item.url or "") | jsonSafe | safe }},
    "thumbnail": {{ (item.thumbnail or "") | jsonSafe | safe }},
    "categories": {{ (item.categories or []) | jsonSafe | safe }},
    "keywords": {{ (item.categories or []) | jsonSafe | safe }},
    "type": "Canva",
    "source": {{ (item.source or "canva") | jsonSafe | safe }}
  }{% if not loop.last or collections.presentations.length or aoeRows.length %},{% endif %}
  {% endfor %}
  {% for presentation in collections.presentations %}
  {% set presentationDate = presentation.data.date or presentation.date %}
  {
    "title": {{ presentation.data.title | jsonSafe | safe }},
    "date": {{ presentationDate | jsonSafe | safe }},
    "formattedDate": "{{ presentationDate | dateFormat }}",
    "description": {{ (presentation.data.description or (presentation.content | excerpt)) | jsonSafe | safe }},
    "url": {{ (presentation.data.url or "") | jsonSafe | safe }},
    "thumbnail": {{ (presentation.data.thumbnail or "") | jsonSafe | safe }},
    "categories": {{ (presentation.data.categories or []) | jsonSafe | safe }},
    "keywords": {{ (presentation.data.keywords or []) | jsonSafe | safe }},
    "type": {{ (presentation.data.type or "Canva") | jsonSafe | safe }},
    "source": {{ (presentation.data.source or "") | jsonSafe | safe }}
  }{% if not loop.last or aoeRows.length %},{% endif %}
  {% endfor %}
  {% for item in aoeRows %}
  {
    "title": {{ item.title | jsonSafe | safe }},
    "date": "{{ item.year }}-01-01",
    "formattedDate": {{ item.year | jsonSafe | safe }},
    "description": {{ (item.summary or "") | jsonSafe | safe }},
    "url": {{ item.url | jsonSafe | safe }},
    "thumbnail": {{ (item.image or "") | jsonSafe | safe }},
    "categories": [],
    "keywords": [],
    "type": "AOE / Finna"
  }{% if not loop.last %},{% endif %}
  {% endfor %}
]
</script>

