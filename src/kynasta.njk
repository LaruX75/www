}

/* ---- Kynasta hero: light theme override ---- */
html:not([data-bs-theme="dark"]) .kynasta-hero {
  background: linear-gradient(135deg, #eef2f7 0%, #e2eaf4 100%);
  border-bottom-color: rgba(15,34,56,0.1);
}
