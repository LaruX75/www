{# ── NYKYINEN TYÖ ─────────────────────────────────────────────────────────── #}
<section class="py-5 bg-body-tertiary">
  <div class="container">
    <p class="ylwork-eyebrow ylwork-eyebrow--dark mb-1"><i class="bi bi-lightning-charge me-1"></i>Nykyinen hanke</p>
    <h2 class="h4 mb-4">Generation AI — strategisen tutkimuksen hanke</h2>
