---
layout: base.njk
title: Sivuston muutokset
description: "Jarilaru.fi-sivuston viimeisimmät muutokset suoraan GitHubista: commitit, päivämäärät, tekijät ja kehityshistoria."
permalink: /sivuston-muutokset/
translationKey: site_changes
lang: fi
---

<section class="py-4 bg-body-tertiary border-bottom">
  <div class="container">
    <p class="text-uppercase small text-muted mb-2">GitHub</p>
    <h1 class="display-6 fw-bold mb-2">Sivuston muutokset</h1>
    <p class="mb-0 text-muted">
      Taulukko näyttää uusimmat muutokset suoraan repositoriosta
      <a href="{{ githubchanges.repo.url }}" target="_blank" rel="noopener noreferrer">{{ githubchanges.repo.owner }}/{{ githubchanges.repo.repo }}</a>
      (haara: <code>{{ githubchanges.repo.branch }}</code>).
    </p>
  </div>
</section>

<section class="py-4">
  <div class="container">
    <div class="alert alert-info py-2 small" role="status">
      Kiinnostavatko toteutuksen työkalut? Katso opas:
      <a href="/miten-sivusto-on-rakennettu/" class="fw-semibold">Miten tämä sivusto on rakennettu</a>.
    </div>

    {% if githubchanges.source == "cache" and githubchanges.cacheSavedAt %}
      <div class="alert alert-warning py-2 small" role="status">
        GitHub API ei ollut saatavilla. Näytetään välimuisti ({{ githubchanges.cacheSavedAt | dateFormat }}).
      </div>
    {% endif %}


    {% if githubchanges.stats %}
      <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
          <div class="card border-0 shadow-sm h-100 text-center">
            <div class="card-body py-3">
              <div class="fs-2 fw-bold text-primary site-changes-kpi-value site-changes-kpi-value--primary">{{ githubchanges.stats.totalCommits }}</div>
              <div class="small text-muted mt-1 site-changes-kpi-label">Committia yhteensä</div>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card border-0 shadow-sm h-100 text-center">
            <div class="card-body py-3">
              <div class="fs-2 fw-bold text-success site-changes-kpi-value site-changes-kpi-value--success">{{ githubchanges.stats.commitsThisYear }}</div>
              <div class="small text-muted mt-1 site-changes-kpi-label">Committia tänä vuonna</div>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card border-0 shadow-sm h-100 text-center">
            <div class="card-body py-3">
              <div class="fs-5 fw-bold text-secondary site-changes-kpi-value site-changes-kpi-value--date">{{ githubchanges.stats.latestDate | dateFormat }}</div>
              <div class="small text-muted mt-1 site-changes-kpi-label">Viimeisin commit</div>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card border-0 shadow-sm h-100 text-center">
            <div class="card-body py-3">
              <div class="fs-5 fw-bold text-secondary site-changes-kpi-value site-changes-kpi-value--date">{{ githubchanges.stats.firstDate | dateFormat }}</div>
              <div class="small text-muted mt-1 site-changes-kpi-label">Ensimmäinen commit</div>
            </div>
          </div>
        </div>
      </div>
    {% endif %}

    {% if githubchanges.rows and githubchanges.rows.length %}
      <div class="table-responsive">
        <table class="table table-hover align-middle" id="github-changes-table">
          <thead>
            <tr>
              <th style="width: 140px;">Päivämäärä</th>
              <th>Muutos</th>
              <th style="width: 180px;">Tekijä</th>
              <th style="width: 130px;">Commit</th>
            </tr>
          </thead>
          <tbody id="github-changes-tbody">
            {% for change in githubchanges.rows %}
              <tr class="github-change-row">
                <td>{{ change.date | dateFormat }}</td>
                <td><a href="{{ change.url }}" target="_blank" rel="noopener noreferrer">{{ change.message }}</a></td>
                <td>{{ change.author }}</td>
                <td>
                  <a href="{{ change.url }}" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary rounded-pill px-2">
                    {{ change.shortSha }}
                  </a>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mt-3 gap-2">
        <small class="text-muted" id="github-changes-meta"></small>
        <ul class="pagination pagination-sm mb-0 justify-content-md-end" id="github-changes-pagination"></ul>
      </div>
    {% else %}
      <div class="alert alert-secondary mb-0" role="status">
        Muutoslistaa ei saatu haettua tällä hetkellä.
        {% if githubchanges.error %}<div class="small mt-2">{{ githubchanges.error }}</div>{% endif %}
      </div>
    {% endif %}
  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const rows = Array.from(document.querySelectorAll("#github-changes-tbody .github-change-row"));
  const pagination = document.getElementById("github-changes-pagination");
  const meta = document.getElementById("github-changes-meta");
  if (!rows.length || !pagination || !meta) return;

  const perPage = 10;
  const totalPages = Math.max(1, Math.ceil(rows.length / perPage));
  let currentPage = 1;

  const createPageItem = (label, page, disabled = false, active = false, isEllipsis = false) => {
    const li = document.createElement("li");
    li.className = `page-item${active ? " active" : ""}${disabled ? " disabled" : ""}`;
    const button = document.createElement("button");
    button.type = "button";
    button.className = "page-link";
    button.textContent = label;
    if (isEllipsis || disabled) {
      button.disabled = true;
    } else {
      button.addEventListener("click", () => {
        currentPage = page;
        render();
      });
    }
    li.appendChild(button);
    return li;
  };

  const getVisiblePages = (current, total) => {
    if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
    const pages = [1];
    const start = Math.max(2, current - 1);
    const end = Math.min(total - 1, current + 1);
    if (start > 2) pages.push("…");
    for (let i = start; i <= end; i += 1) pages.push(i);
    if (end < total - 1) pages.push("…");
    pages.push(total);
    return pages;
  };

  function render() {
    const start = (currentPage - 1) * perPage;
    const end = start + perPage;

    rows.forEach((row, index) => {
      row.style.display = index >= start && index < end ? "" : "none";
    });

    meta.textContent = `Näytetään ${Math.min(start + 1, rows.length)}-${Math.min(end, rows.length)} / ${rows.length}`;

    pagination.innerHTML = "";
    pagination.appendChild(createPageItem("«", Math.max(1, currentPage - 1), currentPage === 1));
    getVisiblePages(currentPage, totalPages).forEach((page) => {
      if (page === "…") {
        pagination.appendChild(createPageItem("…", currentPage, true, false, true));
        return;
      }
      pagination.appendChild(createPageItem(String(page), page, false, page === currentPage));
    });
    pagination.appendChild(createPageItem("»", Math.min(totalPages, currentPage + 1), currentPage === totalPages));
  }

  render();
});
</script>
