---
layout: base.njk
title: Esitykset ja opetusmateriaalit
description: Jari Larun esitykset ja avoimet oppimateriaalit — Canva, AOE, Google Slides ja SlideShare
permalink: /esitykset/
translationKey: presentations_index
---

{# Kerätään SlideShare-esitykset staattisista Markdown-tiedostoista #}
{% set ssDataItems = [] %}
{% set canvaPageUrls = [] %}
{% set canvaThumbnailRows = [] %}
{% for item in collections.presentations %}
  {% if item.data.source == "slideshare" %}
    {% set _ = (ssDataItems.push({
      title: item.data.title,
      url: item.data.url,
      pageUrl: item.url,
      thumbnail: item.data.thumbnail,
      date: item.data.date,
      description: item.data.description or (item.content | excerpt),
      categories: item.data.categories or [],
      keywords: item.data.keywords or []
    }), null) %}
  {% elif item.data.url and "canva.com" in item.data.url %}
    {% set _ = (canvaPageUrls.push({ externalUrl: item.data.url, pageUrl: item.url }), null) %}
  {% endif %}
{% endfor %}
{% for item in ((canva and canva.tableRows) or []) %}
  {% if item.url and item.thumbnail %}
    {% set _ = (canvaThumbnailRows.push({
      title: item.title,
      externalUrl: item.url,
      thumbnail: item.thumbnail
    }), null) %}
  {% endif %}
{% endfor %}
{% set latestPresentationPages = (collections.presentations or []).slice(0, 4) %}
{% set latestShowcaseItems = [] %}
{% if canva and canva.tableRows and canva.tableRows.length %}
  {% for item in (canva.tableRows or []).slice(0, 4) %}
    {% set showcaseDescription = item.description %}
    {% if not showcaseDescription %}
      {% set showcaseDescription = (item.categories or []) | join(", ") %}
    {% endif %}
    {% set _ = (latestShowcaseItems.push({
      title: item.title,
      url: item.url,
      thumbnail: item.thumbnail,
      date: item.date,
      _isoDate: item.date,
      description: showcaseDescription,
      categories: item.categories or [],
      sourceLabel: "Canva",
      ctaLabel: "Avaa esitys",
      external: true
    }), null) %}
  {% endfor %}
{% else %}
  {% for item in latestPresentationPages %}
    {% set showcaseSourceLabel = "Esitys" %}
    {% if item.data.source == "slideshare" %}
      {% set showcaseSourceLabel = "SlideShare" %}
    {% endif %}
    {% set _ = (latestShowcaseItems.push({
      title: item.data.title,
      url: item.url,
      thumbnail: item.data.thumbnail,
      date: item.data.date,
      _isoDate: item.data.date,
      description: item.data.description or (item.content | excerpt),
      categories: item.data.categories or [],
      sourceLabel: showcaseSourceLabel,
      ctaLabel: "Avaa esitys",
      external: false
    }), null) %}
  {% endfor %}
{% endif %}
