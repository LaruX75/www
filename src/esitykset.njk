---
layout: base.njk
title: Esitykset
description: Jari Larun esitykset — Canva, Google Slides ja SlideShare
permalink: /esitykset/
translationKey: presentations_index
---

{% set tocSource %}
<h2 id="canva-heading">Canva-esitykset</h2>
<h2 id="youtube-heading">YouTube-soittolistat</h2>
<h2 id="google-heading">Google Slides -esitykset</h2>
<h2 id="slideshare-heading">SlideShare-esitykset</h2>
{% endset %}
{% set tocMarkup = tocSource | toc %}

<div class="container py-5">
  <header class="mb-5 text-center">
    <h1 class="display-4 fw-bold mb-3">Esitykset</h1>
    <p class="lead text-muted">Valikoima diaesityksiäni eri palveluista.</p>
  </header>

  {% if tocMarkup %}
  <div class="row justify-content-center mb-5">
    <div class="col-lg-8">
      <aside class="card border-0 bg-light">
        <div class="card-body p-3">
          <p class="text-uppercase small text-muted mb-2">Sisällys</p>
          {{ tocMarkup | safe }}
        </div>
      </aside>
    </div>
  </div>
  {% endif %}

  {# ===================== CANVA ===================== #}
  <section class="mb-5" aria-labelledby="canva-heading">
    <h2 id="canva-heading" class="section-title mb-4">
      <i class="bi bi-star-fill text-warning me-2" style="font-size: 1rem;"></i>Canva-esitykset
    </h2>
    {% if canva and canva.tableRows and canva.tableRows.length %}
      <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        {% for p in canva.cardRows %}
        <div class="col">
          <div class="card h-100 border-0 shadow-sm hover-shadow transition">
            <div class="position-relative overflow-hidden">
              {% if p.thumbnail %}
                <img src="{{ p.thumbnail }}"
                     class="card-img-top transition-transform"
                     alt="{{ p.title }}"
                     style="height: 220px; object-fit: cover; object-position: top;">
                {% if p.url %}
                <div class="card-img-overlay d-flex align-items-center justify-content-center opacity-0 bg-dark bg-opacity-50 transition">
                  <a href="{{ p.url }}" target="_blank" rel="noopener noreferrer" class="btn btn-light btn-sm stretched-link">Katso esitys</a>
                </div>
                {% endif %}
              {% else %}
                <div class="d-flex align-items-center justify-content-center text-muted bg-placeholder" style="height: 220px;">
                  <div class="text-center">
                    <i class="bi bi-file-earmark-slides fs-1 mb-2 d-block"></i>
                    <small>Ei esikatselukuvaa</small>
                  </div>
                </div>
              {% endif %}
            </div>
            <div class="card-body">
              <h3 class="h5 card-title mb-1">
                {% if p.url %}
                  <a href="{{ p.url }}" target="_blank" rel="noopener noreferrer" class="text-decoration-none">{{ p.title }}</a>
                {% else %}
                  {{ p.title }}
                {% endif %}
              </h3>
              {% if p.date %}
              <small class="text-muted">{{ p.date | dateFormat }}</small>
              {% endif %}
              {% if p.categories and p.categories.length %}
              <div class="mt-2">
                {% for cat in p.categories %}
                <span class="badge text-bg-secondary rounded-pill me-1">{{ cat }}</span>
                {% endfor %}
              </div>
              {% endif %}
            </div>
            <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-3">
              {% if p.url %}
                <a href="{{ p.url }}" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm rounded-pill px-3">
                  Katso esitys <i class="bi bi-arrow-up-right"></i>
                </a>
              {% else %}
                <span class="text-muted" style="font-size:0.85rem;"><i class="bi bi-link-45deg"></i> Ei linkkiä</span>
              {% endif %}
              <span class="badge text-bg-secondary rounded-pill ms-2">Canva</span>
            </div>
          </div>
        </div>
        {% endfor %}
      </div>

      <div class="mt-3 text-muted small">
        Lähde: Canva Connect API{% if canva.source == 'cache' %} (välimuistista){% elseif canva.source == 'local' %} (paikallisista Markdown-tiedostoista){% endif %}.
      </div>
    {% else %}
      <p class="text-muted">Ei Canva-esityksiä.</p>
    {% endif %}
  </section>

  {# ===================== YOUTUBE ===================== #}
  <section class="mb-5" aria-labelledby="youtube-heading">
    <h2 id="youtube-heading" class="section-title mb-4">
      <i class="bi bi-youtube text-danger me-2" style="font-size: 1rem;"></i>YouTube-soittolistat
    </h2>

    {% if youtube and youtube.tableRows and youtube.tableRows.length %}
      <div class="playlist-ticker mb-4" aria-label="YouTube-soittolistojen skrolleri">
        <div class="playlist-ticker-track">
          {% for p in youtube.tickerRows %}
          <article class="playlist-ticker-item card border-0 shadow-sm">
            {% if p.thumbnail %}
            <img src="{{ p.thumbnail }}" class="card-img-top" alt="{{ p.title }}" style="height: 150px; object-fit: cover;">
            {% endif %}
            <div class="card-body p-3">
              <h3 class="h6 mb-2">{{ p.title }}</h3>
              <p class="text-muted small mb-2">{{ p.itemCount }} videota</p>
              <a href="{{ p.url }}" target="_blank" rel="noopener" class="btn btn-primary btn-sm rounded-pill px-3">
                Avaa soittolista <i class="bi bi-arrow-up-right"></i>
              </a>
            </div>
          </article>
          {% endfor %}
        </div>
      </div>

      <div class="table-responsive">
        <table class="table table-sm table-hover align-middle">
          <thead>
            <tr>
              <th>Soittolista</th>
              <th class="text-nowrap">Videot</th>
              <th class="text-nowrap">Julkaistu</th>
              <th class="text-nowrap">Avaa</th>
            </tr>
          </thead>
          <tbody>
            {% for p in youtube.tableRows %}
            <tr>
              <td>
                <div class="fw-semibold">{{ p.title }}</div>
                {% if p.description %}
                <div class="small text-muted">{{ p.description | truncate(140, true, '...') }}</div>
                {% endif %}
              </td>
              <td>{{ p.itemCount }}</td>
              <td>{{ p.publishedAt | dateFormat }}</td>
              <td>
                <a href="{{ p.url }}" target="_blank" rel="noopener" class="btn btn-outline-primary btn-sm rounded-pill px-3">YouTube</a>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      <div class="mt-3 text-muted small">
        Lähde: YouTube Data API v3{% if youtube.source == 'cache' %} (välimuistista){% endif %}.
      </div>
    {% else %}
      <div class="card border-0 bg-light-subtle">
        <div class="card-body">
          <p class="mb-2 fw-semibold">YouTube-soittolistoja ei saatu haettua.</p>
          <p class="text-muted mb-0 small">
            Lisää ympäristömuuttujat <code>YOUTUBE_API_KEY</code> ja tarvittaessa <code>YOUTUBE_CHANNEL_ID</code> tai <code>YOUTUBE_HANDLE</code>.
          </p>
        </div>
      </div>
    {% endif %}
  </section>

  {# ================ GOOGLE SLIDES ================ #}
  <section class="mb-5" aria-labelledby="google-heading">
    <h2 id="google-heading" class="section-title mb-4">
      <i class="bi bi-file-earmark-slides me-2" style="font-size: 1rem;"></i>Google Slides -esitykset
    </h2>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
      {% for p in googleslides %}
      <div class="col">
        <div class="card h-100 border-0 shadow-sm hover-shadow transition">
          <div class="position-relative overflow-hidden">
            {% if p.thumbnail %}
              <img src="{{ p.thumbnail }}"
                   class="card-img-top transition-transform"
                   alt="{{ p.title }}"
                   style="height: 220px; object-fit: cover; object-position: top;">
              {% if p.url %}
              <div class="card-img-overlay d-flex align-items-center justify-content-center opacity-0 bg-dark bg-opacity-50 transition">
                <a href="{{ p.url }}" target="_blank" rel="noopener noreferrer" class="btn btn-light btn-sm stretched-link">Katso esitys</a>
              </div>
              {% endif %}
            {% else %}
              <div class="d-flex align-items-center justify-content-center text-muted bg-placeholder" style="height: 220px;">
                <div class="text-center">
                  <i class="bi bi-file-earmark-slides fs-1 mb-2 d-block"></i>
                  <small>Ei esikatselukuvaa</small>
                </div>
              </div>
            {% endif %}
          </div>
          <div class="card-body">
            <h3 class="h5 card-title mb-1">
              {% if p.url %}
                <a href="{{ p.url }}" target="_blank" rel="noopener noreferrer" class="text-decoration-none">{{ p.title }}</a>
              {% else %}
                {{ p.title }}
              {% endif %}
            </h3>
            {% if p.date %}
            <small class="text-muted">{{ p.date }}</small>
            {% endif %}
          </div>
          <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-3">
            {% if p.url %}
              <a href="{{ p.url }}" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm rounded-pill px-3">
                Katso esitys <i class="bi bi-arrow-up-right"></i>
              </a>
            {% else %}
              <span class="text-muted" style="font-size:0.85rem;"><i class="bi bi-link-45deg"></i> Ei linkkiä</span>
            {% endif %}
            <span class="badge text-bg-secondary rounded-pill ms-2">Google Slides</span>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </section>

  {# ================= SLIDESHARE ================== #}
  <section class="mb-5" aria-labelledby="slideshare-heading">
    <h2 id="slideshare-heading" class="section-title mb-4">
      <i class="bi bi-collection-play me-2" style="font-size: 1rem;"></i>SlideShare-esitykset
    </h2>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
      {% for p in slideshare %}
      <div class="col">
        <div class="card h-100 border-0 shadow-sm hover-shadow transition">
          <div class="position-relative overflow-hidden">
            {% if p.thumbnail %}
              <img src="{{ p.thumbnail }}"
                   class="card-img-top transition-transform"
                   alt="{{ p.title }}"
                   style="height: 220px; object-fit: cover; object-position: top;">
              <div class="card-img-overlay d-flex align-items-center justify-content-center opacity-0 bg-dark bg-opacity-50 transition">
                <a href="{{ p.url }}" target="_blank" rel="noopener noreferrer" class="btn btn-light btn-sm stretched-link">Katso SlideSharessa</a>
              </div>
            {% else %}
              <div class="d-flex align-items-center justify-content-center text-muted bg-placeholder" style="height: 220px;">
                <div class="text-center">
                  <i class="bi bi-file-earmark-slides fs-1 mb-2 d-block"></i>
                  <small>Ei esikatselukuvaa</small>
                </div>
              </div>
            {% endif %}
          </div>
          <div class="card-body">
            <h3 class="h5 card-title mb-1">
              {% if p.url %}
                <a href="{{ p.url }}" target="_blank" rel="noopener noreferrer" class="text-decoration-none">{{ p.title }}</a>
              {% else %}
                {{ p.title }}
              {% endif %}
            </h3>
          </div>
          <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-3">
            {% if p.url %}
              <a href="{{ p.url }}" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm rounded-pill px-3">
                Katso SlideSharessa <i class="bi bi-arrow-up-right"></i>
              </a>
            {% else %}
              <span class="text-muted" style="font-size:0.85rem;"><i class="bi bi-link-45deg"></i> Ei linkkiä</span>
            {% endif %}
            <span class="badge text-bg-secondary rounded-pill ms-2">SlideShare</span>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>

    <div class="mt-4 text-center">
      <a href="https://www.slideshare.net/larux" target="_blank" rel="noopener noreferrer" class="btn btn-primary px-4 py-2">
        Katso kaikki SlideSharessa (124+) <i class="bi bi-arrow-up-right"></i>
      </a>
    </div>
  </section>

</div>

<style>
/* Section headings */
.section-title {
  font-family: 'Bree Serif', serif;
  font-size: 1.5rem;
  font-weight: 700;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid var(--bs-border-color);
}
[data-bs-theme="dark"] .section-title {
  color: #ffffff;
  border-bottom-color: rgba(255,255,255,0.15);
}

/* Placeholder when no thumbnail */
.bg-placeholder {
  background-color: #dee2e6;
  border-radius: 0;
}
[data-bs-theme="dark"] .bg-placeholder {
  background-color: #2e3f59;
}

/* Card title links — white in dark mode */
.card .card-title a {
  color: var(--bs-body-color) !important;
}
[data-bs-theme="dark"] .card .card-title a {
  color: #ffffff !important;
}
[data-bs-theme="dark"] .card .card-title a:hover {
  color: rgba(255,255,255,0.8) !important;
}

.hover-shadow:hover {
  transform: translateY(-5px);
  box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important;
}
.hover-shadow:hover .card-img-top {
  transform: scale(1.05);
}
.transition-transform {
  transition: transform 0.5s ease-in-out;
}
.transition {
  transition: all 0.3s ease-in-out;
}
.card-img-overlay:hover {
  opacity: 1!important;
}

/* YouTube playlist ticker */
.playlist-ticker {
  overflow-x: auto;
  padding-bottom: 0.25rem;
}

.playlist-ticker-track {
  display: flex;
  gap: 1rem;
  min-width: max-content;
}

.playlist-ticker-item {
  width: 280px;
}
</style>
