{% set combinedLatestItems = [] %}
{% for item in curatedVideoItems %}
  {% set _ = (combinedLatestItems.push({
    title: item.title,
    url: item.url or item.externalUrl,
    thumbnail: item.thumbnail,
    date: item.date,
    _isoDate: item.date,
    description: item.description,
    categories: ["Video"],
    sourceLabel: item.sourceLabel,
    ctaLabel: "Katso tallenne",
    external: true
  }), null) %}
{% endfor %}
{% for item in latestShowcaseItems %}
  {% set _ = (combinedLatestItems.push(item), null) %}
{% endfor %}
{% set latestShowcaseItems = (combinedLatestItems | sort(attribute="_isoDate", reverse=true)).slice(0, 4) %}
{% set latestAoeItems = ((finnaAoe and finnaAoe.rows) or []).slice(0, 2) %}
{% set latestMediaItems = ((mediaArchive and mediaArchive.guest) or []).slice(0, 2) %}
{% set youtubeVideoCount = ((youtube and youtube.videos) or []) | length %}
{% set videoContentCount = youtubeVideoCount + (curatedVideoItems | length) + (videoSeriesItems | length) %}
{% set aoeCount = ((finnaAoe and finnaAoe.rows) or []) | length %}
{% set ownPresentationCount = (((canva and canva.tableRows) or []) | length) + (ssDataItems | length) %}
{% set presentationAnalysisCount = 2 %}
{% set presentationMaterialKeys = [] %}
{% for item in ((canva and canva.tableRows) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (presentationMaterialKeys.indexOf(key) == -1) %}
    {% set _ = (presentationMaterialKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in (collections.presentations or []) %}
  {% set key = (((item.data and item.data.url) or "") ~ "|" ~ ((item.data and item.data.title) or "")) | trim %}
  {% if key != "|" and (presentationMaterialKeys.indexOf(key) == -1) %}
    {% set _ = (presentationMaterialKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in ((finnaAoe and finnaAoe.rows) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (presentationMaterialKeys.indexOf(key) == -1) %}
    {% set _ = (presentationMaterialKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in ((youtube and youtube.videos) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (presentationMaterialKeys.indexOf(key) == -1) %}
    {% set _ = (presentationMaterialKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in curatedVideoItems %}
  {% set key = (((item.url or item.externalUrl) or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (presentationMaterialKeys.indexOf(key) == -1) %}
    {% set _ = (presentationMaterialKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in videoSeriesItems %}
  {% set key = (((item.url or item.externalUrl) or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (presentationMaterialKeys.indexOf(key) == -1) %}
    {% set _ = (presentationMaterialKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% set presentationMaterialTotal = presentationMaterialKeys | length %}
{% set presentationContextItems = (presentationContexts and presentationContexts.items) or [] %}
{% set presentationContextFeedbackRefs = [] %}
{% for context in presentationContextItems %}
  {% for feedbackId in (context.feedbackIds or []) %}
    {% if presentationContextFeedbackRefs.indexOf(feedbackId) == -1 %}
      {% set _ = (presentationContextFeedbackRefs.push(feedbackId), null) %}
    {% endif %}
  {% endfor %}
{% endfor %}
{% set presentationContextFeedbackTotal = presentationContextFeedbackRefs | length %}

{% macro renderContextChips(item) %}
  {% set itemUrl = item.url or item.externalUrl or item.pageUrl or "" %}
  {% set itemTitle = item.title or "" %}
  {% for context in presentationContextItems %}
    {% set materialUrls = context.materialUrls or [] %}
    {% set materialTitles = context.materialTitles or [] %}
    {% if (itemUrl and materialUrls.indexOf(itemUrl) != -1) or (itemTitle and materialTitles.indexOf(itemTitle) != -1) %}
      <span class="presentation-context-chip">{{ context.typeLabel }}: {{ context.title }}</span>
    {% endif %}
  {% endfor %}
{% endmacro %}

<section class="presentation-hero-section py-5 border-bottom">
  <div class="site-shell">
    <div class="row g-4 align-items-center">
      <div class="col-lg-7">
        <p class="text-uppercase text-muted fw-semibold small mb-2">Omat puheenvuorot ja materiaalit</p>
        <h1 class="display-5 fw-bold mb-3">Esitykset ja opetusmateriaalit</h1>
        <p class="lead mb-3">Tältä sivulta löytyvät omat puheenvuoroni, koulutusesitykseni, videotallenteeni ja avoimesti jaetut oppimateriaalini. Painopiste on siinä, mitä olen itse tehnyt ja julkaissut.</p>
        <p class="text-muted mb-4">Jos taas etsit podcasteja, haastatteluja tai muita muiden tuottamia sisältöjä, ne löytyvät erilliseltä <a href="/mediassa/">Mediassa</a>-sivulta. <a href="/kynasta/">Kynästä</a> puolestaan kokoaa kirjoitetut puheenvuorot, lausunnot ja mielipiteet.</p>
        <div class="d-flex flex-wrap gap-2">
          <a href="#ajankohtaiset-nostot" class="btn btn-primary rounded-pill px-4">Ajankohtaiset nostot</a>
          <a href="#sisaltotyypit" class="btn btn-outline-secondary rounded-pill px-4">Sisältötyypit</a>
          <a href="/mediassa/" class="btn btn-outline-secondary rounded-pill px-4">Mediassa</a>
        </div>
      </div>
      <div class="col-lg-5">
        <aside class="card border-0 shadow-sm presentation-hero-panel">
          <div class="card-body p-4 p-xl-5">
            <p class="presentation-hero-panel-kicker mb-3">Silmäys aineistoon</p>
            <dl class="home-hero-kpi-grid mb-0">
              <div class="home-hero-kpi">
                <dd class="home-hero-kpi-value">{{ presentationMaterialTotal }}</dd>
                <dt class="home-hero-kpi-label">materiaalia yhteensä</dt>
              </div>
              <div class="home-hero-kpi">
                <dd class="home-hero-kpi-value">{{ presentationContextItems | length }}</dd>
                <dt class="home-hero-kpi-label">käyttökontekstia</dt>
              </div>
              <div class="home-hero-kpi">
                <dd class="home-hero-kpi-value">{% if videoContentCount %}{{ videoContentCount }}{% else %}{{ presentationAnalysisCount }}{% endif %}</dd>
                <dt class="home-hero-kpi-label">{% if videoContentCount %}videota tai tallennetta{% else %}aineistoanalyysiä{% endif %}</dt>
              </div>
              <div class="home-hero-kpi">
                <dd class="home-hero-kpi-value">{{ aoeCount }}</dd>
                <dt class="home-hero-kpi-label">AOE-materiaalia</dt>
              </div>
            </dl>
          </div>
        </aside>
      </div>
    </div>
  </div>
</section>

<section class="py-5">
  <div class="site-shell">
    <div class="presentation-section-head">
      <p class="presentation-section-kicker mb-1">Mitä etsit?</p>
      <h2 class="presentation-section-title">Puheenvuorot, oppimateriaalit ja tallenteet omissa ryhmissään</h2>
      <p class="presentation-section-lead mb-0">Valitse alta, haluatko selata koulutus- ja keynote-esityksiä, avoimia oppimateriaaleja, videotallenteita vai aineistoanalyysejä. Jokaisesta ryhmästä pääsee myös koko listaan.</p>
    </div>
    <div class="row g-4">
      <div class="col-md-6 col-xl-3">
        <a href="#esitykset-koulutukset" class="card border-0 shadow-sm h-100 presentation-route-card text-decoration-none text-reset">
          <div class="card-body p-4">
            <p class="presentation-route-number">{{ ownPresentationCount }}</p>
            <h3 class="h5 mb-2">Koulutukset ja keynote-esitykset</h3>
            <p class="text-muted mb-0">Omat diaesitykset, koulutusmateriaalit ja tapahtumapuheenvuorot.</p>
          </div>
        </a>
      </div>
      <div class="col-md-6 col-xl-3">
        <a href="#esitykset-oppimateriaalit" class="card border-0 shadow-sm h-100 presentation-route-card text-decoration-none text-reset">
          <div class="card-body p-4">
            <p class="presentation-route-number">{{ aoeCount }}</p>
            <h3 class="h5 mb-2">Avoimet oppimateriaalit</h3>
            <p class="text-muted mb-0">Opetuskäyttöön jaetut materiaalit, jotka elävät myös esitystilanteen ulkopuolella.</p>
          </div>
        </a>
      </div>
      <div class="col-md-6 col-xl-3">
        <a href="#esitykset-videot" class="card border-0 shadow-sm h-100 presentation-route-card text-decoration-none text-reset">
          <div class="card-body p-4">
            <p class="presentation-route-number">{% if videoContentCount %}{{ videoContentCount }}{% else %}<i class="bi bi-youtube"></i>{% endif %}</p>
            <h3 class="h5 mb-2">Videot ja tallenteet</h3>
            <p class="text-muted mb-0">Tallennetut esitykset, omat videosarjat ja YouTube-aineistot.</p>
          </div>
        </a>
      </div>
      <div class="col-md-6 col-xl-3">
        <a href="#esitykset-analyysit" class="card border-0 shadow-sm h-100 presentation-route-card text-decoration-none text-reset">
          <div class="card-body p-4">
            <p class="presentation-route-number">{{ presentationAnalysisCount }}</p>
            <h3 class="h5 mb-2">Aineistoanalyysit</h3>
            <p class="text-muted mb-0">Koosteet siitä, miten esitysten teemat ja painotukset ovat vuosien varrella muuttuneet.</p>
          </div>
        </a>
      </div>
    </div>
    <div class="presentation-media-note mt-4">
      <span class="presentation-media-note-label">Muiden tekemät sisällöt</span>
      <span>Podcastit, haastattelut ja lehtijutut kuuluvat <a href="/mediassa/">Mediassa</a>-sivulle.</span>
    </div>
  </div>
</section>

<section class="py-5 presentation-context-section border-top" id="kayttokontekstit" aria-labelledby="kayttokontekstit-heading">
  <div class="site-shell">
    <div class="presentation-section-head">
      <p class="presentation-section-kicker mb-1">Käyttökontekstit</p>
      <h2 id="kayttokontekstit-heading" class="presentation-section-title">Materiaali, tilaisuus ja palaute samaan ketjuun</h2>
      <p class="presentation-section-lead mb-0">Esitys tai video on harvoin irrallinen tiedosto. Se liittyy yleensä luentoon, harjoitukseen, täydennyskoulutukseen, keynoteen tai julkiseen asiantuntijatilanteeseen. Tämä osio kokoaa ensimmäiset tunnetut yhteydet näkyviin.</p>
    </div>

    <div class="presentation-context-grid">
      {% for context in presentationContextItems | sort(attribute="date", reverse=true) %}
      <article class="presentation-context-card">
        <div class="presentation-context-card-head">
          <span class="presentation-context-type">{{ context.typeLabel }}</span>
          <span class="presentation-context-date">{{ context.displayDate or (context.date | dateFormat) }}</span>
        </div>
        <h3 class="presentation-context-title">{{ context.title }}</h3>
        <p class="presentation-context-summary">{{ context.summary }}</p>
        <dl class="presentation-context-meta">
          <div>
            <dt>Rooli</dt>
            <dd>{{ context.role }}</dd>
          </div>
          <div>
            <dt>Kohderyhmä</dt>
            <dd>{{ context.audience }}</dd>
          </div>
          <div>
            <dt>Järjestäjä</dt>
            <dd>{{ context.organizer }}</dd>
          </div>
        </dl>
        {% if context.topics and context.topics.length %}
        <div class="presentation-context-topics" aria-label="Teemat">
          {% for topic in context.topics %}
          <span>{{ topic }}</span>
          {% endfor %}
        </div>
        {% endif %}
        {% if context.materials and context.materials.length %}
        <div class="presentation-context-materials">
          <p class="presentation-context-subtitle">Kytketyt aineistot</p>
          <div class="d-flex flex-wrap gap-2">
            {% for material in context.materials %}
              {% if material.url %}
              <a href="{{ material.url }}"{% if material.url.startsWith("http") %} target="_blank" rel="noopener noreferrer"{% endif %} class="btn btn-outline-primary btn-sm rounded-pill px-3">{{ material.label }}</a>
              {% else %}
              <span class="presentation-context-material-static">{{ material.label }}</span>
              {% endif %}
            {% endfor %}
          </div>
        </div>
        {% endif %}
        {% if context.feedbackIds and context.feedbackIds.length %}
        <div class="presentation-context-feedback">
          <p class="presentation-context-subtitle">Palaute</p>
          {% for feedback in testimonials.items %}
            {% if context.feedbackIds.indexOf(feedback.id) != -1 %}
            <blockquote>
              <p>“{{ feedback.content.fi.quote }}”</p>
              <footer>{{ feedback.content.fi.attribution }}</footer>
            </blockquote>
            {% endif %}
          {% endfor %}
        </div>
        {% endif %}
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<section class="py-5 bg-body-tertiary border-top border-bottom" id="ajankohtaiset-nostot">
  <div class="site-shell">
    <div class="presentation-section-head">
      <p class="presentation-section-kicker mb-1">Ajankohtaista</p>
      <h2 class="presentation-section-title">Tuoreimmat esitykset ja käyttökelpoiset materiaalit yhdellä silmäyksellä</h2>
      <p class="presentation-section-lead mb-0">Etupää näyttää tuoreimmat omat esitykset, videotallenteet ja käyttökelpoiset materiaalit samassa näkymässä.</p>
    </div>
    <div class="row g-4 align-items-stretch">
      <div class="col-xl-8">
        <div class="row g-4">
          {% for item in latestShowcaseItems %}
          <div class="col-md-6">
            <article class="card border-0 shadow-sm h-100 presentation-latest-card">
              <div class="presentation-latest-media">
                {% if item.thumbnail %}
                <img src="{{ item.thumbnail }}" alt="{{ item.title }}" class="presentation-latest-image" loading="lazy" decoding="async">
                {% else %}
                <div class="presentation-latest-placeholder">
                  <i class="bi bi-easel2"></i>
                </div>
                {% endif %}
              </div>
              <div class="card-body p-4 d-flex flex-column">
                <div class="d-flex flex-wrap gap-2 mb-2">
                  <span class="badge rounded-pill border text-body-secondary">{{ item.sourceLabel }}</span>
                  {% if item.categories and item.categories[0] %}
                  <span class="badge rounded-pill border text-body-secondary">{{ item.categories[0] }}</span>
                  {% endif %}
                </div>
                <p class="text-muted small mb-2">{{ item.date | dateFormat }}</p>
                <div class="presentation-context-chip-row mb-2">
                  {{ renderContextChips(item) }}
                </div>
                <h3 class="h5 mb-2"><a href="{{ item.url }}"{% if item.external %} target="_blank" rel="noopener noreferrer"{% endif %} class="text-decoration-none">{{ item.title }}</a></h3>
                <p class="text-muted small mb-3">{{ item.description }}</p>
                <div class="mt-auto d-flex flex-wrap gap-2">
                  <a href="{{ item.url }}"{% if item.external %} target="_blank" rel="noopener noreferrer"{% endif %} class="btn btn-primary btn-sm rounded-pill px-3">{{ item.ctaLabel or "Avaa" }}</a>
                </div>
              </div>
            </article>
          </div>
          {% endfor %}
        </div>
      </div>
      <div class="col-xl-4">
        <div class="d-grid gap-4 h-100">
          <article class="card border-0 shadow-sm presentation-signal-card">
            <div class="card-body p-4">
              <p class="presentation-signal-kicker mb-2">Videot ja tallenteet</p>
              <h3 class="h5 mb-3">{% if curatedVideoItems.length or videoSeriesItems.length or latestVideoItems.length %}YouTube täydentää esityksiä{% else %}YouTube-tallenteet täydentyvät myöhemmin{% endif %}</h3>
              {% if curatedVideoItems.length or videoSeriesItems.length or latestVideoItems.length %}
              <div class="d-grid gap-3">
                {% for item in curatedVideoItems.slice(0, 1) %}
                <a href="{{ item.url or item.externalUrl }}"{% if item.external %} target="_blank" rel="noopener noreferrer"{% endif %} class="presentation-mini-link">
                  <span class="presentation-mini-thumb">
                    {% if item.thumbnail %}
                    <img src="{{ item.thumbnail }}" alt="{{ item.title }}" class="presentation-mini-thumb-image" loading="lazy" decoding="async">
                    {% else %}
                    <span class="presentation-mini-thumb-placeholder"><i class="bi bi-youtube"></i></span>
                    {% endif %}
                  </span>
                  <span class="presentation-mini-copy">
                    <strong>{{ item.title }}</strong>
                    <span>{{ item.badgeText or item.sourceLabel }}</span>
                  </span>
                </a>
                {% endfor %}
                {% for item in videoSeriesItems.slice(0, 2) %}
                <a href="{{ item.url or item.externalUrl }}"{% if item.external %} target="_blank" rel="noopener noreferrer"{% endif %} class="presentation-mini-link">
                  <span class="presentation-mini-thumb">
                    {% if item.thumbnail %}
