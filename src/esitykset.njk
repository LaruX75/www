              <span class="presentation-mini-thumb">
                {% if item.thumbnail %}
                <img src="{{ item.thumbnail }}" alt="{{ item.title }}" class="presentation-mini-thumb-image" loading="lazy" decoding="async">
                {% else %}
                <span class="presentation-mini-thumb-placeholder"><i class="bi bi-youtube"></i></span>
                {% endif %}
              </span>
              <span class="presentation-mini-copy">
                <strong>{{ item.title }}</strong>
                <span>{{ item.listText or item.badgeText or item.sourceLabel }}</span>
