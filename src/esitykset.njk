---
layout: base.njk
title: Esitykset ja opetusmateriaalit
description: Jari Larun esitykset ja avoimet oppimateriaalit — Canva, AOE, Google Slides ja SlideShare
permalink: /esitykset/
translationKey: presentations_index
---

{% set tocSource %}
<h2 id="aoe-heading">AOE-oppimateriaalit</h2>
<h2 id="canva-heading">Canva-esitykset</h2>
<h2 id="youtube-heading">YouTube-soittolistat</h2>
<h2 id="google-heading">Google Slides -esitykset</h2>
<h2 id="slideshare-heading">SlideShare-esitykset</h2>
{% endset %}
{% set tocMarkup = tocSource | toc %}

<div class="container py-5">
  <header class="mb-5 text-center">
    <h1 class="display-4 fw-bold mb-3">Esitykset ja opetusmateriaalit</h1>
    <p class="lead text-muted">Esitykset, avoimet oppimateriaalit ja muuta sisältöä eri palveluista.</p>
  </header>

  {% if tocMarkup %}
  <div class="row justify-content-center mb-5">
    <div class="col-lg-8">
      <aside class="card border-0 bg-light">
        <div class="card-body p-3">
          <p class="text-uppercase small text-muted mb-2">Sisällys</p>
          {{ tocMarkup | safe }}
        </div>
      </aside>
    </div>
  </div>
  {% endif %}

  {# ===================== AOE ===================== #}
  <section class="mb-5" aria-labelledby="aoe-heading">
    <h2 id="aoe-heading" class="section-title mb-4">
      <i class="bi bi-book-fill text-success me-2" style="font-size: 1rem;"></i>AOE-oppimateriaalit
    </h2>
    {% if finnaAoe and finnaAoe.rows and finnaAoe.rows.length %}
      <div class="presentation-scroller mb-4" data-key="aoe" aria-label="AOE-esitysten skrolleri">
        <div class="presentation-scroller-track"></div>
      </div>
      <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
          <thead>
            <tr>
              <th>Otsikko</th>
              <th>Kuvaus</th>
              <th class="text-nowrap">Päiväys / vuosi</th>
              <th class="text-nowrap">Avaa</th>
            </tr>
          </thead>
          <tbody id="table-body-aoe"></tbody>
        </table>
      </div>
      <nav class="mt-3" aria-label="AOE-sivutus">
        <ul class="pagination pagination-sm mb-0" id="pagination-aoe"></ul>
      </nav>
      <div class="mt-3 text-muted small">
        Lähde: <a href="https://www.finna.fi/" target="_blank" rel="noopener noreferrer">Finna</a> / <a href="https://aoe.fi/" target="_blank" rel="noopener noreferrer">Avointen oppimateriaalien kirjasto (AOE)</a>{% if finnaAoe.source == 'cache' %} (välimuistista){% endif %}.
      </div>
    {% else %}
      <p class="text-muted">Ei AOE-oppimateriaaleja saatavilla.</p>
    {% endif %}
  </section>

  {# ===================== CANVA ===================== #}
  <section class="mb-5" aria-labelledby="canva-heading">
    <h2 id="canva-heading" class="section-title mb-4">
      <i class="bi bi-star-fill text-warning me-2" style="font-size: 1rem;"></i>Canva-esitykset
    </h2>
    {% if canva and canva.tableRows and canva.tableRows.length %}
      <div class="presentation-scroller mb-4" data-key="canva" aria-label="Canva-esitysten skrolleri">
        <div class="presentation-scroller-track"></div>
      </div>
      <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
          <thead>
            <tr>
              <th>Otsikko</th>
              <th>Kuvaus</th>
              <th class="text-nowrap">Päiväys / vuosi</th>
              <th class="text-nowrap">Avaa</th>
            </tr>
          </thead>
          <tbody id="table-body-canva"></tbody>
        </table>
      </div>
      <nav class="mt-3" aria-label="Canva-sivutus">
        <ul class="pagination pagination-sm mb-0" id="pagination-canva"></ul>
      </nav>

      <div class="mt-3 text-muted small">
        Lähde: Canva Connect API{% if canva.source == 'cache' %} (välimuistista){% elseif canva.source == 'local' %} (paikallisista Markdown-tiedostoista){% endif %}.
      </div>
    {% else %}
      <p class="text-muted">Ei Canva-esityksiä.</p>
    {% endif %}
  </section>

  {# ===================== YOUTUBE ===================== #}
  <section class="mb-5" aria-labelledby="youtube-heading">
    <h2 id="youtube-heading" class="section-title mb-4">
      <i class="bi bi-youtube text-danger me-2" style="font-size: 1rem;"></i>YouTube-soittolistat
    </h2>

    {% if youtube and youtube.tableRows and youtube.tableRows.length %}
      <div class="presentation-scroller mb-4" data-key="youtube" aria-label="YouTube-soittolistojen skrolleri">
        <div class="presentation-scroller-track"></div>
      </div>
      <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
          <thead>
            <tr>
              <th>Otsikko</th>
              <th>Kuvaus</th>
              <th class="text-nowrap">Päiväys / vuosi</th>
              <th class="text-nowrap">Avaa</th>
            </tr>
          </thead>
          <tbody id="table-body-youtube"></tbody>
        </table>
      </div>
      <nav class="mt-3" aria-label="YouTube-sivutus">
        <ul class="pagination pagination-sm mb-0" id="pagination-youtube"></ul>
      </nav>
      <div class="mt-3 text-muted small">
        Lähde: YouTube Data API v3{% if youtube.source == 'cache' %} (välimuistista){% endif %}.
      </div>
    {% else %}
      <div class="card border-0 bg-light-subtle">
        <div class="card-body">
          <p class="mb-2 fw-semibold">YouTube-soittolistoja ei saatu haettua.</p>
          <p class="text-muted mb-0 small">
            Lisää ympäristömuuttujat <code>YOUTUBE_API_KEY</code> ja tarvittaessa <code>YOUTUBE_CHANNEL_ID</code> tai <code>YOUTUBE_HANDLE</code>.
          </p>
        </div>
      </div>
    {% endif %}
  </section>

  {# ================ GOOGLE SLIDES ================ #}
  <section class="mb-5" aria-labelledby="google-heading">
    <h2 id="google-heading" class="section-title mb-4">
      <i class="bi bi-file-earmark-slides me-2" style="font-size: 1rem;"></i>Google Slides -esitykset
    </h2>
    {% if googleslides and googleslides.length %}
      <div class="presentation-scroller mb-4" data-key="google" aria-label="Google Slides -esitysten skrolleri">
        <div class="presentation-scroller-track"></div>
      </div>
      <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
          <thead>
            <tr>
              <th>Otsikko</th>
              <th>Kuvaus</th>
              <th class="text-nowrap">Päiväys / vuosi</th>
              <th class="text-nowrap">Avaa</th>
            </tr>
          </thead>
          <tbody id="table-body-google"></tbody>
        </table>
      </div>
      <nav class="mt-3" aria-label="Google Slides -sivutus">
        <ul class="pagination pagination-sm mb-0" id="pagination-google"></ul>
      </nav>
    {% else %}
      <p class="text-muted">Ei Google Slides -esityksiä saatavilla.</p>
    {% endif %}
  </section>

  {# ================= SLIDESHARE ================== #}
  <section class="mb-5" aria-labelledby="slideshare-heading">
    <h2 id="slideshare-heading" class="section-title mb-4">
      <i class="bi bi-collection-play me-2" style="font-size: 1rem;"></i>SlideShare-esitykset
    </h2>
    {% if slideshare and slideshare.length %}
      <div class="presentation-scroller mb-4" data-key="slideshare" aria-label="SlideShare-esitysten skrolleri">
        <div class="presentation-scroller-track"></div>
      </div>
      <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
          <thead>
            <tr>
              <th>Otsikko</th>
              <th>Kuvaus</th>
              <th class="text-nowrap">Päiväys / vuosi</th>
              <th class="text-nowrap">Avaa</th>
            </tr>
          </thead>
          <tbody id="table-body-slideshare"></tbody>
        </table>
      </div>
      <nav class="mt-3" aria-label="SlideShare-sivutus">
        <ul class="pagination pagination-sm mb-0" id="pagination-slideshare"></ul>
      </nav>
    {% else %}
      <p class="text-muted">Ei SlideShare-esityksiä saatavilla.</p>
    {% endif %}

    <div class="mt-4 text-center">
      <a href="https://www.slideshare.net/larux" target="_blank" rel="noopener noreferrer" class="btn btn-primary px-4 py-2">
        Katso kaikki SlideSharessa ({{ (slideshare or []).length }}) <i class="bi bi-arrow-up-right"></i>
      </a>
    </div>
  </section>

</div>

<script>
(() => {
  const PAGE_SIZE = 6;
  const rawData = {
    aoe: {{ (finnaAoe.rows or []) | dump | safe }},
    canva: {{ (canva.tableRows or []) | dump | safe }},
    youtube: {{ (youtube.tableRows or []) | dump | safe }},
    google: {{ (googleslides or []) | dump | safe }},
    slideshare: {{ (slideshare or []) | dump | safe }}
  };

  const iconByKey = {
    aoe: "bi-book",
    canva: "bi-file-earmark-slides",
    youtube: "bi-youtube",
    google: "bi-file-earmark-slides",
    slideshare: "bi-collection-play"
  };

  const linkLabelByKey = {
    aoe: "Avaa Finnassa",
    canva: "Avaa",
    youtube: "YouTube",
    google: "Avaa",
    slideshare: "SlideShare"
  };

  function escHtml(value) {
    return String(value || "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function truncate(value, max = 120) {
    const text = String(value || "").trim();
    if (!text) return "";
    return text.length > max ? `${text.slice(0, max).trim()}…` : text;
  }

  function toDisplayDate(value) {
    if (!value) return "";
    const parsed = new Date(value);
    if (!Number.isNaN(parsed.getTime())) {
      return new Intl.DateTimeFormat("fi-FI").format(parsed);
    }
    return String(value);
  }

  function normalizeRows(key, rows) {
    if (!Array.isArray(rows)) return [];

    if (key === "aoe") {
      return rows.map((r) => ({
        title: r.title || "Nimetön oppimateriaali",
        url: r.url || "",
        thumbnail: r.image || "",
        description: r.summary || "",
        meta: "AOE / Oppimateriaali",
        date: r.year || ""
      }));
    }

    if (key === "canva") {
      return rows.map((r) => ({
        title: r.title || "Nimetön esitys",
        url: r.url || "",
        thumbnail: r.thumbnail || "",
        description: Array.isArray(r.categories) && r.categories.length ? r.categories.join(", ") : "Canva-esitys",
        meta: "Canva",
        date: r.date || ""
      }));
    }

    if (key === "youtube") {
      return rows.map((r) => ({
        title: r.title || "Nimetön soittolista",
        url: r.url || "",
        thumbnail: r.thumbnail || "",
        description: r.description || "",
        meta: `${r.itemCount || 0} videota`,
        date: toDisplayDate(r.publishedAt || "")
      }));
    }

    if (key === "google") {
      return rows.map((r) => ({
        title: r.title || "Nimetön esitys",
        url: r.url || "",
        thumbnail: r.thumbnail || "",
        description: "Google Slides -esitys",
        meta: "Google Slides",
        date: r.date || ""
      }));
    }

    if (key === "slideshare") {
      return rows.map((r) => ({
        title: r.title || "Nimetön esitys",
        url: r.url || "",
        thumbnail: r.thumbnail || "",
        description: r.author ? `Tekijä: ${r.author}` : "SlideShare-esitys",
        meta: r.views ? `${r.views} katselua` : "SlideShare",
        date: ""
      }));
    }

    return [];
  }

  function pickFourRandom(rows) {
    if (!rows.length) return [];
    const shuffled = [...rows];
    for (let i = shuffled.length - 1; i > 0; i -= 1) {
      const j = Math.floor(Math.random() * (i + 1));
      [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
    }
    const picked = shuffled.slice(0, Math.min(4, shuffled.length));
    while (picked.length < 4) {
      picked.push(shuffled[picked.length % shuffled.length]);
    }
    return picked;
  }

  function renderScroller(key, rows) {
    const host = document.querySelector(`.presentation-scroller[data-key="${key}"] .presentation-scroller-track`);
    if (!host) return;
    const cards = pickFourRandom(rows);
    if (!cards.length) {
      host.innerHTML = "";
      return;
    }

    const htmlCards = cards.map((item) => {
      const thumb = item.thumbnail
        ? `<img src="${escHtml(item.thumbnail)}" class="card-img-top" alt="${escHtml(item.title)}">`
        : `<div class="scroller-placeholder"><i class="bi ${escHtml(iconByKey[key] || "bi-file-earmark")}"></i></div>`;
      const link = item.url
        ? `<a href="${escHtml(item.url)}" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm rounded-pill px-3">${escHtml(linkLabelByKey[key] || "Avaa")} <i class="bi bi-arrow-up-right"></i></a>`
        : `<span class="text-muted small"><i class="bi bi-link-45deg"></i> Ei linkkiä</span>`;
      return `
        <article class="card border-0 shadow-sm presentation-scroller-card">
          ${thumb}
          <div class="card-body p-3">
            <h3 class="h6 mb-2">${escHtml(item.title)}</h3>
            <p class="text-muted small mb-3">${escHtml(truncate(item.meta || item.description, 72))}</p>
            ${link}
          </div>
        </article>
      `;
    }).join("");

    host.innerHTML = `${htmlCards}${htmlCards}`;
  }

  function renderPagination(key, rows, page, onChange) {
    const host = document.getElementById(`pagination-${key}`);
    if (!host) return;
    const pageCount = Math.ceil(rows.length / PAGE_SIZE);
    if (pageCount <= 1) {
      host.innerHTML = "";
      return;
    }

    let html = "";
    for (let p = 1; p <= pageCount; p += 1) {
      html += `
        <li class="page-item ${p === page ? "active" : ""}">
          <button class="page-link" type="button" data-page="${p}">${p}</button>
        </li>
      `;
    }
    host.innerHTML = html;
    host.querySelectorAll("button[data-page]").forEach((btn) => {
      btn.addEventListener("click", () => onChange(Number(btn.dataset.page)));
    });
  }

  function renderTable(key, rows, page, onChange) {
    const tbody = document.getElementById(`table-body-${key}`);
    if (!tbody) return;
    const start = (page - 1) * PAGE_SIZE;
    const pageRows = rows.slice(start, start + PAGE_SIZE);

    tbody.innerHTML = pageRows.map((item) => `
      <tr>
        <td class="fw-semibold">${escHtml(item.title)}</td>
        <td>
          <div class="small">${escHtml(truncate(item.description, 140) || "-")}</div>
          <div class="small text-muted">${escHtml(item.meta || "")}</div>
        </td>
        <td class="text-nowrap">${escHtml(item.date || "-")}</td>
        <td>
          ${item.url
            ? `<a href="${escHtml(item.url)}" target="_blank" rel="noopener noreferrer" class="btn btn-outline-primary btn-sm rounded-pill px-3">${escHtml(linkLabelByKey[key] || "Avaa")}</a>`
            : `<span class="text-muted small">Ei linkkiä</span>`}
        </td>
      </tr>
    `).join("");

    renderPagination(key, rows, page, onChange);
  }

  Object.entries(rawData).forEach(([key, rows]) => {
    const normalized = normalizeRows(key, rows);
    if (!normalized.length) return;
    renderScroller(key, normalized);
    let currentPage = 1;
    const rerender = (newPage) => {
      currentPage = newPage;
      renderTable(key, normalized, currentPage, rerender);
    };
    rerender(1);
  });
})();
</script>

<style>
/* Section headings */
.section-title {
  font-family: 'Bree Serif', serif;
  font-size: 1.5rem;
  font-weight: 700;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid var(--bs-border-color);
}
[data-bs-theme="dark"] .section-title {
  color: #ffffff;
  border-bottom-color: rgba(255,255,255,0.15);
}

/* Placeholder when no thumbnail */
.bg-placeholder {
  background-color: #dee2e6;
  border-radius: 0;
}
[data-bs-theme="dark"] .bg-placeholder {
  background-color: #2e3f59;
}

/* Card title links — white in dark mode */
.card .card-title a {
  color: var(--bs-body-color) !important;
}
[data-bs-theme="dark"] .card .card-title a {
  color: #ffffff !important;
}
[data-bs-theme="dark"] .card .card-title a:hover {
  color: rgba(255,255,255,0.8) !important;
}

.hover-shadow:hover {
  transform: translateY(-5px);
  box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important;
}
.hover-shadow:hover .card-img-top {
  transform: scale(1.05);
}
.transition-transform {
  transition: transform 0.5s ease-in-out;
}
.transition {
  transition: all 0.3s ease-in-out;
}
.card-img-overlay:hover {
  opacity: 1!important;
}

/* Category scroller */
.presentation-scroller {
  overflow-x: auto;
  padding-bottom: 0.25rem;
}

.presentation-scroller-track {
  display: flex;
  gap: 1.2rem;
  min-width: max-content;
  animation: presentations-scroll 24s linear infinite;
}

.presentation-scroller:hover .presentation-scroller-track {
  animation-play-state: paused;
}

.presentation-scroller-card {
  width: 280px;
  flex: 0 0 280px;
}

.presentation-scroller-card .card-img-top,
.scroller-placeholder {
  height: 150px;
  object-fit: cover;
}

.scroller-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #dee2e6;
  color: #6c757d;
  font-size: 2rem;
}
[data-bs-theme="dark"] .scroller-placeholder {
  background: #2e3f59;
  color: #d2d9e2;
}

@keyframes presentations-scroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(calc(-50% - 0.6rem)); }
}

@media (max-width: 767.98px) {
  .presentation-scroller-card {
    width: 260px;
    flex-basis: 260px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .presentation-scroller-track {
    animation: none !important;
  }
}
</style>
