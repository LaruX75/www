        {% if finnaAoe and finnaAoe.rows and finnaAoe.rows.length %}
          <div class="mt-4">
            <h3 class="h6 fw-bold">AOE-oppimateriaalit</h3>
            <ul class="list-unstyled row row-cols-1 row-cols-md-2 g-3 mt-1">
              {% for row in finnaAoe.rows %}
                <li class="col">
                  <a class="small fw-semibold text-decoration-none" href="{{ row.url }}" target="_blank" rel="noopener noreferrer">{{ row.title }}</a>
                  <div class="small text-muted mt-1">AOE / Finna{% if row.year %} · {{ row.year }}{% endif %}</div>
                  {% if row.summary %}
