        {% endif %}


        {% if youtube and youtube.tableRows and youtube.tableRows.length %}
          <div class="mt-4">
            <h3 class="h6 fw-bold">YouTube-soittolistat</h3>
            <ul class="list-unstyled row row-cols-1 row-cols-md-2 g-3 mt-1">
              {% for row in youtube.tableRows %}
                <li class="col">
                  <a class="small fw-semibold text-decoration-none" href="{{ row.url }}" target="_blank" rel="noopener noreferrer">{{ row.title }}</a>
                  <div class="small text-muted mt-1">YouTube{% if row.date or row.year %} · {{ row.date or row.year }}{% endif %}</div>
                  {% if row.description or row.summary %}
                    <div class="small text-muted">{{ row.description or row.summary }}</div>
                  {% endif %}
