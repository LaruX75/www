---
layout: base.njk
title: Esitykset ja opetusmateriaalit
description: Jari Larun esitykset ja avoimet oppimateriaalit — Canva, AOE, Google Slides ja SlideShare
permalink: /esitykset/
translationKey: presentations_index
---

{# Kerätään SlideShare-esitykset staattisista Markdown-tiedostoista #}
{% set ssDataItems = [] %}
{% set canvaPageUrls = [] %}
{% set canvaThumbnailRows = [] %}
{% for item in collections.presentations %}
  {% if item.data.source == "slideshare" %}
    {% set _ = (ssDataItems.push({
      title: item.data.title,
      url: item.data.url,
      pageUrl: item.url,
      thumbnail: item.data.thumbnail,
      date: item.data.date,
      description: item.data.description or (item.content | excerpt),
      categories: item.data.categories or [],
      keywords: item.data.keywords or []
    }), null) %}
  {% elif item.data.url and "canva.com" in item.data.url %}
    {% set _ = (canvaPageUrls.push({ externalUrl: item.data.url, pageUrl: item.url }), null) %}
  {% endif %}
{% endfor %}
{% for item in ((canva and canva.tableRows) or []) %}
  {% if item.url and item.thumbnail %}
    {% set _ = (canvaThumbnailRows.push({
      title: item.title,
      externalUrl: item.url,
      thumbnail: item.thumbnail
    }), null) %}
  {% endif %}
{% endfor %}
{% set latestPresentationPages = (collections.presentations or []).slice(0, 4) %}
{% set latestShowcaseItems = [] %}
{% if canva and canva.tableRows and canva.tableRows.length %}
  {% for item in (canva.tableRows or []).slice(0, 4) %}
    {% set showcaseDescription = item.description %}
    {% if not showcaseDescription %}
      {% set showcaseDescription = (item.categories or []) | join(", ") %}
    {% endif %}
    {% set _ = (latestShowcaseItems.push({
      title: item.title,
      url: item.url,
      thumbnail: item.thumbnail,
      date: item.date,
      description: showcaseDescription,
      categories: item.categories or [],
      sourceLabel: "Canva"
    }), null) %}
  {% endfor %}
{% else %}
  {% for item in latestPresentationPages %}
    {% set showcaseSourceLabel = "Esitys" %}
    {% if item.data.source == "slideshare" %}
      {% set showcaseSourceLabel = "SlideShare" %}
    {% endif %}
    {% set _ = (latestShowcaseItems.push({
      title: item.data.title,
      url: item.url,
      thumbnail: item.data.thumbnail,
      date: item.data.date,
      description: item.data.description or (item.content | excerpt),
      categories: item.data.categories or [],
      sourceLabel: showcaseSourceLabel
    }), null) %}
  {% endfor %}
{% endif %}
{% set latestVideoItems = ((youtube and youtube.videos) or []).slice(0, 2) %}
{% set latestAoeItems = ((finnaAoe and finnaAoe.rows) or []).slice(0, 2) %}
{% set latestMediaItems = ((mediaArchive and mediaArchive.guest) or []).slice(0, 2) %}
{% set youtubeVideoCount = ((youtube and youtube.videos) or []) | length %}
{% set aoeCount = ((finnaAoe and finnaAoe.rows) or []) | length %}
{% set ownPresentationCount = (((canva and canva.tableRows) or []) | length) + (ssDataItems | length) %}
{% set presentationAnalysisCount = 2 %}
{% set presentationMaterialKeys = [] %}
{% for item in ((canva and canva.tableRows) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (presentationMaterialKeys.indexOf(key) == -1) %}
    {% set _ = (presentationMaterialKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in (collections.presentations or []) %}
  {% set key = (((item.data and item.data.url) or "") ~ "|" ~ ((item.data and item.data.title) or "")) | trim %}
  {% if key != "|" and (presentationMaterialKeys.indexOf(key) == -1) %}
    {% set _ = (presentationMaterialKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in ((finnaAoe and finnaAoe.rows) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (presentationMaterialKeys.indexOf(key) == -1) %}
    {% set _ = (presentationMaterialKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% for item in ((youtube and youtube.videos) or []) %}
  {% set key = ((item.url or "") ~ "|" ~ (item.title or "")) | trim %}
  {% if key != "|" and (presentationMaterialKeys.indexOf(key) == -1) %}
    {% set _ = (presentationMaterialKeys.push(key), null) %}
  {% endif %}
{% endfor %}
{% set presentationMaterialTotal = presentationMaterialKeys | length %}

<section class="presentation-hero-section py-5 border-bottom">
  <div class="site-shell">
    <div class="row g-4 align-items-center">
      <div class="col-lg-7">
        <p class="text-uppercase text-muted fw-semibold small mb-2">Omat puheenvuorot ja materiaalit</p>
        <h1 class="display-5 fw-bold mb-3">Esitykset ja opetusmateriaalit</h1>
        <p class="lead mb-3">Tältä sivulta löytyvät omat puheenvuoroni, koulutusesitykseni, videotallenteeni ja avoimesti jaetut oppimateriaalini. Painopiste on siinä, mitä olen itse tehnyt ja julkaissut.</p>
        <p class="text-muted mb-4">Jos taas etsit podcasteja, haastatteluja tai muita muiden tuottamia sisältöjä, ne löytyvät erilliseltä <a href="/mediassa/">Mediassa</a>-sivulta. <a href="/kynasta/">Kynästä</a> puolestaan kokoaa kirjoitetut puheenvuorot, lausunnot ja mielipiteet.</p>
        <div class="d-flex flex-wrap gap-2">
          <a href="#ajankohtaiset-nostot" class="btn btn-primary rounded-pill px-4">Ajankohtaiset nostot</a>
          <a href="#sisaltotyypit" class="btn btn-outline-secondary rounded-pill px-4">Sisältötyypit</a>
          <a href="/mediassa/" class="btn btn-outline-secondary rounded-pill px-4">Mediassa</a>
        </div>
      </div>
      <div class="col-lg-5">
        <aside class="card border-0 shadow-sm presentation-hero-panel">
          <div class="card-body p-4 p-xl-5">
            <p class="presentation-hero-panel-kicker mb-3">Silmäys aineistoon</p>
            <dl class="home-hero-kpi-grid mb-0">
              <div class="home-hero-kpi">
                <dd class="home-hero-kpi-value">{{ presentationMaterialTotal }}</dd>
                <dt class="home-hero-kpi-label">materiaalia yhteensä</dt>
              </div>
              <div class="home-hero-kpi">
                <dd class="home-hero-kpi-value">{{ (collections.presentations or []) | length }}</dd>
                <dt class="home-hero-kpi-label">esityssivua sivustolla</dt>
              </div>
              <div class="home-hero-kpi">
                <dd class="home-hero-kpi-value">{% if youtubeVideoCount %}{{ youtubeVideoCount }}{% else %}{{ presentationAnalysisCount }}{% endif %}</dd>
                <dt class="home-hero-kpi-label">{% if youtubeVideoCount %}videota tai tallennetta{% else %}aineistoanalyysiä{% endif %}</dt>
              </div>
              <div class="home-hero-kpi">
                <dd class="home-hero-kpi-value">{{ aoeCount }}</dd>
                <dt class="home-hero-kpi-label">AOE-materiaalia</dt>
              </div>
            </dl>
          </div>
        </aside>
      </div>
    </div>
  </div>
</section>

<section class="py-5">
  <div class="site-shell">
    <div class="presentation-section-head">
      <p class="presentation-section-kicker mb-1">Selaa sisältötyypin mukaan</p>
      <h2 class="presentation-section-title">Etsi ensin sisältöä, älä palvelua</h2>
      <p class="presentation-section-lead mb-0">Canva, SlideShare, YouTube ja AOE jäävät lähdetiedoiksi. Tällä sivulla sisältö on järjestetty sen mukaan, mitä käyttäjä todennäköisesti etsii.</p>
    </div>
    <div class="row g-4">
      <div class="col-md-6 col-xl-3">
        <a href="#esitykset-koulutukset" class="card border-0 shadow-sm h-100 presentation-route-card text-decoration-none text-reset">
          <div class="card-body p-4">
            <p class="presentation-route-number">{{ ownPresentationCount }}</p>
            <h3 class="h5 mb-2">Koulutukset ja keynote-esitykset</h3>
            <p class="text-muted mb-0">Omat diaesitykset, koulutusmateriaalit ja tapahtumapuheenvuorot.</p>
          </div>
        </a>
      </div>
      <div class="col-md-6 col-xl-3">
        <a href="#esitykset-oppimateriaalit" class="card border-0 shadow-sm h-100 presentation-route-card text-decoration-none text-reset">
          <div class="card-body p-4">
            <p class="presentation-route-number">{{ aoeCount }}</p>
            <h3 class="h5 mb-2">Avoimet oppimateriaalit</h3>
            <p class="text-muted mb-0">Opetuskäyttöön jaetut materiaalit, jotka elävät myös esitystilanteen ulkopuolella.</p>
          </div>
        </a>
      </div>
      <div class="col-md-6 col-xl-3">
        <a href="#esitykset-videot" class="card border-0 shadow-sm h-100 presentation-route-card text-decoration-none text-reset">
          <div class="card-body p-4">
            <p class="presentation-route-number">{% if youtubeVideoCount %}{{ youtubeVideoCount }}{% else %}<i class="bi bi-youtube"></i>{% endif %}</p>
            <h3 class="h5 mb-2">Videot ja tallenteet</h3>
            <p class="text-muted mb-0">Tallennetut esitykset ja videot silloin, kun niitä on saatavilla.</p>
          </div>
        </a>
      </div>
      <div class="col-md-6 col-xl-3">
        <a href="#esitykset-analyysit" class="card border-0 shadow-sm h-100 presentation-route-card text-decoration-none text-reset">
          <div class="card-body p-4">
            <p class="presentation-route-number">{{ presentationAnalysisCount }}</p>
            <h3 class="h5 mb-2">Aineistoanalyysit</h3>
            <p class="text-muted mb-0">Koosteet siitä, miten esitysten teemat ja painotukset ovat vuosien varrella muuttuneet.</p>
          </div>
        </a>
      </div>
    </div>
    <div class="presentation-media-note mt-4">
      <span class="presentation-media-note-label">Muiden tekemät sisällöt</span>
      <span>Podcastit, haastattelut ja lehtijutut kuuluvat <a href="/mediassa/">Mediassa</a>-sivulle.</span>
    </div>
  </div>
</section>

<section class="py-5 bg-body-tertiary border-top border-bottom" id="ajankohtaiset-nostot">
  <div class="site-shell">
    <div class="presentation-section-head">
      <p class="presentation-section-kicker mb-1">Ajankohtaista</p>
      <h2 class="presentation-section-title">Tuoreimmat esitykset ja käyttökelpoiset materiaalit yhdellä silmäyksellä</h2>
      <p class="presentation-section-lead mb-0">Etupää näyttää uusimmat omat esityssivut. Vieressä näkyvät viimeisimmät videot, oppimateriaalit ja linkki muuhun julkiseen esiintymiseen.</p>
    </div>
    <div class="row g-4 align-items-stretch">
      <div class="col-xl-8">
        <div class="row g-4">
          {% for item in latestShowcaseItems %}
          <div class="col-md-6">
            <article class="card border-0 shadow-sm h-100 presentation-latest-card">
              <div class="presentation-latest-media">
                {% if item.thumbnail %}
                <img src="{{ item.thumbnail }}" alt="{{ item.title }}" class="presentation-latest-image" loading="lazy" decoding="async">
                {% else %}
                <div class="presentation-latest-placeholder">
                  <i class="bi bi-easel2"></i>
                </div>
                {% endif %}
              </div>
              <div class="card-body p-4 d-flex flex-column">
                <div class="d-flex flex-wrap gap-2 mb-2">
                  <span class="badge rounded-pill border text-body-secondary">{{ item.sourceLabel }}</span>
                  {% if item.categories and item.categories[0] %}
                  <span class="badge rounded-pill border text-body-secondary">{{ item.categories[0] }}</span>
                  {% endif %}
                </div>
                <p class="text-muted small mb-2">{{ item.date | dateFormat }}</p>
                <h3 class="h5 mb-2"><a href="{{ item.url }}" class="text-decoration-none">{{ item.title }}</a></h3>
                <p class="text-muted small mb-3">{{ item.description }}</p>
                <div class="mt-auto d-flex flex-wrap gap-2">
                  <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm rounded-pill px-3">Avaa esitys</a>
                </div>
              </div>
            </article>
          </div>
          {% endfor %}
        </div>
      </div>
      <div class="col-xl-4">
        <div class="d-grid gap-4 h-100">
          <article class="card border-0 shadow-sm presentation-signal-card">
            <div class="card-body p-4">
              <p class="presentation-signal-kicker mb-2">Videot ja tallenteet</p>
              <h3 class="h5 mb-3">{% if latestVideoItems.length %}YouTube täydentää esityksiä{% else %}YouTube-tallenteet täydentyvät myöhemmin{% endif %}</h3>
              {% if latestVideoItems.length %}
              <div class="d-grid gap-3">
                {% for item in latestVideoItems %}
                <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer" class="presentation-mini-link">
                  <span class="presentation-mini-thumb">
                    {% if item.thumbnail %}
                    <img src="{{ item.thumbnail }}" alt="{{ item.title }}" class="presentation-mini-thumb-image" loading="lazy" decoding="async">
                    {% else %}
                    <span class="presentation-mini-thumb-placeholder"><i class="bi bi-youtube"></i></span>
                    {% endif %}
                  </span>
                  <span class="presentation-mini-copy">
                    <strong>{{ item.title }}</strong>
                    <span>{{ item.publishedAt | dateFormat }}</span>
                  </span>
                </a>
                {% endfor %}
              </div>
              {% else %}
              <p class="text-muted small mb-3">Tällä hetkellä painopiste näkyy esityssivuissa ja avoimissa oppimateriaaleissa. Videotallenteet täydentävät kokonaisuutta myöhemmin.</p>
              <a href="https://www.youtube.com/jarilaru" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary btn-sm rounded-pill px-3">YouTube-kanava</a>
              {% endif %}
            </div>
          </article>
          <article class="card border-0 shadow-sm presentation-signal-card">
            <div class="card-body p-4">
              <p class="presentation-signal-kicker mb-2">Avoimet oppimateriaalit</p>
              <h3 class="h5 mb-3">AOE tuo materiaalit opetuskäyttöön</h3>
              {% if latestAoeItems.length %}
              <div class="d-grid gap-3">
                {% for item in latestAoeItems %}
                <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer" class="presentation-mini-link">
                  <span class="presentation-mini-thumb">
                    {% if item.image %}
                    <img src="{{ item.image }}" alt="{{ item.title }}" class="presentation-mini-thumb-image" loading="lazy" decoding="async">
                    {% else %}
                    <span class="presentation-mini-thumb-placeholder"><i class="bi bi-book"></i></span>
                    {% endif %}
                  </span>
                  <span class="presentation-mini-copy">
                    <strong>{{ item.title }}</strong>
                    <span>{% if item.year %}{{ item.year }}{% else %}AOE / Finna{% endif %}</span>
                  </span>
                </a>
                {% endfor %}
              </div>
              {% else %}
              <p class="text-muted small mb-0">AOE-materiaaleja ei ole juuri nyt saatavilla.</p>
              {% endif %}
            </div>
          </article>
          <article class="card border-0 shadow-sm presentation-signal-card presentation-signal-card--accent">
            <div class="card-body p-4">
              <p class="presentation-signal-kicker mb-2">Muu julkinen esiintyminen</p>
              <h3 class="h5 mb-2">Podcastit ja haastattelut ovat omalla sivullaan</h3>
              <p class="text-muted small mb-3">Esitykset kokoaa oman tuotannon. Mediassa näyttää tilanteet, joissa olen mukana muiden tekemissä formaateissa.</p>
              {% if latestMediaItems.length %}
              <div class="d-grid gap-3 mb-3">
                {% for item in latestMediaItems %}
                <a href="{{ item.url }}" class="presentation-mini-link">
                  <span class="presentation-mini-thumb">
                    {% if item.data.thumbnail %}
                    <img src="{{ item.data.thumbnail }}" alt="{{ item.data.title }}" class="presentation-mini-thumb-image" loading="lazy" decoding="async">
                    {% else %}
                    <span class="presentation-mini-thumb-placeholder"><i class="bi bi-mic"></i></span>
                    {% endif %}
                  </span>
                  <span class="presentation-mini-copy">
                    <strong>{{ item.data.title }}</strong>
                    <span>{{ item.data.mediaOutlet or "Mediassa" }}</span>
                  </span>
                </a>
                {% endfor %}
              </div>
              {% endif %}
              <a href="/mediassa/" class="btn btn-outline-primary btn-sm rounded-pill px-3">Avaa mediassa</a>
            </div>
          </article>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-5" id="sisaltotyypit" aria-labelledby="sisaltotyypit-heading">
  <div class="site-shell">
    <div class="presentation-section-head">
      <p class="presentation-section-kicker mb-1">Sisältötyypit</p>
      <h2 id="sisaltotyypit-heading" class="presentation-section-title">Materiaalit käyttötarkoituksen mukaan</h2>
      <p class="presentation-section-lead mb-0">Tämä näkymä kokoaa samantyyppiset aineistot yhteen riippumatta siitä, onko lähde Canva, SlideShare, YouTube vai AOE.</p>
    </div>

    <div class="presentation-type-stack">
      <section class="presentation-type-panel presentation-type-panel--featured" aria-labelledby="esitykset-koulutukset">
        <div class="presentation-type-panel-head">
          <p class="presentation-section-kicker mb-1">Omat esitykset</p>
          <h2 id="esitykset-koulutukset" class="presentation-type-title">Koulutukset ja keynote-esitykset</h2>
          <p class="presentation-type-lead mb-0">Tähän kuuluvat omat puheenvuorot, koulutustilaisuuksien diasetit ja laajemmat esityskokonaisuudet.</p>
        </div>
        <div class="presentation-type-grid presentation-type-grid--cards">
          {% for item in latestShowcaseItems.slice(0, 3) %}
          <article class="presentation-type-card">
            {% if item.thumbnail %}
            <img src="{{ item.thumbnail }}" alt="{{ item.title }}" class="presentation-type-thumb" loading="lazy" decoding="async">
            {% else %}
            <div class="presentation-type-thumb presentation-type-thumb--placeholder"><i class="bi bi-easel2"></i></div>
            {% endif %}
            <div class="presentation-type-card-body">
              <div class="d-flex flex-wrap gap-2 mb-2">
                <span class="badge rounded-pill border text-body-secondary">{{ item.sourceLabel }}</span>
                {% if item.categories and item.categories[0] %}
                <span class="badge rounded-pill border text-body-secondary">{{ item.categories[0] }}</span>
                {% endif %}
              </div>
              <p class="text-muted small mb-2">{{ item.date | dateFormat }}</p>
              <h3 class="h5 mb-2"><a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.title }}</a></h3>
              <p class="text-muted small mb-3">{{ item.description }}</p>
              <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer" class="btn btn-outline-primary btn-sm rounded-pill px-3">Avaa esitys</a>
            </div>
          </article>
          {% endfor %}
        </div>
      </section>

      <div class="presentation-type-columns">
        <section class="presentation-type-panel" aria-labelledby="esitykset-oppimateriaalit">
          <div class="presentation-type-panel-head">
            <p class="presentation-section-kicker mb-1">Opetuskäyttö</p>
            <h2 id="esitykset-oppimateriaalit" class="presentation-type-title">Avoimet oppimateriaalit</h2>
            <p class="presentation-type-lead mb-0">Aineistot, joita voi käyttää, soveltaa tai jakaa opetuksen tueksi.</p>
          </div>
          <div class="presentation-type-list">
            {% for item in latestAoeItems %}
            <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer" class="presentation-mini-link">
              <span class="presentation-mini-thumb">
                {% if item.image %}
                <img src="{{ item.image }}" alt="{{ item.title }}" class="presentation-mini-thumb-image" loading="lazy" decoding="async">
                {% else %}
                <span class="presentation-mini-thumb-placeholder"><i class="bi bi-book"></i></span>
                {% endif %}
              </span>
              <span class="presentation-mini-copy">
                <strong>{{ item.title }}</strong>
                <span>{% if item.year %}{{ item.year }}{% else %}AOE / Finna{% endif %}</span>
              </span>
            </a>
            {% endfor %}
          </div>
        </section>

        <section class="presentation-type-panel" aria-labelledby="esitykset-videot">
          <div class="presentation-type-panel-head">
            <p class="presentation-section-kicker mb-1">Tallenteet</p>
            <h2 id="esitykset-videot" class="presentation-type-title">Videot ja tallenteet</h2>
            <p class="presentation-type-lead mb-0">Videoaineistot täydentävät esityksiä silloin, kun tallenne on saatavilla.</p>
          </div>
          {% if latestVideoItems.length %}
          <div class="presentation-type-list">
            {% for item in latestVideoItems %}
            <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer" class="presentation-mini-link">
              <span class="presentation-mini-thumb">
                {% if item.thumbnail %}
                <img src="{{ item.thumbnail }}" alt="{{ item.title }}" class="presentation-mini-thumb-image" loading="lazy" decoding="async">
                {% else %}
                <span class="presentation-mini-thumb-placeholder"><i class="bi bi-youtube"></i></span>
                {% endif %}
              </span>
              <span class="presentation-mini-copy">
                <strong>{{ item.title }}</strong>
                <span>{{ item.publishedAt | dateFormat }}</span>
              </span>
            </a>
            {% endfor %}
          </div>
          {% else %}
          <p class="text-muted small mb-3">Tällä hetkellä varsinaiset tallenteet eivät ole sivun pääaineistoa.</p>
          <a href="https://www.youtube.com/jarilaru" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary btn-sm rounded-pill px-3">YouTube-kanava</a>
          {% endif %}
        </section>
      </div>

      <section class="presentation-type-panel presentation-type-panel--analysis" aria-labelledby="esitykset-analyysit">
        <div class="presentation-type-panel-head">
          <p class="presentation-section-kicker mb-1">Aineiston tulkinta</p>
          <h2 id="esitykset-analyysit" class="presentation-type-title">Aineistoanalyysit</h2>
          <p class="presentation-type-lead mb-0">Analyysit nostavat esiin vuosien mittaisia teemoja, eivät vain yksittäisiä esityksiä.</p>
        </div>
        <div class="presentation-analysis-grid">
          <a href="/esitykset/canva-analyysi/" class="presentation-analysis-card">
            <span class="presentation-analysis-icon"><i class="bi bi-bar-chart-line"></i></span>
            <span>
              <strong>Canva-esitykset 2021-2026</strong>
              <span>Teemat, kehityskaaret ja laajimmat esitykset.</span>
            </span>
          </a>
          <a href="/esitykset/slideshare-analyysi/" class="presentation-analysis-card">
            <span class="presentation-analysis-icon"><i class="bi bi-collection-play"></i></span>
            <span>
              <strong>SlideShare-esitykset 2009-2020</strong>
              <span>Katsotuimmat, teemat ja kehityskaaret vuosikymmenittäin.</span>
            </span>
          </a>
        </div>
      </section>
    </div>
  </div>
</section>

<div class="site-shell py-5" id="palveluarkisto">
  <div class="presentation-section-head mb-5" id="palveluarkisto-heading">
    <p class="presentation-section-kicker mb-1">Tekninen arkisto</p>
    <h2 class="presentation-section-title">Palvelukohtainen taulukkoarkisto</h2>
