  {# Arkistolista: staattinen linkkilista kaikkiin esityssivuihin (SEO-navigaatio) #}
  <section class="mb-5">
    <div class="site-shell">
      {% set archiveTotal = (collections.presentations | length) + ((finnaAoe.rows or []) | length) + ((youtube.tableRows or []) | length) %}
      <details>
        <summary class="text-muted small py-2" style="cursor:pointer;">Kaikki esitykset ja materiaalit arkistona ({{ archiveTotal }})</summary>

        <div class="mt-3">
          <h3 class="h6 fw-bold">Esityssivut sivustolla</h3>
          <ul class="list-unstyled row row-cols-1 row-cols-md-2 g-3 mt-1">
            {% for item in collections.presentations | sort(attribute="data.date", reverse=true) %}
              <li class="col">
                <a class="small fw-semibold text-decoration-none" href="{{ item.url }}">{{ item.data.title }}</a>
                <div class="small text-muted mt-1">
                  {{ item.data.source or item.data.type or "esitys" }}{% if item.data.date %} · {{ item.data.date | dateFormat }}{% endif %}
