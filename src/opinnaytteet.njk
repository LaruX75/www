---
layout: base.njk
title: Ohjatut opinnäytetyöt
permalink: /opinnaytteet/
translationKey: theses_index
---

<section class="kynasta-hero py-4">
  <div class="container">
    <div class="row align-items-center g-3">
      <div class="col-lg-8">
        <p class="text-uppercase small text-muted mb-1">Ohjaustyö</p>
        <h1 class="display-6 fw-bold mb-1">Ohjatut opinnäytetyöt</h1>
        <p class="text-muted mb-0">Hae ja suodata Jari Larun ohjaamia pro gradu -tutkielmia ja kandidaatintöitä OuluREPO-arkistosta.</p>
      </div>
    </div>
  </div>
</section>

<div class="container py-4">
  {# Laskurit #}
  <div class="row g-3 my-4">
    <div class="col-md-3">
      <div class="card text-center border-primary h-100">
        <div class="card-body d-flex flex-column justify-content-center">
          <div class="display-4 fw-bold text-primary">{{ theses.stats.totalGradut }}</div>
          <div class="text-muted">ohjattua gradua</div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card text-center border-info h-100">
        <div class="card-body d-flex flex-column justify-content-center">
          <div class="display-4 fw-bold text-info">{{ theses.stats.totalKandit }}</div>
          <div class="text-muted">ohjattua kandidaatintyötä</div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card text-center h-100">
        <div class="card-body d-flex flex-column justify-content-center">
          <div class="display-4 fw-bold">{{ theses.stats.total }}</div>
          <div class="text-muted">työtä yhteensä</div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card text-center border-secondary h-100">
        <div class="card-body d-flex flex-column justify-content-center">
          <div class="display-4 fw-bold text-secondary">{{ theses.stats.totalReviewer }}</div>
          <div class="text-muted">muuta työtä, jotka olen tarkastanut</div>
        </div>
      </div>
    </div>
  </div>

  {# Vuosittainen palkki (interaktiivinen) #}
  {% if theses.stats.byYear %}
  <div class="d-flex gap-1 flex-wrap align-items-center mb-4" id="thesis-year-bar" role="group" aria-label="Suodata vuoden mukaan">
    <button type="button" class="badge border-0 thesis-year-btn active" data-year="" style="background-color:#6c757d;color:#fff;cursor:pointer">
      Kaikki vuodet
    </button>
    {% for item in theses.stats.byYear %}
      <button type="button" class="badge border-0 thesis-year-btn" data-year="{{ item[0] }}" style="background-color:#212529;color:#fff;cursor:pointer">
        {{ item[0] }}: {{ item[1] }}
      </button>
    {% endfor %}
  </div>
  {% endif %}

  {# ---- Avainsanapilvi kategorioittain ---- #}
  {% if keywordCategories %}
  <script type="application/json" id="thesis-keyword-categories">{{ keywordCategories | dump | safe }}</script>
  {% endif %}
  {# Ruudunlukijan ilmoitusalue suodatustuloksille #}
  <div id="thesis-filter-status" role="status" aria-live="polite" aria-atomic="true" class="visually-hidden"></div>
  <div class="accordion shadow-sm mb-5" id="thesis-subject-cloud">
    <div class="accordion-item">
      <h2 class="accordion-header">
        <button class="accordion-button collapsed py-2 small fw-semibold" type="button"
                data-bs-toggle="collapse" data-bs-target="#thesis-cloud-collapse"
                aria-expanded="false" aria-controls="thesis-cloud-collapse">
          <i class="bi bi-tags-fill me-2 text-primary" aria-hidden="true"></i>Avainsanat kategorioittain
        </button>
      </h2>
      <div id="thesis-cloud-collapse" class="accordion-collapse collapse">
        <div class="accordion-body p-0 d-flex align-items-center justify-content-end px-3 pt-2" style="min-height:0">
          <button type="button" class="btn btn-link btn-sm p-0 text-muted" id="thesis-cloud-clear" style="display:none!important">
            <i class="bi bi-x-circle me-1" aria-hidden="true"></i>Poista suodatus
          </button>
        </div>
        <div class="p-0" id="thesis-cloud-container">
          <span class="text-muted small p-3 d-block">Ladataan...</span>
        </div>
      </div>
    </div>
  </div>

  {# ---- Pro Gradut Card ---- #}
  <div class="card shadow-sm mb-5 section-card" id="card-master">
    <div class="card-header bg-transparent d-flex align-items-center justify-content-between py-3">
      <h2 class="h5 mb-0"><i class="bi bi-mortarboard-fill me-2 text-primary"></i>Pro gradu -tutkielmat</h2>
      <span class="badge text-bg-primary">{{ theses.stats.totalGradut }}</span>
    </div>
    <div class="card-body p-0">
      <div class="p-3 bg-light-subtle border-bottom">
        <div class="row g-2 align-items-end">
          <div class="col-md-8">
            <label for="gradu-search" class="form-label small text-muted mb-1">Suodata graduja</label>
            <div class="input-group input-group-sm thesis-filter-group">
              <span class="input-group-text thesis-filter-icon"><i class="bi bi-search"></i></span>
              <input type="search" id="gradu-search" class="form-control thesis-filter-input" placeholder="Hae otsikosta, tekijästä..." autocomplete="off" data-thesis-search="gradutabl">
            </div>
          </div>
          <div class="col-md-4">
            <label for="gradu-year" class="form-label small text-muted mb-1">Vuosi</label>
            <select id="gradu-year" class="form-select form-select-sm thesis-filter-select" data-thesis-year="gradutabl">
              <option value="">Kaikki vuodet</option>
            </select>
          </div>
        </div>
      </div>
      <div id="gradutabl">
        {% if theses.gradut.length %}
          {% set thesisItems = theses.gradut %}
          {% set showType = false %}
          {% include "thesis-table.njk" %}
        {% else %}
          <div class="p-4 text-center text-muted">Ei tuloksia.</div>
        {% endif %}
      </div>
    </div>
  </div>

  {# ---- Kandidaatintyöt Card ---- #}
  <div class="card shadow-sm mb-5 section-card" id="card-bachelor">
    <div class="card-header bg-transparent d-flex align-items-center justify-content-between py-3">
      <h2 class="h5 mb-0"><i class="bi bi-book-half me-2 text-info"></i>Kandidaatintyöt</h2>
      <span class="badge text-bg-info">{{ theses.stats.totalKandit }}</span>
    </div>
    <div class="card-body p-0">
      <div class="p-3 bg-light-subtle border-bottom">
        <div class="row g-2 align-items-end">
          <div class="col-md-8">
            <label for="kandi-search" class="form-label small text-muted mb-1">Suodata kandeja</label>
            <div class="input-group input-group-sm thesis-filter-group">
              <span class="input-group-text thesis-filter-icon"><i class="bi bi-search"></i></span>
              <input type="search" id="kandi-search" class="form-control thesis-filter-input" placeholder="Hae otsikosta, tekijästä..." autocomplete="off" data-thesis-search="kanditabl">
            </div>
          </div>
          <div class="col-md-4">
            <label for="kandi-year" class="form-label small text-muted mb-1">Vuosi</label>
            <select id="kandi-year" class="form-select form-select-sm thesis-filter-select" data-thesis-year="kanditabl">
              <option value="">Kaikki vuodet</option>
            </select>
          </div>
        </div>
      </div>
      <div id="kanditabl">
        {% if theses.kandit.length %}
          {% set thesisItems = theses.kandit %}
          {% set showType = false %}
          {% include "thesis-table.njk" %}
        {% else %}
          <div class="p-4 text-center text-muted">Ei tuloksia.</div>
        {% endif %}
      </div>
    </div>
  </div>

  {# ═══ TARKASTANUT (valinnainen lohko) ═══ #}
  {% if theses.reviewerOnly.length %}
  <div class="card shadow-sm mb-5 section-card" id="card-reviewer">
    <div class="card-header bg-transparent d-flex align-items-center justify-content-between py-3">
      <h2 class="h5 mb-0"><i class="bi bi-eye-fill me-2 text-secondary"></i>Tarkastajana toiminut</h2>
      <span class="badge text-bg-secondary">{{ theses.stats.totalReviewer }}</span>
    </div>
    <div class="card-body p-0">
      <div class="p-3 bg-light-subtle border-bottom">
        <div class="row g-2 align-items-end">
          <div class="col-md-6">
            <label for="reviewer-search" class="form-label small text-muted mb-1">Suodata tarkastettuja</label>
            <div class="input-group input-group-sm thesis-filter-group">
              <span class="input-group-text thesis-filter-icon"><i class="bi bi-search"></i></span>
              <input type="search" id="reviewer-search" class="form-control thesis-filter-input" placeholder="Hae otsikosta, tekijästä..." autocomplete="off" data-thesis-search="reviewertabl">
            </div>
          </div>
          <div class="col-md-3">
            <label for="reviewer-year" class="form-label small text-muted mb-1">Vuosi</label>
            <select id="reviewer-year" class="form-select form-select-sm thesis-filter-select" data-thesis-year="reviewertabl">
              <option value="">Kaikki vuodet</option>
            </select>
          </div>
          <div class="col-md-3">
            <label for="reviewer-type" class="form-label small text-muted mb-1">Tyyppi</label>
            <select id="reviewer-type" class="form-select form-select-sm thesis-filter-select" data-thesis-type="reviewertabl">
              <option value="">Kaikki tyypit</option>
              <option value="masterThesis">Pro gradu</option>
              <option value="bachelorThesis">Kandidaatintyö</option>
            </select>
          </div>
        </div>
      </div>
      <div id="reviewertabl">
        {% set thesisItems = theses.reviewerOnly %}
        {% set showType = true %}
        {% include "thesis-table.njk" %}
      </div>
    </div>
  </div>
  {% endif %}

  <div class="text-muted small py-3">
    Lähde: <a href="https://oulurepo.oulu.fi" target="_blank" rel="noopener noreferrer" class="text-decoration-underline">OuluREPO</a>,
    Oulun yliopiston julkaisuarkisto.
    Data haettu automaattisesti OpenSearch-rajapinnasta: {{ theses.fetchedAt | default("N/A") }}.
  </div>

</div>

<div class="modal fade" id="thesisAbstractModal" tabindex="-1" aria-labelledby="thesisAbstractModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title fs-6" id="thesisAbstractModalLabel">Tiivistelmä</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Sulje"></button>
      </div>
      <div class="modal-body">
        <div class="border rounded p-2 mb-3 bg-body-secondary">
          <p class="text-uppercase mb-1" style="font-size:0.65rem;letter-spacing:.08em;color:var(--bs-secondary-color);">APA 7</p>
          <p class="mb-0 small font-monospace lh-sm" id="thesisModalApaText"></p>
        </div>
        <h3 class="h6 mb-2" id="thesisAbstractModalTitle"></h3>
        <div class="d-none d-md-block" style="max-height:260px;overflow-y:auto;padding-right:4px;">
          <p class="small mb-0 text-body" id="thesisAbstractModalTextDesktop"></p>
        </div>
        <p class="d-md-none small mb-0 text-body thesis-abstract-snippet" id="thesisAbstractModalTextMobile"></p>
      </div>
      <div class="modal-footer gap-2">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="thesisAbstractExportBtn">
          <i class="bi bi-quote me-1"></i>Vie viite
        </button>
        <a href="#" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm" id="thesisAbstractModalOpen">
          <i class="bi bi-box-arrow-up-right me-1"></i>Avaa koko opinnäytetyö
        </a>
      </div>
    </div>
  </div>
</div>

<div class="modal fade citation-export-modal" id="thesisCitationModal" tabindex="-1" aria-labelledby="thesisCitationModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title fs-5" id="thesisCitationModalLabel">Vie lähdeviite</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Sulje"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3 align-items-end">
          <div class="col-12 col-lg-5">
            <label for="thesisCitationFormatSelect" class="form-label small text-muted">Viittausmuoto</label>
            <select id="thesisCitationFormatSelect" class="form-select form-select-sm">
              <option value="bibtex">BibTeX (.bib)</option>
              <option value="apa">APA 7</option>
              <option value="mla">MLA</option>
              <option value="chicago">Chicago</option>
            </select>
          </div>
          <div class="col-12 col-lg-7">
            <div class="citation-export-actions">
              <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill" id="thesisCitationCopyBtn">
                <i class="bi bi-clipboard me-1"></i>Kopioi
              </button>
              <button type="button" class="btn btn-primary btn-sm rounded-pill" id="thesisCitationDownloadBtn">
                <i class="bi bi-download me-1"></i>Lataa
              </button>
              <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill" id="thesisCitationZoteroBtn" title="Lataa RIS Zotero-tuontiin">
                <img src="https://cdn.simpleicons.org/zotero/cc2936" alt="" width="14" height="14" class="me-1 align-text-bottom">Zotero
              </button>
              <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill" id="thesisCitationMendeleyBtn" title="Lataa RIS Mendeley-tuontiin">
                <img src="https://cdn.simpleicons.org/mendeley/9d1620" alt="" width="14" height="14" class="me-1 align-text-bottom">Mendeley
              </button>
            </div>
          </div>
        </div>
        <div class="mt-3">
          <label for="thesisCitationOutput" class="form-label small text-muted mb-1">Esikatselu</label>
          <textarea id="thesisCitationOutput" class="form-control form-control-sm font-monospace" rows="12" readonly></textarea>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const ITEMS_PER_PAGE = 5;
  const urlState = new URL(window.location.href);
  const urlParams = urlState.searchParams;
  const defaultPageTitle = document.title;
  const ogTitleMeta = document.querySelector('meta[property="og:title"]');
  const twitterTitleMeta = document.querySelector('meta[name="twitter:title"]');
  const defaultOgTitle = ogTitleMeta?.getAttribute('content') || '';
  const defaultTwitterTitle = twitterTitleMeta?.getAttribute('content') || '';
  const filterKey = (tableId, kind) => `th_${tableId}_${kind}`;
  const setFilterParam = (key, value) => {
    if (!value) {
      urlParams.delete(key);
      return;
    }
    urlParams.set(key, String(value).trim());
  };
  const updateFilterUrl = () => {
    const qs = urlParams.toString();
    const next = qs ? `${window.location.pathname}?${qs}${window.location.hash}` : `${window.location.pathname}${window.location.hash}`;
    window.history.replaceState({}, '', next);
    applyKeywordToPageShareMeta(getKeywordFromUrlContext());
  };

  function buildThesisBibTeX(payload) {
    const title = (payload.title || '').trim();
    const authors = (payload.authors || 'Laru, Jari').trim();
    const year = String(payload.year || '').trim();
    const thesisType = (payload.type || '').trim();
    const url = (payload.url || '').trim();
    const firstAuthor = authors.split(';')[0].trim();
    const lastName = (firstAuthor.split(',')[0].trim().split(/\s+/).pop() || 'tekijä')
      .toLowerCase()
      .replace(/[^a-z0-9]/g, '');
    const firstWord = ((title.match(/[A-Za-zÅÄÖåäö0-9]+/) || ['opinnayte'])[0])
      .toLowerCase()
      .replace(/[^a-z0-9]/g, '');
    const key = `${lastName}${year || 'nd'}${firstWord}`;
    const bibType = thesisType === 'masterThesis' ? 'mastersthesis' : 'misc';
    const safeTitle = title.replace(/[{}]/g, '');
    const safeAuthors = authors.replace(/[{}]/g, '');

    let bib = `@${bibType}{${key},\n`;
    bib += `  title = {${safeTitle}},\n`;
    bib += `  author = {${safeAuthors}},\n`;
    if (year) bib += `  year = {${year}},\n`;
    bib += `  school = {University of Oulu},\n`;
    if (thesisType === 'bachelorThesis') bib += `  note = {Bachelor's thesis},\n`;
    if (url) bib += `  url = {${url}},\n`;
    bib += `}`;
    return { key, bib };
  }

  function sanitizeFilenamePart(value) {
    return String(value || '')
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/(^-|-$)/g, '')
      .slice(0, 60) || 'viite';
  }

  function downloadTextFile(fileName, content) {
    const blob = new Blob([content], { type: 'text/plain;charset=utf-8' });
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = fileName;
    document.body.appendChild(link);
    link.click();
    URL.revokeObjectURL(link.href);
    document.body.removeChild(link);
  }

  function escapeHtml(value) {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function getThesisLevelLabel(payload) {
    if (payload.type === 'masterThesis') return 'Pro gradu -tutkielma';
    if (payload.type === 'bachelorThesis') return 'Kandidaatintyö';
    return 'Opinnäytetyö';
  }

  function buildThesisApa(payload) {
    const title = (payload.title || '').trim();
    const authors = (payload.authors || '').trim();
    const year = String(payload.year || '').trim() || 'n.d.';
    const url = (payload.url || '').trim();
    const level = getThesisLevelLabel(payload);
    let citation = `${authors} (${year}). ${title} [${level}, University of Oulu].`;
    if (url) citation += ` ${url}`;
    return citation.trim();
  }

  function buildThesisMla(payload) {
    const title = (payload.title || '').trim();
    const authors = (payload.authors || '').trim();
    const year = String(payload.year || '').trim();
    const url = (payload.url || '').trim();
    const level = getThesisLevelLabel(payload);
    let citation = `${authors}. "${title}." ${level}, University of Oulu`;
    if (year) citation += `, ${year}`;
    citation += '.';
    if (url) citation += ` ${url}`;
    return citation.trim();
  }

  function buildThesisChicago(payload) {
    const title = (payload.title || '').trim();
    const authors = (payload.authors || '').trim();
    const year = String(payload.year || '').trim() || 'n.d.';
    const url = (payload.url || '').trim();
    const level = getThesisLevelLabel(payload);
    let citation = `${authors}. ${year}. "${title}." ${level}, University of Oulu.`;
    if (url) citation += ` ${url}`;
    return citation.trim();
  }

  function getThesisCitationByFormat(payload, format) {
    if (format === 'apa') return buildThesisApa(payload);
    if (format === 'mla') return buildThesisMla(payload);
    if (format === 'chicago') return buildThesisChicago(payload);
    const { bib } = buildThesisBibTeX(payload);
    return bib;
  }

  function buildThesisRis(payload) {
    const title = (payload.title || '').trim();
    const authors = String(payload.authors || '')
      .split(';')
      .map((a) => a.trim())
      .filter(Boolean);
    const year = String(payload.year || '').trim();
    const url = (payload.url || '').trim();
    const level = getThesisLevelLabel(payload);
    const lines = ['TY  - THES'];
    authors.forEach((author) => lines.push(`AU  - ${author}`));
    if (year) lines.push(`PY  - ${year}`);
    if (title) lines.push(`TI  - ${title}`);
    lines.push(`PB  - University of Oulu`);
    lines.push(`M3  - ${level}`);
    if (url) lines.push(`UR  - ${url}`);
    lines.push('ER  -');
    return lines.join('\n');
  }

  function initTablePagination(tableContainer) {
    const table = tableContainer.querySelector('table');
    if (!table) return;

    const tbody = table.querySelector('tbody');
    const rows = Array.from(tbody.querySelectorAll('tr'));
    
    // Create pagination container if it doesn't exist
    let paginationNav = tableContainer.querySelector('.thesis-pagination');
    if (!paginationNav) {
      paginationNav = document.createElement('nav');
      const containerId = tableContainer.id || Math.random().toString(36).substring(7);
      paginationNav.setAttribute('aria-label', `Taulukon sivutus ${containerId}`);
      paginationNav.className = 'thesis-pagination d-flex align-items-center justify-content-between mt-3 px-2';
      paginationNav.innerHTML = '<div class="thesis-pagination-left"></div><ul class="pagination pagination-sm mb-3"></ul>';
      tableContainer.appendChild(paginationNav);
    }

    const ul = paginationNav.querySelector('ul');
    const paginationLeft = paginationNav.querySelector('.thesis-pagination-left');

    let currentPage = 1;
    let showAll = false;
    let filteredRows = [...rows];

    // "Näytä kaikki" -painike
    const showAllBtn = document.createElement('button');
    showAllBtn.type = 'button';
    showAllBtn.className = 'btn btn-outline-secondary btn-sm mb-3';
    showAllBtn.innerHTML = '<i class="bi bi-list-ul me-1" aria-hidden="true"></i>Näytä kaikki';
    showAllBtn.addEventListener('click', () => {
      showAll = !showAll;
      if (showAll) {
        showAllBtn.innerHTML = '<i class="bi bi-layout-text-window me-1" aria-hidden="true"></i>Sivuta';
        filteredRows.forEach(r => r.style.display = '');
        ul.innerHTML = '';
      } else {
        showAllBtn.innerHTML = '<i class="bi bi-list-ul me-1" aria-hidden="true"></i>Näytä kaikki';
        renderPage(1);
      }
    });
    if (paginationLeft) paginationLeft.appendChild(showAllBtn);

    const searchInput = document.querySelector(`[data-thesis-search="${tableContainer.id}"]`);
    const yearSelect = document.querySelector(`[data-thesis-year="${tableContainer.id}"]`);
    const typeSelect = document.querySelector(`[data-thesis-type="${tableContainer.id}"]`);
    const searchParamKey = filterKey(tableContainer.id, 'q');
    const yearParamKey = filterKey(tableContainer.id, 'y');
    const typeParamKey = filterKey(tableContainer.id, 't');

    if (searchInput) {
      searchInput.value = urlParams.get(searchParamKey) || '';
    }

    if (yearSelect) {
      const years = [...new Set(rows.map((row) => row.dataset.year).filter(Boolean))]
        .sort((a, b) => Number(b) - Number(a));
      years.forEach((year) => {
        const option = document.createElement('option');
        option.value = year;
        option.textContent = year;
        yearSelect.appendChild(option);
      });
      const urlYear = urlParams.get(yearParamKey) || '';
      if (urlYear && Array.from(yearSelect.options).some((opt) => opt.value === urlYear)) {
        yearSelect.value = urlYear;
      }
    }

    if (typeSelect) {
      const urlType = urlParams.get(typeParamKey) || '';
      if (urlType && Array.from(typeSelect.options).some((opt) => opt.value === urlType)) {
        typeSelect.value = urlType;
      }
    }

    function syncFiltersToUrl() {
      setFilterParam(searchParamKey, searchInput?.value || '');
      setFilterParam(yearParamKey, yearSelect?.value || '');
      setFilterParam(typeParamKey, typeSelect?.value || '');
      updateFilterUrl();
    }

    function applyFilters() {
      const q = (searchInput?.value || '').toLowerCase().trim();
      const year = yearSelect?.value || '';
      const type = typeSelect?.value || '';

      filteredRows = rows.filter((row) => {
        const rowText = row.textContent.toLowerCase();
        const rowYear = row.dataset.year || '';
        const rowType = row.dataset.type || '';
        const matchesSearch = !q || rowText.includes(q);
        const matchesYear = !year || rowYear === year;
        const matchesType = !type || rowType === type;
        return matchesSearch && matchesYear && matchesType;
      });
      syncFiltersToUrl();
      renderPage(showAll ? 'all' : 1);

      // Ilmoita suodatustulos ruudunlukijalle
      const statusEl = document.getElementById('thesis-filter-status');
      if (statusEl) {
        const n = filteredRows.length;
        statusEl.textContent = n === 0
          ? 'Ei tuloksia.'
          : `${n} opinnäytetyötä löydetty.`;
      }
    }

    function renderPage(page) {
      if (showAll) {
        filteredRows.forEach(r => r.style.display = '');
        rows.filter(r => !filteredRows.includes(r)).forEach(r => r.style.display = 'none');
        return;
      }
      currentPage = page;
      const totalPages = Math.ceil(filteredRows.length / ITEMS_PER_PAGE);
      if (currentPage < 1) currentPage = 1;
      if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;

      // Hide all rows
      rows.forEach(r => r.style.display = 'none');

      // Show rows for current page
      const start = (currentPage - 1) * ITEMS_PER_PAGE;
      const end = start + ITEMS_PER_PAGE;
      filteredRows.slice(start, end).forEach(r => r.style.display = '');

      renderPaginationControls(totalPages);
    }

    function renderPaginationControls(totalPages) {
      ul.innerHTML = '';
      showAllBtn.style.display = totalPages <= 1 ? 'none' : '';
      if (totalPages <= 1) return;

      // Previous button
      const prevLi = document.createElement('li');
      prevLi.className = `page-item ${currentPage === 1 ? 'disabled' : ''}`;
      prevLi.innerHTML = `<button type="button" class="page-link" aria-label="Edellinen"><span aria-hidden="true">&laquo;</span></button>`;
      prevLi.addEventListener('click', (e) => {
        e.preventDefault();
        if (currentPage > 1) renderPage(currentPage - 1);
      });
      ul.appendChild(prevLi);

      // Page numbers
      for (let i = 1; i <= totalPages; i++) {
        const li = document.createElement('li');
        li.className = `page-item ${i === currentPage ? 'active' : ''}`;
        li.innerHTML = `<button type="button" class="page-link" aria-label="Sivu ${i}">${i}</button>`;
        li.addEventListener('click', (e) => {
          e.preventDefault();
          renderPage(i);
        });
        ul.appendChild(li);
      }

      // Next button
      const nextLi = document.createElement('li');
      nextLi.className = `page-item ${currentPage === totalPages ? 'disabled' : ''}`;
      nextLi.innerHTML = `<button type="button" class="page-link" aria-label="Seuraava"><span aria-hidden="true">&raquo;</span></button>`;
      nextLi.addEventListener('click', (e) => {
        e.preventDefault();
        if (currentPage < totalPages) renderPage(currentPage + 1);
      });
      ul.appendChild(nextLi);
    }

    // Handle filters
    if (searchInput) {
      searchInput.addEventListener('input', applyFilters);
    }

    if (yearSelect) {
      yearSelect.addEventListener('change', applyFilters);
    }

    if (typeSelect) {
      typeSelect.addEventListener('change', applyFilters);
    }

    // Initial render
    applyFilters();
  }

  // Initialize pagination for each table container
  ['gradutabl', 'kanditabl', 'reviewertabl'].forEach(id => {
    const container = document.getElementById(id);
    if (container) {
      initTablePagination(container);
    }
  });

  let currentCitationPayload = null;
  const thesisCitationModalEl = document.getElementById('thesisCitationModal');
  const thesisCitationFormatSelect = document.getElementById('thesisCitationFormatSelect');
  const thesisCitationOutput = document.getElementById('thesisCitationOutput');
  const thesisCitationDownloadBtn = document.getElementById('thesisCitationDownloadBtn');
  const thesisCitationCopyBtn = document.getElementById('thesisCitationCopyBtn');
  const thesisCitationZoteroBtn = document.getElementById('thesisCitationZoteroBtn');
  const thesisCitationMendeleyBtn = document.getElementById('thesisCitationMendeleyBtn');

  function renderThesisCitationPreview() {
    if (!currentCitationPayload || !thesisCitationOutput) return;
    const format = thesisCitationFormatSelect?.value || 'bibtex';
    thesisCitationOutput.value = getThesisCitationByFormat(currentCitationPayload, format);
  }

  document.querySelectorAll('.thesis-bib-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      currentCitationPayload = {
        title: btn.dataset.title || '',
        authors: btn.dataset.authors || '',
        year: btn.dataset.year || '',
        type: btn.dataset.type || '',
        url: btn.dataset.url || ''
      };
      if (thesisCitationFormatSelect) thesisCitationFormatSelect.value = 'bibtex';
      renderThesisCitationPreview();
      if (window.bootstrap && window.bootstrap.Modal && thesisCitationModalEl) {
        window.bootstrap.Modal.getOrCreateInstance(thesisCitationModalEl).show();
      }
    });
  });

  if (thesisCitationFormatSelect) {
    thesisCitationFormatSelect.addEventListener('change', renderThesisCitationPreview);
  }

  if (thesisCitationDownloadBtn) {
    thesisCitationDownloadBtn.addEventListener('click', () => {
      if (!currentCitationPayload) return;
      const format = thesisCitationFormatSelect?.value || 'bibtex';
      const citation = getThesisCitationByFormat(currentCitationPayload, format);
      const base = sanitizeFilenamePart(currentCitationPayload.title || currentCitationPayload.authors || 'viite');
      const ext = format === 'bibtex' ? 'bib' : 'txt';
      downloadTextFile(`${base}.${ext}`, citation + '\n');
    });
  }

  if (thesisCitationCopyBtn) {
    thesisCitationCopyBtn.addEventListener('click', async () => {
      if (!thesisCitationOutput?.value) return;
      try {
        await navigator.clipboard.writeText(thesisCitationOutput.value);
        thesisCitationCopyBtn.innerHTML = '<i class="bi bi-check2 me-1"></i>Kopioitu';
        setTimeout(() => {
          thesisCitationCopyBtn.innerHTML = '<i class="bi bi-clipboard me-1"></i>Kopioi';
        }, 1200);
      } catch (_) {
        thesisCitationOutput.select();
        document.execCommand('copy');
      }
    });
  }

  if (thesisCitationZoteroBtn) {
    thesisCitationZoteroBtn.addEventListener('click', () => {
      if (!currentCitationPayload) return;
      const base = sanitizeFilenamePart(currentCitationPayload.title || currentCitationPayload.authors || 'viite');
      downloadTextFile(`${base}-zotero.ris`, buildThesisRis(currentCitationPayload) + '\n');
    });
  }

  if (thesisCitationMendeleyBtn) {
    thesisCitationMendeleyBtn.addEventListener('click', () => {
      if (!currentCitationPayload) return;
      const base = sanitizeFilenamePart(currentCitationPayload.title || currentCitationPayload.authors || 'viite');
      downloadTextFile(`${base}-mendeley.ris`, buildThesisRis(currentCitationPayload) + '\n');
    });
  }

  const abstractModalEl = document.getElementById('thesisAbstractModal');
  const abstractModalTitle = document.getElementById('thesisAbstractModalTitle');
  const abstractModalTextDesktop = document.getElementById('thesisAbstractModalTextDesktop');
  const abstractModalTextMobile = document.getElementById('thesisAbstractModalTextMobile');
  const abstractModalOpen = document.getElementById('thesisAbstractModalOpen');
  const thesisModalApaText = document.getElementById('thesisModalApaText');
  const thesisAbstractExportBtn = document.getElementById('thesisAbstractExportBtn');

  document.addEventListener('click', (event) => {
    const trigger = event.target.closest('.thesis-abstract-trigger');
    if (!trigger) return;
    event.preventDefault();
    const title = trigger.getAttribute('data-thesis-title') || 'Opinnäytetyö';
    const summary = trigger.getAttribute('data-thesis-abstract') || 'Tiivistelmää ei saatavilla.';
    const url = trigger.getAttribute('data-thesis-url') || '#';
    const authors = trigger.getAttribute('data-thesis-authors') || '';
    const year = trigger.getAttribute('data-thesis-year') || '';
    const type = trigger.getAttribute('data-thesis-type') || '';
    currentCitationPayload = { title, authors, year, type, url };
    if (abstractModalTitle) abstractModalTitle.textContent = title;
    const escaped = escapeHtml(summary).replace(/\n/g, '<br>');
    if (abstractModalTextDesktop) abstractModalTextDesktop.innerHTML = escaped;
    if (abstractModalTextMobile) abstractModalTextMobile.innerHTML = escaped;
    if (abstractModalOpen) abstractModalOpen.href = url;
    if (thesisModalApaText) thesisModalApaText.textContent = buildThesisApa(currentCitationPayload);
    if (window.bootstrap && window.bootstrap.Modal && abstractModalEl) {
      window.bootstrap.Modal.getOrCreateInstance(abstractModalEl).show();
    }
  });

  if (thesisAbstractExportBtn) {
    thesisAbstractExportBtn.addEventListener('click', () => {
      if (!currentCitationPayload) return;
      if (thesisCitationFormatSelect) thesisCitationFormatSelect.value = 'apa';
      renderThesisCitationPreview();
      if (window.bootstrap && window.bootstrap.Modal && thesisCitationModalEl) {
        window.bootstrap.Modal.getOrCreateInstance(thesisCitationModalEl).show();
      }
    });
  }

  // ---- Avainsanapilvi kategorioittain ----
  function buildKeywordCloud() {
    const cloudContainer = document.getElementById('thesis-cloud-container');
    const clearBtn = document.getElementById('thesis-cloud-clear');
    if (!cloudContainer) return;

    // Laske avainsanojen esiintymistiheys taulukon riveiltä
    const freq = new Map();
    document.querySelectorAll('.thesis-keyword-link[data-keyword]').forEach(btn => {
      const kw = (btn.dataset.keyword || '').trim().toLowerCase();
      if (!kw) return;
      freq.set(kw, (freq.get(kw) || 0) + 1);
    });

    const allCounts = Array.from(freq.values());
    const minCount = allCounts.length ? Math.min(...allCounts) : 1;
    const maxCount = allCounts.length ? Math.max(...allCounts) : 1;
    const normalize = (count) => {
      if (maxCount === minCount) return 0.5;
      return (count - minCount) / (maxCount - minCount);
    };

    // Lue kategoriat JSON-tagista
    let categories = null;
    const catScript = document.getElementById('thesis-keyword-categories');
    if (catScript) {
      try { categories = JSON.parse(catScript.textContent); } catch (_) {}
    }

    cloudContainer.innerHTML = '';

    if (!categories || Object.keys(categories).length === 0) {
      // Fallback: tasainen pilvi
      const subjects = Array.from(freq.keys()).sort((a, b) => a.localeCompare(b, 'fi'));
      if (subjects.length === 0) {
        cloudContainer.innerHTML = '<span class="text-muted small p-3 d-block">Ei avainsanoja.</span>';
        return;
      }
      const wrapper = document.createElement('div');
      wrapper.className = 'd-flex flex-wrap gap-1 p-3';
      subjects.forEach(kw => {
        wrapper.appendChild(makeKwBadge(kw, freq.get(kw) || 1, normalize));
      });
      cloudContainer.appendChild(wrapper);
      setupClearBtn(clearBtn, cloudContainer);
      return;
    }

    // Rakenna accordion kategorioittain
    const accordion = document.createElement('div');
    accordion.className = 'accordion accordion-flush';
    accordion.id = 'thesis-cat-accordion';

    const catEntries = Object.entries(categories);
    catEntries.forEach(([catName, keywords], idx) => {
      if (!Array.isArray(keywords) || keywords.length === 0) return;

      // Laske kategorian kokonaisosumien summa
      const catTotal = keywords.reduce((sum, kw) => sum + (freq.get(kw.toLowerCase()) || 0), 0);

      const item = document.createElement('div');
      item.className = 'accordion-item';

      const headerId = `thesis-cat-h${idx}`;
      const collapseId = `thesis-cat-c${idx}`;

      item.innerHTML = `
        <h3 class="accordion-header" id="${headerId}">
          <button class="accordion-button collapsed py-2 small fw-semibold" type="button"
            data-bs-toggle="collapse" data-bs-target="#${collapseId}"
            aria-expanded="false" aria-controls="${collapseId}">
            <i class="bi bi-tag-fill me-2 text-primary opacity-75"></i>${catName}
            <span class="badge text-bg-secondary ms-2 fw-normal">${keywords.length}</span>
          </button>
        </h3>
        <div id="${collapseId}" class="accordion-collapse collapse"
          aria-labelledby="${headerId}" data-bs-parent="#thesis-cat-accordion">
          <div class="accordion-body py-2 d-flex flex-wrap gap-1" id="thesis-cat-body-${idx}"></div>
        </div>`;

      accordion.appendChild(item);

      // Lisää badget kun collapse on luotu
      const body = item.querySelector(`#thesis-cat-body-${idx}`);
      const sorted = [...keywords].sort((a, b) => {
        const countDiff = (freq.get(b.toLowerCase()) || 0) - (freq.get(a.toLowerCase()) || 0);
        return countDiff !== 0 ? countDiff : a.localeCompare(b, 'fi');
      });
      sorted.forEach(kw => {
        const count = freq.get(kw.toLowerCase()) || 0;
        body.appendChild(makeKwBadge(kw, count, normalize));
      });
    });

    cloudContainer.appendChild(accordion);
    setupClearBtn(clearBtn, cloudContainer);
  }

  function makeKwBadge(kw, count, normalize) {
    const scale = normalize(count);
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'badge text-bg-light border thesis-keyword-link';
    btn.dataset.keyword = kw;
    btn.textContent = kw;
    btn.setAttribute('aria-pressed', 'false');
    btn.style.setProperty('--thesis-keyword-size', `${(0.78 + (scale * 0.52)).toFixed(2)}rem`);
    btn.style.setProperty('--thesis-keyword-weight', String(Math.round(450 + (scale * 250))));
    if (count > 0) btn.title = `${kw} (${count} opinnäytetyötä)`;
    return btn;
  }

  function setupClearBtn(clearBtn, cloudContainer) {
    if (!clearBtn) return;
    clearBtn.addEventListener('click', () => {
      document.querySelectorAll('[data-thesis-search]').forEach(input => {
        input.value = '';
        input.dispatchEvent(new Event('input', { bubbles: true }));
      });
      cloudContainer.querySelectorAll('.thesis-keyword-link').forEach(b => {
        b.classList.remove('text-bg-primary', 'active');
        b.classList.add('text-bg-light');
        b.setAttribute('aria-pressed', 'false');
      });
      clearBtn.style.setProperty('display', 'none', 'important');
    });
  }

  function findCloudKeywordButton(cloudContainer, keyword) {
    if (!cloudContainer || !keyword) return null;
    const normalized = String(keyword).trim().toLowerCase();
    if (!normalized) return null;
    return Array.from(cloudContainer.querySelectorAll('.thesis-keyword-link[data-keyword]'))
      .find((btn) => (btn.dataset.keyword || '').trim().toLowerCase() === normalized) || null;
  }

  function activateKeywordContext(keyword) {
    const clearBtn = document.getElementById('thesis-cloud-clear');
    const cloudContainer = document.getElementById('thesis-cloud-container');
    if (!cloudContainer || !keyword) return false;

    cloudContainer.querySelectorAll('.thesis-keyword-link').forEach((b) => {
      b.classList.remove('text-bg-primary', 'active');
      b.classList.add('text-bg-light');
      b.setAttribute('aria-pressed', 'false');
    });

    const cloudBtn = findCloudKeywordButton(cloudContainer, keyword);
    if (!cloudBtn) return false;

    cloudBtn.classList.remove('text-bg-light');
    cloudBtn.classList.add('text-bg-primary', 'active');
    cloudBtn.setAttribute('aria-pressed', 'true');
    if (clearBtn) clearBtn.style.removeProperty('display');

    const collapse = cloudBtn.closest('.accordion-collapse');
    if (collapse && !collapse.classList.contains('show') && window.bootstrap?.Collapse) {
      window.bootstrap.Collapse.getOrCreateInstance(collapse).show();
    }
    return true;
  }

  function getKeywordFromUrlContext() {
    const direct = (urlParams.get('keyword') || urlParams.get('avainsana') || '').trim();
    if (direct) return direct;
    const searchKeys = Array.from(urlParams.keys()).filter((key) => /^th_.+_q$/.test(key));
    for (const key of searchKeys) {
      const value = (urlParams.get(key) || '').trim();
      if (value) return value;
    }
    return '';
  }

  function applyKeywordToPageShareMeta(keyword) {
    const term = String(keyword || '').trim();
    if (!term) {
      document.title = defaultPageTitle;
      if (ogTitleMeta && defaultOgTitle) ogTitleMeta.setAttribute('content', defaultOgTitle);
      if (twitterTitleMeta && defaultTwitterTitle) twitterTitleMeta.setAttribute('content', defaultTwitterTitle);
      return;
    }
    const dynamicTitle = `${defaultPageTitle} | Hakusana: ${term}`;
    document.title = dynamicTitle;
    if (ogTitleMeta) ogTitleMeta.setAttribute('content', dynamicTitle);
    if (twitterTitleMeta) twitterTitleMeta.setAttribute('content', dynamicTitle);
  }

  // Delegoitu klikkaus kaikille avainsanapainikkeille (pilvi + taulukon rivit)
  document.addEventListener('click', (event) => {
    const kwBtn = event.target.closest('.thesis-keyword-link');
    if (!kwBtn) return;
    const kw = kwBtn.dataset.keyword || '';
    activateKeywordContext(kw);

    // Aseta hakusana kaikkiin hakukenttiin ja käynnistä suodatus
    document.querySelectorAll('[data-thesis-search]').forEach(input => {
      input.value = kw;
      input.dispatchEvent(new Event('input', { bubbles: true }));
    });

    // Vieritä ensimmäiseen taulukkoon
    const firstCard = document.getElementById('card-master');
    if (firstCard) firstCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  buildKeywordCloud();
  const initialKeyword = getKeywordFromUrlContext();
  if (initialKeyword) activateKeywordContext(initialKeyword);
  applyKeywordToPageShareMeta(initialKeyword);

  // ---- Vuosirimps: interaktiivinen vuosisuodatin ----
  document.querySelectorAll('.thesis-year-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const year = btn.dataset.year || '';

      // Päivitä napien tila
      document.querySelectorAll('.thesis-year-btn').forEach(b => {
        b.classList.remove('active');
        b.style.backgroundColor = b.dataset.year ? '#212529' : '#6c757d';
        b.style.opacity = '1';
      });
      btn.classList.add('active');
      btn.style.backgroundColor = '#0d6efd';

      // Aseta vuosisuodatin kaikkiin taulukoihin
      ['gradutabl', 'kanditabl', 'reviewertabl'].forEach(tableId => {
        const yearSelect = document.querySelector(`[data-thesis-year="${tableId}"]`);
        if (yearSelect) {
          yearSelect.value = year;
          yearSelect.dispatchEvent(new Event('change', { bubbles: true }));
        }
      });

      // Vieritä taulukoihin jos vuosi valittu
      if (year) {
        const firstCard = document.getElementById('card-master');
        if (firstCard) firstCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

});
</script>

